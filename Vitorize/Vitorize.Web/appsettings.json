{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System.Net.Http.HttpClient": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} {Level:u3}] [{Application}] [{EventType}] [CorrelationId:{CorrelationId}] [TraceId:{TraceId}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/vitorize-web-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "fileSizeLimitBytes": 104857600,
          "rollOnFileSizeLimit": true,
          "shared": true,
          "flushToDiskInterval": "00:00:02",
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} {Level:u3}] [{Application}] [{EventType}] [CorrelationId:{CorrelationId}] [TraceId:{TraceId}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithEnvironmentName", "WithThreadId" ],
    "Properties": {
      "Application": "Vitorize.Web",
      "Service": "Web"
    }
  },
  "Seq": {
    "Enabled": false,
    "ServerUrl": "",
    "ApiKey": "",
    "ApplicationName": "Vitorize.Web",
    "QueueSizeLimit": 10000
  },
  "ApiSettings": {
    "BaseUrl": "https://localhost:7221/api/",
    "MediaBaseUrl": "https://localhost:7221"
  },
  "AllowedHosts": "*"
}
