@inject IConfiguration Configuration
@inject Vitorize.Web.Services.UI.StoreBrandingService Branding
@inject MediaUrlResolver Media

<!DOCTYPE html>
<html lang="fa" dir="rtl">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light dark" />
    <base href="/" />
    <title>@_b.PageTitle()</title>
    @if (!string.IsNullOrWhiteSpace(_b.MetaDescription))
    {
        <meta name="description" content="@_b.MetaDescription" />
    }
    @if (!string.IsNullOrWhiteSpace(_b.MetaKeywords))
    {
        <meta name="keywords" content="@_b.MetaKeywords" />
    }

    <link rel="icon" href="@_favicon" />
    @if (!string.IsNullOrWhiteSpace(_appleIcon))
    {
        <link rel="apple-touch-icon" href="@_appleIcon" />
    }

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="@_b.SiteName" />
    <meta property="og:title" content="@_b.PageTitle()" />
    <meta property="og:description" content="@_b.MetaDescription" />
    @if (!string.IsNullOrWhiteSpace(_ogImage))
    {
        <meta property="og:image" content="@_ogImage" />
    }
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@_b.PageTitle()" />
    <meta name="twitter:description" content="@_b.MetaDescription" />
    @if (!string.IsNullOrWhiteSpace(_twitterImage))
    {
        <meta name="twitter:image" content="@_twitterImage" />
    }

    <script>
        (function () {
            try {
                var t = localStorage.getItem('vitorize-theme');
                if (!t) {
                    t = (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) ? 'dark' : 'light';
                }
                document.documentElement.setAttribute('data-theme', t);
            } catch (e) { document.documentElement.setAttribute('data-theme', 'light'); }
        })();
    </script>
    <link rel="stylesheet" href="css/admin.css?v=@AssetVersion" />
    <link rel="stylesheet" href="lib/quill/quill.snow.css?v=2.0.3" />
    <link rel="stylesheet" href="css/storefront.css?v=@AssetVersion" />

    @if (!string.IsNullOrWhiteSpace(_b.GoogleAnalyticsId))
    {
        <script async src="https://www.googletagmanager.com/gtag/js?id=@_b.GoogleAnalyticsId"></script>
        <script>
            window.dataLayer = window.dataLayer || [];
            function gtag() { dataLayer.push(arguments); }
            gtag('js', new Date());
            gtag('config', '@_b.GoogleAnalyticsId');
        </script>
    }
    @if (!string.IsNullOrWhiteSpace(_fontFaceCss)) { <style>@((MarkupString)_fontFaceCss)</style> }

    <HeadOutlet @rendermode="PageRenderMode" />
</head>

<body>
    <div id="vz-initial-loader" class="vz-splash">
        <div class="vz-splash-mark"><img src="@_logoSrc" alt="@_b.SiteName" /></div>
        <div class="vz-spinner"></div>
    </div>

    <Routes @rendermode="PageRenderMode" />

    <div id="blazor-error-ui" class="vz-error-ui">
        یک خطای پیش‌بینی‌نشده رخ داد.
        <a href="" class="reload">بارگذاری مجدد</a>
        <span class="dismiss">🗙</span>
    </div>

    <script src="_framework/blazor.web.js"></script>
    <script src="lib/quill/quill.js?v=2.0.3"></script>
    <script src="js/rich-editor.js?v=@AssetVersion"></script>
    <script src="js/admin.js"></script>
    <script src="js/lucide-picker.js?v=@AssetVersion"></script>
    <script src="js/storefront-theme.js"></script>
</body>

</html>

@code {
    private readonly IComponentRenderMode PageRenderMode =
        new InteractiveServerRenderMode(prerender: false);

    // Cache-busting token for the global stylesheets. Bump when admin.css/storefront.css change
    // so browsers fetch the new CSS instead of a stale copy.
    private const string AssetVersion = "20260714-lucide-1.24.0";

    private Vitorize.Web.Services.UI.StoreBranding _b = new(new Dictionary<string, string>());
    private string _favicon = "favicon.ico";
    private string _logoSrc = "images/logo.png";
    private string? _appleIcon, _ogImage, _twitterImage;
    private string? _fontFaceCss;

    protected override async Task OnInitializedAsync()
    {
        // برندینگ عمومی از API خوانده می‌شود (کش استاتیک ۲ دقیقه‌ای)؛ در صورت خطا پیش‌فرض‌ها استفاده می‌شوند.
        _b = await Branding.GetAsync();

        if (!string.IsNullOrWhiteSpace(_b.FaviconPath)) _favicon = Versioned(Media.Resolve(_b.FaviconPath), _b.AssetVersion);
        if (!string.IsNullOrWhiteSpace(_b.AppleTouchIconPath)) _appleIcon = Versioned(Media.Resolve(_b.AppleTouchIconPath), _b.AssetVersion);
        if (!string.IsNullOrWhiteSpace(_b.OgImagePath)) _ogImage = Versioned(Media.Resolve(_b.OgImagePath), _b.AssetVersion);
        if (!string.IsNullOrWhiteSpace(_b.TwitterImagePath)) _twitterImage = Versioned(Media.Resolve(_b.TwitterImagePath), _b.AssetVersion);

        var logo = _b.LogoPath;
        if (string.IsNullOrWhiteSpace(logo)) logo = _b.SiteLogoPath;
        if (!string.IsNullOrWhiteSpace(logo)) _logoSrc = Versioned(Media.Resolve(logo), _b.AssetVersion);
        if (!string.IsNullOrWhiteSpace(_b.FontPath) && IsSafeFont(_b.FontPath, _b.FontFormat))
        {
            var family = CssString(_b.FontFamily);
            var url = CssString(Versioned(Media.Resolve(_b.FontPath), _b.FontVersion));
            var selector = _b.FontScope switch { 1 => ".st-shell", 2 => ".vz-shell", _ => ":root" };
            _fontFaceCss = $"@font-face{{font-family:'{family}';src:url('{url}') format('{CssString(_b.FontFormat)}');font-display:swap;}}{selector}{{--font:'{family}',Vazirmatn,Tahoma,sans-serif;--st-font:'{family}',Vazirmatn,Tahoma,sans-serif;}}";
        }
    }

    private static string Versioned(string url, string version) => $"{url}{(url.Contains('?') ? '&' : '?')}v={Uri.EscapeDataString(version)}";
    private static string CssString(string value) => new(value.Where(c => char.IsLetterOrDigit(c) || c is ' ' or '-' or '_' or '.' or '/' or ':' or '?' or '&' or '=').ToArray());
    private static bool IsSafeFont(string path, string format) => path.StartsWith("/uploads/fonts/", StringComparison.OrdinalIgnoreCase) && format is "woff2" or "woff" or "ttf";
}
