@inject ApiClient Api
@inject NavigationManager Nav
@using Vitorize.Shared.Common
@using AUI = Vitorize.Web.Helpers.AdminUiHelper

<div class="st-bc">
    <a href="/">خانه</a> <Icon Name="chevron-left" Size="13" />
    <span>@Title</span>
</div>

<h1 style="font-size:24px;font-weight:800;letter-spacing:-0.01em;margin:6px 0 14px">@Title</h1>

@* ---------- category pill rail ---------- *@
@if (_categories.Count > 0)
{
    <div class="st-catrail" aria-label="فیلتر دسته‌بندی محصولات">
        <button type="button" class="st-catpill @(string.IsNullOrEmpty(_categoryId) ? "active" : null)" @onclick="() => SelectCategory(null)">
            <span class="st-catpill__ic"><Icon Name="grid" Size="13" /></span> همه
        </button>
        @foreach (var c in _categories)
        {
            <button type="button" class="st-catpill @(_categoryId == c.Id.ToString() ? "active" : null)" @onclick="() => SelectCategory(c.Id.ToString())">
                <span class="st-catpill__ic"><StoreImage Url="@c.ImagePath" Alt="@c.Title" Icon="gamepad" IconSize="13" Contain="true" /></span> @c.Title
            </button>
        }
    </div>
}

@{
    RenderFragment filters =
    @<div>
        <div class="st-fhead">
            <div class="st-fhead__t">فیلترها @if (ActiveCount > 0) { <span class="st-fhead__count">@AUI.Number(ActiveCount)</span> }</div>
            @if (ActiveCount > 0) { <button class="st-fhead__clear" @onclick="ClearAll">پاک کردن همه</button> }
        </div>

        <div class="st-fsearch">
            <span class="ic"><Icon Name="search" Size="13" /></span>
            <input placeholder="جستجو در فیلترها ..." @bind="_filterSearch" @bind:event="oninput" />
        </div>

        @if (ActiveChips.Count > 0)
        {
            <div class="st-fchips">
                @foreach (var chip in ActiveChips)
                {
                    <span class="st-fchip">@chip.Label <button @onclick="chip.Remove"><Icon Name="x" Size="9" /></button></span>
                }
            </div>
        }

        @* Category (single-select) *@
        <div class="st-fg">
            <div class="st-fg__head" @onclick="() => _gCat = !_gCat">
                <span class="st-fg__label">دسته‌بندی @if (!string.IsNullOrEmpty(_categoryId)) { <span class="st-fg__sel">۱</span> }</span>
                <span class="st-fg__chev @(_gCat ? "open" : null)">▾</span>
            </div>
            @if (_gCat)
            {
                <div class="st-fg__body">
                    @foreach (var c in FilterList(_categories))
                    {
                        var on = _categoryId == c.Id.ToString();
                        <div class="st-fopt" @onclick="() => SelectCategory(on ? null : c.Id.ToString())">
                            <span class="st-fopt__l"><span class="st-fbox @(on ? "on" : null)">@if (on) { <Icon Name="check" Size="11" /> }</span><span>@c.Title</span></span>
                        </div>
                    }
                    @if (FilterList(_categories).Count == 0) { <div class="st-fg__empty">موردی یافت نشد</div> }
                </div>
            }
        </div>

        @* Brand (single-select) *@
        <div class="st-fg">
            <div class="st-fg__head" @onclick="() => _gBrand = !_gBrand">
                <span class="st-fg__label">برند @if (!string.IsNullOrEmpty(_brandId)) { <span class="st-fg__sel">۱</span> }</span>
                <span class="st-fg__chev @(_gBrand ? "open" : null)">▾</span>
            </div>
            @if (_gBrand)
            {
                <div class="st-fg__body">
                    @foreach (var b in FilterList(_brands))
                    {
                        var on = _brandId == b.Id.ToString();
                        <div class="st-fopt" @onclick="() => SelectBrand(on ? null : b.Id.ToString())">
                            <span class="st-fopt__l"><span class="st-fbox @(on ? "on" : null)">@if (on) { <Icon Name="check" Size="11" /> }</span><span>@b.Title</span></span>
                        </div>
                    }
                    @if (FilterList(_brands).Count == 0) { <div class="st-fg__empty">موردی یافت نشد</div> }
                </div>
            }
        </div>

        @* Product type (client refine, multi) *@
        <div class="st-fg">
            <div class="st-fg__head" @onclick="() => _gType = !_gType">
                <span class="st-fg__label">نوع محصول @if (_types.Count > 0) { <span class="st-fg__sel">@AUI.Number(_types.Count)</span> }</span>
                <span class="st-fg__chev @(_gType ? "open" : null)">▾</span>
            </div>
            @if (_gType)
            {
                <div class="st-fg__body">
                    @foreach (var t in ProductTypes)
                    {
                        var on = _types.Contains(t.Key);
                        <div class="st-fopt" @onclick="() => ToggleType(t.Key)">
                            <span class="st-fopt__l"><span class="st-fbox @(on ? "on" : null)">@if (on) { <Icon Name="check" Size="11" /> }</span><span>@t.Value</span></span>
                        </div>
                    }
                </div>
            }
        </div>

        @* Availability + delivery (client/server) *@
        <div class="st-fg">
            <div class="st-fg__head" @onclick="() => _gAvail = !_gAvail">
                <span class="st-fg__label">موجودی و تحویل</span>
                <span class="st-fg__chev @(_gAvail ? "open" : null)">▾</span>
            </div>
            @if (_gAvail)
            {
                <div class="st-fg__body">
                    <div class="st-fopt" @onclick="ToggleInStock">
                        <span class="st-fopt__l"><span class="st-fbox @(_inStockOnly ? "on" : null)">@if (_inStockOnly) { <Icon Name="check" Size="11" /> }</span><span>فقط کالاهای موجود</span></span>
                    </div>
                    <div class="st-fopt" @onclick="() => { _instantOnly = !_instantOnly; ApplyClient(); }">
                        <span class="st-fopt__l"><span class="st-fbox @(_instantOnly ? "on" : null)">@if (_instantOnly) { <Icon Name="check" Size="11" /> }</span><span>تحویل آنی</span></span>
                    </div>
                    <div class="st-fopt" @onclick="() => { _verifiedOnly = !_verifiedOnly; ApplyClient(); }">
                        <span class="st-fopt__l"><span class="st-fbox @(_verifiedOnly ? "on" : null)">@if (_verifiedOnly) { <Icon Name="check" Size="11" /> }</span><span>نیازمند احراز هویت</span></span>
                    </div>
                </div>
            }
        </div>

        @* Discount tiers *@
        <div class="st-fg">
            <div class="st-fg__head" @onclick="() => _gDiscount = !_gDiscount">
                <span class="st-fg__label">تخفیف</span>
                <span class="st-fg__chev @(_gDiscount ? "open" : null)">▾</span>
            </div>
            @if (_gDiscount)
            {
                <div class="st-dpills">
                    <button class="st-dpill @(_discountTier == 0 && !_discountOnly ? "active" : null)" @onclick="() => SetDiscount(0)">همه</button>
                    <button class="st-dpill @(_discountTier == 1 ? "active" : null)" @onclick="() => SetDiscount(1)">تخفیف‌دار</button>
                    <button class="st-dpill @(_discountTier == 10 ? "active" : null)" @onclick="() => SetDiscount(10)">۱۰٪+</button>
                    <button class="st-dpill @(_discountTier == 25 ? "active" : null)" @onclick="() => SetDiscount(25)">۲۵٪+</button>
                    <button class="st-dpill @(_discountTier == 50 ? "active" : null)" @onclick="() => SetDiscount(50)">۵۰٪+</button>
                </div>
            }
        </div>

        @* Price range *@
        <div class="st-fg">
            <div class="st-fg__head" @onclick="() => _gPrice = !_gPrice">
                <span class="st-fg__label">محدوده قیمت</span>
                <span class="st-fg__chev @(_gPrice ? "open" : null)">▾</span>
            </div>
            @if (_gPrice)
            {
                <div class="st-prange">
                    <div class="st-prange__inputs">
                        <input type="number" placeholder="از (تومان)" @bind="_minPrice" @bind:after="ReloadFromFilters" />
                        <input type="number" placeholder="تا (تومان)" @bind="_maxPrice" @bind:after="ReloadFromFilters" />
                    </div>
                </div>
            }
        </div>

        @* Top rated mini-list *@
        @if (TopRated.Count > 0)
        {
            <div class="st-fg">
                <div class="st-fg__label" style="margin-bottom:10px">پرامتیازترین‌ها</div>
                <div class="st-toprated">
                    @foreach (var tr in TopRated)
                    {
                        <a class="st-toprated__item" href="@($"/product/{tr.Slug}")">
                            <span class="st-toprated__ic"><StoreImage Url="@tr.ThumbnailImagePath" Alt="@tr.Title" Icon="gamepad" IconSize="16" /></span>
                            <div style="min-width:0">
                                <div class="st-toprated__t">@tr.Title</div>
                                <div class="st-toprated__m"><span class="r">★ @PersianDateHelper.ToPersianDigits(tr.AverageRating.ToString("0.0"))</span><span class="p">@AUI.Number((long)tr.FinalPrice)</span></div>
                            </div>
                        </a>
                    }
                </div>
            </div>
        }
    </div>;
}

<div class="st-listing">
    <aside class="st-fsidebar">@filters</aside>

    <div>
        <div class="st-results">
            <div class="st-results__count">
                @if (_loading) { <span>در حال بارگذاری ...</span> }
                else { <span>نمایش <b>@AUI.Number(PageStart)</b> تا <b>@AUI.Number(PageEnd)</b> از <b>@AUI.Number(_totalCount)</b> محصول</span> }
            </div>
            <div class="st-sort">
                <button class="st-sort__btn" @onclick="() => _sortOpen = !_sortOpen">
                    @SortLabel(_sort) <span class="chev">▾</span>
                </button>
                @if (_sortOpen)
                {
                    <div class="st-scrim" @onclick="() => _sortOpen = false"></div>
                    <div class="st-sort__menu">
                        @foreach (var opt in SortOptions)
                        {
                            <button class="st-sort__opt @(_sort == opt.Key ? "active" : null)" @onclick="() => SelectSort(opt.Key)">@opt.Value</button>
                        }
                    </div>
                }
            </div>
        </div>

        @if (_loading)
        {
            <div class="st-lgrid">
                @for (var i = 0; i < 6; i++)
                {
                    <div class="st-skel" style="height:300px;border-radius:var(--st-clip)"></div>
                }
            </div>
        }
        else if (_view.Count == 0)
        {
            <div class="st-empty">
                <Mascot Class="st-empty__mascot" />
                <div class="st-empty__t">محصولی با این فیلترها یافت نشد</div>
                <div class="st-empty__s">محدوده قیمت را گسترده‌تر کنید یا یکی از فیلترها را بردارید.</div>
                <button class="st-btn st-btn--accent st-btn--lg" @onclick="ClearAll"><Icon Name="refresh" Size="17" /> پاک کردن فیلترها</button>
            </div>
        }
        else
        {
            <div class="st-lgrid">
                @foreach (var p in _view)
                {
                    <StoreProductCard Product="p" />
                }
            </div>
            <div class="st-pager">
                <button @onclick="() => GoPage(_page - 1)" disabled="@(_page <= 1)" aria-label="صفحه قبل"><Icon Name="chevron-right" Size="16" /></button>
                @foreach (var p in PagerPages())
                {
                    var pageNo = p;
                    <button class="@(pageNo == _page ? "active" : null)" @onclick="() => GoPage(pageNo)">@AUI.Number(pageNo)</button>
                }
                <button @onclick="() => GoPage(_page + 1)" disabled="@(_page >= _totalPages)" aria-label="صفحه بعد"><Icon Name="chevron-left" Size="16" /></button>
            </div>
        }
    </div>
</div>

@* ---------- mobile filter FAB + bottom sheet ---------- *@
<button class="st-fab" @onclick="() => _sheetOpen = true">
    <Icon Name="sliders" Size="17" /> فیلترها @if (ActiveCount > 0) { <span class="st-fab__c">@AUI.Number(ActiveCount)</span> }
</button>
@if (_sheetOpen)
{
    <div class="st-sheet">
        <div class="st-sheet__bd" @onclick="() => _sheetOpen = false"></div>
        <div class="st-sheet__panel">
            <div class="st-sheet__grip"></div>
            @filters
            <button class="st-btn st-btn--accent st-btn--block st-btn--lg" style="margin-top:14px" @onclick="() => _sheetOpen = false">
                نمایش @AUI.Number(_totalCount) محصول
            </button>
        </div>
    </div>
}

@code {
    [Parameter] public string Title { get; set; } = "فروشگاه";
    [Parameter] public string? CategorySlug { get; set; }
    [Parameter] public string? BrandSlug { get; set; }
    [Parameter] public string? InitialSearch { get; set; }
    [Parameter] public string? InitialSort { get; set; }

    private List<StoreLookupModel> _categories = new();
    private List<StoreLookupModel> _brands = new();

    private List<StoreProductModel> _all = new();
    private List<StoreProductModel> _view = new();

    private bool _loading = true;
    private int _page = 1;
    private const int _pageSize = 24;
    private int _totalCount;
    private int _totalPages = 1;

    private string _search = string.Empty;
    private string _filterSearch = string.Empty;
    private string _categoryId = string.Empty;
    private string _brandId = string.Empty;
    private string _sort = "newest";
    private readonly HashSet<byte> _types = new();
    private bool _instantOnly, _verifiedOnly, _discountOnly, _inStockOnly;
    private int _discountTier;   // 0=none, 1=any-discount, 10/25/50 = percent tiers
    private decimal? _minPrice, _maxPrice;

    private bool _gCat = true, _gBrand = true, _gType, _gAvail = true, _gDiscount = true, _gPrice = true;
    private bool _sortOpen, _sheetOpen;

    private static readonly Dictionary<byte, string> ProductTypes = new()
    {
        { 1, "گیفت کارت" }, { 2, "اکانت بازی" }, { 3, "سرویس بازی" }, { 4, "اشتراک" }, { 5, "سایر" }
    };
    private static readonly Dictionary<string, string> SortOptions = new()
    {
        { "newest", "جدیدترین" }, { "cheapest", "ارزان‌ترین" }, { "expensive", "گران‌ترین" }, { "discount", "بیشترین تخفیف" }
    };
    private static string SortLabel(string k) => SortOptions.TryGetValue(k, out var v) ? v : "مرتب‌سازی";

    private int PageStart => _totalCount == 0 ? 0 : (_page - 1) * _pageSize + 1;
    private int PageEnd => Math.Min(_page * _pageSize, _totalCount);

    private string? _appliedKey;

    private List<StoreLookupModel> FilterList(List<StoreLookupModel> src) =>
        string.IsNullOrWhiteSpace(_filterSearch)
            ? src
            : src.Where(x => x.Title.Contains(_filterSearch, StringComparison.OrdinalIgnoreCase)).ToList();

    private int ActiveCount =>
        (string.IsNullOrEmpty(_categoryId) ? 0 : 1) + (string.IsNullOrEmpty(_brandId) ? 0 : 1)
        + _types.Count + (_instantOnly ? 1 : 0) + (_verifiedOnly ? 1 : 0) + (_inStockOnly ? 1 : 0)
        + (_discountTier > 0 || _discountOnly ? 1 : 0) + ((_minPrice is > 0 || _maxPrice is > 0) ? 1 : 0);

    private record Chip(string Label, EventCallback Remove);
    private List<Chip> ActiveChips
    {
        get
        {
            var chips = new List<Chip>();
            if (!string.IsNullOrEmpty(_categoryId))
            {
                var t = _categories.FirstOrDefault(c => c.Id.ToString() == _categoryId)?.Title ?? "دسته";
                chips.Add(new(t, EventCallback.Factory.Create(this, () => SelectCategory(null))));
            }
            if (!string.IsNullOrEmpty(_brandId))
            {
                var t = _brands.FirstOrDefault(b => b.Id.ToString() == _brandId)?.Title ?? "برند";
                chips.Add(new(t, EventCallback.Factory.Create(this, () => SelectBrand(null))));
            }
            foreach (var ty in _types.ToList())
                chips.Add(new(ProductTypes.GetValueOrDefault(ty, "نوع"), EventCallback.Factory.Create(this, () => ToggleType(ty))));
            if (_inStockOnly) chips.Add(new("موجود", EventCallback.Factory.Create(this, ToggleInStock)));
            if (_instantOnly) chips.Add(new("تحویل آنی", EventCallback.Factory.Create(this, () => { _instantOnly = false; ApplyClient(); })));
            if (_verifiedOnly) chips.Add(new("احراز هویت", EventCallback.Factory.Create(this, () => { _verifiedOnly = false; ApplyClient(); })));
            if (_discountTier > 0 || _discountOnly) chips.Add(new(_discountTier > 1 ? $"+{AUI.Number(_discountTier)}٪ تخفیف" : "تخفیف‌دار", EventCallback.Factory.Create(this, () => SetDiscount(0))));
            if (_minPrice is > 0 || _maxPrice is > 0) chips.Add(new("محدوده قیمت", EventCallback.Factory.Create(this, () => { _minPrice = null; _maxPrice = null; _ = ReloadFromFilters(); })));
            return chips;
        }
    }

    private List<StoreProductModel> TopRated =>
        _all.Where(p => p.ReviewCount > 0).OrderByDescending(p => p.AverageRating).ThenByDescending(p => p.ReviewCount).Take(3).ToList();

    protected override async Task OnInitializedAsync()
    {
        var catTask = Api.GetAsync<List<StoreLookupModel>>("products/categories");
        var brandTask = Api.GetAsync<List<StoreLookupModel>>("products/brands");
        await Task.WhenAll(catTask, brandTask);
        _categories = catTask.Result.Data ?? new();
        _brands = brandTask.Result.Data ?? new();
    }

    protected override async Task OnParametersSetAsync()
    {
        var key = $"{CategorySlug}|{BrandSlug}|{InitialSearch}|{InitialSort}";
        if (key == _appliedKey) return;
        _appliedKey = key;

        _search = InitialSearch ?? string.Empty;
        if (!string.IsNullOrWhiteSpace(InitialSort) && SortOptions.ContainsKey(InitialSort)) _sort = InitialSort;
        _categoryId = string.Empty;
        _brandId = string.Empty;

        if (!string.IsNullOrWhiteSpace(CategorySlug))
            _categoryId = _categories.FirstOrDefault(x => string.Equals(x.Slug, CategorySlug, StringComparison.OrdinalIgnoreCase))?.Id.ToString() ?? "";
        if (!string.IsNullOrWhiteSpace(BrandSlug))
            _brandId = _brands.FirstOrDefault(x => string.Equals(x.Slug, BrandSlug, StringComparison.OrdinalIgnoreCase))?.Id.ToString() ?? "";

        _page = 1;
        await Load();
    }

    private async Task SelectCategory(string? id) { _categoryId = id ?? string.Empty; await ReloadFromFilters(); }
    private async Task SelectBrand(string? id) { _brandId = id ?? string.Empty; await ReloadFromFilters(); }
    private async Task SelectSort(string s) { _sort = s; _sortOpen = false; await ReloadFromFilters(); }

    private async Task SetDiscount(int tier)
    {
        _discountTier = tier;
        _discountOnly = tier == 1;
        // tiers >1 still need the server "has discount" set; then refine client-side by percent
        await ReloadFromFilters();
    }

    private async Task ToggleInStock() { _inStockOnly = !_inStockOnly; await ReloadFromFilters(); }

    private async Task ClearAll()
    {
        _search = string.Empty; _filterSearch = string.Empty; _categoryId = string.Empty; _brandId = string.Empty;
        _types.Clear(); _instantOnly = _verifiedOnly = _discountOnly = _inStockOnly = false; _discountTier = 0;
        _minPrice = _maxPrice = null;
        await ReloadFromFilters();
    }

    private async Task ReloadFromFilters() { _page = 1; await Load(); }

    private async Task GoPage(int page)
    {
        if (page < 1 || page > _totalPages) return;
        _page = page;
        await Load();
    }

    private async Task Load()
    {
        _loading = true;
        StateHasChanged();
        var query = $"products?page={_page}&pageSize={_pageSize}&sort={_sort}";
        if (!string.IsNullOrWhiteSpace(_search)) query += $"&search={Uri.EscapeDataString(_search)}";
        if (!string.IsNullOrWhiteSpace(_categoryId)) query += $"&categoryId={_categoryId}";
        if (!string.IsNullOrWhiteSpace(_brandId)) query += $"&brandId={_brandId}";
        if (_minPrice is > 0) query += $"&minPrice={_minPrice}";
        if (_maxPrice is > 0) query += $"&maxPrice={_maxPrice}";
        if (_discountOnly || _discountTier > 0) query += "&hasDiscount=true";
        if (_inStockOnly) query += "&inStock=true";

        var result = await Api.GetAsync<PagedResult<StoreProductModel>>(query);
        _all = result.Data?.Items?.ToList() ?? new();
        _totalCount = result.Data?.TotalCount ?? _all.Count;
        _totalPages = Math.Max(1, (int)Math.Ceiling((double)_totalCount / _pageSize));
        _loading = false;
        ApplyClient();
    }

    private void ApplyClient()
    {
        IEnumerable<StoreProductModel> q = _all;
        if (_types.Count > 0) q = q.Where(p => _types.Contains(p.ProductType));
        if (_instantOnly) q = q.Where(p => p.DeliveryType == (byte)DeliveryType.Instant);
        if (_verifiedOnly) q = q.Where(p => p.RequiresVerification);
        if (_discountTier > 1) q = q.Where(p => p.DiscountPercent >= _discountTier);
        _view = q.ToList();
        StateHasChanged();
    }

    private IEnumerable<int> PagerPages()
    {
        var from = Math.Max(1, _page - 2);
        var to = Math.Min(_totalPages, _page + 2);
        for (var p = from; p <= to; p++) yield return p;
    }

    private void ToggleType(byte t)
    {
        if (!_types.Add(t)) _types.Remove(t);
        ApplyClient();
    }
}
