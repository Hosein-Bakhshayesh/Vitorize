@implements IDisposable
@inject NavigationManager Nav
@inject ApiClient Api
@inject CartState Cart
@inject WishlistState Wishlist
@using Vitorize.Web.Models.Store

<header class="st-header">
    <div class="st-container">
        <div class="st-header__row">
            <StoreLogo />

            <nav class="st-nav">
                <a href="/" class="@Active("/")">خانه</a>
                <div class="st-nav__mega">
                    <button class="st-nav__trigger @(_megaOpen ? "open" : null)" @onclick="ToggleMega" type="button">
                        فروشگاه <span class="chev">▾</span>
                    </button>
                    @if (_megaOpen)
                    {
                        <div class="st-scrim" @onclick="CloseMega"></div>
                        <div class="st-mega">
                            <div>
                                <div class="st-mega__label">دسته‌بندی‌ها</div>
                                <div class="st-mega__list">
                                    @foreach (var c in _categories.Take(6))
                                    {
                                        <a class="st-mega__item" href="@($"/category/{c.Slug}")" @onclick="CloseMega">
                                            <span class="st-mega__ic"><StoreImage Url="@c.ImagePath" Alt="@c.Title" Icon="gamepad" IconSize="16" Contain="true" /></span>
                                            <div class="st-mega__t">@c.Title</div>
                                        </a>
                                    }
                                    @if (_categories.Count == 0)
                                    {
                                        <a class="st-mega__item" href="/categories" @onclick="CloseMega"><span class="st-mega__ic"><Icon Name="grid" Size="16" /></span><div class="st-mega__t">همه دسته‌بندی‌ها</div></a>
                                    }
                                </div>
                            </div>
                            <a class="st-mega__feat" href="/shop" @onclick="CloseMega">
                                <div class="tag">ویژه</div>
                                <div class="ttl">همه محصولات فروشگاه را ببینید ←</div>
                            </a>
                        </div>
                    }
                </div>
                <a href="/categories" class="@Active("/categories")">دسته‌بندی‌ها</a>
                <a href="/blog" class="@Active("/blog")">وبلاگ</a>
                <a href="/faq" class="@Active("/faq")">سوالات متداول</a>
            </nav>

            <div class="st-search">
                <span class="ico"><Icon Name="search" Size="18" /></span>
                <input type="text" placeholder="جستجو در محصولات، بازی‌ها، گیفت کارت‌ها ..."
                       @bind="_search" @bind:event="oninput" @onkeydown="OnSearchKey" @onfocus="OpenSearch" />
                @if (_searchOpen && Suggestions.Count > 0)
                {
                    <div class="st-scrim" @onclick="CloseSearch"></div>
                    <div class="st-search__drop">
                        <div class="st-search__label">@(string.IsNullOrWhiteSpace(_search) ? "دسته‌بندی‌های محبوب" : "پیشنهادها")</div>
                        @foreach (var s in Suggestions)
                        {
                            <a class="st-search__item" href="@($"/category/{s.Slug}")" @onclick="CloseSearch">
                                <Icon Name="search" Size="13" /> <span>@s.Title</span>
                            </a>
                        }
                    </div>
                }
            </div>

            <div class="st-header__actions">
                <ThemeToggle />

                <a class="st-iconbtn st-mobile-only" href="/search" title="جستجو"><Icon Name="search" Size="19" /></a>

                @if (_authenticated)
                {
                    <a class="st-iconbtn st-mobile-hide" href="/customer/wishlist" title="علاقه‌مندی‌ها">
                        <Icon Name="heart" Size="19" />
                        @if (Wishlist.Count > 0)
                        {
                            <span class="badge">@AdminUiHelper.Number(Wishlist.Count)</span>
                        }
                    </a>
                }

                <a class="st-iconbtn" href="/cart" title="سبد خرید">
                    <Icon Name="cart" Size="19" />
                    @if (Cart.Count > 0)
                    {
                        <span class="badge">@AdminUiHelper.Number(Cart.Count)</span>
                    }
                </a>

                @if (_authenticated)
                {
                    <div class="st-pmenu">
                        <button class="st-avatar" @onclick="ToggleMenu" type="button">@Initial</button>
                        @if (_menuOpen)
                        {
                            <div style="position:fixed;inset:0;z-index:120" @onclick="CloseMenu"></div>
                            <div class="st-dropdown">
                                <a href="/customer/dashboard"><Icon Name="dashboard" Size="17" /> داشبورد</a>
                                <a href="/customer/orders"><Icon Name="cart" Size="17" /> سفارش‌های من</a>
                                <a href="/customer/wishlist"><Icon Name="heart" Size="17" /> علاقه‌مندی‌ها</a>
                                <a href="/customer/gift-codes"><Icon Name="gift" Size="17" /> کدهای من</a>
                                <a href="/customer/wallet"><Icon Name="wallet" Size="17" /> کیف پول</a>
                                <a href="/customer/tickets"><Icon Name="message" Size="17" /> پشتیبانی</a>
                                <div class="st-dropdown__divider"></div>
                                <form method="post" action="/auth/customer/logout" style="margin:0">
                                    <button type="submit" class="danger"><Icon Name="logout" Size="17" /> خروج از حساب</button>
                                </form>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <a class="st-btn st-btn--primary" href="/login"><Icon Name="log-in" Size="17" /> <span class="st-mobile-hide">ورود | ثبت‌نام</span></a>
                }
            </div>
        </div>
    </div>
</header>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private bool _authenticated;
    private bool _menuOpen;
    private bool _megaOpen;
    private bool _searchOpen;
    private string _search = string.Empty;
    private string _name = "کاربر";
    private string Initial => string.IsNullOrWhiteSpace(_name) ? "ک" : _name.Trim()[..1];

    private List<StoreLookupModel> _categories = new();

    private List<StoreLookupModel> Suggestions => (string.IsNullOrWhiteSpace(_search)
        ? _categories
        : _categories.Where(c => c.Title.Contains(_search, StringComparison.OrdinalIgnoreCase)))
        .Take(6).ToList();

    protected override void OnInitialized()
    {
        Cart.OnChange += OnCartChange;
        Wishlist.OnChange += OnCartChange;
    }

    protected override async Task OnInitializedAsync()
    {
        // Categories feed both the mega menu and the search suggestions (real lookup API).
        try
        {
            var cats = await Api.GetAsync<List<StoreLookupModel>>("products/categories");
            if (cats.IsSuccess && cats.Data is not null) _categories = cats.Data;
        }
        catch { }

        if (AuthState is null) return;

        var state = await AuthState;
        _authenticated = state.User.Identity?.IsAuthenticated == true;

        if (_authenticated)
        {
            _name = state.User.Identity?.Name ?? "کاربر";
            await Task.WhenAll(RefreshCartCount(), RefreshWishlist());
        }
    }

    private void ToggleMega() { _megaOpen = !_megaOpen; _searchOpen = false; }
    private void CloseMega() => _megaOpen = false;
    private void OpenSearch() { _searchOpen = true; _megaOpen = false; }
    private void CloseSearch() => _searchOpen = false;

    private async Task RefreshCartCount()
    {
        try
        {
            var result = await Api.GetAsync<CartModel>("cart");
            if (result.IsSuccess && result.Data is not null)
                Cart.Set(result.Data.TotalQuantity);
        }
        catch { }
    }

    private async Task RefreshWishlist()
    {
        try
        {
            var result = await Api.GetAsync<List<Guid>>("wishlist/product-ids");
            if (result.IsSuccess && result.Data is not null)
                Wishlist.SetIds(result.Data);
        }
        catch { }
    }

    private void OnCartChange() => InvokeAsync(StateHasChanged);

    private string Active(string path)
    {
        var current = "/" + Nav.ToBaseRelativePath(Nav.Uri).Split('?')[0].TrimEnd('/');
        if (path == "/") return current == "/" || current == "" ? "active" : "";
        return current.StartsWith(path, StringComparison.OrdinalIgnoreCase) ? "active" : "";
    }

    private void ToggleMenu() => _menuOpen = !_menuOpen;
    private void CloseMenu() => _menuOpen = false;

    private void OnSearchKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_search))
        {
            Nav.NavigateTo($"/search?q={Uri.EscapeDataString(_search.Trim())}");
            _search = string.Empty;
        }
    }

    public void Dispose()
    {
        Cart.OnChange -= OnCartChange;
        Wishlist.OnChange -= OnCartChange;
    }
}
