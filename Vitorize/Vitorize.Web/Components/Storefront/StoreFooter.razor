@inject Vitorize.Web.Services.UI.StoreBrandingService Branding
@inject MediaUrlResolver Media

<footer class="st-footer">
    <div class="st-container">
        <div class="st-footer__main">
            <div class="st-footer__brand">
                <StoreLogo Variant="footer" />
                <p>@_b.FooterDescription</p>
                @if (!string.IsNullOrWhiteSpace(_b.FooterText))
                {
                    <p class="st-footer__note">@_b.FooterText</p>
                }
                @if (!string.IsNullOrWhiteSpace(_b.ContactAddress) || !string.IsNullOrWhiteSpace(_b.WorkingHours))
                {
                    <div class="st-footer__contact">
                        @if (!string.IsNullOrWhiteSpace(_b.ContactAddress))
                        {
                            <span><Icon Name="map-pin" Size="15" /> @_b.ContactAddress</span>
                        }
                        @if (!string.IsNullOrWhiteSpace(_b.WorkingHours))
                        {
                            <span><Icon Name="clock" Size="15" /> @_b.WorkingHours</span>
                        }
                    </div>
                }
                <div class="st-socials">
                    @Social(_b.InstagramUrl, "instagram", "اینستاگرام")
                    @Social(_b.TelegramUrl, "send", "تلگرام")
                    @Social(_b.WhatsAppUrl, "message-circle", "واتساپ")
                    @Social(_b.XUrl, "twitter", "X")
                    @Social(_b.LinkedInUrl, "linkedin", "لینکدین")
                    @Social(_b.YouTubeUrl, "youtube", "یوتیوب")
                    @Social(_b.DiscordUrl, "message-circle", "دیسکورد")
                    @Social(_b.FacebookUrl, "facebook", "فیسبوک")
                    @if (!string.IsNullOrWhiteSpace(_b.SupportPhone))
                    {
                        <a href="tel:@_b.SupportPhone" title="تماس" aria-label="تماس با پشتیبانی"><Icon Name="phone" Size="18" /></a>
                    }
                    @if (!string.IsNullOrWhiteSpace(_b.SupportEmail))
                    {
                        <a href="mailto:@_b.SupportEmail" title="ایمیل" aria-label="ارسال ایمیل به پشتیبانی"><Icon Name="mail" Size="18" /></a>
                    }
                </div>
            </div>
            <div class="st-footer__col">
                <h4>دسترسی سریع</h4>
                <a href="/shop">فروشگاه</a>
                <a href="/categories">دسته‌بندی‌ها</a>
                <a href="/blog">وبلاگ</a>
                <a href="/faq">سوالات متداول</a>
            </div>
            <div class="st-footer__col">
                <h4>حساب کاربری</h4>
                <a href="/login">ورود</a>
                <a href="/register">ثبت‌نام</a>
                <a href="/customer/orders">سفارش‌های من</a>
                <a href="/customer/wallet">کیف پول</a>
            </div>
            <div class="st-footer__col">
                <h4>پشتیبانی</h4>
                <a href="/customer/tickets">تیکت پشتیبانی</a>
                <a href="/page/about">درباره ما</a>
                <a href="/page/terms">قوانین و مقررات</a>
                <a href="/page/privacy">حریم خصوصی</a>
            </div>
            @if (_b.TrustSeals.Count > 0)
            {
                <div class="st-footer__seals" aria-label="مجوزها و نمادهای اعتماد">
                    @foreach (var seal in _b.TrustSeals)
                    {
                        <a href="@seal.Url" target="@(seal.NewTab ? "_blank" : null)" rel="noopener noreferrer" title="@seal.Title">
                            <img src="@Media.Resolve(seal.ImagePath)" alt="@seal.Alt" loading="lazy" width="96" height="96" />
                        </a>
                    }
                </div>
            }
        </div>
        <div class="st-footer__bottom">
            <span>© @PersianDateHelper.ToPersianDigits(DateTime.Now.Year.ToString()) — @_b.CopyrightText</span>
            <span style="display:flex;align-items:center;gap:8px"><Icon Name="shield-check" Size="16" /> پرداخت امن و رمزگذاری‌شده</span>
        </div>
    </div>
</footer>

@code {
    private Vitorize.Web.Services.UI.StoreBranding _b =
        new(new Dictionary<string, string>());

    protected override async Task OnInitializedAsync()
    {
        _b = await Branding.GetAsync();
    }

    private RenderFragment Social(string url, string icon, string title) =>
        string.IsNullOrWhiteSpace(url)
            ? _ => { }
            : @<a href="@url" target="_blank" rel="noopener noreferrer" title="@title" aria-label="@title"><Icon Name="@icon" Size="18" /></a>;
}
