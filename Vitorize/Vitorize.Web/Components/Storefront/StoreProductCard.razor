@implements IDisposable
@inject ApiClient Api
@inject MediaUrlResolver Media
@inject CartState Cart
@inject WishlistState Wishlist
@inject ToastService Toasts
@inject NavigationManager Nav
@using Vitorize.Web.Models.Store
@using AUI = Vitorize.Web.Helpers.AdminUiHelper

<div class="st-pcard">
    <a class="st-pcard__media" href="@($"/product/{Product.Slug}")" aria-label="مشاهده @Product.Title">
        <StoreImage Url="@Product.ThumbnailImagePath" Alt="@Product.Title" Icon="gamepad" />
        @if (Product.DiscountPercent > 0)
        {
            <span class="st-pcard__off">@AUI.Number(Product.DiscountPercent)٪</span>
        }
    </a>
    <button class="st-pcard__wish @(InWishlist ? "active" : null)"
            title="@(InWishlist ? "حذف از علاقه‌مندی‌ها" : "افزودن به علاقه‌مندی‌ها")"
            @onclick="ToggleWishlist" @onclick:stopPropagation="true" disabled="@_wishBusy">
        <Icon Name="heart" Size="16" />
    </button>
    @if (!InStock)
    {
        <span class="st-pcard__stock out">ناموجود</span>
    }
    <div class="st-pcard__body">
        <div class="st-pcard__cat">@Product.CategoryTitle</div>
        <a class="st-pcard__title" href="@($"/product/{Product.Slug}")">@Product.Title</a>
        <div class="st-pcard__rate">
            @if (Product.ReviewCount > 0)
            {
                <span class="st-pcard__stars"><Icon Name="star" Size="12" /> @PersianDateHelper.ToPersianDigits(Product.AverageRating.ToString("0.0"))</span>
                <span class="st-pcard__reviews">(@AUI.Number(Product.ReviewCount))</span>
            }
            else
            {
                <span class="st-pcard__reviews">بدون امتیاز</span>
            }
            @if (Product.DeliveryType == (byte)DeliveryType.Instant)
            {
                <span class="st-tag st-tag--brand" style="margin-inline-start:auto"><Icon Name="zap" Size="11" /> آنی</span>
            }
        </div>
        <div class="st-pcard__foot">
            <div class="st-price">
                @if (Product.HasDiscount)
                {
                    <span class="st-price__old">@AUI.MoneyFa(Product.BasePrice, Product.CurrencyType)</span>
                }
                <span class="st-price__now">@AUI.Number((long)Product.FinalPrice) <span class="st-price__unit">@Unit</span></span>
            </div>
            <button class="st-btn st-btn--primary st-btn--sm" @onclick="AddToCart" disabled="@_busy" title="افزودن به سبد">
                @if (_busy) { <span class="st-spinner sm"></span> } else { <Icon Name="cart" Size="16" /> }
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public StoreProductModel Product { get; set; } = default!;
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private bool _busy;
    private bool _wishBusy;
    private string Unit => Product.CurrencyType == (byte)CurrencyType.Rial ? "ریال" : "تومان";
    private bool InWishlist => Wishlist.Contains(Product.Id);
    private bool InStock => Product.HasVariants || Product.AvailableStock > 0;

    protected override void OnInitialized() => Wishlist.OnChange += OnWishlistChange;

    private void OnWishlistChange() => InvokeAsync(StateHasChanged);

    public void Dispose() => Wishlist.OnChange -= OnWishlistChange;

    private async Task ToggleWishlist()
    {
        if (AuthState is not null)
        {
            var state = await AuthState;
            if (state.User.Identity?.IsAuthenticated != true)
            {
                Nav.NavigateTo($"/login?returnUrl={Uri.EscapeDataString(Nav.ToBaseRelativePath(Nav.Uri))}");
                return;
            }
        }

        _wishBusy = true;
        var result = await Api.PostAsync<bool>($"wishlist/{Product.Id}/toggle");
        _wishBusy = false;

        if (result.IsSuccess)
        {
            if (result.Data) Wishlist.Add(Product.Id);
            else Wishlist.Remove(Product.Id);
            Toasts.Success(result.Message);
        }
        else
        {
            Toasts.Error(result.Message);
        }
    }

    private async Task AddToCart()
    {
        if (Product.HasVariants)
        {
            Nav.NavigateTo($"/product/{Product.Slug}");
            return;
        }

        _busy = true;
        var result = await Api.PostAsync<CartModel>("cart/items",
            new { ProductId = Product.Id, ProductVariantId = (Guid?)null, Quantity = 1 });
        _busy = false;

        if (result.IsSuccess && result.Data is not null)
        {
            Cart.Set(result.Data.TotalQuantity);
            Toasts.Success("محصول به سبد خرید اضافه شد.");
        }
        else
        {
            Toasts.Error(result.Message);
        }
    }
}
