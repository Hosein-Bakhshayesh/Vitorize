@* Backward-compatible façade for fixed application icons. Configurable UI should use LucideIcon directly. *@
<LucideIcon IconKey="@Name" Size="@Size" StrokeWidth="@StrokeWidth" CssClass="@Class"
            Title="@Title" AriaLabel="@AriaLabel" Decorative="@Decorative"
            FallbackIconKey="@FallbackIconKey" />

@code {
    [Parameter] public string Name { get; set; } = "circle";
    [Parameter] public int Size { get; set; } = 20;
    [Parameter] public double StrokeWidth { get; set; } = 2;
    [Parameter] public string? Class { get; set; }
    [Parameter] public string? Title { get; set; }
    [Parameter] public string? AriaLabel { get; set; }
    [Parameter] public bool Decorative { get; set; } = true;
    [Parameter] public string FallbackIconKey { get; set; } = "circle-question-mark";
}
