@using System.Security.Claims
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthenticationStateProvider

<div class="vz-icon-field @(Compact ? "compact" : null) @(!string.IsNullOrWhiteSpace(Value) && CurrentEntry is null ? "invalid" : null)">
    <button @ref="_trigger" type="button" class="vz-icon-field__trigger" disabled="@(Disabled || ReadOnly)"
            aria-haspopup="dialog" aria-expanded="@_open" @onclick="OpenAsync">
        <span class="vz-icon-field__preview">
            @if (CurrentEntry is not null)
            {
                <LucideIcon IconKey="@CurrentEntry.Key" Size="@(Compact ? 22 : 28)" />
            }
            else
            {
                <LucideIcon IconKey="@(!string.IsNullOrWhiteSpace(Value) ? "triangle-alert" : "shapes")"
                            Size="@(Compact ? 22 : 28)" />
            }
        </span>
        <span class="vz-icon-field__text">
            @if (CurrentEntry is not null)
            {
                <strong>@CurrentEntry.EnglishName</strong>
                <small>@CurrentEntry.Key</small>
            }
            else if (!string.IsNullOrWhiteSpace(Value))
            {
                <strong>آیکون قدیمی یا نامعتبر</strong>
                <small>@Value</small>
            }
            else
            {
                <span class="vz-icon-field__placeholder">@Placeholder</span>
            }
        </span>
        <LucideIcon IconKey="chevron-down" Size="16" CssClass="vz-icon-field__chevron" />
    </button>
    @if (!ReadOnly && !Disabled && !Required && !string.IsNullOrWhiteSpace(Value))
    {
        <button type="button" class="vz-icon-field__clear" title="حذف آیکون" aria-label="حذف آیکون" @onclick="ClearAsync">
            <LucideIcon IconKey="x" Size="15" />
        </button>
    }
    @if (!string.IsNullOrWhiteSpace(Value) && CurrentEntry is null)
    {
        <div class="vz-field-error">این مقدار در کاتالوگ Lucide وجود ندارد؛ آن را با یک آیکون معتبر جایگزین کنید.</div>
    }
</div>

<dialog @ref="_dialog" class="vz-icon-picker" dir="rtl" aria-labelledby="@_titleId" @oncancel="CancelAsync">
    <div class="vz-icon-picker__shell">
        <header class="vz-icon-picker__header">
            <div>
                <h2 id="@_titleId">انتخاب آیکون Lucide</h2>
                <p>@LucideIconCatalog.Count آیکون رسمی — نسخه @LucideIconCatalog.Version</p>
            </div>
            <button type="button" class="vz-iconaction" aria-label="بستن" title="بستن" @onclick="CancelAsync">
                <LucideIcon IconKey="x" Size="19" />
            </button>
        </header>

        <div class="vz-icon-picker__searchbar">
            <div class="vz-icon-picker__search">
                <LucideIcon IconKey="search" Size="18" />
                <input type="search" placeholder="جستجو: game، wallet، سفارش، فضای ابری…"
                       aria-label="جستجوی آیکون" @bind="_search" @bind:event="oninput" @bind:after="ApplyFilter" />
                @if (!string.IsNullOrWhiteSpace(_search))
                {
                    <button type="button" aria-label="پاک کردن جستجو" @onclick="ClearSearch"><LucideIcon IconKey="x" Size="15" /></button>
                }
            </div>
            <div class="vz-icon-picker__categories" role="tablist" aria-label="دسته‌بندی آیکون‌ها">
                <button type="button" role="tab" aria-selected="@(_category is null)" class="@(_category is null ? "active" : null)"
                        @onclick="() => SelectCategory(null)">همه</button>
                @foreach (var category in AvailableCategories)
                {
                    <button type="button" role="tab" aria-selected="@(_category == category.Key)"
                            class="@(_category == category.Key ? "active" : null)" @onclick="() => SelectCategory(category.Key)">
                        @category.PersianTitle
                    </button>
                }
            </div>
        </div>

        <div class="vz-icon-picker__body">
            <aside class="vz-icon-picker__preview" aria-live="polite">
                @if (PendingEntry is not null)
                {
                    <div class="vz-icon-picker__large"><LucideIcon IconKey="@PendingEntry.Key" Size="72" StrokeWidth="1.6" /></div>
                    <strong>@PendingEntry.EnglishName</strong>
                    <code dir="ltr">@PendingEntry.Key</code>
                    <span>@CategoryTitle(PendingEntry.Category)</span>
                    @if (!string.IsNullOrWhiteSpace(PendingEntry.PersianAliases))
                    {
                        <p>@PendingEntry.PersianAliases</p>
                    }
                    <div class="vz-icon-picker__preview-actions">
                        <button type="button" class="vz-btn vz-btn--ghost vz-btn--sm" @onclick="() => CopyAsync(PendingEntry.Key)">
                            <LucideIcon IconKey="copy" Size="14" /> کپی نام
                        </button>
                        <button type="button" class="vz-btn vz-btn--ghost vz-btn--sm" aria-pressed="@IsFavorite(PendingEntry.Key)"
                                @onclick="() => ToggleFavoriteAsync(PendingEntry.Key)">
                            <LucideIcon IconKey="@(IsFavorite(PendingEntry.Key) ? "star" : "star-off")" Size="14" />
                            @(IsFavorite(PendingEntry.Key) ? "حذف علاقه‌مندی" : "افزودن علاقه‌مندی")
                        </button>
                    </div>
                }
                else
                {
                    <div class="vz-icon-picker__large muted"><LucideIcon IconKey="mouse-pointer-click" Size="58" /></div>
                    <strong>یک آیکون انتخاب کنید</strong>
                    <p>نام رسمی Lucide در پایگاه داده ذخیره می‌شود.</p>
                }
            </aside>

            <section class="vz-icon-picker__results">
                @if (string.IsNullOrWhiteSpace(_search) && _category is null && FavoriteEntries.Count > 0)
                {
                    <div class="vz-icon-picker__quick">
                        <h3><LucideIcon IconKey="star" Size="15" /> علاقه‌مندی‌ها</h3>
                        <div>@foreach (var entry in FavoriteEntries.Take(12)) { @QuickIcon(entry) }</div>
                    </div>
                }
                @if (string.IsNullOrWhiteSpace(_search) && _category is null && RecentEntries.Count > 0)
                {
                    <div class="vz-icon-picker__quick">
                        <h3><LucideIcon IconKey="history" Size="15" /> استفاده‌شده‌های اخیر</h3>
                        <div>@foreach (var entry in RecentEntries.Take(12)) { @QuickIcon(entry) }</div>
                    </div>
                }

                <div class="vz-icon-picker__result-head">
                    <span>@PersianNumber(_filtered.Count) نتیجه</span>
                    @if (_filtered.Count > _visibleCount) { <small>نمایش تدریجی برای عملکرد بهتر</small> }
                </div>
                @if (_filtered.Count == 0)
                {
                    <div class="vz-icon-picker__empty">
                        <LucideIcon IconKey="search-x" Size="42" />
                        <strong>آیکونی پیدا نشد</strong>
                        <span>عبارت دیگری یا دسته‌بندی «همه» را امتحان کنید.</span>
                    </div>
                }
                else
                {
                    <div class="vz-icon-picker__grid" role="listbox" aria-label="نتایج آیکون‌ها">
                        @foreach (var entry in VisibleEntries)
                        {
                            <div class="vz-icon-picker__cell @(_pending == entry.Key ? "selected" : null)" @key="entry.Key">
                                <button type="button" class="vz-icon-picker__cell-main" role="option"
                                        aria-selected="@(_pending == entry.Key)" title="@CellTitle(entry)"
                                        @onclick="() => Select(entry.Key)" @ondblclick="() => ConfirmEntryAsync(entry.Key)">
                                    <LucideIcon IconKey="@entry.Key" Size="25" />
                                    <span dir="ltr">@entry.Key</span>
                                </button>
                                <button type="button" class="vz-icon-picker__favorite" aria-label="علاقه‌مندی"
                                        aria-pressed="@IsFavorite(entry.Key)" @onclick="() => ToggleFavoriteAsync(entry.Key)">
                                    <LucideIcon IconKey="@(IsFavorite(entry.Key) ? "star" : "star-off")" Size="13" />
                                </button>
                            </div>
                        }
                    </div>
                    @if (_visibleCount < _filtered.Count)
                    {
                        <button type="button" class="vz-btn vz-btn--outline vz-icon-picker__more" @onclick="ShowMore">
                            نمایش آیکون‌های بیشتر
                        </button>
                    }
                }
            </section>
        </div>

        <footer class="vz-icon-picker__footer">
            <div>
                @if (!Required)
                {
                    <button type="button" class="vz-btn vz-btn--ghost" @onclick="ClearFromDialogAsync">بدون آیکون</button>
                }
            </div>
            <div>
                <button type="button" class="vz-btn vz-btn--outline" @onclick="CancelAsync">انصراف</button>
                <button type="button" class="vz-btn vz-btn--primary" disabled="@(PendingEntry is null)" @onclick="ConfirmAsync">
                    <LucideIcon IconKey="check" Size="16" /> تأیید انتخاب
                </button>
            </div>
        </footer>
    </div>
</dialog>

@code {
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }
    [Parameter] public bool Required { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool ReadOnly { get; set; }
    [Parameter] public string Placeholder { get; set; } = "انتخاب آیکون";
    [Parameter] public IReadOnlyCollection<string>? AllowedCategories { get; set; }
    [Parameter] public IReadOnlyCollection<string>? ExcludedIcons { get; set; }
    [Parameter] public bool Compact { get; set; }

    private readonly string _titleId = $"lucide-picker-{Guid.NewGuid():N}";
    private ElementReference _dialog;
    private ElementReference _trigger;
    private bool _open;
    private string? _pending;
    private string _search = string.Empty;
    private string? _category;
    private int _visibleCount = 120;
    private string _preferenceScope = "admin";
    private List<LucideIconEntry> _filtered = [];
    private List<string> _favorites = [];
    private List<string> _recent = [];

    private LucideIconEntry? CurrentEntry => LucideIconCatalog.Find(Value);
    private LucideIconEntry? PendingEntry => LucideIconCatalog.Find(_pending);
    private IEnumerable<LucideIconEntry> VisibleEntries => _filtered.Take(_visibleCount);
    private List<LucideIconEntry> FavoriteEntries => PreferenceEntries(_favorites);
    private List<LucideIconEntry> RecentEntries => PreferenceEntries(_recent);
    private IEnumerable<LucideIconCategory> AvailableCategories => LucideIconCatalog.Categories
        .Where(x => AllowedCategories is null || AllowedCategories.Contains(x.Key, StringComparer.OrdinalIgnoreCase))
        .Where(x => LucideIconCatalog.Entries.Any(e => e.Category == x.Key));

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var userKey = state.User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? state.User.Identity?.Name ?? "anonymous";
        _preferenceScope = $"admin:{userKey}";
        ApplyFilter();
    }

    private async Task OpenAsync()
    {
        if (Disabled || ReadOnly) return;
        var prefs = await JS.InvokeAsync<IconPreferences>("vitorizeLucide.loadPreferences", _preferenceScope);
        ApplyPreferences(prefs);
        _pending = LucideIconCatalog.TryNormalizeKey(Value, out var normalized) ? normalized : null;
        _search = string.Empty;
        _category = null;
        _open = true;
        ApplyFilter();
        await InvokeAsync(StateHasChanged);
        await JS.InvokeVoidAsync("vitorizeLucide.showDialog", _dialog, _trigger);
    }

    private void ApplyFilter()
    {
        _visibleCount = 120;
        _filtered = LucideIconCatalog.Search(_search, _category, LucideIconCatalog.Count, ExcludedIcons).ToList();
        if (AllowedCategories is not null)
            _filtered = _filtered.Where(x => AllowedCategories.Contains(x.Category, StringComparer.OrdinalIgnoreCase)).ToList();
    }

    private void SelectCategory(string? category) { _category = category; ApplyFilter(); }
    private void ClearSearch() { _search = string.Empty; ApplyFilter(); }
    private void Select(string key) => _pending = key;
    private void ShowMore() => _visibleCount = Math.Min(_visibleCount + 120, _filtered.Count);

    private async Task ConfirmEntryAsync(string key) { _pending = key; await ConfirmAsync(); }

    private async Task ConfirmAsync()
    {
        if (!LucideIconCatalog.TryNormalizeKey(_pending, out var normalized)) return;
        Value = normalized;
        await ValueChanged.InvokeAsync(normalized);
        ApplyPreferences(await JS.InvokeAsync<IconPreferences>("vitorizeLucide.recordRecent", _preferenceScope, normalized));
        await CloseAsync();
    }

    private async Task ClearAsync() { if (!Required) { Value = null; await ValueChanged.InvokeAsync(null); } }
    private async Task ClearFromDialogAsync() { if (!Required) { await ClearAsync(); await CloseAsync(); } }
    private async Task CancelAsync() => await CloseAsync();

    private async Task CloseAsync()
    {
        _open = false;
        await JS.InvokeVoidAsync("vitorizeLucide.closeDialog", _dialog);
    }

    private async Task ToggleFavoriteAsync(string key)
    {
        var selected = !_favorites.Contains(key, StringComparer.OrdinalIgnoreCase);
        ApplyPreferences(await JS.InvokeAsync<IconPreferences>("vitorizeLucide.setFavorite", _preferenceScope, key, selected));
    }

    private async Task CopyAsync(string key) => await JS.InvokeVoidAsync("vitorizeLucide.copy", key);
    private bool IsFavorite(string key) => _favorites.Contains(key, StringComparer.OrdinalIgnoreCase);
    private void ApplyPreferences(IconPreferences? value) { _favorites = value?.Favorites ?? []; _recent = value?.Recent ?? []; }
    private static string PersianNumber(int value) => string.Concat(value.ToString(CultureInfo.InvariantCulture).Select(ch => char.IsDigit(ch) ? "۰۱۲۳۴۵۶۷۸۹"[ch - '0'] : ch));
    private static string CellTitle(LucideIconEntry entry) => string.IsNullOrWhiteSpace(entry.PersianAliases) ? entry.EnglishName : $"{entry.EnglishName} — {entry.PersianAliases}";
    private static string CategoryTitle(string key) => LucideIconCatalog.Categories.FirstOrDefault(x => x.Key == key)?.PersianTitle ?? key;
    private static List<LucideIconEntry> PreferenceEntries(IEnumerable<string> keys) => keys.Select(LucideIconCatalog.Find).OfType<LucideIconEntry>().ToList();

    private RenderFragment QuickIcon(LucideIconEntry entry) => @<button type="button" title="@CellTitle(entry)" class="@(_pending == entry.Key ? "selected" : null)" @onclick="() => Select(entry.Key)">
        <LucideIcon IconKey="@entry.Key" Size="21" /><span dir="ltr">@entry.Key</span>
    </button>;

    private sealed class IconPreferences
    {
        public List<string> Favorites { get; set; } = [];
        public List<string> Recent { get; set; } = [];
    }
}
