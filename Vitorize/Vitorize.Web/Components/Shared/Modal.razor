@if (Visible)
{
    <div class="vz-overlay" @onclick="BackdropClose" @onkeydown="HandleKeyDown">
        <div @ref="_dialog" class="vz-dialog @Size" role="dialog" aria-modal="true"
             aria-labelledby="@_titleId" tabindex="-1" @onclick:stopPropagation="true">
            <div class="vz-dialog__head">
                @if (!string.IsNullOrEmpty(Icon))
                {
                    <div class="vz-page-head__icon" style="width:40px;height:40px;border-radius:11px">
                        <Icon Name="@Icon" Size="20" />
                    </div>
                }
                <div>
                    <div id="@_titleId" class="vz-dialog__title">@Title</div>
                    @if (!string.IsNullOrWhiteSpace(Subtitle))
                    {
                        <div class="vz-card__sub">@Subtitle</div>
                    }
                </div>
                <button class="vz-dialog__close" @onclick="CloseAsync" type="button" aria-label="بستن">
                    <Icon Name="x" Size="18" />
                </button>
            </div>
            <div class="vz-dialog__body">
                @ChildContent
            </div>
            @if (Footer is not null)
            {
                <div class="vz-dialog__foot">
                    @Footer
                </div>
            }
        </div>
    </div>
}

@code {
    private readonly string _titleId = $"dialog-title-{Guid.NewGuid():N}";
    private ElementReference _dialog;
    private bool _focused;

    [Parameter] public bool Visible { get; set; }
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public string? Subtitle { get; set; }
    [Parameter] public string? Icon { get; set; }
    [Parameter] public string Size { get; set; } = string.Empty;
    [Parameter] public bool CloseOnBackdrop { get; set; } = true;
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public RenderFragment? Footer { get; set; }

    private async Task CloseAsync() => await OnClose.InvokeAsync();

    private async Task BackdropClose()
    {
        if (CloseOnBackdrop)
            await OnClose.InvokeAsync();
    }

    private async Task HandleKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Escape")
            await CloseAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Visible && !_focused)
        {
            _focused = true;
            await _dialog.FocusAsync();
        }
        else if (!Visible)
        {
            _focused = false;
        }
    }
}
