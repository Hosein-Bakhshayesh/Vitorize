<div class="vz-state">
    <div class="vz-state__icon"><Icon Name="@Icon" Size="32" /></div>
    <div class="vz-state__title">@Title</div>
    @if (!string.IsNullOrWhiteSpace(Text))
    {
        <div class="vz-state__text">@Text</div>
    }
    @if (Actions is not null)
    {
        <div style="margin-top:6px">@Actions</div>
    }
</div>

@code {
    [Parameter] public string Title { get; set; } = "موردی یافت نشد";
    [Parameter] public string? Text { get; set; }
    [Parameter] public string Icon { get; set; } = "inbox";
    [Parameter] public RenderFragment? Actions { get; set; }
}
