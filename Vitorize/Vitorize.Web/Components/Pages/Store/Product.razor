@page "/product/{Slug}"
@implements IDisposable
@inject ApiClient Api
@inject MediaUrlResolver Media
@inject CartState Cart
@inject WishlistState Wishlist
@inject ToastService Toasts
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject StoreBrandingService Branding
@inject IHttpContextAccessor HttpContext
@using Vitorize.Web.Models.Customer
@using Vitorize.Web.Models.Store
@using AUI = Vitorize.Web.Helpers.AdminUiHelper

@if (_p is not null)
{
    <SeoHead Title="@(_p.SeoTitle ?? _p.Title)" Description="@(_p.SeoDescription ?? _p.ShortDescription)"
             CanonicalPath="@($"/product/{Uri.EscapeDataString(_p.Slug)}")" ImagePath="@_p.ThumbnailImagePath"
             OpenGraphType="product" LastModified="@(_p.UpdatedAt ?? _p.CreatedAt)" JsonLd="@ProductJsonLd()" />
}
else if (!_loading)
{
    <SeoHead Title="محصول یافت نشد" Description="این محصول در دسترس نیست." Index="false" Follow="false" />
}

@if (_loading)
{
    <div class="st-pd2">
        <div>
            <div class="st-skel" style="height:400px;border-radius:var(--st-clip);margin-bottom:22px"></div>
            <div class="st-skel" style="height:220px;border-radius:var(--st-clip)"></div>
        </div>
        <div class="st-skel" style="height:420px;border-radius:var(--st-clip)"></div>
    </div>
}
else if (_p is null)
{
    <div class="st-empty" style="margin-top:40px">
        <div class="st-empty__ic"><Icon Name="box" Size="30" /></div>
        <div class="st-empty__t">محصول یافت نشد</div>
        <div class="st-empty__s">این محصول حذف شده یا آدرس آن نامعتبر است.</div>
        <a class="st-btn st-btn--accent st-btn--lg" href="/shop">بازگشت به فروشگاه</a>
    </div>
}
else
{
    <div class="st-bc">
        <a href="/">خانه</a> <Icon Name="chevron-left" Size="13" />
        <a href="/shop">فروشگاه</a> <Icon Name="chevron-left" Size="13" />
        <span>@_p.Title</span>
    </div>

    <div class="st-pd2">
        @* ---------- LEFT: gallery + tabs ---------- *@
        <div>
            <div class="st-gal">
                <span class="st-gal__glow"></span>
                @if (_gallery.Count > 1)
                {
                    <div class="st-gal__rail">
                        @foreach (var img in _gallery)
                        {
                            <div class="st-gal__thumb @(img == _activeImage ? "active" : null)" @onclick="() => _activeImage = img">
                                <StoreImage Url="@img.ImagePath" Alt="@(img.AltText ?? _p.ThumbnailAltText ?? _p.Title)" Icon="gamepad" IconSize="18" />
                            </div>
                        }
                    </div>
                }
                <div class="st-gal__main" @key="_activeImage">
                    @if (_p.HasDiscount)
                    {
                        <span class="st-gal__badge">@AUI.Number(DiscountPercent)٪ تخفیف</span>
                    }
                    <StoreImage Url="@_activeImage?.ImagePath" Alt="@(_activeImage?.AltText ?? _p.ThumbnailAltText ?? _p.Title)" Icon="gamepad" IconSize="56" Loading="eager" FetchPriority="high" Width="900" Height="900" />
                </div>
            </div>

            @if (_p.Features.Any(x => x.IsActive))
            {
                <section class="st-product-features" aria-labelledby="product-features-title">
                    <h2 id="product-features-title">ویژگی‌ها و مشخصات</h2>
                    <dl class="st-feature-grid">
                        @foreach (var feature in _p.Features.Where(x => x.IsActive).OrderBy(x => x.SortOrder))
                        {
                            <div class="st-feature-card">
                                <span class="st-feature-card__icon"><LucideIcon IconKey="@feature.IconKey" Size="20" FallbackIconKey="circle-check" /></span>
                                <div><dt>@feature.Title</dt><dd>@feature.Value</dd></div>
                            </div>
                        }
                    </dl>
                </section>
            }

            <div class="st-ptabs st-tabs">
                <button class="st-tab @(_tab == "desc" ? "active" : "")" @onclick='() => _tab = "desc"'>توضیحات</button>
                <button class="st-tab @(_tab == "reviews" ? "active" : "")" @onclick='() => _tab = "reviews"'>نظرات (@AUI.Number(_summary.TotalApprovedReviews))</button>
                <button class="st-tab @(_tab == "faq" ? "active" : "")" @onclick='() => _tab = "faq"'>سوالات متداول</button>
            </div>

            <div style="margin-top:20px">
                @if (_tab == "desc")
                {
                    <div class="st-rich-content">
                        @if (!string.IsNullOrWhiteSpace(_p.FullDescription))
                        { @((MarkupString)_p.FullDescription) }
                        else if (!string.IsNullOrWhiteSpace(_p.ShortDescription))
                        { <p>@_p.ShortDescription</p> }
                        else { <p class="st-muted">توضیحاتی برای این محصول ثبت نشده است.</p> }
                    </div>

                    <div class="st-trustchips">
                        <div class="st-trustchip"><span class="st-trustchip__ic"><Icon Name="shield-check" Size="14" /></span><div><div class="st-trustchip__t">ضمانت اصالت</div><div class="st-trustchip__s">فروشنده معتبر</div></div></div>
                        <div class="st-trustchip"><span class="st-trustchip__ic"><Icon Name="zap" Size="14" /></span><div><div class="st-trustchip__t">تحویل آنی</div><div class="st-trustchip__s">بلافاصله پس از پرداخت</div></div></div>
                        <div class="st-trustchip"><span class="st-trustchip__ic"><Icon Name="lock" Size="14" /></span><div><div class="st-trustchip__t">پرداخت امن</div><div class="st-trustchip__s">رمزگذاری ۲۵۶ بیتی</div></div></div>
                        <div class="st-trustchip"><span class="st-trustchip__ic"><Icon Name="headphones" Size="14" /></span><div><div class="st-trustchip__t">پشتیبانی ۲۴/۷</div><div class="st-trustchip__s">همیشه در دسترس</div></div></div>
                    </div>

                    <div class="st-whyband">
                        <span class="st-whyband__aurora"></span>
                        <div class="st-whyband__t">چرا از ویتورایز بخریم؟</div>
                        <div class="st-whyband__grid">
                            <div class="st-whyitem"><span class="st-whyitem__ic"><Icon Name="shield-check" Size="15" /></span><span class="st-whyitem__t">اصالت تضمینی</span><span class="st-whyitem__s">فقط محصولات رسمی و اورجینال</span></div>
                            <div class="st-whyitem"><span class="st-whyitem__ic"><Icon Name="zap" Size="15" /></span><span class="st-whyitem__t">تحویل فوری</span><span class="st-whyitem__s">کد در چند ثانیه فعال می‌شود</span></div>
                            <div class="st-whyitem"><span class="st-whyitem__ic"><Icon Name="credit-card" Size="15" /></span><span class="st-whyitem__t">پرداخت مطمئن</span><span class="st-whyitem__s">درگاه‌های بانکی معتبر</span></div>
                            <div class="st-whyitem"><span class="st-whyitem__ic"><Icon Name="headphones" Size="15" /></span><span class="st-whyitem__t">پشتیبانی واقعی</span><span class="st-whyitem__s">تیم پاسخگو در هر ساعت</span></div>
                        </div>
                    </div>

                    <div class="st-metarow">
                        <div class="st-metarow__l">
                            <span>دسته‌بندی: <b>@_p.CategoryTitle</b></span>
                            @if (!string.IsNullOrWhiteSpace(_p.BrandTitle)) { <span>برند: <b>@_p.BrandTitle</b></span> }
                            <span>نوع تحویل: <b>@AUI.DeliveryType(_p.DeliveryType)</b></span>
                        </div>
                        <div class="st-share">
                            <span class="st-muted" style="font-size:11.5px;font-weight:600">اشتراک‌گذاری</span>
                            <a class="st-share__b" href="@TelegramShare" target="_blank" rel="noopener noreferrer" title="تلگرام" aria-label="اشتراک‌گذاری در تلگرام"><Icon Name="send" Size="13" /></a>
                            <button class="st-share__b" @onclick="CopyLink" title="کپی لینک" aria-label="کپی لینک محصول"><Icon Name="copy" Size="13" /></button>
                        </div>
                    </div>
                }
                else if (_tab == "reviews")
                {
                    @if (_summary.TotalApprovedReviews > 0)
                    {
                        <div class="st-revsum">
                            <div class="st-revsum__n">@PersianDateHelper.ToPersianDigits(_summary.AverageRating.ToString("0.0"))</div>
                            <div>
                                <div class="st-revsum__stars">@Stars((int)Math.Round(_summary.AverageRating))</div>
                                <div class="st-revsum__c">@AUI.Number(_summary.TotalApprovedReviews) نظر ثبت‌شده</div>
                            </div>
                        </div>
                    }
                    <ProductReviews ProductId="_p.Id" Summary="_summary" />
                }
                else
                {
                    @if (_faqs.Count == 0)
                    {
                        <p class="st-muted" style="font-size:14px">سوال متداولی ثبت نشده است.</p>
                    }
                    else
                    {
                        <div class="st-stack">
                            @foreach (var f in _faqs)
                            {
                                <FaqItem Question="@f.Question" Answer="@f.Answer" />
                            }
                        </div>
                    }
                }
            </div>
        </div>

        @* ---------- RIGHT: sticky buy box ---------- *@
        <div class="st-buy">
            <div class="st-buy__kicker">@_p.CategoryTitle@(string.IsNullOrWhiteSpace(_p.BrandTitle) ? "" : $" · {_p.BrandTitle}")</div>
            <h1 class="st-buy__title">@_p.Title</h1>
            @if (_summary.TotalApprovedReviews > 0)
            {
                <div class="st-buy__rate">
                    <span class="stars">@Stars((int)Math.Round(_summary.AverageRating))</span>
                    <span>@PersianDateHelper.ToPersianDigits(_summary.AverageRating.ToString("0.0")) · @AUI.Number(_summary.TotalApprovedReviews) نظر</span>
                </div>
            }

            <div class="st-buy__card">
                <div class="st-buy__price">
                    <span class="st-buy__now">@AUI.Number((long)CurrentPrice)</span>
                    <span class="st-buy__unit">@Unit</span>
                    @if (CurrentDiscounted)
                    {
                        <span class="st-buy__old">@AUI.Number((long)CurrentBase)</span>
                    }
                </div>
                @if (CurrentDiscounted)
                {
                    <div class="st-buy__save">@AUI.Number((long)(CurrentBase - CurrentPrice)) @Unit سود شما (@AUI.Number(DiscountPercent)٪)</div>
                }

                @if (_p.Variants.Count > 0)
                {
                    <div class="st-buy__lbl">انتخاب نسخه</div>
                    <div class="st-vcards">
                        @foreach (var v in _p.Variants.OrderBy(x => x.SortOrder))
                        {
                            <button class="st-vcard @(_variant?.Id == v.Id ? "active" : null)" @onclick="() => SelectVariant(v)">
                                <div class="st-vcard__t">@v.Title</div>
                                <div class="st-vcard__p">@AUI.Number((long)v.FinalPrice) @Unit</div>
                                <div class="st-vcard__stock">@(v.AvailableStock > 0 ? $"{AUI.Number(v.AvailableStock)} موجود" : "ناموجود")</div>
                            </button>
                        }
                    </div>
                }

                @* payment -> delivery flow *@
                <div class="st-flow">
                    <div class="st-flow__step"><span class="st-flow__dot on"><Icon Name="check" Size="11" /></span><span class="st-flow__t">پرداخت</span></div>
                    <div class="st-flow__line"></div>
                    <div class="st-flow__step"><span class="st-flow__dot off"><Icon Name="zap" Size="12" /></span><span class="st-flow__t">@AUI.DeliveryType(_p.DeliveryType)</span></div>
                </div>

                <div class="st-trustbar">
                    <div class="st-trustbar__row"><span><Icon Name="shield-check" Size="13" /> ضمانت فروشنده معتبر</span><span class="ok">@AUI.Number(TrustScore)٪</span></div>
                    <div class="st-trustbar__track"><div class="st-trustbar__fill" style="width:@(TrustScore)%"></div></div>
                </div>

                @if (_p.RequiresVerification)
                {
                    <div class="st-alert st-alert--info" style="margin-bottom:12px"><Icon Name="shield" Size="16" /> <span>خرید این محصول نیازمند احراز هویت است.</span></div>
                }

                <div class="st-buy__qty">
                    <span class="st-label" style="margin:0">تعداد</span>
                    <div class="st-qty">
                        <button @onclick="() => SetQty(_qty - 1)">−</button>
                        <span>@AUI.Number(_qty)</span>
                        <button @onclick="() => SetQty(_qty + 1)">+</button>
                    </div>
                </div>

                @if (OutOfStock)
                {
                    <div class="st-alert st-alert--warn" style="margin-bottom:12px">
                        <Icon Name="package" Size="16" /> <span>این محصول در حال حاضر ناموجود است.</span>
                    </div>
                }
                @if (_p.InputFields.Any(x => x.IsActive))
                {
                    <div class="st-required-info"><Icon Name="file-text" Size="15" /><span>این محصول برای تکمیل سفارش به @AUI.Number(_p.InputFields.Count(x => x.IsActive)) مورد اطلاعات نیاز دارد.</span></div>
                }
                <button class="st-btn st-btn--accent st-btn--block st-btn--lg" @onclick="() => BeginAddToCart(false)" disabled="@(_busy || OutOfStock)">
                    @if (_busy) { <span class="st-spinner sm"></span> } else { <Icon Name="cart" Size="18" /> <span>@(OutOfStock ? "ناموجود" : "افزودن به سبد خرید")</span> }
                </button>
                <div style="display:flex;gap:10px;margin-top:10px">
                    <button class="st-btn st-btn--outline st-btn--block" @onclick="() => BeginAddToCart(true)" disabled="@(_busy || OutOfStock)">خرید فوری</button>
                    <button class="st-btn st-btn--ghost" style="flex:0 0 auto" @onclick="ToggleWishlist" disabled="@_wishBusy" title="علاقه‌مندی">
                        <Icon Name="heart" Size="18" Class="@(InWishlist ? "st-heart-on" : null)" />
                    </button>
                </div>
                <div class="st-buy__secure"><Icon Name="lock" Size="13" /> پرداخت امن · رمزگذاری ۲۵۶ بیتی</div>
            </div>
        </div>
    </div>

    @if (_related.Count > 0)
    {
        <section class="st-section st-reveal">
            <div class="st-section__head"><div class="st-section__title"><span class="bar"></span> محصولات مرتبط</div></div>
            <div class="st-grid">
                @foreach (var r in _related) { <StoreProductCard Product="r" /> }
            </div>
        </section>
    }
}

<Modal Visible="_inputOpen" Title="اطلاعات موردنیاز خرید" Icon="file-text" OnClose="CloseInputForm">
    <ChildContent>
        <div class="st-dynamic-form">
            @foreach (var field in ProductStageFields)
            {
                <div class="st-field">
                    <label class="st-label" for="@($"product-input-{field.Key}")">@field.Label @if (field.IsRequired) { <span class="req">*</span> }</label>
                    @if (!string.IsNullOrWhiteSpace(field.Description)) { <span class="st-help">@field.Description</span> }
                    @if (field.FieldType is 6 or 7)
                    {
                        <select id="@($"product-input-{field.Key}")" class="st-select" value="@GetInput(field.Key)" @onchange="e => SetInput(field.Key, e.Value?.ToString())">
                            <option value="">— انتخاب کنید —</option>@foreach (var option in field.Options) { <option value="@option">@option</option> }
                        </select>
                    }
                    else if (field.FieldType == 8)
                    {
                        <label class="st-check"><input type="checkbox" checked="@IsInputChecked(field.Key)" @onchange="e => SetInputCheckbox(field.Key, e.Value)" /><span>@field.Placeholder</span></label>
                    }
                    else if (field.FieldType == 5)
                    {
                        <textarea id="@($"product-input-{field.Key}")" class="st-textarea" placeholder="@field.Placeholder" value="@GetInput(field.Key)" @oninput="e => SetInput(field.Key, e.Value?.ToString())"></textarea>
                    }
                    else
                    {
                        <input id="@($"product-input-{field.Key}")" class="st-input" type="@InputType(field.FieldType)" inputmode="@InputMode(field.FieldType)"
                               placeholder="@field.Placeholder" minlength="@field.MinLength" maxlength="@field.MaxLength"
                               value="@GetInput(field.Key)" @oninput="e => SetInput(field.Key, e.Value?.ToString())" autocomplete="off" />
                    }
                    @if (field.IsSensitive) { <span class="st-help"><Icon Name="lock" Size="12" /> این مقدار رمزگذاری و در نمایش‌ها مخفی می‌شود.</span> }
                    @if (field.IsSensitive && field.RequiresConfirmation)
                    {
                        <input class="st-input" type="password" placeholder="تکرار @field.Label" value="@GetConfirmation(field.Key)" @oninput="e => SetConfirmation(field.Key, e.Value?.ToString())" autocomplete="off" />
                    }
                </div>
            }
        </div>
    </ChildContent>
    <Footer>
        <button class="st-btn st-btn--outline" @onclick="CloseInputForm">انصراف</button>
        <button class="st-btn st-btn--accent" @onclick="SubmitInputForm" disabled="@_busy">تأیید و افزودن</button>
    </Footer>
</Modal>

@code {
    [Parameter] public string Slug { get; set; } = string.Empty;
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private bool _loading = true, _busy, _wishBusy;
    private StoreProductDetailModel? _p;
    private StoreVariantModel? _variant;
    private List<StoreProductImageModel> _gallery = new();
    private StoreProductImageModel? _activeImage;
    private StoreBranding _branding = new(new Dictionary<string, string>());
    private string _tab = "desc";
    private int _qty = 1;
    private CustomerReviewSummaryModel _summary = new();
    private List<CustomerReviewModel> _structuredReviews = new();
    private List<StoreProductModel> _related = new();
    private List<StoreFaqModel> _faqs = new();
    private string? _loadedSlug;
    private bool _inputOpen, _pendingBuyNow;
    private readonly Dictionary<string, string?> _inputValues = new(StringComparer.OrdinalIgnoreCase);
    private readonly Dictionary<string, string?> _confirmValues = new(StringComparer.OrdinalIgnoreCase);
    private IEnumerable<StoreProductInputFieldModel> ProductStageFields => _p?.InputFields.Where(x => x.IsActive && x.DisplayStage == 1).OrderBy(x => x.SortOrder) ?? Enumerable.Empty<StoreProductInputFieldModel>();

    private decimal CurrentBase => _variant?.Price ?? _p?.BasePrice ?? 0;
    private decimal CurrentPrice => _variant?.FinalPrice ?? _p?.FinalPrice ?? 0;
    private bool CurrentDiscounted => CurrentPrice < CurrentBase;
    private int DiscountPercent => CurrentBase > 0 && CurrentDiscounted ? (int)Math.Round((CurrentBase - CurrentPrice) / CurrentBase * 100) : 0;
    private string Unit => (_p?.CurrencyType ?? 2) == (byte)CurrencyType.Rial ? "ریال" : "تومان";
    private bool InWishlist => _p is not null && Wishlist.Contains(_p.Id);

    // فقط تحویل آنی موجودی واقعی (کد) دارد؛ تحویل دستی/پشتیبانی همیشه قابل سفارش است.
    private bool OutOfStock =>
        _p is not null &&
        _p.DeliveryType == (byte)DeliveryType.Instant &&
        (_variant is not null
            ? _variant.AvailableStock <= 0
            : (_p.Variants.Count > 0
                ? _p.Variants.All(v => v.AvailableStock <= 0)
                : _p.AvailableStock <= 0));
    // Trust score derived from real review rating; falls back to a guarantee baseline when unrated.
    private int TrustScore => _summary.TotalApprovedReviews > 0 ? (int)Math.Round(_summary.AverageRating / 5 * 100) : 95;
    private string ShareUrl => $"{Nav.BaseUri.TrimEnd('/')}/product/{Slug}";
    private string TelegramShare => $"https://t.me/share/url?url={Uri.EscapeDataString(ShareUrl)}&text={Uri.EscapeDataString(_p?.Title ?? "")}";

    protected override void OnInitialized() => Wishlist.OnChange += OnWishChange;
    private void OnWishChange() => InvokeAsync(StateHasChanged);

    protected override async Task OnParametersSetAsync()
    {
        if (Slug == _loadedSlug) return;
        _loadedSlug = Slug;
        await Load();
    }

    private async Task Load()
    {
        _loading = true;
        _p = null; _variant = null; _gallery.Clear(); _activeImage = null; _qty = 1; _tab = "desc"; _summary = new(); _structuredReviews = new(); _related = new();

        var productTask = Api.GetAsync<StoreProductDetailModel>($"products/slug/{Uri.EscapeDataString(Slug)}");
        var brandingTask = Branding.GetAsync();
        await Task.WhenAll(productTask, brandingTask);
        var result = productTask.Result;
        _branding = brandingTask.Result;
        if (result.IsSuccess && result.Data is not null)
        {
            _p = result.Data;
            _gallery = new List<StoreProductImageModel>();
            if (!string.IsNullOrWhiteSpace(_p.ThumbnailImagePath)) _gallery.Add(new() { ImagePath = _p.ThumbnailImagePath, AltText = _p.ThumbnailAltText });
            foreach (var img in _p.ImageItems.Where(i => !string.IsNullOrWhiteSpace(i.ImagePath)).OrderBy(i => i.SortOrder))
                if (_gallery.All(x => !x.ImagePath.Equals(img.ImagePath, StringComparison.OrdinalIgnoreCase))) _gallery.Add(img);
            _activeImage = _gallery.FirstOrDefault();
            _variant = _p.Variants.FirstOrDefault(v => v.IsDefault) ?? _p.Variants.OrderBy(v => v.SortOrder).FirstOrDefault();
            _qty = Math.Max(1, _p.MinOrderQuantity);
            await LoadExtras(_p.Id);
        }
        else if (HttpContext.HttpContext is { Response.HasStarted: false } context)
        {
            context.Response.StatusCode = StatusCodes.Status404NotFound;
        }
        _loading = false;
    }

    private async Task LoadExtras(Guid id)
    {
        var sumTask = Api.GetAsync<CustomerReviewSummaryModel>($"product-reviews/product/{id}/summary");
        var reviewsTask = Api.GetAsync<CustomerReviewListModel>($"product-reviews/product/{id}?page=1&pageSize=10&sort=newest");
        var relTask = Api.GetAsync<List<StoreProductModel>>($"products/{id}/related?count=8");
        var faqTask = Api.GetAsync<List<StoreFaqModel>>("faqs");
        await Task.WhenAll(sumTask, reviewsTask, relTask, faqTask);
        if (sumTask.Result.Data is not null) _summary = sumTask.Result.Data;
        _structuredReviews = reviewsTask.Result.Data?.Reviews.Items
            .Where(x => x.IsApproved && !string.IsNullOrWhiteSpace(x.Comment))
            .Take(3)
            .ToList() ?? new();
        _related = relTask.Result.Data ?? new();
        _faqs = (faqTask.Result.Data ?? new()).Take(6).ToList();
        StateHasChanged();
    }

    private void SelectVariant(StoreVariantModel v) => _variant = v;

    private string ProductJsonLd()
    {
        if (_p is null) return string.Empty;
        var canonical = SeoUrlBuilder.Canonical(_branding, Nav.Uri, $"/product/{Uri.EscapeDataString(_p.Slug)}");
        var product = new Dictionary<string, object?>
        {
            ["@context"] = "https://schema.org", ["@type"] = "Product",
            ["name"] = _p.Title, ["description"] = _p.ShortDescription,
            ["sku"] = _variant?.Sku ?? _p.Slug, ["url"] = canonical,
            ["category"] = _p.CategoryTitle,
            ["image"] = _gallery.Select(x => AbsoluteMedia(x.ImagePath, canonical)).ToList(),
            ["offers"] = new Dictionary<string, object?>
            {
                ["@type"] = "Offer", ["url"] = canonical,
                ["priceCurrency"] = "IRR",
                ["price"] = CurrentPrice * (_p.CurrencyType == 2 ? 10 : 1),
                ["availability"] = OutOfStock ? "https://schema.org/OutOfStock" : "https://schema.org/InStock"
            }
        };
        if (!string.IsNullOrWhiteSpace(_p.BrandTitle))
            product["brand"] = new Dictionary<string, object?> { ["@type"] = "Brand", ["name"] = _p.BrandTitle };
        if (_summary.TotalApprovedReviews > 0)
            product["aggregateRating"] = new Dictionary<string, object?>
            {
                ["@type"] = "AggregateRating", ["ratingValue"] = _summary.AverageRating,
                ["reviewCount"] = _summary.TotalApprovedReviews
            };
        if (_structuredReviews.Count > 0)
            product["review"] = _structuredReviews.Select(review => new Dictionary<string, object?>
            {
                ["@type"] = "Review",
                ["author"] = new Dictionary<string, object?>
                {
                    ["@type"] = "Person",
                    ["name"] = review.UserDisplayName
                },
                ["datePublished"] = review.CreatedAt.ToString("yyyy-MM-dd"),
                ["name"] = review.Title,
                ["reviewBody"] = review.Comment,
                ["reviewRating"] = new Dictionary<string, object?>
                {
                    ["@type"] = "Rating",
                    ["ratingValue"] = review.Rating,
                    ["bestRating"] = 5,
                    ["worstRating"] = 1
                }
            }).ToList();
        return SeoJsonLd.Serialize(product);
    }

    private string AbsoluteMedia(string path, string canonical)
    {
        var resolved = Media.Resolve(path);
        return Uri.TryCreate(resolved, UriKind.Absolute, out var absolute) ? absolute.AbsoluteUri : new Uri(new Uri(canonical), resolved).AbsoluteUri;
    }

    private void SetQty(int q)
    {
        var min = Math.Max(1, _p?.MinOrderQuantity ?? 1);
        var max = _p?.MaxOrderQuantity ?? 99;
        _qty = Math.Clamp(q, min, max);
    }

    private async Task BeginAddToCart(bool buyNow)
    {
        if (_p is null) return;
        if (_p.Variants.Count > 0 && _variant is null) { Toasts.Error("لطفاً یک نسخه را انتخاب کنید."); return; }
        if (ProductStageFields.Any())
        {
            _pendingBuyNow = buyNow;
            foreach (var field in ProductStageFields)
                if (!_inputValues.ContainsKey(field.Key)) _inputValues[field.Key] = field.DefaultValue;
            _inputOpen = true;
            return;
        }
        await AddToCart(buyNow);
    }

    private async Task SubmitInputForm()
    {
        foreach (var field in ProductStageFields)
        {
            var value = GetInput(field.Key);
            if (field.IsRequired && string.IsNullOrWhiteSpace(value)) { Toasts.Error($"تکمیل «{field.Label}» الزامی است."); return; }
            if (field.RequiresConfirmation && value != GetConfirmation(field.Key)) { Toasts.Error($"تکرار «{field.Label}» یکسان نیست."); return; }
        }
        _inputOpen = false;
        await AddToCart(_pendingBuyNow);
    }

    private async Task AddToCart(bool buyNow)
    {
        if (_p is null) return;

        _busy = true;
        var result = await Api.PostAsync<CartModel>("cart/items",
            new { ProductId = _p.Id, ProductVariantId = _variant?.Id, Quantity = _qty, InputValues = _inputValues });
        _busy = false;

        if (result.IsSuccess && result.Data is not null)
        {
            Cart.Set(result.Data.TotalQuantity);
            if (buyNow) { Nav.NavigateTo("/cart"); return; }
            Toasts.Success("به سبد خرید اضافه شد.");
        }
        else if (result.Message.Contains("احراز") || result.Message.Contains("نشست") || result.Message.Contains("مجاز"))
        {
            Nav.NavigateTo($"/login?returnUrl=/product/{Slug}", forceLoad: true);
        }
        else { Toasts.Error(result.Message); }
    }

    private string? GetInput(string key) => _inputValues.GetValueOrDefault(key);
    private void SetInput(string key, string? value) => _inputValues[key] = value;
    private bool IsInputChecked(string key) => string.Equals(GetInput(key), "true", StringComparison.OrdinalIgnoreCase);
    private void SetInputCheckbox(string key, object? value) => SetInput(key, value is true ? "true" : "false");
    private string? GetConfirmation(string key) => _confirmValues.GetValueOrDefault(key);
    private void SetConfirmation(string key, string? value) => _confirmValues[key] = value;
    private void CloseInputForm() => _inputOpen = false;
    private static string InputType(byte type) => type switch { 2 => "email", 3 => "tel", 4 => "number", 10 => "url", 11 => "date", 12 => "password", _ => "text" };
    private static string? InputMode(byte type) => type switch { 2 => "email", 3 => "tel", 4 => "decimal", 10 => "url", _ => null };

    private async Task ToggleWishlist()
    {
        if (_p is null) return;
        if (AuthState is not null)
        {
            var state = await AuthState;
            if (state.User.Identity?.IsAuthenticated != true)
            {
                Nav.NavigateTo($"/login?returnUrl=/product/{Slug}");
                return;
            }
        }
        _wishBusy = true;
        var result = await Api.PostAsync<bool>($"wishlist/{_p.Id}/toggle");
        _wishBusy = false;
        if (result.IsSuccess)
        {
            if (result.Data) Wishlist.Add(_p.Id); else Wishlist.Remove(_p.Id);
            Toasts.Success(result.Message);
        }
        else Toasts.Error(result.Message);
    }

    private async Task CopyLink()
    {
        var ok = await JS.InvokeAsync<bool>("vzAdmin.copy", ShareUrl);
        if (ok) Toasts.Success("لینک محصول کپی شد.");
    }

    public void Dispose() => Wishlist.OnChange -= OnWishChange;

    private static string Stars(int rating) => new string('★', Math.Clamp(rating, 0, 5)) + new string('☆', 5 - Math.Clamp(rating, 0, 5));
}
