@page "/cart"
@inject ApiClient Api
@inject MediaUrlResolver Media
@inject CartState CartSvc
@inject ToastService Toasts
@inject NavigationManager Nav
@using AUI = Vitorize.Web.Helpers.AdminUiHelper

<PageTitle>سبد خرید | ویتورایز</PageTitle>

<div class="st-bc"><a href="/">خانه</a> <Icon Name="chevron-left" Size="13" /> <span>سبد خرید</span></div>
<h1 style="font-size:22px;margin-bottom:18px">سبد خرید شما</h1>

@if (_loading)
{
    <div class="st-state"><div class="st-spinner"></div></div>
}
else if (_cart is null || _cart.Items.Count == 0)
{
    <div class="st-state" style="padding:70px 24px">
        <div class="st-state__ic"><Icon Name="cart" Size="34" /></div>
        <div style="font-weight:700;font-size:16px">سبد خرید شما خالی است</div>
        <p class="st-muted">محصولات مورد علاقه خود را به سبد اضافه کنید.</p>
        <a class="st-btn st-btn--primary" href="/shop"><Icon Name="shopping-bag" Size="17" /> رفتن به فروشگاه</a>
    </div>
}
else
{
    <div class="st-split">
        <div class="st-stack">
            @foreach (var item in _cart.Items)
            {
                <div class="st-card st-card__pad" style="display:flex;gap:14px;align-items:center">
                    <div style="width:70px;height:56px;border-radius:10px;overflow:hidden;background:var(--st-surface-2);flex:0 0 70px">
                        @if (!string.IsNullOrWhiteSpace(item.ThumbnailImagePath))
                        { <img src="@Media.Resolve(item.ThumbnailImagePath)" alt="" style="width:100%;height:100%;object-fit:cover" /> }
                        else { <div style="display:flex;align-items:center;justify-content:center;height:100%;color:var(--st-muted)"><Icon Name="box" Size="22" /></div> }
                    </div>
                    <div style="flex:1;min-width:0">
                        <div style="font-weight:700;font-size:14px">@item.ProductTitle</div>
                        @if (!string.IsNullOrWhiteSpace(item.VariantTitle))
                        { <div class="st-muted" style="font-size:12px">@item.VariantTitle</div> }
                        <div class="st-muted" style="font-size:12.5px;margin-top:4px">قیمت واحد: @AUI.MoneyFa(item.UnitPrice)</div>
                    </div>
                    <div class="st-qty">
                        <button @onclick="() => UpdateQty(item, item.Quantity - 1)" disabled="@_busy">−</button>
                        <span>@AUI.Number(item.Quantity)</span>
                        <button @onclick="() => UpdateQty(item, item.Quantity + 1)" disabled="@_busy">+</button>
                    </div>
                    <div style="text-align:end;min-width:120px">
                        <div style="font-weight:800">@AUI.MoneyFa(item.TotalPrice)</div>
                        <button class="st-btn st-btn--ghost st-btn--sm" style="color:var(--st-danger);margin-top:4px" @onclick="() => Remove(item)" disabled="@_busy"><Icon Name="trash" Size="14" /> حذف</button>
                    </div>
                </div>
            }
            <button class="st-btn st-btn--ghost st-btn--sm" style="color:var(--st-danger);align-self:flex-start" @onclick="Clear" disabled="@_busy">
                <Icon Name="trash" Size="14" /> خالی کردن سبد خرید
            </button>
        </div>

        <div class="st-card st-card__pad st-cart-sum" style="align-self:start;position:sticky;top:calc(var(--st-header-h) + 16px)">
            <h3 style="font-size:16px;margin-bottom:16px">خلاصه سفارش</h3>

            <div class="st-promo">
                <input class="st-input" placeholder="کد تخفیف" @bind="_coupon" disabled="@(_discount > 0)" />
                @if (_discount > 0)
                {
                    <button class="st-btn st-btn--ghost st-btn--sm" @onclick="ClearCoupon">حذف</button>
                }
                else
                {
                    <button class="st-btn st-btn--outline st-btn--sm" @onclick="ApplyCoupon" disabled="@_couponBusy">
                        @if (_couponBusy) { <span class="st-spinner sm"></span> } else { <span>اعمال</span> }
                    </button>
                }
            </div>
            @if (!string.IsNullOrWhiteSpace(_couponMsg))
            {
                <div class="st-promo__msg @(_discount > 0 ? "ok" : "err")">@_couponMsg</div>
            }

            <div class="st-sumrow"><span class="st-muted">تعداد اقلام</span><span>@AUI.Number(_cart.TotalQuantity)</span></div>
            <div class="st-sumrow"><span class="st-muted">جمع کل</span><span>@AUI.MoneyFa(_cart.SubtotalAmount)</span></div>
            @if (_discount > 0)
            {
                <div class="st-sumrow" style="color:var(--st-success)"><span>تخفیف کد @_appliedCode</span><span>−@AUI.MoneyFa(_discount)</span></div>
            }
            <div class="st-sumrow total"><span>مبلغ قابل پرداخت</span><span>@AUI.MoneyFa(_cart.SubtotalAmount - _discount)</span></div>

            <a class="st-btn st-btn--accent st-btn--block st-btn--lg" style="margin-top:14px" href="@CheckoutHref">
                <Icon Name="lock" Size="17" /> ادامه و پرداخت امن
            </a>
            <a class="st-btn st-btn--ghost st-btn--block" style="margin-top:8px" href="/shop">ادامه خرید</a>

            <div class="st-cart-trust">
                <span><Icon Name="lock" Size="14" /> پرداخت امن</span>
                <span><Icon Name="zap" Size="14" /> تحویل آنی</span>
                <span><Icon Name="shield-check" Size="14" /> اصالت تضمینی</span>
            </div>
        </div>
    </div>
}

@code {
    private bool _loading = true, _busy, _couponBusy;
    private CartModel? _cart;
    private string _coupon = string.Empty;
    private string _appliedCode = string.Empty;
    private decimal _discount;
    private string? _couponMsg;

    private string CheckoutHref => _discount > 0 && !string.IsNullOrWhiteSpace(_appliedCode)
        ? $"/checkout?coupon={Uri.EscapeDataString(_appliedCode)}"
        : "/checkout";

    protected override Task OnInitializedAsync() => Load();

    private async Task ApplyCoupon()
    {
        if (_cart is null || string.IsNullOrWhiteSpace(_coupon)) return;
        _couponBusy = true; _couponMsg = null;
        var r = await Api.PostAsync<ValidateCouponResultModel>("coupons/validate",
            new { Code = _coupon.Trim(), OrderAmount = _cart.SubtotalAmount });
        _couponBusy = false;
        if (r.IsSuccess && r.Data is { IsValid: true })
        {
            _discount = r.Data.DiscountAmount;
            _appliedCode = r.Data.Code ?? _coupon.Trim();
            _couponMsg = $"کد تخفیف اعمال شد: {AUI.MoneyFa(_discount)} تخفیف";
        }
        else
        {
            _discount = 0; _appliedCode = string.Empty;
            _couponMsg = r.Data?.Message ?? r.Message ?? "کد تخفیف نامعتبر است.";
        }
    }

    private void ClearCoupon()
    {
        _discount = 0; _appliedCode = string.Empty; _coupon = string.Empty; _couponMsg = null;
    }

    private async Task Load()
    {
        _loading = true;
        var result = await Api.GetAsync<CartModel>("cart");
        if (result.IsSuccess && result.Data is not null)
        {
            _cart = result.Data;
            CartSvc.Set(_cart.TotalQuantity);
        }
        _loading = false;
    }

    private async Task UpdateQty(CartItemModel item, int qty)
    {
        if (qty < 1) { await Remove(item); return; }
        _busy = true;
        var result = await Api.PutAsync<CartModel>($"cart/items/{item.Id}", new { Quantity = qty });
        _busy = false;
        Apply(result);
    }

    private async Task Remove(CartItemModel item)
    {
        _busy = true;
        var result = await Api.DeleteAsync($"cart/items/{item.Id}");
        _busy = false;
        if (result.IsSuccess) await Load();
        else Toasts.Error(result.Message);
    }

    private async Task Clear()
    {
        _busy = true;
        var result = await Api.DeleteAsync("cart/clear");
        _busy = false;
        if (result.IsSuccess) { CartSvc.Clear(); await Load(); }
        else Toasts.Error(result.Message);
    }

    private void Apply(ApiResult<CartModel> result)
    {
        if (result.IsSuccess && result.Data is not null)
        {
            _cart = result.Data;
            CartSvc.Set(_cart.TotalQuantity);
        }
        else Toasts.Error(result.Message);
    }
}
