@page "/checkout"
@inject ApiClient Api
@inject ToastService Toasts
@inject NavigationManager Nav
@using Vitorize.Web.Models.Customer
@using AUI = Vitorize.Web.Helpers.AdminUiHelper

<PageTitle>تکمیل خرید | ویتورایز</PageTitle>

<div class="st-steps">
    <div class="st-step done"><span class="st-step__n"><Icon Name="check" Size="13" /></span> سبد خرید</div>
    <div class="st-step active"><span class="st-step__n">۲</span> اطلاعات و پرداخت</div>
    <div class="st-step"><span class="st-step__n">۳</span> تکمیل سفارش</div>
</div>

@if (_loading)
{
    <div class="st-state"><div class="st-spinner"></div></div>
}
else if (_cart is null || _cart.Items.Count == 0)
{
    <div class="st-state" style="padding:60px 24px">
        <div class="st-state__ic"><Icon Name="cart" Size="32" /></div>
        <div style="font-weight:700">سبد خرید شما خالی است</div>
        <a class="st-btn st-btn--primary st-btn--sm" href="/shop">رفتن به فروشگاه</a>
    </div>
}
else
{
    <div class="st-split">
        <div class="st-stack">
            <div class="st-card">
                <div class="st-card__head"><Icon Name="user" Size="18" /> اطلاعات مشتری</div>
                <div class="st-card__pad">
                    <div class="st-stats" style="grid-template-columns:1fr 1fr">
                        <div><div class="st-muted" style="font-size:12px">نام</div><div style="font-weight:700">@(_user?.FullName ?? "-")</div></div>
                        <div><div class="st-muted" style="font-size:12px">موبایل</div><div style="font-weight:700" class="st-mono">@(_user?.Mobile ?? "-")</div></div>
                    </div>
                </div>
            </div>

            @if (_user is not null && _user.VerificationStatus != (byte)VerificationStatus.Verified)
            {
                <div class="st-alert st-alert--warn">
                    <Icon Name="shield" Size="20" />
                    <div>
                        <div style="font-weight:700">احراز هویت</div>
                        <div style="font-size:12.5px;margin-top:3px">برخی محصولات برای تحویل نیازمند احراز هویت هستند. در صورت نیاز ابتدا احراز هویت را تکمیل کنید.</div>
                        <a class="st-btn st-btn--outline st-btn--sm" style="margin-top:8px" href="/customer/verification">تکمیل احراز هویت</a>
                    </div>
                </div>
            }

            <div class="st-card">
                <div class="st-card__head"><Icon Name="percent" Size="18" /> کد تخفیف</div>
                <div class="st-card__pad">
                    <div class="st-promo">
                        <input class="st-input" placeholder="کد تخفیف خود را وارد کنید" @bind="_coupon" disabled="@(_discount > 0)" />
                        @if (_discount > 0)
                        {
                            <button class="st-btn st-btn--ghost st-btn--sm" @onclick="ClearCoupon">حذف</button>
                        }
                        else
                        {
                            <button class="st-btn st-btn--outline st-btn--sm" @onclick="ApplyCoupon" disabled="@_couponBusy">
                                @if (_couponBusy) { <span class="st-spinner sm"></span> } else { <span>اعمال</span> }
                            </button>
                        }
                    </div>
                    @if (!string.IsNullOrWhiteSpace(_couponMsg))
                    {
                        <div class="st-promo__msg @(_discount > 0 ? "ok" : "err")">@_couponMsg</div>
                    }
                </div>
            </div>

            <div class="st-card">
                <div class="st-card__head"><Icon Name="credit-card" Size="18" /> روش پرداخت</div>
                <div class="st-card__pad">
                    <div class="st-paycards">
                        <div class="st-paycard @(_method == "gateway" ? "active" : null)" @onclick='() => _method = "gateway"'>
                            <span class="st-paycard__ic"><Icon Name="credit-card" Size="19" /></span>
                            <div><div class="st-paycard__t">پرداخت اینترنتی</div><div class="st-paycard__s">درگاه بانکی امن</div></div>
                            <span class="st-paycard__radio"></span>
                        </div>
                        <div class="st-paycard @(_method == "wallet" ? "active" : null) @(WalletEnough ? "" : "disabled")"
                             @onclick='() => { if (WalletEnough) _method = "wallet"; }'>
                            <span class="st-paycard__ic"><Icon Name="wallet" Size="19" /></span>
                            <div>
                                <div class="st-paycard__t">کیف پول ویتورایز</div>
                                <div class="st-paycard__s">موجودی: @AUI.MoneyFa(_walletBalance)@(WalletEnough ? "" : " (ناکافی)")</div>
                            </div>
                            <span class="st-paycard__radio"></span>
                        </div>
                    </div>
                    <div class="st-delivery-note">
                        <span class="ic"><Icon Name="zap" Size="16" /></span>
                        محصولات با تحویل آنی، بلافاصله پس از پرداخت در «سفارش‌های من» و «کدهای من» فعال می‌شوند.
                    </div>
                </div>
            </div>
        </div>

        <div class="st-card st-card__pad" style="align-self:start;position:sticky;top:calc(var(--st-header-h) + 16px)">
            <h3 style="font-size:16px;margin-bottom:14px">خلاصه سفارش</h3>
            <div class="st-stack" style="gap:8px;max-height:230px;overflow-y:auto;margin-bottom:10px">
                @foreach (var item in _cart.Items)
                {
                    <div class="st-spread" style="font-size:12.5px">
                        <span style="flex:1;min-width:0">@item.ProductTitle <span class="st-muted">×@AUI.Number(item.Quantity)</span></span>
                        <span class="st-mono">@AUI.MoneyFa(item.TotalPrice)</span>
                    </div>
                }
            </div>
            <div class="st-sumrow"><span class="st-muted">تعداد اقلام</span><span>@AUI.Number(_cart.TotalQuantity)</span></div>
            <div class="st-sumrow"><span class="st-muted">جمع کل</span><span>@AUI.MoneyFa(_cart.SubtotalAmount)</span></div>
            @if (_discount > 0)
            {
                <div class="st-sumrow" style="color:var(--st-success)"><span>تخفیف کد @_appliedCode</span><span>−@AUI.MoneyFa(_discount)</span></div>
            }
            <div class="st-sumrow total"><span>مبلغ قابل پرداخت</span><span>@AUI.MoneyFa(Payable)</span></div>

            <button class="st-btn st-btn--accent st-btn--block st-btn--lg" style="margin-top:14px" @onclick="PlaceOrder" disabled="@_placing">
                @if (_placing) { <span class="st-spinner sm"></span> <span>در حال پردازش ...</span> }
                else { <Icon Name="lock" Size="18" /> <span>پرداخت امن @AUI.MoneyFa(Payable)</span> }
            </button>
            <div class="st-secure"><Icon Name="lock" Size="13" /> رمزگذاری ۲۵۶ بیتی · ضمانت فروشنده معتبر</div>
            <div class="st-cart-trust">
                <span><Icon Name="shield-check" Size="14" /> اصالت تضمینی</span>
                <span><Icon Name="zap" Size="14" /> تحویل آنی</span>
                <span><Icon Name="headphones" Size="14" /> پشتیبانی ۲۴/۷</span>
            </div>
        </div>
    </div>
}

@code {
    [SupplyParameterFromQuery(Name = "coupon")] public string? CouponFromQuery { get; set; }

    private bool _loading = true, _placing, _couponBusy;
    private CartModel? _cart;
    private CustomerProfileModel? _user;
    private decimal _walletBalance;
    private string _coupon = string.Empty;
    private string _appliedCode = string.Empty;
    private decimal _discount;
    private string? _couponMsg;
    private string _method = "gateway";

    private decimal Payable => _cart is null ? 0 : Math.Max(0, _cart.SubtotalAmount - _discount);
    private bool WalletEnough => _cart is not null && _walletBalance >= Payable && Payable > 0;

    protected override async Task OnInitializedAsync()
    {
        var cartTask = Api.GetAsync<CartModel>("cart");
        var meTask = Api.GetAsync<CustomerProfileModel>("auth/me");
        var walletTask = Api.GetAsync<CustomerWalletModel>("wallet");
        await Task.WhenAll(cartTask, meTask, walletTask);

        _cart = cartTask.Result.Data;
        _user = meTask.Result.Data;
        _walletBalance = walletTask.Result.Data?.Balance ?? 0;
        _loading = false;

        // Re-validate a coupon carried over from the cart so its discount shows on the summary.
        if (!string.IsNullOrWhiteSpace(CouponFromQuery) && _cart is not null && _cart.Items.Count > 0)
        {
            _coupon = CouponFromQuery.Trim();
            await ApplyCoupon();
        }
    }

    private async Task ApplyCoupon()
    {
        if (_cart is null || string.IsNullOrWhiteSpace(_coupon)) return;
        _couponBusy = true; _couponMsg = null;
        var r = await Api.PostAsync<ValidateCouponResultModel>("coupons/validate",
            new { Code = _coupon.Trim(), OrderAmount = _cart.SubtotalAmount });
        _couponBusy = false;
        if (r.IsSuccess && r.Data is { IsValid: true })
        {
            _discount = r.Data.DiscountAmount;
            _appliedCode = r.Data.Code ?? _coupon.Trim();
            _couponMsg = $"کد تخفیف اعمال شد: {AUI.MoneyFa(_discount)} تخفیف";
        }
        else
        {
            _discount = 0; _appliedCode = string.Empty;
            _couponMsg = r.Data?.Message ?? r.Message ?? "کد تخفیف نامعتبر است.";
        }
    }

    private void ClearCoupon()
    {
        _discount = 0; _appliedCode = string.Empty; _coupon = string.Empty; _couponMsg = null;
    }

    private async Task PlaceOrder()
    {
        if (_cart is null || _cart.Items.Count == 0) return;
        _placing = true;

        var key = Guid.NewGuid().ToString("N");
        var headers = new Dictionary<string, string> { ["Idempotency-Key"] = key };

        var checkout = await Api.PostAsync<CheckoutResultModel>(
            "checkout",
            new { Description = (string?)null, CouponCode = string.IsNullOrWhiteSpace(_appliedCode) ? null : _appliedCode },
            headers);

        if (!checkout.IsSuccess || checkout.Data is null)
        {
            _placing = false;
            Toasts.Error(checkout.Message);
            return;
        }

        var orderId = checkout.Data.OrderId;

        if (_method == "wallet")
        {
            var payKey = new Dictionary<string, string> { ["Idempotency-Key"] = Guid.NewGuid().ToString("N") };
            var pay = await Api.PostAsync<PaymentVerifyResultModel>($"payments/wallet/pay/{orderId}", null, payKey);
            _placing = false;
            if (pay.IsSuccess && pay.Data is not null)
                Nav.NavigateTo($"/payment/result?orderId={orderId}&paid={(pay.Data.IsPaid ? "1" : "0")}");
            else
                Toasts.Error(pay.Message);
            return;
        }

        // درگاه پرداخت
        var start = await Api.PostAsync<PaymentStartResultModel>($"payments/start/{orderId}");
        if (!start.IsSuccess || start.Data is null)
        {
            _placing = false;
            Toasts.Error(start.Message);
            return;
        }

        if (!string.IsNullOrWhiteSpace(start.Data.PaymentUrl) &&
            start.Data.PaymentUrl.StartsWith("http", StringComparison.OrdinalIgnoreCase))
        {
            Nav.NavigateTo(start.Data.PaymentUrl, forceLoad: true);
            return;
        }

        // درگاه تستی: تایید داخلی
        var verify = await Api.PostAsync<PaymentVerifyResultModel>($"payments/mock/verify/{start.Data.PaymentId}");
        _placing = false;
        if (verify.IsSuccess && verify.Data is not null)
            Nav.NavigateTo($"/payment/result?orderId={orderId}&paid={(verify.Data.IsPaid ? "1" : "0")}");
        else
            Nav.NavigateTo($"/payment/result?orderId={orderId}&paid=0");
    }
}
