@page "/reset-password"
@inject ApiClient Api
@inject NavigationManager Nav
@inject ToastService Toasts

<PageTitle>تغییر رمز عبور | ویتورایز</PageTitle>

<div style="max-width:440px;margin:30px auto">
    <div class="st-card st-card__pad">
        <div style="text-align:center;margin-bottom:22px">
            <div style="width:54px;height:54px;border-radius:15px;background:var(--st-chip);color:var(--st-brand-2);display:flex;align-items:center;justify-content:center;margin:0 auto 12px"><Icon Name="shield-lock" Size="24" /></div>
            <h1 style="font-size:20px">تنظیم رمز عبور جدید</h1>
            <p class="st-muted" style="font-size:13px;margin-top:6px">کد بازیابی و رمز عبور جدید خود را وارد کنید.</p>
        </div>

        <div class="st-field">
            <label class="st-label">شماره موبایل</label>
            <input class="st-input" @bind="_mobile" inputmode="tel" />
        </div>
        <div class="st-field">
            <label class="st-label">کد بازیابی</label>
            <input class="st-input" @bind="_code" inputmode="numeric" placeholder="کد ارسال‌شده" />
        </div>
        <div class="st-field">
            <label class="st-label">رمز عبور جدید</label>
            <input class="st-input" type="password" @bind="_newPassword" placeholder="حداقل ۶ کاراکتر" />
        </div>
        <div class="st-field">
            <label class="st-label">تکرار رمز عبور</label>
            <input class="st-input" type="password" @bind="_confirm" />
        </div>
        <button class="st-btn st-btn--primary st-btn--block st-btn--lg" @onclick="Submit" disabled="@_busy">
            @if (_busy) { <span class="st-spinner sm"></span> } else { <span>تغییر رمز عبور</span> }
        </button>

        <div class="st-divider"></div>
        <div style="text-align:center;font-size:13px"><a href="/login" style="color:var(--st-brand-2)">بازگشت به ورود</a></div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery] public string? Mobile { get; set; }

    private string _mobile = string.Empty;
    private string _code = string.Empty;
    private string _newPassword = string.Empty;
    private string _confirm = string.Empty;
    private bool _busy;

    protected override void OnParametersSet()
    {
        if (string.IsNullOrWhiteSpace(_mobile) && !string.IsNullOrWhiteSpace(Mobile))
            _mobile = Mobile;
    }

    private async Task Submit()
    {
        if (string.IsNullOrWhiteSpace(_mobile) || string.IsNullOrWhiteSpace(_code) || string.IsNullOrWhiteSpace(_newPassword))
        { Toasts.Error("همه فیلدها را تکمیل کنید."); return; }
        if (_newPassword != _confirm) { Toasts.Error("رمز عبور و تکرار آن یکسان نیست."); return; }

        _busy = true;
        var result = await Api.PostAsync("auth/reset-password", new
        {
            Mobile = _mobile.Trim(),
            Code = _code.Trim(),
            NewPassword = _newPassword,
            ConfirmNewPassword = _confirm
        });
        _busy = false;

        if (result.IsSuccess)
        {
            Toasts.Success("رمز عبور با موفقیت تغییر کرد. اکنون وارد شوید.");
            Nav.NavigateTo("/login");
        }
        else Toasts.Error(result.Message);
    }
}
