@page "/shop"

<SeoHead Title="فروشگاه" Description="مشاهده و خرید محصولات دیجیتال ویتورایز" CanonicalPath="/shop"
         Index="@(string.IsNullOrWhiteSpace(Q) && string.IsNullOrWhiteSpace(Sort))" />

<ShopBrowser Title="فروشگاه" InitialSearch="@Q" InitialSort="@Sort" />

@code {
    [SupplyParameterFromQuery(Name = "q")] public string? Q { get; set; }
    [SupplyParameterFromQuery(Name = "sort")] public string? Sort { get; set; }
}
