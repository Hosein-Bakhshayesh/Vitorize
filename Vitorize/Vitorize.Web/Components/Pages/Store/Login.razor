@page "/login"

<PageTitle>ورود | ویتورایز</PageTitle>

<div style="max-width:440px;margin:30px auto">
    <div class="st-card st-card__pad">
        <div style="text-align:center;margin-bottom:22px">
            <div class="st-logo" style="justify-content:center;margin-bottom:10px"><span class="st-logo__mark">V</span> <span>VITORIZE</span></div>
            <h1 style="font-size:20px">ورود به حساب کاربری</h1>
            <p class="st-muted" style="font-size:13px;margin-top:6px">برای ادامه، وارد حساب خود شوید.</p>
        </div>

        @if (!string.IsNullOrWhiteSpace(Error))
        {
            <div class="st-alert st-alert--danger" style="margin-bottom:16px"><Icon Name="x-circle" Size="18" /> <span>@Error</span></div>
        }

        <form method="post" action="/auth/customer/login">
            <input type="hidden" name="returnUrl" value="@ReturnUrl" />
            <div class="st-field">
                <label class="st-label">شماره موبایل</label>
                <input class="st-input" name="mobile" inputmode="tel" placeholder="۰۹۱۲۳۴۵۶۷۸۹" required />
            </div>
            <div class="st-field">
                <label class="st-label">رمز عبور</label>
                <input class="st-input" name="password" type="password" placeholder="رمز عبور" required />
            </div>
            <div style="text-align:start;margin-bottom:16px">
                <a href="/forgot-password" style="font-size:12.5px;color:var(--st-brand-2)">رمز عبور را فراموش کرده‌اید؟</a>
            </div>
            <button type="submit" class="st-btn st-btn--primary st-btn--block st-btn--lg"><Icon Name="log-in" Size="18" /> ورود</button>
        </form>

        <div class="st-divider"></div>
        <div style="text-align:center;font-size:13px">
            حساب کاربری ندارید؟ <a href="@RegisterLink" style="color:var(--st-brand-2);font-weight:700">ثبت‌نام کنید</a>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery] public string? Error { get; set; }
    [SupplyParameterFromQuery] public string? ReturnUrl { get; set; }

    private string RegisterLink => string.IsNullOrWhiteSpace(ReturnUrl)
        ? "/register"
        : $"/register?returnUrl={Uri.EscapeDataString(ReturnUrl)}";
}
