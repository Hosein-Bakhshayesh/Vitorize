@page "/forgot-password"
@inject ApiClient Api
@inject NavigationManager Nav
@inject ToastService Toasts

<PageTitle>بازیابی رمز عبور | ویتورایز</PageTitle>

<div style="max-width:440px;margin:30px auto">
    <div class="st-card st-card__pad">
        <div style="text-align:center;margin-bottom:22px">
            <div class="st-confirm" style="width:54px;height:54px;border-radius:15px;background:var(--st-chip);color:var(--st-brand-2);display:flex;align-items:center;justify-content:center;margin:0 auto 12px"><Icon Name="lock" Size="24" /></div>
            <h1 style="font-size:20px">بازیابی رمز عبور</h1>
            <p class="st-muted" style="font-size:13px;margin-top:6px">شماره موبایل خود را وارد کنید تا کد بازیابی ارسال شود.</p>
        </div>

        <div class="st-field">
            <label class="st-label">شماره موبایل</label>
            <input class="st-input" @bind="_mobile" inputmode="tel" placeholder="۰۹۱۲۳۴۵۶۷۸۹" />
        </div>
        <button class="st-btn st-btn--primary st-btn--block st-btn--lg" @onclick="Submit" disabled="@_busy">
            @if (_busy) { <span class="st-spinner sm"></span> } else { <span>ارسال کد بازیابی</span> }
        </button>

        <div class="st-divider"></div>
        <div style="text-align:center;font-size:13px">
            <a href="/login" style="color:var(--st-brand-2)">بازگشت به ورود</a>
        </div>
    </div>
</div>

@code {
    private string _mobile = string.Empty;
    private bool _busy;

    private async Task Submit()
    {
        if (string.IsNullOrWhiteSpace(_mobile)) { Toasts.Error("شماره موبایل را وارد کنید."); return; }
        _busy = true;
        var result = await Api.PostAsync("auth/forgot-password", new { Mobile = _mobile.Trim() });
        _busy = false;
        // پیام عمومی برای جلوگیری از افشای وجود حساب.
        Toasts.Success("در صورت وجود حساب کاربری، کد بازیابی ارسال شد.");
        Nav.NavigateTo($"/reset-password?mobile={Uri.EscapeDataString(_mobile.Trim())}");
    }
}
