@page "/"
@inject ApiClient Api
@inject MediaUrlResolver Media
@inject Vitorize.Web.Services.UI.StoreBrandingService Branding
@using Vitorize.Web.Models.Store
@using AUI = Vitorize.Web.Helpers.AdminUiHelper

<PageTitle>@_branding.PageTitle()</PageTitle>

@if (_loading)
{
    <section class="st-hwrap">
        <div class="st-skel" style="height:460px;border-radius:var(--st-clip-xl)"></div>
        <div class="st-hstats">
            <div class="st-skel" style="height:88px;border-radius:var(--st-clip-sm)"></div>
            <div class="st-skel" style="height:88px;border-radius:var(--st-clip-sm)"></div>
            <div class="st-skel" style="height:120px;border-radius:var(--st-clip-sm)"></div>
        </div>
    </section>
    <div class="st-grid" style="margin-top:48px">
        @for (var i = 0; i < 8; i++)
        {
            <div class="st-skel" style="height:280px;border-radius:var(--st-clip)"></div>
        }
    </div>
}
else
{
    @* ---------- Hero: dynamic banner slider + value-prop stack ---------- *@
    <section class="st-hwrap">
        @if (HeroBanners.Count > 0)
        {
            <HeroSlider Banners="HeroBanners" />
        }
        else
        {
            <div class="st-hslider">
                <span class="st-hslider__aurora a1"></span>
                <span class="st-hslider__aurora a2"></span>
                <div class="st-hslider__overlay"></div>
                <div class="st-hslide enter">
                    <span class="st-hslide__kicker"><span class="dot"></span> @_branding.HeroKicker</span>
                    <h1 class="st-hslide__title">@_branding.HeroTitle</h1>
                    <p class="st-hslide__sub">@_branding.HeroSubtitle</p>
                    <a class="st-hslide__cta" href="/shop"><Icon Name="shopping-bag" Size="17" /> @_branding.HeroCtaText</a>
                </div>
            </div>
        }
        <div class="st-hstats">
            <div class="st-hstat">
                <span class="st-hstat__ic"><Icon Name="zap" Size="22" /></span>
                <div><div class="st-hstat__t">تحویل آنی</div><div class="st-hstat__s">کدها بلافاصله پس از پرداخت</div></div>
            </div>
            <div class="st-hstat">
                <span class="st-hstat__ic"><Icon Name="headphones" Size="22" /></span>
                <div><div class="st-hstat__t">پشتیبانی ۲۴/۷</div><div class="st-hstat__s">همیشه کنار شما</div></div>
            </div>
            <div class="st-hstat accent">
                <span class="st-hstat__ic"><Icon Name="shield-check" Size="22" /></span>
                <div><div class="st-hstat__t">ضمانت اصالت</div><div class="st-hstat__s">محصولات رسمی و اورجینال با پرداخت امن</div></div>
            </div>
        </div>
    </section>

    @* ---------- Marquee: brands / platforms strip ---------- *@
    @if (MarqueeItems.Count > 0)
    {
        <div class="st-marquee">
            <div class="st-marquee__track">
                @foreach (var m in MarqueeItems) { <span class="st-marquee__item">@m</span> }
                @foreach (var m in MarqueeItems) { <span class="st-marquee__item">@m</span> }
            </div>
        </div>
    }

    @* ---------- Featured Categories (bento) ---------- *@
    @if (_data.Categories.Count > 0)
    {
        <section class="st-section st-reveal">
            <div class="st-section__head">
                <div class="st-section__title"><span class="bar"></span> دسته‌بندی‌ها</div>
                <a class="st-section__more" href="/categories">مشاهده همه <Icon Name="chevron-left" Size="15" /></a>
            </div>
            <div class="st-bento">
                @{ var cats = _data.Categories.Take(5).ToList(); }
                @for (var i = 0; i < cats.Count; i++)
                {
                    var c = cats[i];
                    <a class="st-bento__tile @(i == 0 ? "lead" : null)" href="@($"/category/{c.Slug}")">
                        <div class="st-bento__ic">
                            <StoreImage Url="@c.ImagePath" Alt="@c.Title" Icon="gamepad" IconSize="18" Contain="true" />
                        </div>
                        <div>
                            <div class="st-bento__t">@c.Title</div>
                            @if (i == 0) { <div class="st-bento__c">پرطرفدارترین دسته فروشگاه</div> }
                        </div>
                    </a>
                }
            </div>
        </section>
    }

    @* ---------- Featured Products ---------- *@
    @if (_data.FeaturedProducts.Count > 0)
    {
        <ProductRow Title="محصولات ویژه" MoreHref="/shop" Products="_data.FeaturedProducts" />
    }

    @* ---------- Campaign banner (home-secondary) ---------- *@
    @if (CampaignBanner is not null)
    {
        <section class="st-section st-reveal">
            <a class="st-campaign" href="@(string.IsNullOrWhiteSpace(CampaignBanner.LinkUrl) ? "/shop" : CampaignBanner.LinkUrl)">
                <StoreImage Url="@CampaignBanner.ImagePath" Alt="@CampaignBanner.Title" Icon="gift" />
            </a>
        </section>
    }

    @* ---------- Latest Products ---------- *@
    @if (_latest.Count > 0)
    {
        <ProductRow Title="جدیدترین محصولات" MoreHref="/shop?sort=newest" Products="_latest" />
    }

    @* ---------- Popular Products ---------- *@
    @if (_popular.Count > 0)
    {
        <ProductRow Title="محبوب‌ترین محصولات" MoreHref="/shop" Products="_popular" />
    }

    @* ---------- Why Vitorize / How it works ---------- *@
    <section class="st-section st-reveal">
        <div class="st-section__center">
            <div class="st-section__kicker">چرا ویتورایز؟</div>
            <h2 class="st-section__h">خرید دیجیتال، ساده و مطمئن</h2>
        </div>
        <div class="st-hiw">
            <div class="st-hiw__step">
                <div class="st-hiw__num">۱</div>
                <div class="st-hiw__ic"><Icon Name="grid" Size="22" /></div>
                <div class="st-hiw__t">انتخاب محصول</div>
                <div class="st-hiw__d">از میان هزاران گیفت کارت، اشتراک و خدمت دیجیتال، محصول مورد نظرت را پیدا کن.</div>
            </div>
            <div class="st-hiw__step">
                <div class="st-hiw__num">۲</div>
                <div class="st-hiw__ic"><Icon Name="credit-card" Size="22" /></div>
                <div class="st-hiw__t">پرداخت امن</div>
                <div class="st-hiw__d">با درگاه‌های معتبر بانکی یا کیف پول ویتورایز، پرداخت سریع و امن انجام بده.</div>
            </div>
            <div class="st-hiw__step">
                <div class="st-hiw__num">۳</div>
                <div class="st-hiw__ic"><Icon Name="zap" Size="22" /></div>
                <div class="st-hiw__t">تحویل آنی</div>
                <div class="st-hiw__d">کد یا خدمت دیجیتال بلافاصله پس از پرداخت در حساب کاربری‌ات فعال می‌شود.</div>
            </div>
        </div>
    </section>

    @* ---------- Trust Section ---------- *@
    <section class="st-section st-reveal">
        <div class="st-hero-mini" style="margin:0">
            <div class="st-trust"><span class="st-trust__ic"><Icon Name="shield-check" Size="20" /></span><div><div class="st-trust__t">تضمین اصالت</div><div class="st-trust__s">محصولات رسمی و اورجینال</div></div></div>
            <div class="st-trust"><span class="st-trust__ic"><Icon Name="zap" Size="20" /></span><div><div class="st-trust__t">تحویل آنی</div><div class="st-trust__s">سریع و بدون انتظار</div></div></div>
            <div class="st-trust"><span class="st-trust__ic"><Icon Name="headphones" Size="20" /></span><div><div class="st-trust__t">پشتیبانی ۲۴/۷</div><div class="st-trust__s">همیشه کنار شما</div></div></div>
            <div class="st-trust"><span class="st-trust__ic"><Icon Name="lock" Size="20" /></span><div><div class="st-trust__t">پرداخت امن</div><div class="st-trust__s">درگاه‌های معتبر</div></div></div>
        </div>
    </section>

    @* ---------- Brands ---------- *@
    @if (_data.Brands.Count > 0)
    {
        <section class="st-section st-reveal">
            <div class="st-section__head"><div class="st-section__title"><span class="bar"></span> برندهای محبوب</div></div>
            <div class="st-brands">
                @foreach (var b in _data.Brands.Take(12))
                {
                    <a class="st-brand-tile" href="@($"/brand/{b.Slug}")" title="@b.Title">
                        @if (!string.IsNullOrWhiteSpace(b.ImagePath))
                        {
                            <img src="@Media.Resolve(b.ImagePath)" alt="@b.Title"
                                 onerror="this.style.display='none';var s=this.nextElementSibling;if(s)s.style.display='block';" />
                            <span style="display:none">@b.Title</span>
                        }
                        else { <span>@b.Title</span> }
                    </a>
                }
            </div>
        </section>
    }

    @* ---------- Latest Blog ---------- *@
    @if (_data.LatestBlogPosts.Count > 0)
    {
        <section class="st-section st-reveal">
            <div class="st-section__head">
                <div class="st-section__title"><span class="bar"></span> آخرین مطالب</div>
                <a class="st-section__more" href="/blog">مشاهده همه <Icon Name="chevron-left" Size="15" /></a>
            </div>
            <div class="st-grid">
                @foreach (var post in _data.LatestBlogPosts.Take(4))
                {
                    <a class="st-pcard" href="@($"/blog/{post.Slug}")">
                        <div class="st-pcard__media">
                            <StoreImage Url="@post.CoverImagePath" Alt="@post.Title" Icon="file-text" />
                        </div>
                        <div class="st-pcard__body">
                            <div class="st-pcard__title">@post.Title</div>
                            <div class="st-muted" style="font-size:12px"><PersianDateDisplay Value="post.CreatedAt" /></div>
                        </div>
                    </a>
                }
            </div>
        </section>
    }

    @* ---------- FAQ Preview ---------- *@
    @if (_data.Faqs.Count > 0)
    {
        <section class="st-section st-reveal">
            <div class="st-section__head">
                <div class="st-section__title"><span class="bar"></span> سوالات متداول</div>
                <a class="st-section__more" href="/faq">همه سوالات <Icon Name="chevron-left" Size="15" /></a>
            </div>
            <div class="st-stack">
                @foreach (var f in _data.Faqs.Take(5))
                {
                    <FaqItem Question="@f.Question" Answer="@f.Answer" />
                }
            </div>
        </section>
    }

    @* ---------- Newsletter ---------- *@
    <section class="st-section st-reveal">
        <div class="st-news">
            <span class="st-news__aurora"></span>
            <div class="st-news__in">
                <h2 class="st-news__t">از تخفیف‌ها جا نمون!</h2>
                <p class="st-news__s">ایمیلت را وارد کن تا جدیدترین محصولات، کدهای تخفیف و پیشنهادهای ویژه ویتورایز را دریافت کنی.</p>
                <form class="st-news__form" @onsubmit="SubscribeNewsletter" @onsubmit:preventDefault="true">
                    <input type="email" placeholder="ایمیل خود را وارد کنید" @bind="_newsletterEmail" />
                    <button class="st-btn st-btn--accent st-btn--lg" type="submit"><Icon Name="send" Size="16" /> عضویت</button>
                </form>
            </div>
        </div>
    </section>
}

@code {
    [Inject] private ToastService Toasts { get; set; } = default!;

    private bool _loading = true;
    private StoreHomeModel _data = new();
    private List<StoreProductModel> _latest = new();
    private List<StoreProductModel> _popular = new();
    private string _newsletterEmail = string.Empty;

    private List<StoreBannerModel> HeroBanners => _data.Banners
        .Where(b => string.Equals(b.Position, "home-hero", StringComparison.OrdinalIgnoreCase) && !string.IsNullOrWhiteSpace(b.ImagePath))
        .OrderBy(b => b.SortOrder)
        .ToList();

    private StoreBannerModel? CampaignBanner => _data.Banners
        .FirstOrDefault(b => !string.Equals(b.Position, "home-hero", StringComparison.OrdinalIgnoreCase) && !string.IsNullOrWhiteSpace(b.ImagePath));

    private List<string> MarqueeItems
    {
        get
        {
            var items = _data.Brands.Select(b => b.Title)
                .Concat(_data.Categories.Select(c => c.Title))
                .Where(s => !string.IsNullOrWhiteSpace(s))
                .Distinct()
                .Take(12)
                .ToList();
            return items;
        }
    }

    private Vitorize.Web.Services.UI.StoreBranding _branding =
        new(new Dictionary<string, string>());

    protected override async Task OnInitializedAsync()
    {
        var homeTask = Api.GetAsync<StoreHomeModel>("storefront/home");
        var latestTask = Api.GetAsync<PagedResult<StoreProductModel>>("products?sort=newest&pageSize=8");
        var popularTask = Api.GetAsync<PagedResult<StoreProductModel>>("products?pageSize=20");
        var brandingTask = Branding.GetAsync();
        await Task.WhenAll(homeTask, latestTask, popularTask, brandingTask);

        _branding = brandingTask.Result;

        if (homeTask.Result is { IsSuccess: true, Data: not null }) _data = homeTask.Result.Data;
        if (latestTask.Result is { IsSuccess: true, Data: not null }) _latest = latestTask.Result.Data.Items.ToList();

        // "Popular" has no dedicated backend sort — rank the catalogue by real engagement
        // (review count, then rating). No fabricated data; purely client-side ordering of the API result.
        if (popularTask.Result is { IsSuccess: true, Data: not null })
        {
            _popular = popularTask.Result.Data.Items
                .OrderByDescending(p => p.ReviewCount)
                .ThenByDescending(p => p.AverageRating)
                .Take(8)
                .ToList();
        }

        _loading = false;
    }

    private void SubscribeNewsletter()
    {
        // No newsletter backend endpoint exists; acknowledge locally without inventing an API.
        if (string.IsNullOrWhiteSpace(_newsletterEmail) || !_newsletterEmail.Contains('@'))
        {
            Toasts.Error("لطفاً یک ایمیل معتبر وارد کنید.");
            return;
        }
        Toasts.Success("از عضویت شما سپاسگزاریم! به‌زودی با شما در تماس خواهیم بود.");
        _newsletterEmail = string.Empty;
    }
}
