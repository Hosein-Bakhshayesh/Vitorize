@page "/error"
@page "/error/{Code}"
@using Vitorize.Web.Helpers
@inject Vitorize.Web.Services.UI.StoreBrandingService Branding
@inject IHttpContextAccessor HttpContextAccessor

@* صفحه‌ی وضعیت/خطای برنددار — برای UseExceptionHandler، StatusCodePages و لینک‌های دستی. *@

<SeoHead Title="@_info.Title" Description="@_info.Message" Index="false" Follow="false" />

<StoreState Info="_info" />

@code {
    [Parameter] public string? Code { get; set; }

    private Vitorize.Web.Services.UI.StoreBranding _b = new(new Dictionary<string, string>());
    private ErrorStateInfo _info =
        ErrorStates.Resolve("500", new Vitorize.Web.Services.UI.StoreBranding(new Dictionary<string, string>()));

    protected override async Task OnParametersSetAsync()
    {
        var response = HttpContextAccessor.HttpContext?.Response;
        if (response is not null && !response.HasStarted && int.TryParse(Code, out var status) && status is >= 400 and <= 599)
            response.StatusCode = status;
        _b = await Branding.GetAsync();
        _info = ErrorStates.Resolve(string.IsNullOrWhiteSpace(Code) ? "500" : Code, _b);
    }
}
