@page "/{*PageRoute}"
@using Vitorize.Web.Helpers
@inject Vitorize.Web.Services.UI.StoreBrandingService Branding

@* در Blazor Web App (.NET 8) بخش NotFound روتر برای مسیرهای ناموجود رندر نمی‌شود؛
   این صفحه‌ی Catch-all (کم‌اولویت‌ترین مسیر) نقش ۴۰۴ برنددار فروشگاه را دارد. *@

<PageTitle>@_info.Title | @_b.SiteName</PageTitle>

<StoreState Info="_info" />

@code {
    [Parameter] public string? PageRoute { get; set; }

    private Vitorize.Web.Services.UI.StoreBranding _b = new(new Dictionary<string, string>());
    private ErrorStateInfo _info =
        ErrorStates.Resolve("404", new Vitorize.Web.Services.UI.StoreBranding(new Dictionary<string, string>()));

    protected override async Task OnInitializedAsync()
    {
        _b = await Branding.GetAsync();
        _info = ErrorStates.Resolve("404", _b);
    }
}
