@page "/customer/wallet"
@inject ApiClient Api
@inject ToastService Toasts
@inject NavigationManager Nav
@using AUI = Vitorize.Web.Helpers.AdminUiHelper

<PageTitle>کیف پول | ویتورایز</PageTitle>

<h1 style="font-size:22px;margin-bottom:18px">کیف پول من</h1>

@if (_loading)
{
    <div class="st-state"><div class="st-spinner"></div></div>
}
else
{
    <div class="st-split" style="grid-template-columns:1.2fr 1fr;margin-bottom:22px">
        <div class="st-card st-card__pad st-anim" style="background:var(--st-hero-bg);color:#fff;border:none">
            <div class="st-spread">
                <div>
                    <div style="opacity:.85;font-size:13px">موجودی فعلی</div>
                    <div style="font-size:30px;font-weight:800;margin-top:6px">@AUI.MoneyFa(_balance)</div>
                </div>
                <div style="width:60px;height:60px;border-radius:16px;background:rgba(45,212,191,.18);display:flex;align-items:center;justify-content:center;color:#5eead4"><Icon Name="wallet" Size="30" /></div>
            </div>
            <div style="margin-top:18px;font-size:12px;opacity:.75;display:flex;align-items:center;gap:6px">
                <Icon Name="shield-check" Size="14" /> موجودی کیف پول برای پرداخت سریع سفارش‌ها استفاده می‌شود.
            </div>
        </div>

        <div class="st-card st-anim d1">
            <div class="st-card__head"><Icon Name="plus" Size="18" /> شارژ کیف پول</div>
            <div class="st-card__pad">
                <div class="st-chips" style="margin-bottom:14px">
                    @foreach (var amount in QuickAmounts)
                    {
                        var a = amount;
                        <button type="button"
                                class="st-pill @(_amount == a ? "active" : null)"
                                @onclick="() => _amount = a">
                            @AUI.MoneyFa(a)
                        </button>
                    }
                </div>
                <div class="st-field" style="margin-bottom:12px">
                    <label class="st-label">مبلغ دلخواه (تومان)</label>
                    <input class="st-input st-mono" type="number" min="10000" step="10000" @bind="_amount" />
                </div>
                <button class="st-btn st-btn--primary st-btn--block" @onclick="TopUp" disabled="@_busy">
                    @if (_busy) { <span class="st-spinner sm"></span> <span>در حال اتصال ...</span> }
                    else { <Icon Name="credit-card" Size="16" /> <span>پرداخت و شارژ</span> }
                </button>
            </div>
        </div>
    </div>

    <div class="st-card st-anim d2">
        <div class="st-card__head"><Icon Name="activity" Size="18" /> تراکنش‌ها</div>
        @if (_transactions.Count == 0)
        {
            <div class="st-state" style="padding:40px"><div class="st-muted">تراکنشی ثبت نشده است.</div></div>
        }
        else
        {
            <div class="st-table-wrap">
                <table class="st-table">
                    <thead><tr><th>نوع</th><th>مبلغ</th><th>موجودی پس از تراکنش</th><th>توضیحات</th><th>تاریخ</th></tr></thead>
                    <tbody>
                        @foreach (var t in _transactions)
                        {
                            var credit = t.Type == (byte)WalletTransactionType.Credit;
                            <tr>
                                <td><StoreBadge Text="@AUI.WalletTransactionType(t.Type)" Intent="@(credit ? "success" : "danger")" /></td>
                                <td style="color:@(credit ? "var(--st-success)" : "var(--st-danger)");font-weight:700">@(credit ? "+" : "−")@AUI.MoneyFa(t.Amount)</td>
                                <td>@AUI.MoneyFa(t.BalanceAfter)</td>
                                <td class="st-muted">@(string.IsNullOrWhiteSpace(t.Description) ? AUI.WalletReferenceType(t.ReferenceType) : t.Description)</td>
                                <td><PersianDateDisplay Value="t.CreatedAt" WithTime="true" /></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
}

@code {
    private static readonly decimal[] QuickAmounts = { 200_000, 500_000, 1_000_000, 2_000_000 };

    private bool _loading = true, _busy;
    private decimal _balance;
    private decimal _amount = 500_000;
    private List<CustomerWalletTransactionModel> _transactions = new();

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        var walletTask = Api.GetAsync<CustomerWalletModel>("wallet");
        var txTask = Api.GetAsync<List<CustomerWalletTransactionModel>>("wallet/transactions");
        await Task.WhenAll(walletTask, txTask);
        _balance = walletTask.Result.Data?.Balance ?? 0;
        _transactions = (txTask.Result.Data ?? new()).OrderByDescending(t => t.CreatedAt).ToList();
        _loading = false;
    }

    private async Task TopUp()
    {
        if (_amount <= 0)
        {
            Toasts.Error("مبلغ شارژ را وارد کنید.");
            return;
        }

        _busy = true;

        var start = await Api.PostAsync<CustomerTopUpStartModel>("wallet/topup", new { Amount = _amount });

        if (!start.IsSuccess || start.Data is null)
        {
            _busy = false;
            Toasts.Error(start.Message);
            return;
        }

        // درگاه واقعی — انتقال کاربر به صفحه پرداخت
        if (!string.IsNullOrWhiteSpace(start.Data.PaymentUrl))
        {
            Nav.NavigateTo(start.Data.PaymentUrl, forceLoad: true);
            return;
        }

        // درگاه تست (Mock) — تایید مستقیم
        var verify = await Api.PostAsync<CustomerTopUpVerifyModel>(
            $"wallet/topup/mock/verify/{start.Data.TopUpId}");

        _busy = false;

        if (verify.IsSuccess && verify.Data is { IsPaid: true })
        {
            Toasts.Success($"کیف پول با موفقیت {AUI.MoneyFa(verify.Data.Amount)} شارژ شد.");
            _loading = true;
            await Load();
        }
        else
        {
            Toasts.Error(verify.Message);
        }
    }
}
