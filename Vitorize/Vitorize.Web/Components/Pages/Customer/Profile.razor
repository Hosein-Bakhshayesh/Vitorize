@page "/customer/profile"
@inject ApiClient Api
@inject ToastService Toasts
@using AUI = Vitorize.Web.Helpers.AdminUiHelper

<PageTitle>پروفایل | ویتورایز</PageTitle>

<h1 style="font-size:22px;margin-bottom:18px">پروفایل و امنیت</h1>

@if (_loading)
{
    <div class="st-state"><div class="st-spinner"></div></div>
}
else
{
    <div class="st-split" style="grid-template-columns:1fr 1fr">
        <div class="st-card st-anim">
            <div class="st-card__head"><Icon Name="user" Size="18" /> اطلاعات حساب</div>
            <div class="st-card__pad">
                <div class="st-field">
                    <label class="st-label" for="profile-full-name">نام و نام خانوادگی</label>
                    <input id="profile-full-name" class="st-input" @bind="_fullName" />
                </div>
                <div class="st-field">
                    <label class="st-label" for="profile-email">ایمیل</label>
                    <input id="profile-email" class="st-input" type="email" dir="ltr" placeholder="you@example.com" @bind="_email" />
                    @if (!string.IsNullOrWhiteSpace(_user?.Email) && _user!.IsEmailConfirmed == false)
                    {
                        <div class="st-hint" style="color:var(--st-warning)">ایمیل شما هنوز تایید نشده است.</div>
                    }
                </div>
                <div class="st-field">
                    <label class="st-label" for="profile-mobile">شماره موبایل</label>
                    <input id="profile-mobile" class="st-input st-mono" value="@(_user?.Mobile)" disabled />
                    <div class="st-hint">شماره موبایل قابل تغییر نیست.</div>
                </div>
                <button class="st-btn st-btn--primary" @onclick="SaveProfile" disabled="@_savingProfile">
                    @if (_savingProfile) { <span class="st-spinner sm"></span> } else { <Icon Name="save" Size="16" /> <span>ذخیره تغییرات</span> }
                </button>

                <div class="st-divider"></div>
                <div class="st-stack" style="gap:14px">
                    <div class="st-spread"><span class="st-muted">وضعیت حساب</span><StoreBadge Text="@AUI.UserStatus(_user?.Status ?? 0)" Intent="@AUI.StatusBadgeIntent(_user?.Status ?? 0, "user")" /></div>
                    <div class="st-spread"><span class="st-muted">احراز هویت</span><StoreBadge Text="@AUI.VerificationStatus(_user?.VerificationStatus ?? 0)" Intent="@AUI.StatusBadgeIntent(_user?.VerificationStatus ?? 0, "verify")" /></div>
                </div>
                @if ((_user?.VerificationStatus ?? 0) != (byte)VerificationStatus.Verified)
                {
                    <a class="st-btn st-btn--outline st-btn--block" style="margin-top:16px" href="/customer/verification"><Icon Name="user-check" Size="16" /> تکمیل احراز هویت</a>
                }
            </div>
        </div>

        <div class="st-card st-anim d1">
            <div class="st-card__head"><Icon Name="lock" Size="18" /> تغییر رمز عبور</div>
            <div class="st-card__pad">
                <div class="st-field"><label class="st-label" for="current-password">رمز عبور فعلی</label><input id="current-password" class="st-input" type="password" @bind="_current" /></div>
                <div class="st-field"><label class="st-label" for="new-password">رمز عبور جدید</label><input id="new-password" class="st-input" type="password" @bind="_new" /></div>
                <div class="st-field"><label class="st-label" for="confirm-password">تکرار رمز عبور جدید</label><input id="confirm-password" class="st-input" type="password" @bind="_confirm" /></div>
                <button class="st-btn st-btn--primary" @onclick="ChangePassword" disabled="@_busy">
                    @if (_busy) { <span class="st-spinner sm"></span> } else { <Icon Name="save" Size="16" /> <span>تغییر رمز عبور</span> }
                </button>
            </div>
        </div>
    </div>
}

@code {
    private bool _loading = true, _busy, _savingProfile;
    private CustomerProfileModel? _user;
    private string _current = "", _new = "", _confirm = "";
    private string _fullName = "", _email = "";

    protected override async Task OnInitializedAsync()
    {
        var result = await Api.GetAsync<CustomerProfileModel>("auth/me");
        _user = result.Data;
        _fullName = _user?.FullName ?? "";
        _email = _user?.Email ?? "";
        _loading = false;
    }

    private async Task SaveProfile()
    {
        if (string.IsNullOrWhiteSpace(_fullName))
        {
            Toasts.Error("نام و نام خانوادگی را وارد کنید.");
            return;
        }

        _savingProfile = true;
        var result = await Api.PutAsync<CustomerProfileModel>("auth/profile", new
        {
            FullName = _fullName.Trim(),
            Email = string.IsNullOrWhiteSpace(_email) ? null : _email.Trim()
        });
        _savingProfile = false;

        if (result.IsSuccess && result.Data is not null)
        {
            var emailChanged = !string.Equals(_user?.Email, result.Data.Email, StringComparison.OrdinalIgnoreCase);
            _user = result.Data;
            _fullName = _user.FullName;
            _email = _user.Email ?? "";
            Toasts.Success(emailChanged && !string.IsNullOrWhiteSpace(_user.Email)
                ? "پروفایل ذخیره شد. ایمیل جدید نیاز به تایید دارد."
                : "پروفایل با موفقیت ذخیره شد.");
        }
        else Toasts.Error(result.Message);
    }

    private async Task ChangePassword()
    {
        if (string.IsNullOrWhiteSpace(_current) || string.IsNullOrWhiteSpace(_new))
        { Toasts.Error("رمز فعلی و جدید را وارد کنید."); return; }
        if (_new != _confirm) { Toasts.Error("رمز جدید و تکرار آن یکسان نیست."); return; }

        _busy = true;
        var result = await Api.PostAsync("auth/change-password", new
        {
            CurrentPassword = _current,
            NewPassword = _new,
            ConfirmNewPassword = _confirm
        });
        _busy = false;

        if (result.IsSuccess)
        {
            Toasts.Success("رمز عبور با موفقیت تغییر کرد.");
            _current = _new = _confirm = "";
        }
        else Toasts.Error(result.Message);
    }
}
