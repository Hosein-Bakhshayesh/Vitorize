@page "/admin/products/create"
@page "/admin/products/{Id:guid}"
@inject ApiClient Api
@inject MediaUrlResolver Media
@inject ToastService Toasts
@inject NavigationManager Nav
@using AUI = Vitorize.Web.Helpers.AdminUiHelper

<PageHeader Title="@(IsEdit ? "ویرایش محصول" : "افزودن محصول جدید")"
            Subtitle="جزئیات محصول دیجیتال و تنظیمات آن را وارد کنید"
            Icon="box"
            Breadcrumbs="@(new(){ ("محصولات", "admin/products"), (IsEdit ? (_model.Title ?? "ویرایش") : "محصول جدید", null) })">
    <Actions>
        <a class="vz-btn vz-btn--ghost" href="admin/products"><Icon Name="arrow-right" Size="17" /> بازگشت</a>
        @if (IsEdit)
        {
            <a class="vz-btn vz-btn--outline" href="@($"admin/products/{Id}/details")"><Icon Name="eye" Size="17" /> جزئیات</a>
            <a class="vz-btn vz-btn--outline" href="@($"admin/products/{Id}/images")"><Icon Name="image" Size="17" /> مدیریت تصاویر</a>
        }
        <button class="vz-btn vz-btn--primary" @onclick="Save" disabled="@_saving">
            @if (_saving) { <span class="vz-spinner sm"></span> } else { <Icon Name="save" Size="17" /> <span>@(IsEdit ? "ذخیره تغییرات" : "ثبت محصول")</span> }
        </button>
    </Actions>
</PageHeader>

@if (_loading) { <LoadingState /> }
else if (_error is not null) { <ErrorState Message="@_error" OnRetry="Load" /> }
else
{
    @if (IsEdit)
    {
        <div class="vz-card" style="margin-bottom:16px">
            <div class="vz-card__body">
                <div class="vz-summary">
                    <div class="vz-summary__item">
                        <span class="vz-summary__label">قیمت نهایی</span>
                        <span class="vz-summary__value">@AUI.MoneyFa(FinalPrice, _model.CurrencyType)</span>
                    </div>
                    <div class="vz-summary__item">
                        <span class="vz-summary__label">موجودی</span>
                        <span class="vz-summary__value">@(_hasVariants ? "واریانت‌دار" : AUI.Number(_availableStock))</span>
                    </div>
                    <div class="vz-summary__item">
                        <span class="vz-summary__label">وضعیت</span>
                        <span class="vz-summary__value">
                            <StatusBadge Text="@(_model.IsActive ? "منتشر شده" : "پیش‌نویس")" Intent="@(_model.IsActive ? "success" : "muted")" />
                        </span>
                    </div>
                    <div class="vz-summary__item">
                        <span class="vz-summary__label">تصاویر گالری</span>
                        <span class="vz-summary__value">@AUI.Number(_imageCount)</span>
                    </div>
                    <div class="vz-summary__item">
                        <span class="vz-summary__label">تاریخ ایجاد</span>
                        <span class="vz-summary__value" style="font-size:13px"><PersianDateDisplay Value="_createdAt" /></span>
                    </div>
                </div>
            </div>
        </div>
    }

    <EditForm Model="_model" OnValidSubmit="Save">
        <DataAnnotationsValidator />
        <div class="vz-grid-2">
            <div class="vz-stack">
                <div class="vz-card">
                    <div class="vz-card__body">
                        <div class="vz-section__head">
                            <span class="vz-section__badge"><Icon Name="file-text" Size="16" /></span>
                            <span class="vz-section__title">اطلاعات اصلی</span>
                        </div>
                        <p class="vz-section__desc">عنوان و دسته‌بندی که در فروشگاه به مشتری نمایش داده می‌شود.</p>
                        <div class="vz-form-grid">
                            <div class="vz-field span-2">
                                <label class="vz-label">عنوان محصول <span class="req">*</span></label>
                                <InputText class="vz-input" @bind-Value="_model.Title" @bind-Value:after="OnTitleChanged" />
                                <ValidationMessage For="() => _model.Title" class="vz-val-msg" />
                            </div>
                            <div class="vz-field">
                                <label class="vz-label">اسلاگ <span class="req">*</span></label>
                                <InputText class="vz-input vz-mono" @bind-Value="_model.Slug" />
                                <ValidationMessage For="() => _model.Slug" class="vz-val-msg" />
                            </div>
                            <div class="vz-field">
                                <label class="vz-label">دسته‌بندی <span class="req">*</span></label>
                                <select class="vz-select" value="@(_model.CategoryId == Guid.Empty ? "" : _model.CategoryId.ToString())"
                                        @onchange="e => _model.CategoryId = Guid.TryParse(e.Value?.ToString(), out var g) ? g : Guid.Empty">
                                    <option value="">— انتخاب دسته‌بندی —</option>
                                    @foreach (var c in _categories) { <option value="@c.Id">@c.Title</option> }
                                </select>
                                <ValidationMessage For="() => _model.CategoryId" class="vz-val-msg" />
                            </div>
                            <div class="vz-field">
                                <label class="vz-label">برند</label>
                                <select class="vz-select" value="@(_model.BrandId?.ToString() ?? "")"
                                        @onchange="e => _model.BrandId = Guid.TryParse(e.Value?.ToString(), out var g) ? g : null">
                                    <option value="">— بدون برند —</option>
                                    @foreach (var b in _brands) { <option value="@b.Id">@b.Title</option> }
                                </select>
                            </div>
                            <div class="vz-field">
                                <label class="vz-label">نوع محصول</label>
                                <select class="vz-select" value="@_model.ProductType" @onchange="e => _model.ProductType = byte.Parse(e.Value!.ToString()!)">
                                    <option value="1">گیفت کارت</option>
                                    <option value="2">اکانت بازی</option>
                                    <option value="3">سرویس بازی</option>
                                    <option value="4">اشتراک</option>
                                    <option value="5">سایر</option>
                                </select>
                            </div>
                            <div class="vz-field span-2">
                                <label class="vz-label">توضیحات کوتاه</label>
                                <InputTextArea class="vz-textarea" style="min-height:80px" @bind-Value="_model.ShortDescription" />
                            </div>
                            <div class="vz-field span-2">
                                <label class="vz-label">توضیحات کامل</label>
                                <RichTextEditor @bind-Value="_model.FullDescription" />
                                <span class="vz-hint">HTML خروجی هنگام ذخیره در سرور با فهرست سخت‌گیرانه تگ‌ها و ویژگی‌های مجاز پاک‌سازی می‌شود.</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="vz-card">
                    <div class="vz-card__body">
                        <div class="vz-spread">
                            <div><div class="vz-section__head"><span class="vz-section__badge"><Icon Name="star" Size="16" /></span><span class="vz-section__title">ویژگی‌ها و مشخصات</span></div>
                            <p class="vz-section__desc">کارت‌های مرتب‌شده‌ای که در صفحه محصول نمایش داده می‌شوند.</p></div>
                            <button type="button" class="vz-btn vz-btn--outline vz-btn--sm" @onclick="AddFeature"><Icon Name="plus" Size="14" /> افزودن ویژگی</button>
                        </div>
                        @if (_model.Features.Count == 0) { <EmptyState Title="ویژگی‌ای تعریف نشده" Text="عنوان و مقدار مشخصات محصول را اضافه کنید." Icon="star" /> }
                        @for (var i = 0; i < _model.Features.Count; i++)
                        {
                            var index = i; var feature = _model.Features[index];
                            <div class="vz-builder-row" @key="feature">
                                <div class="vz-form-grid three">
                                    <div class="vz-field"><label class="vz-label">عنوان *</label><InputText class="vz-input" @bind-Value="feature.Title" /></div>
                                    <div class="vz-field"><label class="vz-label">مقدار *</label><InputText class="vz-input" @bind-Value="feature.Value" /></div>
                                    <div class="vz-field"><label class="vz-label">آیکن</label><LucideIconPicker @bind-Value="feature.IconKey" Compact="true" Placeholder="انتخاب آیکون ویژگی" /></div>
                                </div>
                                <div class="vz-builder-actions">
                                    <label class="vz-switch"><input type="checkbox" @bind="feature.IsActive" /><span class="vz-switch__track"></span><span class="vz-switch__label">فعال</span></label>
                                    <button type="button" class="vz-iconaction" disabled="@(index == 0)" @onclick="() => MoveFeature(index, -1)"><Icon Name="arrow-up" Size="15" /></button>
                                    <button type="button" class="vz-iconaction" disabled="@(index == _model.Features.Count - 1)" @onclick="() => MoveFeature(index, 1)"><Icon Name="arrow-down" Size="15" /></button>
                                    <button type="button" class="vz-iconaction danger" @onclick="() => _model.Features.RemoveAt(index)"><Icon Name="trash" Size="15" /></button>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <div class="vz-card">
                    <div class="vz-card__body">
                        <div class="vz-spread">
                            <div><div class="vz-section__head"><span class="vz-section__badge"><Icon Name="file-text" Size="16" /></span><span class="vz-section__title">اطلاعات موردنیاز خریدار</span></div>
                            <p class="vz-section__desc">فرم پویا برای دریافت یک یا چند مقدار پیش از خرید یا در سبد خرید.</p></div>
                            <button type="button" class="vz-btn vz-btn--outline vz-btn--sm" @onclick="AddInputField"><Icon Name="plus" Size="14" /> افزودن فیلد</button>
                        </div>
                        @if (_model.InputFields.Count == 0) { <EmptyState Title="اطلاعاتی لازم نیست" Text="برای این محصول فرم اختصاصی تعریف نشده است." Icon="file-text" /> }
                        @for (var i = 0; i < _model.InputFields.Count; i++)
                        {
                            var index = i; var field = _model.InputFields[index];
                            <div class="vz-builder-row" @key="field">
                                <div class="vz-form-grid three">
                                    <div class="vz-field"><label class="vz-label">نام داخلی *</label><InputText class="vz-input vz-mono" @bind-Value="field.Key" /></div>
                                    <div class="vz-field"><label class="vz-label">برچسب فارسی *</label><InputText class="vz-input" @bind-Value="field.Label" /></div>
                                    <div class="vz-field"><label class="vz-label">نوع</label><select class="vz-select" @bind="field.FieldType">@foreach (var type in InputTypes) { <option value="@type.Key">@type.Label</option> }</select></div>
                                    <div class="vz-field"><label class="vz-label">Placeholder</label><InputText class="vz-input" @bind-Value="field.Placeholder" /></div>
                                    <div class="vz-field"><label class="vz-label">مرحله نمایش</label><select class="vz-select" @bind="field.DisplayStage"><option value="1">صفحه محصول</option><option value="2">سبد/تسویه</option></select></div>
                                    <div class="vz-field"><label class="vz-label">پیام اعتبارسنجی</label><InputText class="vz-input" @bind-Value="field.ValidationMessage" /></div>
                                    <div class="vz-field"><label class="vz-label">حداقل طول</label><InputNumber class="vz-input" @bind-Value="field.MinLength" /></div>
                                    <div class="vz-field"><label class="vz-label">حداکثر طول</label><InputNumber class="vz-input" @bind-Value="field.MaxLength" /></div>
                                    <div class="vz-field"><label class="vz-label">الگوی Regex امن</label><InputText class="vz-input vz-mono" @bind-Value="field.ValidationPattern" /></div>
                                    @if (field.FieldType is 6 or 7) { <div class="vz-field span-2"><label class="vz-label">گزینه‌ها (هر خط یک گزینه)</label><InputTextArea class="vz-textarea" @bind-Value="field.OptionsText" /></div> }
                                </div>
                                <div class="vz-builder-actions">
                                    <label class="vz-switch"><input type="checkbox" @bind="field.IsRequired" /><span class="vz-switch__track"></span><span class="vz-switch__label">الزامی</span></label>
                                    <label class="vz-switch"><input type="checkbox" @bind="field.IsSensitive" /><span class="vz-switch__track"></span><span class="vz-switch__label">حساس/رمزشده</span></label>
                                    <label class="vz-switch"><input type="checkbox" @bind="field.IsActive" /><span class="vz-switch__track"></span><span class="vz-switch__label">فعال</span></label>
                                    <button type="button" class="vz-iconaction" disabled="@(index == 0)" @onclick="() => MoveInput(index, -1)"><Icon Name="arrow-up" Size="15" /></button>
                                    <button type="button" class="vz-iconaction" disabled="@(index == _model.InputFields.Count - 1)" @onclick="() => MoveInput(index, 1)"><Icon Name="arrow-down" Size="15" /></button>
                                    <button type="button" class="vz-iconaction danger" @onclick="() => _model.InputFields.RemoveAt(index)"><Icon Name="trash" Size="15" /></button>
                                </div>
                            </div>
                        }
                        <div class="vz-alert vz-alert--warning">رمز عبور سرویس‌های شخص ثالث را دریافت نکنید. داده حساس فقط در صورت ضرورت قانونی و با دوره نگهداری مشخص فعال شود.</div>
                    </div>
                </div>

                <div class="vz-card">
                    <div class="vz-card__body">
                        <div class="vz-section__head">
                            <span class="vz-section__badge"><Icon Name="credit-card" Size="16" /></span>
                            <span class="vz-section__title">قیمت‌گذاری و موجودی</span>
                        </div>
                        <p class="vz-section__desc">قیمت پایه و قیمت تخفیف‌خورده اختیاری را تعیین کنید.</p>
                        <div class="vz-form-grid three">
                            <div class="vz-field">
                                <label class="vz-label">واحد پول</label>
                                <select class="vz-select" value="@_model.CurrencyType" @onchange="e => _model.CurrencyType = byte.Parse(e.Value!.ToString()!)">
                                    <option value="2">تومان</option>
                                    <option value="1">ریال</option>
                                </select>
                            </div>
                            <div class="vz-field">
                                <label class="vz-label">قیمت پایه <span class="req">*</span></label>
                                <InputNumber class="vz-input" @bind-Value="_model.BasePrice" />
                            </div>
                            <div class="vz-field">
                                <label class="vz-label">قیمت با تخفیف</label>
                                <InputNumber class="vz-input" @bind-Value="_model.DiscountPrice" />
                            </div>
                            <div class="vz-field">
                                <label class="vz-label">حداقل تعداد سفارش</label>
                                <InputNumber class="vz-input" @bind-Value="_model.MinOrderQuantity" />
                            </div>
                            <div class="vz-field">
                                <label class="vz-label">حداکثر تعداد سفارش</label>
                                <InputNumber class="vz-input" @bind-Value="_model.MaxOrderQuantity" />
                            </div>
                            <div class="vz-field">
                                <label class="vz-label">ترتیب نمایش</label>
                                <InputNumber class="vz-input" @bind-Value="_model.SortOrder" />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="vz-card">
                    <div class="vz-card__body">
                        <div class="vz-section__head">
                            <span class="vz-section__badge"><Icon Name="zap" Size="16" /></span>
                            <span class="vz-section__title">تحویل و واریانت‌ها</span>
                        </div>
                        <p class="vz-section__desc">نحوه تحویل محصول و نسخه‌هایی که مشتری می‌تواند انتخاب کند.</p>

                        <label class="vz-label" style="margin-bottom:8px">نوع تحویل</label>
                        <div class="vz-delivery-pills">
                            @foreach (var d in DeliveryOptions)
                            {
                                <button type="button" class="vz-delivery-pill @(_model.DeliveryType == d.Key ? "active" : "")"
                                        @onclick="() => _model.DeliveryType = d.Key">@d.Label</button>
                            }
                        </div>

                        <div class="vz-divider"></div>

                        <div class="vz-spread" style="margin-bottom:12px">
                            <label class="vz-label" style="margin:0">واریانت‌ها (تنوع محصول)</label>
                            @if (IsEdit)
                            {
                                <button type="button" class="vz-btn vz-btn--outline vz-btn--sm" @onclick="OpenVariantCreate"><Icon Name="plus" Size="14" /> واریانت جدید</button>
                            }
                        </div>

                        @if (!IsEdit)
                        {
                            <div class="vz-hint" style="padding:14px;border:1px dashed var(--border-strong);border-radius:var(--clip-xs);text-align:center">
                                برای افزودن واریانت، ابتدا محصول را ذخیره کنید.
                            </div>
                        }
                        else if (_variants.Count == 0)
                        {
                            <EmptyState Title="واریانتی تعریف نشده" Text="در صورت داشتن نسخه‌های مختلف (استاندارد، ویژه…) واریانت اضافه کنید." Icon="layers" />
                        }
                        else
                        {
                            <div class="vz-table-wrap">
                                <table class="vz-table">
                                    <thead><tr><th>عنوان</th><th>SKU</th><th>قیمت</th><th>حالت موجودی</th><th>موجودی</th><th>وضعیت</th><th class="col-actions">عملیات</th></tr></thead>
                                    <tbody>
                                        @foreach (var v in _variants.OrderBy(x => x.SortOrder))
                                        {
                                            <tr>
                                                <td class="vz-cell-title">@v.Title @if (v.IsDefault) { <span class="vz-chip">پیش‌فرض</span> }</td>
                                                <td class="vz-mono">@(string.IsNullOrWhiteSpace(v.Sku) ? "—" : v.Sku)</td>
                                                <td><MoneyDisplay Amount="v.Price" Currency="v.CurrencyType" /></td>
                                                <td><span class="vz-chip">@AUI.VariantStockMode(v.StockMode)</span></td>
                                                <td class="num">@AUI.Number(v.AvailableStock)</td>
                                                <td><StatusBadge Text="@(v.IsActive ? "فعال" : "غیرفعال")" Intent="@(v.IsActive ? "success" : "muted")" /></td>
                                                <td class="col-actions">
                                                    <button type="button" class="vz-iconaction" @onclick="() => OpenVariantEdit(v)" title="ویرایش"><Icon Name="edit" Size="15" /></button>
                                                    <button type="button" class="vz-iconaction danger" @onclick="() => AskDeleteVariant(v)" title="حذف"><Icon Name="trash" Size="15" /></button>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>

                <div class="vz-card">
                    <div class="vz-card__body">
                        <div class="vz-section__head">
                            <span class="vz-section__badge"><Icon Name="search" Size="16" /></span>
                            <span class="vz-section__title">تنظیمات سئو</span>
                        </div>
                        <p class="vz-section__desc">عنوان و توضیحات نمایش‌داده‌شده در نتایج موتورهای جستجو.</p>
                        <div class="vz-form-grid one">
                            <div class="vz-field">
                                <label class="vz-label">عنوان سئو</label>
                                <InputText class="vz-input" @bind-Value="_model.SeoTitle" />
                            </div>
                            <div class="vz-field">
                                <label class="vz-label">توضیحات متا</label>
                                <InputTextArea class="vz-textarea" style="min-height:70px" @bind-Value="_model.SeoDescription" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="vz-stack">
                <div class="vz-card">
                    <div class="vz-card__head"><Icon Name="image" Size="18" /><div><div class="vz-card__title">تصویر شاخص</div></div></div>
                    <div class="vz-card__body">
                        <UploadBox @bind-Value="_model.ThumbnailImagePath" Label="آپلود تصویر شاخص" />
                        <ImageGuideline Spec="ImageSpecs.ProductThumbnail" />
                        @if (IsEdit)
                        {
                            <a class="vz-btn vz-btn--outline vz-btn--block" style="margin-top:12px" href="@($"admin/products/{Id}/images")">
                                <Icon Name="image" Size="16" /> مدیریت گالری تصاویر
                            </a>
                        }
                    </div>
                </div>

                <div class="vz-card">
                    <div class="vz-card__head"><Icon Name="settings" Size="18" /><div><div class="vz-card__title">وضعیت و گزینه‌ها</div></div></div>
                    <div class="vz-card__body vz-stack">
                        <label class="vz-switch"><input type="checkbox" @bind="_model.IsActive" /><span class="vz-switch__track"></span><span class="vz-switch__label">محصول فعال (منتشر شده)</span></label>
                        <label class="vz-switch"><input type="checkbox" @bind="_model.IsFeatured" /><span class="vz-switch__track"></span><span class="vz-switch__label">محصول ویژه</span></label>
                        <label class="vz-switch"><input type="checkbox" @bind="_model.RequiresVerification" /><span class="vz-switch__track"></span><span class="vz-switch__label">نیازمند احراز هویت</span></label>
                        <label class="vz-switch"><input type="checkbox" @bind="_model.RequiresSupportMessage" /><span class="vz-switch__track"></span><span class="vz-switch__label">نیازمند پیام پشتیبانی</span></label>
                    </div>
                </div>
            </div>
        </div>

        <div class="vz-savebar">
            <span class="vz-savebar__hint"><Icon Name="alert" Size="15" /> پیش از خروج از صفحه، تغییرات را ذخیره کنید.</span>
            <div style="display:flex;gap:10px">
                <a class="vz-btn vz-btn--outline" href="admin/products">انصراف</a>
                <button class="vz-btn vz-btn--primary" type="submit" disabled="@_saving">
                    @if (_saving) { <span class="vz-spinner sm"></span> } else { <Icon Name="save" Size="17" /> <span>@(IsEdit ? "ذخیره تغییرات" : "ثبت محصول")</span> }
                </button>
            </div>
        </div>
    </EditForm>
}

<Modal Visible="_variantOpen" Title="@(_variantEditingId is null ? "افزودن واریانت" : "ویرایش واریانت")" Icon="layers" OnClose="() => _variantOpen = false">
    <ChildContent>
        <EditForm Model="_variant" OnValidSubmit="SaveVariant" id="variant-form">
            <DataAnnotationsValidator />
            <div class="vz-form-grid">
                <div class="vz-field span-2">
                    <label class="vz-label">عنوان واریانت <span class="req">*</span></label>
                    <InputText class="vz-input" @bind-Value="_variant.Title" />
                    <ValidationMessage For="() => _variant.Title" class="vz-val-msg" />
                </div>
                <div class="vz-field">
                    <label class="vz-label">SKU</label>
                    <InputText class="vz-input vz-mono" @bind-Value="_variant.Sku" />
                </div>
                <div class="vz-field">
                    <label class="vz-label">مقدار / Value</label>
                    <InputText class="vz-input" @bind-Value="_variant.Value" />
                </div>
                <div class="vz-field">
                    <label class="vz-label">قیمت <span class="req">*</span></label>
                    <InputNumber class="vz-input" @bind-Value="_variant.Price" />
                </div>
                <div class="vz-field">
                    <label class="vz-label">قیمت با تخفیف</label>
                    <InputNumber class="vz-input" @bind-Value="_variant.DiscountPrice" />
                </div>
                <div class="vz-field">
                    <label class="vz-label">حالت موجودی</label>
                    <select class="vz-select" value="@_variant.StockMode" @onchange="e => _variant.StockMode = byte.Parse(e.Value!.ToString()!)">
                        <option value="1">وابسته به کد گیفت</option>
                        <option value="2">موجودی دستی</option>
                        <option value="3">بدون محدودیت</option>
                    </select>
                </div>
                <div class="vz-field">
                    <label class="vz-label">ترتیب نمایش</label>
                    <InputNumber class="vz-input" @bind-Value="_variant.SortOrder" />
                </div>
                <div class="vz-field span-2" style="display:flex;gap:22px">
                    <label class="vz-switch"><input type="checkbox" @bind="_variant.IsDefault" /><span class="vz-switch__track"></span><span class="vz-switch__label">پیش‌فرض</span></label>
                    <label class="vz-switch"><input type="checkbox" @bind="_variant.IsActive" /><span class="vz-switch__track"></span><span class="vz-switch__label">فعال</span></label>
                </div>
            </div>
        </EditForm>
    </ChildContent>
    <Footer>
        <button class="vz-btn vz-btn--outline" @onclick="() => _variantOpen = false" disabled="@_savingVariant">انصراف</button>
        <button class="vz-btn vz-btn--primary" type="submit" form="variant-form" disabled="@_savingVariant">
            @if (_savingVariant) { <span class="vz-spinner sm"></span> } else { <span>ذخیره واریانت</span> }
        </button>
    </Footer>
</Modal>

<ConfirmDialog Visible="_confirmVariantDelete" Title="حذف واریانت"
               Message="@($"آیا از حذف واریانت «{_variantTarget?.Title}» مطمئن هستید؟")"
               ConfirmText="حذف" Busy="_deletingVariant"
               OnConfirm="ConfirmDeleteVariant" OnCancel="() => _confirmVariantDelete = false" />

@code {
    [Parameter] public Guid? Id { get; set; }
    private bool IsEdit => Id is not null && Id != Guid.Empty;

    private bool _loading = true, _saving;
    private string? _error;

    private CreateProductRequestModel _model = new();
    private List<AdminCategoryModel> _categories = new();
    private List<AdminBrandModel> _brands = new();
    private List<AdminProductVariantModel> _variants = new();

    // summary (edit mode)
    private int _availableStock;
    private bool _hasVariants;
    private int _imageCount;
    private DateTime _createdAt;

    private bool _variantOpen, _savingVariant;
    private CreateProductVariantRequestModel _variant = new();
    private Guid? _variantEditingId;

    private bool _confirmVariantDelete, _deletingVariant;
    private AdminProductVariantModel? _variantTarget;

    private decimal FinalPrice => _model.DiscountPrice is > 0 && _model.DiscountPrice < _model.BasePrice
        ? _model.DiscountPrice.Value : _model.BasePrice;

    private record DeliveryOption(byte Key, string Label);
    private static readonly DeliveryOption[] DeliveryOptions =
    {
        new(1, "تحویل آنی"), new(2, "تحویل دستی"), new(3, "نیازمند پشتیبانی"),
    };

    protected override async Task OnParametersSetAsync() => await Load();

    private async Task Load()
    {
        _loading = true; _error = null;

        var catTask = Api.GetAsync<List<AdminCategoryModel>>("admin/categories");
        var brandTask = Api.GetAsync<List<AdminBrandModel>>("admin/brands");
        await Task.WhenAll(catTask, brandTask);

        _categories = catTask.Result.Data ?? new();
        _brands = brandTask.Result.Data ?? new();

        if (IsEdit)
        {
            var result = await Api.GetAsync<AdminProductModel>($"admin/products/{Id}");
            if (!result.IsSuccess || result.Data is null) { _error = result.Message; _loading = false; return; }

            var p = result.Data;
            _availableStock = p.AvailableStock;
            _hasVariants = p.HasVariants;
            _createdAt = p.CreatedAt;
            _model = new CreateProductRequestModel
            {
                CategoryId = p.CategoryId, BrandId = p.BrandId, Title = p.Title, Slug = p.Slug,
                ShortDescription = p.ShortDescription, FullDescription = p.FullDescription,
                ThumbnailImagePath = p.ThumbnailImagePath, ProductType = p.ProductType, DeliveryType = p.DeliveryType,
                CurrencyType = p.CurrencyType, BasePrice = p.BasePrice, DiscountPrice = p.DiscountPrice,
                RequiresVerification = p.RequiresVerification, RequiresSupportMessage = p.RequiresSupportMessage,
                MinOrderQuantity = p.MinOrderQuantity, MaxOrderQuantity = p.MaxOrderQuantity,
                IsFeatured = p.IsFeatured, IsActive = p.IsActive, SeoTitle = p.SeoTitle,
                SeoDescription = p.SeoDescription, SortOrder = p.SortOrder,
                Features = p.Features ?? new(), InputFields = p.InputFields ?? new()
            };

            await LoadVariants();
            await LoadImageCount();
        }
        else
        {
            _model = new CreateProductRequestModel { IsActive = true, CurrencyType = 2, ProductType = 1, DeliveryType = 1, MinOrderQuantity = 1 };
        }

        _loading = false;
    }

    private async Task LoadVariants()
    {
        var r = await Api.GetAsync<List<AdminProductVariantModel>>($"admin/products/{Id}/variants");
        _variants = r.Data ?? new();
    }

    private async Task LoadImageCount()
    {
        var r = await Api.GetAsync<List<AdminProductImageModel>>($"admin/products/{Id}/images");
        _imageCount = r.Data?.Count ?? 0;
    }

    private void OnTitleChanged()
    {
        // Auto-suggest a slug for brand-new products only (never overwrite on edit).
        if (!IsEdit && !string.IsNullOrWhiteSpace(_model.Title))
            _model.Slug = Slugify(_model.Title);
    }

    private static string Slugify(string input)
    {
        var slug = input.Trim().ToLowerInvariant();
        var sb = new System.Text.StringBuilder();
        foreach (var ch in slug)
        {
            if (ch == ' ' || ch == '_' || ch == '-') sb.Append('-');
            else if (char.IsLetterOrDigit(ch)) sb.Append(ch);
        }
        var result = sb.ToString();
        while (result.Contains("--")) result = result.Replace("--", "-");
        return result.Trim('-');
    }

    private async Task Save()
    {
        if (_model.CategoryId == Guid.Empty) { Toasts.Error("انتخاب دسته‌بندی الزامی است."); return; }
        if (string.IsNullOrWhiteSpace(_model.Title) || string.IsNullOrWhiteSpace(_model.Slug)) { Toasts.Error("عنوان و اسلاگ محصول الزامی است."); return; }

        if (_model.Features.Any(x => string.IsNullOrWhiteSpace(x.Title) || string.IsNullOrWhiteSpace(x.Value))) { Toasts.Error("عنوان و مقدار همه ویژگی‌ها الزامی است."); return; }
        if (_model.InputFields.Any(x => string.IsNullOrWhiteSpace(x.Key) || string.IsNullOrWhiteSpace(x.Label))) { Toasts.Error("نام داخلی و برچسب همه فیلدها الزامی است."); return; }
        for (var i = 0; i < _model.Features.Count; i++) _model.Features[i].SortOrder = (i + 1) * 10;
        for (var i = 0; i < _model.InputFields.Count; i++) _model.InputFields[i].SortOrder = (i + 1) * 10;
        _saving = true;
        var result = IsEdit
            ? await Api.PutAsync<AdminProductModel>($"admin/products/{Id}", _model)
            : await Api.PostAsync<AdminProductModel>("admin/products", _model);
        _saving = false;

        if (result.IsSuccess && result.Data is not null)
        {
            Toasts.Success(IsEdit ? "تغییرات محصول ذخیره شد." : "محصول با موفقیت ایجاد شد.");
            if (!IsEdit) Nav.NavigateTo($"admin/products/{result.Data.Id}");
        }
        else Toasts.Error(result.Message);
    }

    private record InputTypeOption(byte Key, string Label);
    private static readonly InputTypeOption[] InputTypes =
    {
        new(1,"متن"), new(2,"ایمیل"), new(3,"موبایل"), new(4,"عدد"), new(5,"متن چندخطی"),
        new(6,"انتخابی"), new(7,"رادیویی"), new(8,"تأیید/چک‌باکس"), new(9,"نام کاربری تلگرام"),
        new(10,"نشانی وب"), new(11,"تاریخ"), new(12,"محرمانه")
    };

    private void AddFeature() => _model.Features.Add(new ProductFeatureModel { IsActive = true, SortOrder = (_model.Features.Count + 1) * 10 });
    private void MoveFeature(int index, int offset) => Move(_model.Features, index, offset);
    private void AddInputField() => _model.InputFields.Add(new ProductInputFieldModel { IsActive = true, FieldType = 1, DisplayStage = 1, SortOrder = (_model.InputFields.Count + 1) * 10 });
    private void MoveInput(int index, int offset) => Move(_model.InputFields, index, offset);
    private static void Move<T>(List<T> list, int index, int offset)
    {
        var target = index + offset;
        if (index < 0 || index >= list.Count || target < 0 || target >= list.Count) return;
        (list[index], list[target]) = (list[target], list[index]);
    }

    private void OpenVariantCreate()
    {
        _variantEditingId = null;
        _variant = new CreateProductVariantRequestModel { IsActive = true, StockMode = 1, SortOrder = 10 };
        _variantOpen = true;
    }

    private void OpenVariantEdit(AdminProductVariantModel v)
    {
        _variantEditingId = v.Id;
        _variant = new CreateProductVariantRequestModel
        {
            Title = v.Title, Sku = v.Sku, Price = v.Price, DiscountPrice = v.DiscountPrice,
            Value = v.Value, StockMode = v.StockMode, IsDefault = v.IsDefault, IsActive = v.IsActive, SortOrder = v.SortOrder
        };
        _variantOpen = true;
    }

    private async Task SaveVariant()
    {
        _savingVariant = true;
        var r = _variantEditingId is null
            ? await Api.PostAsync<AdminProductVariantModel>($"admin/products/{Id}/variants", _variant)
            : await Api.PutAsync<AdminProductVariantModel>($"admin/product-variants/{_variantEditingId}", _variant);
        _savingVariant = false;

        if (r.IsSuccess) { Toasts.Success("واریانت ذخیره شد."); _variantOpen = false; await LoadVariants(); }
        else Toasts.Error(r.Message);
    }

    private void AskDeleteVariant(AdminProductVariantModel v) { _variantTarget = v; _confirmVariantDelete = true; }

    private async Task ConfirmDeleteVariant()
    {
        if (_variantTarget is null) return;
        _deletingVariant = true;
        var r = await Api.DeleteAsync($"admin/product-variants/{_variantTarget.Id}");
        _deletingVariant = false; _confirmVariantDelete = false;
        if (r.IsSuccess) { Toasts.Success("واریانت حذف شد."); await LoadVariants(); }
        else Toasts.Error(r.Message);
    }
}
