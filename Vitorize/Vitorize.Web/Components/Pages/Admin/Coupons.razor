@page "/admin/coupons"
@inject ApiClient Api
@inject ToastService Toasts
@inject IJSRuntime JS
@implements IAsyncDisposable
@using Vitorize.Web.Helpers
@using AUI = Vitorize.Web.Helpers.AdminUiHelper

<PageHeader Title="کدهای تخفیف" Subtitle="مدیریت کدهای تخفیف و کمپین‌های فروش"
            Icon="percent" Breadcrumbs="@(new(){ ("کدهای تخفیف", null) })">
    <Actions>
        <button class="vz-btn vz-btn--ghost vz-btn--icon" title="خروجی CSV" @onclick="Export"><Icon Name="download" Size="17" /></button>
        <button class="vz-btn vz-btn--outline" @onclick="Load"><Icon Name="refresh" Size="17" /> بروزرسانی</button>
        <button class="vz-btn vz-btn--primary" @onclick="OpenCreate"><Icon Name="plus" Size="17" /> کد تخفیف جدید</button>
    </Actions>
</PageHeader>

@if (!_loading && _error is null)
{
    <div class="vz-stats">
        <StatCard Label="همه کدها" Value="@AUI.Number(_items.Count)" Icon="percent" Accent="purple" />
        <StatCard Label="فعال" Value="@AUI.Number(_items.Count(c => State(c) == "active"))" Icon="check-circle" Accent="green" />
        <StatCard Label="زمان‌بندی‌شده" Value="@AUI.Number(_items.Count(c => State(c) == "scheduled"))" Icon="clock" Accent="blue" />
        <StatCard Label="منقضی" Value="@AUI.Number(_items.Count(c => State(c) == "expired"))" Icon="alert" Accent="orange" />
    </div>

    <div class="vz-spread" style="margin-bottom:16px;align-items:flex-end">
        <div class="vz-pills">
            @foreach (var f in Filters)
            {
                <button class="vz-pill @(_stateFilter == f.Key ? "active" : "")" @onclick="() => _stateFilter = f.Key">
                    @f.Label <span class="vz-pill__count">@AUI.Number(CountFor(f.Key))</span>
                </button>
            }
        </div>
        <div style="position:relative;min-width:240px">
            <input id="coupon-search" class="vz-input" style="padding-inline-start:38px" placeholder="کد یا عنوان ... ( / )"
                   @bind="_search" @bind:event="oninput" />
            <span style="position:absolute;inset-inline-start:12px;top:50%;transform:translateY(-50%);color:var(--text-3)"><Icon Name="search" Size="17" /></span>
        </div>
    </div>
}

<div class="vz-card">
    <div class="vz-card__body flush">
        @if (_loading) { <LoadingState /> }
        else if (_error is not null) { <ErrorState Message="@_error" OnRetry="Load" /> }
        else if (Filtered.Count == 0)
        {
            <EmptyState Title="کد تخفیفی یافت نشد" Text="با فیلتر فعلی کدی وجود ندارد یا هنوز کدی ثبت نشده است." Icon="percent">
                <Actions><button class="vz-btn vz-btn--primary vz-btn--sm" @onclick="OpenCreate"><Icon Name="plus" Size="15" /> افزودن کد تخفیف</button></Actions>
            </EmptyState>
        }
        else
        {
            <div class="vz-table-wrap">
                <table class="vz-table">
                    <thead>
                        <tr><th>کد</th><th>عنوان</th><th>تخفیف</th><th>استفاده</th><th>اعتبار</th><th>وضعیت</th><th>فعال</th><th class="col-actions">عملیات</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var c in Filtered)
                        {
                            <tr>
                                <td>
                                    <span class="vz-copy vz-chip vz-mono" title="کپی کد" @onclick="() => Copy(c.Code)">
                                        @c.Code <span class="vz-copy__icon"><Icon Name="copy" Size="13" /></span>
                                    </span>
                                </td>
                                <td class="vz-cell-title">@c.Title</td>
                                <td>
                                    @if (c.DiscountType == (byte)DiscountType.Percentage)
                                    { <span>@AUI.Number((long)c.DiscountValue)٪</span> }
                                    else
                                    { <MoneyDisplay Amount="c.DiscountValue" /> }
                                </td>
                                <td class="num">@AUI.Number(c.UsedCount)@(c.MaxUsageCount.HasValue ? $" / {AUI.Number(c.MaxUsageCount.Value)}" : "")</td>
                                <td class="vz-mono" style="font-size:12px">
                                    <PersianDateDisplay Value="c.StartsAt" /> － <PersianDateDisplay Value="c.EndsAt" />
                                </td>
                                <td><StatusBadge Text="@StateLabel(State(c))" Intent="@StateIntent(State(c))" /></td>
                                <td>
                                    <label class="vz-switch" title="@(c.IsActive ? "غیرفعال کردن" : "فعال کردن")">
                                        <input type="checkbox" checked="@c.IsActive" @onchange="() => ToggleActive(c)" disabled="@(_togglingId == c.Id)" />
                                        <span class="vz-switch__track"></span>
                                    </label>
                                </td>
                                <td class="col-actions">
                                    <AdminContextMenu>
                                                <button class="vz-ctx__item" @onclick="() => OpenEdit(c)"><Icon Name="edit" Size="15" /> ویرایش</button>
                                                <button class="vz-ctx__item" @onclick="() => Duplicate(c)"><Icon Name="copy" Size="15" /> تکثیر کد</button>
                                                <button class="vz-ctx__item" @onclick="() => Copy(c.Code)"><Icon Name="copy" Size="15" /> کپی کد</button>
                                                <div class="vz-ctx__divider"></div>
                                                <button class="vz-ctx__item danger" @onclick="() => AskDelete(c)"><Icon Name="trash" Size="15" /> حذف</button>
                                    </AdminContextMenu>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<SlidePanel Visible="_formOpen" Title="@(_editingId is null ? "افزودن کد تخفیف" : "ویرایش کد تخفیف")"
            Subtitle="@(_editingId is null ? "یک کمپین تخفیف جدید بسازید" : _model.Code)"
            Icon="percent" OnClose="CloseForm">
    <ChildContent>
        <EditForm Model="_model" OnValidSubmit="Save" id="coupon-form">
            <DataAnnotationsValidator />
            <div class="vz-form-grid one">
                <div class="vz-field">
                    <label class="vz-label">کد تخفیف <span class="req">*</span></label>
                    <div class="vz-input-group">
                        <InputText class="vz-input vz-mono" @bind-Value="_model.Code" placeholder="مثال: NOWRUZ1403" />
                        <button type="button" class="suffix" style="pointer-events:auto;cursor:pointer;background:none;border:none;color:var(--admin-primary);font-weight:700" @onclick="GenerateCode">تولید</button>
                    </div>
                    <ValidationMessage For="() => _model.Code" class="vz-val-msg" />
                </div>
                <div class="vz-field">
                    <label class="vz-label">عنوان <span class="req">*</span></label>
                    <InputText class="vz-input" @bind-Value="_model.Title" />
                    <ValidationMessage For="() => _model.Title" class="vz-val-msg" />
                </div>
                <div class="vz-form-grid" style="gap:14px">
                    <div class="vz-field">
                        <label class="vz-label">نوع تخفیف</label>
                        <select class="vz-select" value="@_model.DiscountType" @onchange="e => _model.DiscountType = byte.Parse(e.Value!.ToString()!)">
                            <option value="1">درصدی</option>
                            <option value="2">مبلغ ثابت</option>
                        </select>
                    </div>
                    <div class="vz-field">
                        <label class="vz-label">مقدار تخفیف <span class="req">*</span></label>
                        <div class="vz-input-group">
                            <InputNumber class="vz-input" @bind-Value="_model.DiscountValue" />
                            <span class="suffix">@(_model.DiscountType == 1 ? "درصد" : "تومان")</span>
                        </div>
                    </div>
                </div>
                <div class="vz-form-grid" style="gap:14px">
                    <div class="vz-field">
                        <label class="vz-label">حداکثر دفعات استفاده</label>
                        <InputNumber class="vz-input" @bind-Value="_model.MaxUsageCount" placeholder="نامحدود" />
                    </div>
                    <div class="vz-field">
                        <label class="vz-label">حداکثر برای هر کاربر</label>
                        <InputNumber class="vz-input" @bind-Value="_model.MaxUsagePerUser" placeholder="نامحدود" />
                    </div>
                </div>
                <div class="vz-field">
                    <label class="vz-label">حداقل مبلغ سفارش</label>
                    <div class="vz-input-group">
                        <InputNumber class="vz-input" @bind-Value="_model.MinOrderAmount" placeholder="بدون محدودیت" />
                        <span class="suffix">تومان</span>
                    </div>
                </div>
                <div class="vz-form-grid" style="gap:14px">
                    <div class="vz-field">
                        <label class="vz-label">تاریخ شروع</label>
                        <PersianDatePicker @bind-Value="_model.StartsAt" Placeholder="بدون محدودیت" />
                    </div>
                    <div class="vz-field">
                        <label class="vz-label">تاریخ پایان</label>
                        <PersianDatePicker @bind-Value="_model.EndsAt" Placeholder="بدون محدودیت" />
                    </div>
                </div>
                <div class="vz-field">
                    <label class="vz-switch">
                        <input type="checkbox" @bind="_model.IsActive" />
                        <span class="vz-switch__track"></span>
                        <span class="vz-switch__label">کد تخفیف فعال باشد</span>
                    </label>
                </div>
            </div>
        </EditForm>
    </ChildContent>
    <Footer>
        <button class="vz-btn vz-btn--outline" @onclick="CloseForm" disabled="@_saving">انصراف</button>
        <button class="vz-btn vz-btn--primary" type="submit" form="coupon-form" disabled="@_saving">
            @if (_saving) { <span class="vz-spinner sm"></span> } else { <Icon Name="save" Size="16" /> <span>ذخیره</span> }
        </button>
    </Footer>
</SlidePanel>

<ConfirmDialog Visible="_confirmDelete" Title="حذف کد تخفیف"
               Message="@($"آیا از حذف کد «{_target?.Code}» مطمئن هستید؟")"
               ConfirmText="حذف" Busy="_deleting"
               OnConfirm="ConfirmDelete" OnCancel="() => _confirmDelete = false" />

@code {
    private bool _loading = true;
    private string? _error;
    private List<AdminCouponModel> _items = new();

    private string _search = string.Empty;
    private string _stateFilter = "all";

    private bool _formOpen, _saving;
    private AdminCouponInputModel _model = new();
    private Guid? _editingId;

    private Guid? _openMenuId;
    private Guid? _togglingId;

    private bool _confirmDelete, _deleting;
    private AdminCouponModel? _target;

    private DotNetObjectReference<Coupons>? _selfRef;

    private static readonly (string Key, string Label)[] Filters =
    {
        ("all", "همه"), ("active", "فعال"), ("scheduled", "زمان‌بندی‌شده"),
        ("expired", "منقضی"), ("inactive", "غیرفعال"),
    };

    protected override Task OnInitializedAsync() => Load();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _selfRef = DotNetObjectReference.Create(this);
            try { await JS.InvokeVoidAsync("vzAdmin.registerShortcuts", _selfRef, nameof(OnShortcut)); } catch { }
        }
    }

    private async Task Load()
    {
        _loading = true; _error = null;
        var result = await Api.GetAsync<List<AdminCouponModel>>("admin/coupons");
        if (result.IsSuccess && result.Data is not null) _items = result.Data;
        else _error = result.Message;
        _loading = false;
    }

    // ----- smart state -----
    private static string State(AdminCouponModel c)
    {
        if (!c.IsActive) return "inactive";
        var now = DateTime.Now;
        if (c.EndsAt is not null && c.EndsAt < now) return "expired";
        if (c.StartsAt is not null && c.StartsAt > now) return "scheduled";
        return "active";
    }
    private static string StateLabel(string s) => s switch
    {
        "active" => "فعال", "scheduled" => "زمان‌بندی‌شده", "expired" => "منقضی", "inactive" => "غیرفعال", _ => s
    };
    private static string StateIntent(string s) => s switch
    {
        "active" => "success", "scheduled" => "info", "expired" => "warning", "inactive" => "muted", _ => "muted"
    };
    private int CountFor(string key) => key == "all" ? _items.Count : _items.Count(c => State(c) == key);

    private List<AdminCouponModel> Filtered => _items
        .Where(c => string.IsNullOrWhiteSpace(_search)
            || c.Code.Contains(_search, StringComparison.OrdinalIgnoreCase)
            || c.Title.Contains(_search, StringComparison.OrdinalIgnoreCase))
        .Where(c => _stateFilter == "all" || State(c) == _stateFilter)
        .OrderByDescending(c => c.CreatedAt)
        .ToList();

    // ----- menu -----
    private void ToggleMenu(Guid id) => _openMenuId = _openMenuId == id ? null : id;
    private void CloseMenu() => _openMenuId = null;

    // ----- create / edit -----
    private void OpenCreate()
    {
        _editingId = null;
        _model = new AdminCouponInputModel { IsActive = true, DiscountType = 1 };
        _formOpen = true;
    }

    private void OpenEdit(AdminCouponModel c)
    {
        CloseMenu();
        _editingId = c.Id;
        _model = ToInput(c);
        _formOpen = true;
    }

    private void Duplicate(AdminCouponModel c)
    {
        CloseMenu();
        _editingId = null;
        _model = ToInput(c);
        _model.Code = $"{c.Code}-COPY";
        _model.Title = $"{c.Title} (کپی)";
        _formOpen = true;
        Toasts.Info("یک نسخه از کد ساخته شد؛ کد و عنوان را بازبینی کنید.");
    }

    private static AdminCouponInputModel ToInput(AdminCouponModel c) => new()
    {
        Code = c.Code, Title = c.Title, DiscountType = c.DiscountType, DiscountValue = c.DiscountValue,
        MaxUsageCount = c.MaxUsageCount, MaxUsagePerUser = c.MaxUsagePerUser, MinOrderAmount = c.MinOrderAmount,
        StartsAt = c.StartsAt, EndsAt = c.EndsAt, IsActive = c.IsActive
    };

    private void GenerateCode()
    {
        const string chars = "ABCDEFGHJKLMNPQRSTUVWXYZ23456789";
        var rnd = Random.Shared;
        _model.Code = new string(Enumerable.Range(0, 8).Select(_ => chars[rnd.Next(chars.Length)]).ToArray());
    }

    private void CloseForm() => _formOpen = false;

    private async Task Save()
    {
        _saving = true;
        var result = _editingId is null
            ? await Api.PostAsync<AdminCouponModel>("admin/coupons", Payload(_model))
            : await Api.PutAsync<AdminCouponModel>($"admin/coupons/{_editingId}", Payload(_model));

        _saving = false;
        if (result.IsSuccess)
        {
            Toasts.Success(_editingId is null ? "کد تخفیف ایجاد شد." : "کد تخفیف ویرایش شد.");
            _formOpen = false;
            await Load();
        }
        else Toasts.Error(result.Message);
    }

    private static object Payload(AdminCouponInputModel m) => new
    {
        m.Code, m.Title, m.DiscountType, m.DiscountValue,
        m.MaxUsageCount, m.MaxUsagePerUser, m.MinOrderAmount,
        m.StartsAt, m.EndsAt, m.IsActive
    };

    // ----- inline active toggle -----
    private async Task ToggleActive(AdminCouponModel c)
    {
        _togglingId = c.Id;
        var input = ToInput(c);
        input.IsActive = !c.IsActive;
        var r = await Api.PutAsync<AdminCouponModel>($"admin/coupons/{c.Id}", Payload(input));
        _togglingId = null;
        if (r.IsSuccess)
        {
            c.IsActive = input.IsActive;
            Toasts.Success(c.IsActive ? "کد فعال شد." : "کد غیرفعال شد.");
        }
        else Toasts.Error(r.Message);
    }

    // ----- delete -----
    private void AskDelete(AdminCouponModel c) { CloseMenu(); _target = c; _confirmDelete = true; }

    private async Task ConfirmDelete()
    {
        if (_target is null) return;
        _deleting = true;
        var result = await Api.DeleteAsync($"admin/coupons/{_target.Id}");
        _deleting = false; _confirmDelete = false;
        if (result.IsSuccess) { Toasts.Success("کد تخفیف حذف شد."); await Load(); }
        else Toasts.Error(result.Message);
    }

    // ----- copy / export -----
    private async Task Copy(string text)
    {
        CloseMenu();
        var ok = await JS.InvokeAsync<bool>("vzAdmin.copy", text);
        if (ok) Toasts.Success($"کد «{text}» کپی شد.");
    }

    private async Task Export()
    {
        var rows = Filtered.Select(c => new[]
        {
            AdminCsv.Field(c.Code), AdminCsv.Field(c.Title),
            AdminCsv.Field(c.DiscountType == 1 ? "percent" : "fixed"), AdminCsv.Num(c.DiscountValue),
            c.UsedCount.ToString(), c.MaxUsageCount?.ToString() ?? "",
            AdminCsv.Field(StateLabel(State(c)))
        });
        var csv = AdminCsv.Build(
            new[] { "Code", "Title", "Type", "Value", "Used", "MaxUsage", "State" }, rows);
        await JS.InvokeVoidAsync("vzAdmin.downloadText", $"coupons-{DateTime.Now:yyyyMMdd-HHmm}.csv", csv, "text/csv");
        Toasts.Success($"{AUI.Number(Filtered.Count)} کد در فایل CSV ذخیره شد.");
    }

    // ----- keyboard shortcuts -----
    [JSInvokable]
    public async Task OnShortcut(string key)
    {
        switch (key)
        {
            case "/": await JS.InvokeVoidAsync("vzAdmin.focusById", "coupon-search"); break;
            case "n": OpenCreate(); break;
            case "r": await Load(); break;
            case "Escape":
                if (_formOpen) CloseForm();
                else if (_openMenuId is not null) CloseMenu();
                break;
        }
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        try { await JS.InvokeVoidAsync("vzAdmin.unregisterShortcuts"); } catch { }
        _selfRef?.Dispose();
    }
}
