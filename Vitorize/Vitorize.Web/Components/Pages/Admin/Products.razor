@page "/admin/products"
@inject ApiClient Api
@inject MediaUrlResolver Media
@inject ToastService Toasts
@inject NavigationManager Nav
@inject IJSRuntime JS
@using AUI = Vitorize.Web.Helpers.AdminUiHelper

<PageHeader Title="مدیریت محصولات" Subtitle="لیست محصولات فروشگاه خود را مدیریت و ویرایش کنید"
            Icon="box" Breadcrumbs="@(new(){ ("محصولات", null) })">
    <Actions>
        <button class="vz-btn vz-btn--outline" @onclick="Load"><Icon Name="refresh" Size="17" /> بروزرسانی</button>
        <a class="vz-btn vz-btn--primary" href="admin/products/create"><Icon Name="plus" Size="17" /> افزودن محصول جدید</a>
    </Actions>
</PageHeader>

@if (_loading) { <LoadingState /> }
else if (_error is not null) { <ErrorState Message="@_error" OnRetry="Load" /> }
else
{
    <div class="vz-stats">
        <StatCard Label="همه محصولات" Value="@AUI.Number(_items.Count)" Icon="box" Accent="purple" />
        <StatCard Label="محصولات فعال" Value="@AUI.Number(_items.Count(p => p.IsActive))" Icon="check-circle" Accent="green" />
        <StatCard Label="ویژه" Value="@AUI.Number(_items.Count(p => p.IsFeatured))" Icon="star" Accent="orange" />
        <StatCard Label="ناموجود" Value="@AUI.Number(_items.Count(p => p.AvailableStock <= 0 && !p.HasVariants))" Icon="alert" Accent="red" />
    </div>

    <div class="vz-spread" style="margin-bottom:16px">
        <div class="vz-pills">
            @foreach (var f in StockFilters)
            {
                <button class="vz-pill @(_stockFilter == f.Key ? "active" : "")" @onclick="() => SelectStock(f.Key)">
                    @f.Label <span class="vz-pill__count">@AUI.Number(f.Count(_items))</span>
                </button>
            }
        </div>
    </div>

    <div class="vz-filterbar">
        <div class="vz-filterbar__row">
            <div class="vz-field">
                <label class="vz-label">جستجو</label>
                <div class="vz-input-group">
                    <input class="vz-input" style="padding-inline-start:38px" placeholder="عنوان، اسلاگ ..." @bind="_search" @bind:event="oninput" @bind:after="ResetPage" />
                    <span style="position:absolute;inset-inline-start:13px;color:var(--text-3)"><Icon Name="search" Size="16" /></span>
                </div>
            </div>
            <div class="vz-field">
                <label class="vz-label">نوع محصول</label>
                <select class="vz-select" @bind="_typeFilter" @bind:after="ResetPage">
                    <option value="all">همه نوع‌ها</option>
                    <option value="1">گیفت کارت</option>
                    <option value="2">اکانت بازی</option>
                    <option value="3">سرویس بازی</option>
                    <option value="4">اشتراک</option>
                    <option value="5">سایر</option>
                </select>
            </div>
            <div class="vz-field">
                <label class="vz-label">دسته‌بندی</label>
                <select class="vz-select" @bind="_categoryFilter" @bind:after="ResetPage">
                    <option value="all">همه دسته‌ها</option>
                    @foreach (var cat in _items.Select(p => p.CategoryTitle).Where(t => !string.IsNullOrWhiteSpace(t)).Distinct())
                    {
                        <option value="@cat">@cat</option>
                    }
                </select>
            </div>
            <div class="vz-field">
                <label class="vz-label">وضعیت</label>
                <select class="vz-select" @bind="_statusFilter" @bind:after="ResetPage">
                    <option value="all">همه وضعیت‌ها</option>
                    <option value="active">فعال</option>
                    <option value="inactive">غیرفعال</option>
                    <option value="featured">ویژه</option>
                </select>
            </div>
        </div>
    </div>

    @if (_selected.Count > 0)
    {
        <div class="vz-bulkbar">
            <span>@AUI.Number(_selected.Count) محصول انتخاب شده</span>
            <div style="margin-inline-start:auto;display:flex;gap:8px">
                <button class="vz-btn vz-btn--outline vz-btn--sm" @onclick="ExportSelected"><Icon Name="download" Size="14" /> خروجی CSV</button>
                <button class="vz-btn vz-btn--danger-soft vz-btn--sm" @onclick="AskBulkDelete"><Icon Name="trash" Size="14" /> حذف</button>
                <button class="vz-btn vz-btn--ghost vz-btn--sm" @onclick="ClearSelection">پاک‌کردن انتخاب</button>
            </div>
        </div>
    }

    <div class="vz-card">
        <div class="vz-card__body flush">
            @if (Filtered.Count == 0)
            {
                <EmptyState Title="محصولی یافت نشد" Text="با فیلترهای انتخابی محصولی پیدا نشد. فیلتر دیگری را امتحان کنید یا محصول جدیدی بسازید." Icon="box">
                    <Actions><a class="vz-btn vz-btn--primary vz-btn--sm" href="admin/products/create"><Icon Name="plus" Size="15" /> افزودن محصول</a></Actions>
                </EmptyState>
            }
            else
            {
                <div class="vz-table-wrap">
                    <table class="vz-table">
                        <thead>
                            <tr>
                                <th style="width:40px">
                                    <span class="vz-check @(AllPageSelected ? "checked" : "")" @onclick="ToggleSelectAllPage" role="checkbox">
                                        @if (AllPageSelected) { <Icon Name="check" Size="12" /> }
                                    </span>
                                </th>
                                <th>محصول</th><th>نوع</th><th>برند</th><th>قیمت</th><th>تخفیف</th><th>موجودی</th><th>وضعیت</th><th class="col-actions">عملیات</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in Paged)
                            {
                                <tr>
                                    <td>
                                        <span class="vz-check @(_selected.Contains(p.Id) ? "checked" : "")" @onclick="() => ToggleSelect(p.Id)" role="checkbox">
                                            @if (_selected.Contains(p.Id)) { <Icon Name="check" Size="12" /> }
                                        </span>
                                    </td>
                                    <td>
                                        <div class="vz-cell-main">
                                            @if (!string.IsNullOrWhiteSpace(p.ThumbnailImagePath))
                                            {
                                                <img class="vz-thumb" src="@Media.Resolve(p.ThumbnailImagePath)" alt="@p.Title" />
                                            }
                                            else
                                            {
                                                <div class="vz-thumb" style="display:flex;align-items:center;justify-content:center;color:var(--text-3)"><Icon Name="box" Size="18" /></div>
                                            }
                                            <div>
                                                <a class="vz-cell-title" href="@($"admin/products/{p.Id}/details")" style="transition:color .12s" onmouseover="this.style.color='var(--admin-primary)'" onmouseout="this.style.color=''">@p.Title</a>
                                                <div class="vz-cell-sub">@p.CategoryTitle</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td><span class="vz-chip">@AUI.ProductType(p.ProductType)</span></td>
                                    <td>@(string.IsNullOrWhiteSpace(p.BrandTitle) ? "—" : p.BrandTitle)</td>
                                    <td><MoneyDisplay Amount="p.BasePrice" Currency="p.CurrencyType" /></td>
                                    <td>
                                        @if (p.DiscountPrice is > 0 && p.DiscountPrice < p.BasePrice)
                                        { <StatusBadge Text="@AUI.MoneyFa(p.DiscountPrice.Value, p.CurrencyType)" Intent="success" Dot="false" /> }
                                        else { <span class="vz-muted">—</span> }
                                    </td>
                                    <td class="num">
                                        @if (p.HasVariants) { <span class="vz-chip">واریانت‌دار</span> }
                                        else if (p.AvailableStock > 0) { @AUI.Number(p.AvailableStock) }
                                        else { <StatusBadge Text="ناموجود" Intent="danger" Dot="false" /> }
                                    </td>
                                    <td>
                                        <StatusBadge Text="@(p.IsActive ? "فعال" : "غیرفعال")" Intent="@(p.IsActive ? "success" : "muted")" />
                                        @if (p.IsFeatured) { <StatusBadge Text="ویژه" Intent="warning" Dot="false" /> }
                                    </td>
                                    <td class="col-actions">
                                        <AdminContextMenu>
                                                    <a class="vz-ctx__item" href="@($"admin/products/{p.Id}/details")"><Icon Name="eye" Size="15" /> مشاهده جزئیات</a>
                                                    <a class="vz-ctx__item" href="@($"admin/products/{p.Id}")"><Icon Name="edit" Size="15" /> ویرایش محصول</a>
                                                    <a class="vz-ctx__item" href="@($"admin/products/{p.Id}/images")"><Icon Name="image" Size="15" /> مدیریت تصاویر</a>
                                                    <button class="vz-ctx__item" @onclick="() => Duplicate(p)"><Icon Name="copy" Size="15" /> تکثیر محصول</button>
                                                    <div class="vz-ctx__divider"></div>
                                                    <button class="vz-ctx__item danger" @onclick="() => AskDelete(p)"><Icon Name="trash" Size="15" /> حذف محصول</button>
                                        </AdminContextMenu>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <Pagination Page="_page" PageSize="_pageSize" TotalCount="Filtered.Count" OnPageChanged="p => { _page = p; CloseMenu(); }" />
            }
        </div>
    </div>
}

<ConfirmDialog Visible="_confirmDelete" Title="@_deleteTitle"
               Message="@_deleteMessage"
               ConfirmText="حذف" Busy="_deleting"
               OnConfirm="ConfirmDelete" OnCancel="CancelDelete" />

@code {
    private bool _loading = true;
    private string? _error;
    private List<AdminProductModel> _items = new();

    private string _search = string.Empty;
    private string _typeFilter = "all";
    private string _categoryFilter = "all";
    private string _statusFilter = "all";
    private string _stockFilter = "all";

    private int _page = 1;
    private const int _pageSize = 10;

    private readonly HashSet<Guid> _selected = new();
    private Guid? _openMenuId;

    private bool _confirmDelete, _deleting, _bulkMode;
    private AdminProductModel? _target;
    private string _deleteTitle = "حذف محصول";
    private string _deleteMessage = string.Empty;

    private record StockFilter(string Key, string Label, Func<List<AdminProductModel>, int> Count);

    private static readonly StockFilter[] StockFilters =
    {
        new("all", "همه", items => items.Count),
        new("instock", "موجود", items => items.Count(p => p.HasVariants || p.AvailableStock > 0)),
        new("out", "ناموجود", items => items.Count(p => !p.HasVariants && p.AvailableStock <= 0)),
        new("variants", "واریانت‌دار", items => items.Count(p => p.HasVariants)),
    };

    protected override async Task OnInitializedAsync()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var q = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        if (q.TryGetValue("q", out var search)) _search = search.ToString();
        await Load();
    }

    private async Task Load()
    {
        _loading = true; _error = null;
        var result = await Api.GetAsync<List<AdminProductModel>>("admin/products");
        if (result.IsSuccess && result.Data is not null) _items = result.Data;
        else _error = result.Message;
        _selected.Clear();
        CloseMenu();
        _loading = false;
    }

    private void ResetPage() => _page = 1;
    private void SelectStock(string key) { _stockFilter = key; _page = 1; }

    private List<AdminProductModel> Filtered => _items
        .Where(p => string.IsNullOrWhiteSpace(_search)
            || p.Title.Contains(_search, StringComparison.OrdinalIgnoreCase)
            || p.Slug.Contains(_search, StringComparison.OrdinalIgnoreCase))
        .Where(p => _typeFilter == "all" || p.ProductType.ToString() == _typeFilter)
        .Where(p => _categoryFilter == "all" || p.CategoryTitle == _categoryFilter)
        .Where(p => _statusFilter switch
        {
            "active" => p.IsActive,
            "inactive" => !p.IsActive,
            "featured" => p.IsFeatured,
            _ => true
        })
        .Where(p => _stockFilter switch
        {
            "instock" => p.HasVariants || p.AvailableStock > 0,
            "out" => !p.HasVariants && p.AvailableStock <= 0,
            "variants" => p.HasVariants,
            _ => true
        })
        .OrderByDescending(p => p.CreatedAt)
        .ToList();

    private List<AdminProductModel> Paged => Filtered
        .Skip((_page - 1) * _pageSize).Take(_pageSize).ToList();

    // ----- selection -----
    private bool AllPageSelected => Paged.Count > 0 && Paged.All(p => _selected.Contains(p.Id));

    private void ToggleSelect(Guid id)
    {
        if (!_selected.Add(id)) _selected.Remove(id);
    }

    private void ToggleSelectAllPage()
    {
        if (AllPageSelected) { foreach (var p in Paged) _selected.Remove(p.Id); }
        else { foreach (var p in Paged) _selected.Add(p.Id); }
    }

    private void ClearSelection() => _selected.Clear();

    // ----- context menu -----
    private void ToggleMenu(Guid id) => _openMenuId = _openMenuId == id ? null : id;
    private void CloseMenu() => _openMenuId = null;

    // ----- duplicate -----
    private async Task Duplicate(AdminProductModel p)
    {
        CloseMenu();
        var suffix = DateTime.Now.ToString("HHmmss");
        var payload = new CreateProductRequestModel
        {
            CategoryId = p.CategoryId, BrandId = p.BrandId,
            Title = $"{p.Title} (کپی)", Slug = $"{p.Slug}-copy-{suffix}",
            ShortDescription = p.ShortDescription, FullDescription = p.FullDescription,
            ThumbnailImagePath = p.ThumbnailImagePath, ProductType = p.ProductType, DeliveryType = p.DeliveryType,
            CurrencyType = p.CurrencyType, BasePrice = p.BasePrice, DiscountPrice = p.DiscountPrice,
            RequiresVerification = p.RequiresVerification, RequiresSupportMessage = p.RequiresSupportMessage,
            MinOrderQuantity = p.MinOrderQuantity, MaxOrderQuantity = p.MaxOrderQuantity,
            IsFeatured = false, IsActive = false, SeoTitle = p.SeoTitle,
            SeoDescription = p.SeoDescription, SortOrder = p.SortOrder
        };
        var r = await Api.PostAsync<AdminProductModel>("admin/products", payload);
        if (r.IsSuccess && r.Data is not null)
        {
            Toasts.Success("نسخه جدید محصول ساخته شد. برای ویرایش هدایت می‌شوید.");
            Nav.NavigateTo($"admin/products/{r.Data.Id}");
        }
        else Toasts.Error(r.Message);
    }

    // ----- export -----
    private async Task ExportSelected()
    {
        var rows = _items.Where(p => _selected.Contains(p.Id)).ToList();
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("Title,Slug,Category,Brand,Type,BasePrice,DiscountPrice,Stock,Active,Featured");
        foreach (var p in rows)
        {
            sb.AppendLine(string.Join(",", new[]
            {
                Csv(p.Title), Csv(p.Slug), Csv(p.CategoryTitle), Csv(p.BrandTitle ?? ""),
                Csv(AUI.ProductType(p.ProductType)), p.BasePrice.ToString(System.Globalization.CultureInfo.InvariantCulture),
                (p.DiscountPrice ?? 0).ToString(System.Globalization.CultureInfo.InvariantCulture),
                (p.HasVariants ? "variants" : p.AvailableStock.ToString()),
                p.IsActive ? "1" : "0", p.IsFeatured ? "1" : "0"
            }));
        }
        await JS.InvokeVoidAsync("vzAdmin.downloadText", $"products-{DateTime.Now:yyyyMMdd-HHmm}.csv", sb.ToString(), "text/csv");
        Toasts.Success($"{AUI.Number(rows.Count)} محصول در فایل CSV ذخیره شد.");
    }

    private static string Csv(string value)
    {
        if (string.IsNullOrEmpty(value)) return "";
        if (value.Contains(',') || value.Contains('"') || value.Contains('\n'))
            return "\"" + value.Replace("\"", "\"\"") + "\"";
        return value;
    }

    // ----- delete (single + bulk) -----
    private void AskDelete(AdminProductModel p)
    {
        CloseMenu();
        _bulkMode = false; _target = p;
        _deleteTitle = "حذف محصول";
        _deleteMessage = $"آیا از حذف محصول «{p.Title}» مطمئن هستید؟ این عملیات قابل بازگشت نیست.";
        _confirmDelete = true;
    }

    private void AskBulkDelete()
    {
        _bulkMode = true; _target = null;
        _deleteTitle = "حذف گروهی محصولات";
        _deleteMessage = $"آیا از حذف {AUI.Number(_selected.Count)} محصول انتخاب‌شده مطمئن هستید؟ این عملیات قابل بازگشت نیست.";
        _confirmDelete = true;
    }

    private void CancelDelete()
    {
        if (_deleting) return;
        _confirmDelete = false; _target = null;
    }

    private async Task ConfirmDelete()
    {
        _deleting = true;
        if (_bulkMode)
        {
            int ok = 0, fail = 0;
            foreach (var id in _selected.ToList())
            {
                var r = await Api.DeleteAsync($"admin/products/{id}");
                if (r.IsSuccess) ok++; else fail++;
            }
            _deleting = false; _confirmDelete = false;
            if (ok > 0) Toasts.Success($"{AUI.Number(ok)} محصول حذف شد.");
            if (fail > 0) Toasts.Error($"{AUI.Number(fail)} محصول حذف نشد.");
            await Load();
        }
        else if (_target is not null)
        {
            var result = await Api.DeleteAsync($"admin/products/{_target.Id}");
            _deleting = false; _confirmDelete = false;
            if (result.IsSuccess) { Toasts.Success("محصول حذف شد."); await Load(); }
            else Toasts.Error(result.Message);
        }
        else { _deleting = false; _confirmDelete = false; }
    }
}
