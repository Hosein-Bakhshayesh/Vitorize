@page
@model Vitorize.Web.Pages.Auth.LoginModel
@{
    ViewData["Title"] = "ورود کاربران | Vitorize";
}

<section class="vt-auth-page">
    <div class="vt-auth-visual">
        <span>Vitorize Account</span>
        <h1>ورود به حساب کاربری</h1>
        <p>برای خرید گیفت کارت، مشاهده سفارش‌ها و دریافت کدهای تحویل‌شده وارد حساب خود شوید.</p>

        <div class="vt-auth-benefits">
            <div>⚡ تحویل سریع</div>
            <div>🛡 ضمانت اصالت</div>
            <div>🎧 پشتیبانی واقعی</div>
        </div>
    </div>

    <div class="vt-auth-card">
        <div class="vt-auth-logo">
            <img src="~/img/vitorize-logo.png" alt="Vitorize" />
            <b>Vitorize</b>
        </div>

        <h2>ورود کاربران</h2>
        <p>شماره موبایل و رمز عبور خود را وارد کنید.</p>

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="vt-auth-error">
                @Model.ErrorMessage
            </div>
        }

        <form method="post" class="vt-auth-form">
            <input type="hidden" asp-for="Input.ReturnUrl" />

            <div>
                <label asp-for="Input.Mobile">شماره موبایل</label>
                <input asp-for="Input.Mobile" placeholder="09123456789" />
                <span asp-validation-for="Input.Mobile"></span>
            </div>

            <div>
                <label asp-for="Input.Password">رمز عبور</label>
                <input asp-for="Input.Password" type="password" placeholder="رمز عبور" />
                <span asp-validation-for="Input.Password"></span>
            </div>

            <button type="submit">ورود به حساب</button>
        </form>

        <div class="vt-auth-footer-link">
            حساب نداری؟
            <a asp-page="/Auth/Register" asp-route-returnUrl="@Model.Input.ReturnUrl">ثبت‌نام کن</a>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}