@page
@model Vitorize.Web.Pages.Auth.RegisterModel
@{
    ViewData["Title"] = "ثبت‌نام کاربران | Vitorize";
}

<section class="vt-auth-page">
    <div class="vt-auth-visual">
        <span>Join Vitorize</span>
        <h1>ساخت حساب کاربری</h1>
        <p>با ثبت‌نام در ویتورایز، خریدهای دیجیتال خود را سریع‌تر و مطمئن‌تر مدیریت کنید.</p>

        <div class="vt-auth-benefits">
            <div>🎮 گیفت کارت و اکانت بازی</div>
            <div>🤖 سرویس‌های ChatGPT و AI</div>
            <div>📦 مشاهده تحویل سفارش</div>
        </div>
    </div>

    <div class="vt-auth-card">
        <div class="vt-auth-logo">
            <img src="~/img/vitorize-logo.png" alt="Vitorize" />
            <b>Vitorize</b>
        </div>

        <h2>ثبت‌نام کاربران</h2>
        <p>اطلاعات اولیه حساب کاربری را وارد کنید.</p>

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="vt-auth-error">
                @Model.ErrorMessage
            </div>
        }

        <form method="post" class="vt-auth-form">
            <input type="hidden" asp-for="ReturnUrl" />

            <div>
                <label asp-for="Input.FullName">نام و نام خانوادگی</label>
                <input asp-for="Input.FullName" placeholder="مثلاً حسین بخشایش" />
                <span asp-validation-for="Input.FullName"></span>
            </div>

            <div>
                <label asp-for="Input.Mobile">شماره موبایل</label>
                <input asp-for="Input.Mobile" placeholder="09123456789" />
                <span asp-validation-for="Input.Mobile"></span>
            </div>

            <div>
                <label asp-for="Input.Email">ایمیل</label>
                <input asp-for="Input.Email" placeholder="اختیاری" />
                <span asp-validation-for="Input.Email"></span>
            </div>

            <div>
                <label asp-for="Input.Password">رمز عبور</label>
                <input asp-for="Input.Password" type="password" placeholder="حداقل ۶ کاراکتر" />
                <span asp-validation-for="Input.Password"></span>
            </div>

            <button type="submit">ثبت‌نام و ورود</button>
        </form>

        <div class="vt-auth-footer-link">
            قبلاً ثبت‌نام کردی؟
            <a asp-page="/Auth/Login" asp-route-returnUrl="@Model.ReturnUrl">وارد شو</a>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}