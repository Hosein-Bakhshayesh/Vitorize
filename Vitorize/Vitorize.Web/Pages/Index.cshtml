@page
@model IndexModel
@{
    ViewData["Title"] = "Vitorize | فروشگاه گیفت کارت";
}

<section class="vt-hero">
    <button class="vt-hero-arrow vt-hero-arrow-right" type="button">›</button>
    <button class="vt-hero-arrow vt-hero-arrow-left" type="button">‹</button>

    <div class="vt-hero-content">
        <h1>گیفت کارت‌های جهانی را<br />سریع، امن و مطمئن بخرید</h1>
        <p>به بهترین تجربه خرید گیفت کارت</p>

        <div class="mt-7 flex flex-wrap items-center justify-center gap-4 md:justify-start">
            <a asp-page="/Products/Index" class="vt-hero-primary">مشاهده محصولات</a>
            <a href="#why-vitorize" class="vt-hero-secondary">اطلاعات بیشتر</a>
        </div>
    </div>

    <div class="vt-hero-dots">
        <span class="active"></span>
        <span></span>
        <span></span>
    </div>
</section>

<section class="vt-trustbar">
    <div class="vt-trust-item">
        <span class="vt-trust-icon">⚙</span>
        <div>
            <b>تحویل آنی</b>
            <small>سریع و بدون معطلی</small>
        </div>
    </div>

    <div class="vt-trust-item">
        <span class="vt-trust-icon">✚</span>
        <div>
            <b>ضمانت اصالت</b>
            <small>کد اصلی و معتبر</small>
        </div>
    </div>

    <div class="vt-trust-item">
        <span class="vt-trust-icon">✪</span>
        <div>
            <b>بهترین قیمت</b>
            <small>قیمت رقابتی و منصفانه</small>
        </div>
    </div>

    <div class="vt-trust-item">
        <span class="vt-trust-icon">🎧</span>
        <div>
            <b>پشتیبانی ۲۴/۷</b>
            <small>همیشه پاسخگوی شما هستیم</small>
        </div>
    </div>

    <div class="vt-trust-item">
        <span class="vt-trust-icon">🛡</span>
        <div>
            <b>پرداخت امن</b>
            <small>درگاه پرداخت معتبر</small>
        </div>
    </div>

    <div class="vt-trust-item">
        <span class="vt-trust-icon">▣</span>
        <div>
            <b>موجودی دائم</b>
            <small>محصولات متنوع و در دسترس</small>
        </div>
    </div>
</section>

<section class="vt-section">
    <div class="vt-section-head">
        <a asp-page="/Products/Index" class="vt-outline-link">مشاهده همه</a>
        <h2>دسته‌بندی فروشگاه</h2>
    </div>

    <div class="vt-category-strip">
        @foreach (var category in Model.Categories.Take(10))
        {
            <a asp-page="/Products/Index"
               asp-route-CategoryId="@category.Id"
               class="vt-category-item">
                <img src="@StorefrontFormat.ProductImage(category.ImagePath)" alt="@category.Title" />
                <b>@category.Title</b>
            </a>
        }

        @if (!Model.Categories.Any())
        {
            <div class="vt-empty-state">دسته‌بندی فعالی برای نمایش وجود ندارد.</div>
        }
    </div>
</section>

<section class="vt-section">
    <div class="vt-section-head">
        <a asp-page="/Products/Index" asp-route-IsFeatured="true" class="vt-outline-link">مشاهده همه</a>
        <h2>محبوب‌ترین گیفت‌کارت‌ها</h2>
    </div>

    <div class="vt-product-grid">
        @foreach (var product in Model.FeaturedProducts.Take(6))
        {
            <partial name="Shared/_ProductCard" model="product" />
        }

        @if (!Model.FeaturedProducts.Any())
        {
            <div class="vt-empty-state col-span-full">محصول ویژه‌ای برای نمایش وجود ندارد.</div>
        }
    </div>
</section>

<section class="vt-promo-grid">
    <a asp-page="/Products/Index" asp-route-Search="Xbox" class="vt-promo vt-promo-xbox">
        <div>
            <span>خرید گیفت کارت</span>
            <b>Xbox</b>
            <small>مشاهده</small>
        </div>
    </a>

    <a asp-page="/Products/Index" asp-route-Search="PlayStation" class="vt-promo vt-promo-playstation">
        <div>
            <span>خرید گیفت کارت</span>
            <b>PlayStation</b>
            <small>مشاهده</small>
        </div>
    </a>

    <a asp-page="/Products/Index" asp-route-Search="Nintendo" class="vt-promo vt-promo-nintendo">
        <div>
            <span>خرید گیفت کارت</span>
            <b>Nintendo</b>
            <small>مشاهده</small>
        </div>
    </a>
</section>

<section class="vt-section">
    <div class="vt-section-head">
        <a asp-page="/Products/Index" class="vt-outline-link">مشاهده همه</a>
        <h2>خدمات پرطرفدار</h2>
    </div>

    <div class="vt-service-grid">
        @foreach (var product in Model.ServiceProducts.Take(5))
        {
            <a asp-page="/Products/Details"
               asp-route-slug="@product.Slug"
               class="vt-service-card">
                <img src="@StorefrontFormat.ProductImage(product.ThumbnailImagePath)" alt="@product.Title" />
                <b>@product.Title</b>
                <span>@(product.ShortDescription ?? product.BrandTitle ?? product.CategoryTitle)</span>
            </a>
        }

        @if (!Model.ServiceProducts.Any())
        {
            <div class="vt-empty-state col-span-full">خدمتی برای نمایش وجود ندارد.</div>
        }
    </div>
</section>

<section id="why-vitorize" class="vt-section">
    <div class="vt-section-head">
        <span></span>
        <h2>چرا ویتورایز را انتخاب کنید؟</h2>
    </div>

    <div class="vt-why-grid">
        <div class="vt-why-card">
            <span>⚙</span>
            <b>سرعت و مطمئن</b>
            <small>تحویل مطمئن در کمترین زمان</small>
        </div>

        <div class="vt-why-card">
            <span>🛡</span>
            <b>تضمین بازگشت وجه</b>
            <small>در صورت بروز مشکل</small>
        </div>

        <div class="vt-why-card">
            <span>🎮</span>
            <b>تجربه خرید لذت‌بخش</b>
            <small>طراحی کاربرپسند و حرفه‌ای</small>
        </div>

        <div class="vt-why-card">
            <span>💬</span>
            <b>پشتیبانی واقعی</b>
            <small>تیم متخصص در کنار شما</small>
        </div>

        <div class="vt-why-card">
            <span>🔒</span>
            <b>امنیت در پرداخت</b>
            <small>استفاده از درگاه‌های معتبر</small>
        </div>
    </div>
</section>