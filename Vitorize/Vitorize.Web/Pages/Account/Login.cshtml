@page
@model Vitorize.Web.Pages.Account.LoginModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>ورود به پنل مدیریت | Vitorize</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        vitorize: {
                            500: '#06B6D4',
                            700: '#0891B2',
                            900: '#0F172A'
                        }
                    }
                }
            }
        }
    </script>
</head>

<body class="min-h-screen overflow-hidden bg-slate-50 text-slate-900">
    <main class="relative flex min-h-screen items-center justify-center px-6 py-10">

        <div class="absolute inset-0 overflow-hidden">
            <div class="absolute -top-40 -right-40 h-[520px] w-[520px] rounded-full bg-cyan-400/10 blur-3xl"></div>
            <div class="absolute -bottom-40 -left-40 h-[520px] w-[520px] rounded-full bg-teal-400/10 blur-3xl"></div>
            <div class="absolute left-1/2 top-1/2 h-[360px] w-[360px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-white/50 blur-3xl"></div>
        </div>

        <div class="relative z-10 w-full max-w-md">

            <div class="mb-8 text-center">
                <div class="mx-auto flex h-28 w-28 items-center justify-center rounded-[2rem] border border-white/60 bg-white/40 shadow-[0_20px_60px_rgba(15,23,42,.08)] backdrop-blur-2xl">
                    <img src="/images/logo.png" class="h-16 w-16" alt="Vitorize" />
                </div>
            </div>

            <div class="rounded-[2.5rem] border border-white/60 bg-white/45 p-8 shadow-[0_25px_80px_rgba(15,23,42,.10)] backdrop-blur-2xl">

                <div class="mb-8 text-center">
                    <h1 class="text-3xl font-black text-slate-800">
                        Vitorize
                    </h1>

                    <p class="mt-2 text-sm font-bold text-slate-500">
                        ورود به پنل مدیریت
                    </p>
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                {
                    <div class="mb-5 rounded-2xl border border-red-100 bg-red-50/80 px-4 py-3 text-sm font-bold text-red-700">
                        @Model.ErrorMessage
                    </div>
                }

                <form method="post" class="space-y-5">
                    <div>
                        <label asp-for="Input.Mobile" class="mb-2 block text-sm font-black text-slate-700">
                            شماره موبایل
                        </label>

                        <input asp-for="Input.Mobile"
                               placeholder="09123456789"
                               class="w-full rounded-2xl border border-white/60 bg-white/55 px-5 py-4 text-sm outline-none backdrop-blur-xl transition focus:border-vitorize-500 focus:bg-white/80 focus:ring-4 focus:ring-cyan-100" />

                        <span asp-validation-for="Input.Mobile" class="mt-2 block text-xs font-bold text-red-600"></span>
                    </div>

                    <div>
                        <label asp-for="Input.Password" class="mb-2 block text-sm font-black text-slate-700">
                            رمز عبور
                        </label>

                        <input asp-for="Input.Password"
                               type="password"
                               placeholder="رمز عبور"
                               class="w-full rounded-2xl border border-white/60 bg-white/55 px-5 py-4 text-sm outline-none backdrop-blur-xl transition focus:border-vitorize-500 focus:bg-white/80 focus:ring-4 focus:ring-cyan-100" />

                        <span asp-validation-for="Input.Password" class="mt-2 block text-xs font-bold text-red-600"></span>
                    </div>

                    <button type="submit"
                            class="w-full rounded-2xl bg-gradient-to-r from-vitorize-700 to-vitorize-500 py-4 text-sm font-black text-white shadow-xl shadow-cyan-900/20 transition hover:scale-[1.02]">
                        ورود به داشبورد
                    </button>
                </form>
            </div>

            <p class="mt-6 text-center text-xs font-bold text-slate-400">
                © Vitorize Admin Console
            </p>

        </div>
    </main>

    <partial name="_ValidationScriptsPartial" />
</body>
</html>