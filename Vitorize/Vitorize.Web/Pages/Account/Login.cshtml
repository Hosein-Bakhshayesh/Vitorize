@page
@model Vitorize.Web.Pages.Account.LoginModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>ورود مدیران | Vitorize</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen overflow-hidden bg-slate-50 text-slate-900">
    <main class="relative flex min-h-screen items-center justify-center px-6 py-10">
        <div class="absolute inset-0 overflow-hidden">
            <div class="absolute -top-40 -right-40 h-[520px] w-[520px] rounded-full bg-cyan-400/10 blur-3xl"></div>
            <div class="absolute -bottom-40 -left-40 h-[520px] w-[520px] rounded-full bg-teal-400/10 blur-3xl"></div>
        </div>

        <div class="relative z-10 w-full max-w-md">
            <div class="mb-8 text-center">
                <div class="mx-auto flex h-28 w-28 items-center justify-center rounded-[2rem] border border-white/60 bg-white/50 shadow-[0_20px_60px_rgba(15,23,42,.08)] backdrop-blur-2xl">
                    <img src="/img/vitorize-logo.png" class="h-16 w-16" alt="Vitorize" />
                </div>
            </div>

            <div class="rounded-[2.5rem] border border-white/60 bg-white/60 p-8 shadow-[0_25px_80px_rgba(15,23,42,.10)] backdrop-blur-2xl">
                <div class="mb-8 text-center">
                    <h1 class="text-3xl font-black text-slate-800">Vitorize Admin</h1>
                    <p class="mt-2 text-sm font-bold text-slate-500">ورود فقط مخصوص مدیران</p>
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                {
                    <div class="mb-5 rounded-2xl border border-red-100 bg-red-50/80 px-4 py-3 text-sm font-bold text-red-700">
                        @Model.ErrorMessage
                    </div>
                }

                <form method="post" class="space-y-5">
                    <input type="hidden" asp-for="Input.ReturnUrl" />

                    <div>
                        <label asp-for="Input.Mobile" class="mb-2 block text-sm font-black text-slate-700"></label>
                        <input asp-for="Input.Mobile" placeholder="09123456789" class="w-full rounded-2xl border border-white/70 bg-white/70 px-5 py-4 text-sm outline-none transition focus:border-teal-600 focus:ring-4 focus:ring-teal-100" />
                        <span asp-validation-for="Input.Mobile" class="mt-2 block text-xs font-bold text-red-600"></span>
                    </div>

                    <div>
                        <label asp-for="Input.Password" class="mb-2 block text-sm font-black text-slate-700"></label>
                        <input asp-for="Input.Password" type="password" placeholder="رمز عبور" class="w-full rounded-2xl border border-white/70 bg-white/70 px-5 py-4 text-sm outline-none transition focus:border-teal-600 focus:ring-4 focus:ring-teal-100" />
                        <span asp-validation-for="Input.Password" class="mt-2 block text-xs font-bold text-red-600"></span>
                    </div>

                    <button type="submit" class="w-full rounded-2xl bg-gradient-to-r from-teal-800 to-teal-600 py-4 text-sm font-black text-white shadow-xl shadow-teal-900/20 transition hover:scale-[1.02]">
                        ورود به داشبورد مدیریت
                    </button>
                </form>

                <a asp-page="/Auth/Login" class="mt-5 block text-center text-xs font-bold text-slate-500 hover:text-teal-700">
                    ورود کاربران فروشگاه
                </a>
            </div>
        </div>
    </main>

    <partial name="_ValidationScriptsPartial" />
</body>
</html>
