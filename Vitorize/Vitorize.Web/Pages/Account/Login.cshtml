@page
@model Vitorize.Web.Pages.Account.LoginModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>ورود به پنل مدیریت | Vitorize</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        vitorize: {
                            500: '#00A79D',
                            700: '#006D6F',
                            900: '#004E50'
                        }
                    }
                }
            }
        }
    </script>
</head>

<body class="min-h-screen bg-slate-50 text-slate-900">
    <main class="min-h-screen grid grid-cols-1 lg:grid-cols-2">

        <section class="hidden lg:flex bg-gradient-to-br from-vitorize-900 to-vitorize-500 p-14 text-white relative overflow-hidden">
            <div class="absolute -top-32 -left-32 h-96 w-96 rounded-full bg-white/10 blur-3xl"></div>
            <div class="absolute bottom-0 right-0 h-96 w-96 rounded-full bg-teal-300/20 blur-3xl"></div>

            <div class="relative z-10 flex flex-col justify-between w-full">
                <div class="flex items-center gap-4">
                    <div class="h-16 w-16 rounded-3xl bg-white/10 flex items-center justify-center">
                        <img src="/images/logo.png" class="h-11 w-11" alt="Vitorize" />
                    </div>
                    <div>
                        <h1 class="text-3xl font-black">Vitorize</h1>
                        <p class="text-sm text-white/70 mt-1">Admin Console</p>
                    </div>
                </div>

                <div>
                    <p class="inline-flex rounded-full bg-white/10 px-4 py-2 text-sm font-bold text-white/80">
                        مدیریت فروشگاه دیجیتال
                    </p>

                    <h2 class="mt-6 text-5xl font-black leading-[1.5]">
                        مدیریت سریع، امن و یکپارچه
                    </h2>

                    <p class="mt-5 max-w-xl text-base leading-8 text-white/70">
                        محصولات، سفارش‌ها، گیفت‌کارت‌ها، کدهای تخفیف و گزارش‌های فروش را از یک پنل حرفه‌ای کنترل کنید.
                    </p>
                </div>

                <div class="grid grid-cols-3 gap-4">
                    <div class="rounded-3xl bg-white/10 p-5">
                        <p class="text-xl font-black">Orders</p>
                        <p class="mt-1 text-xs text-white/60">مدیریت سفارش‌ها</p>
                    </div>
                    <div class="rounded-3xl bg-white/10 p-5">
                        <p class="text-xl font-black">Codes</p>
                        <p class="mt-1 text-xs text-white/60">تحویل کدها</p>
                    </div>
                    <div class="rounded-3xl bg-white/10 p-5">
                        <p class="text-xl font-black">Reports</p>
                        <p class="mt-1 text-xs text-white/60">گزارش فروش</p>
                    </div>
                </div>
            </div>
        </section>

        <section class="flex items-center justify-center px-6 py-10">
            <div class="w-full max-w-md">
                <div class="text-center mb-8">
                    <div class="mx-auto h-24 w-24 rounded-[2rem] bg-white shadow-2xl shadow-slate-200 flex items-center justify-center">
                        <img src="/images/logo.png" class="h-16 w-16" alt="Vitorize" />
                    </div>

                    <h1 class="mt-6 text-2xl font-black">
                        ورود به پنل مدیریت
                    </h1>

                    <p class="mt-2 text-sm text-slate-500">
                        حساب مدیریتی خود را وارد کنید.
                    </p>
                </div>

                <div class="rounded-[2rem] bg-white border border-slate-100 p-7 shadow-2xl shadow-slate-200/70">
                    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                    {
                        <div class="mb-5 rounded-2xl bg-red-50 border border-red-100 px-4 py-3 text-sm text-red-700">
                            @Model.ErrorMessage
                        </div>
                    }

                    <form method="post" class="space-y-5">
                        <div>
                            <label asp-for="Input.Mobile" class="block mb-2 text-sm font-bold">
                                شماره موبایل
                            </label>
                            <input asp-for="Input.Mobile"
                                   class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3.5 text-sm outline-none focus:border-vitorize-500 focus:ring-4 focus:ring-teal-100"
                                   placeholder="09123456789" />
                            <span asp-validation-for="Input.Mobile" class="block mt-1 text-xs text-red-600"></span>
                        </div>

                        <div>
                            <label asp-for="Input.Password" class="block mb-2 text-sm font-bold">
                                رمز عبور
                            </label>
                            <input asp-for="Input.Password"
                                   type="password"
                                   class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3.5 text-sm outline-none focus:border-vitorize-500 focus:ring-4 focus:ring-teal-100"
                                   placeholder="رمز عبور" />
                            <span asp-validation-for="Input.Password" class="block mt-1 text-xs text-red-600"></span>
                        </div>

                        <button type="submit"
                                class="w-full rounded-2xl bg-vitorize-700 py-3.5 text-sm font-black text-white shadow-lg shadow-teal-900/20 hover:bg-vitorize-900 transition">
                            ورود به داشبورد
                        </button>
                    </form>
                </div>
            </div>
        </section>

    </main>
</body>
</html>