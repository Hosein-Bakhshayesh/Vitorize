@page "{slug}"
@model Vitorize.Web.Pages.Products.DetailsModel

@{
    var p = Model.Product!;
    var selectedVariant = Model.SelectedVariant;
    var mainImage = StorefrontFormat.ProductImage(p.Images.FirstOrDefault() ?? p.ThumbnailImagePath);
    var isAvailable = Model.CurrentStock > 0;
    ViewData["Title"] = $"{p.Title} | Vitorize";
}

<nav class="vt-product-breadcrumb">
    <a asp-page="/Index">خانه</a>
    <span>/</span>
    <a asp-page="/Products/Index" asp-route-CategoryId="@p.CategoryId">@p.CategoryTitle</a>
    <span>/</span>
    <b>@p.Title</b>
</nav>

<section class="vt-product-detail">
    <div class="vt-product-gallery">
        <div class="vt-product-thumbs">
            @foreach (var img in (p.Images.Any() ? p.Images : new List<string> { p.ThumbnailImagePath ?? "" }).Take(5))
            {
                <img src="@StorefrontFormat.ProductImage(img)" alt="@p.Title" />
            }
        </div>

        <div class="vt-product-main-image">
            @if (p.IsFeatured)
            {
                <span class="vt-product-detail-badge">فروش ویژه</span>
            }

            <img src="@mainImage" alt="@p.Title" />
        </div>
    </div>

    <div class="vt-product-buybox">
        <div class="vt-product-title-row">
            <div>
                <span class="vt-product-category">@p.CategoryTitle</span>
                <h1>@p.Title</h1>
                <p>@(p.ShortDescription ?? "خرید سریع و مطمئن با تحویل دیجیتال")</p>
            </div>
        </div>

        <div class="vt-product-mini-info">
            <span>✅ تحویل سریع</span>
            <span>🛡 ضمانت اصالت</span>
            <span>🎧 پشتیبانی واقعی</span>
            @if (p.RequiresVerification)
            {
                <span>🔐 نیازمند احراز هویت</span>
            }
        </div>

        <form method="post" asp-page-handler="AddToCart" class="vt-product-form">
            @if (p.Variants.Any())
            {
                <div class="vt-product-section-title">
                    <b>انتخاب نسخه / مبلغ</b>
                    <small>موجودی و قیمت هر گزینه متفاوت است</small>
                </div>

                <div class="vt-variant-grid">
                    @foreach (var variant in p.Variants.OrderBy(x => x.SortOrder))
                    {
                        var variantAvailable = variant.AvailableStock > 0;

                        <label class="vt-variant-card @(variantAvailable ? "" : "disabled")">
                            <input type="radio"
                                   name="ProductVariantId"
                                   value="@variant.Id"
                                   checked="@(Model.ProductVariantId == variant.Id)"
                                   disabled="@(!variantAvailable)" />

                            <span>
                                <b>@variant.Title</b>
                                @if (!string.IsNullOrWhiteSpace(variant.Value))
                                {
                                    <small>@variant.Value</small>
                                }
                            </span>

                            <strong>@StorefrontFormat.Money(variant.FinalPrice)</strong>

                            @if (variant.DiscountPrice.HasValue)
                            {
                                <del>@StorefrontFormat.Money(variant.Price)</del>
                            }

                            <em>
                                @(variantAvailable ? $"موجودی {StorefrontFormat.Number(variant.AvailableStock)}" : "ناموجود")
                            </em>
                        </label>
                    }
                </div>
            }
            else
            {
                <input type="hidden" name="ProductVariantId" value="" />
            }

            <div class="vt-product-price-box">
                <div>
                    <small>قیمت نهایی</small>
                    <b>@StorefrontFormat.Money(Model.CurrentPrice)</b>

                    @if (p.DiscountPrice.HasValue && p.DiscountPrice.Value < p.BasePrice)
                    {
                        <del>@StorefrontFormat.Money(p.BasePrice)</del>
                    }
                </div>

                <div class="vt-product-stock @(isAvailable ? "available" : "unavailable")">
                    @(isAvailable ? $"موجودی {StorefrontFormat.Number(Model.CurrentStock)}" : "ناموجود")
                </div>
            </div>

            <div class="vt-product-quantity-row">
                <label>تعداد</label>

                <input name="Quantity"
                       type="number"
                       value="@(p.MinOrderQuantity > 0 ? p.MinOrderQuantity : 1)"
                       min="@(p.MinOrderQuantity > 0 ? p.MinOrderQuantity : 1)"
                       max="@(p.MaxOrderQuantity ?? 99)" />
            </div>

            @if (isAvailable)
            {
                <button type="submit" class="vt-add-to-cart-btn">
                    افزودن به سبد خرید
                    <span>🛒</span>
                </button>
            }
            else
            {
                <button type="button" class="vt-add-to-cart-btn disabled" disabled>
                    فعلاً ناموجود است
                </button>
            }
        </form>
    </div>
</section>

<section class="vt-product-tabs">
    <div class="vt-product-tabs-head">
        <span class="active">توضیحات محصول</span>
        <span>نحوه تحویل</span>
        <span>نکات مهم</span>
    </div>

    <div class="vt-product-tabs-body">
        <h2>درباره @p.Title</h2>

        @if (!string.IsNullOrWhiteSpace(p.FullDescription))
        {
            <p>@p.FullDescription</p>
        }
        else
        {
            <p>
                این محصول به صورت دیجیتال ارائه می‌شود و پس از ثبت سفارش و پرداخت موفق،
                اطلاعات مربوط به تحویل از طریق بخش سفارش‌های من در اختیار شما قرار می‌گیرد.
            </p>
        }

        <ul>
            <li>قبل از خرید، ریجن، نوع محصول و توضیحات را بررسی کنید.</li>
            <li>در صورت نیاز به احراز هویت، سفارش پس از تایید اطلاعات پردازش می‌شود.</li>
            <li>برای محصولات نیازمند پشتیبانی، تیم ویتورایز از طریق تیکت با شما هماهنگ می‌کند.</li>
        </ul>
    </div>
</section>