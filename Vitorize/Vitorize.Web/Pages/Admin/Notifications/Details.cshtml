@page "{id:guid}"
@model Vitorize.Web.Pages.Admin.Notifications.DetailsModel
@using Vitorize.Web.Helpers
@{
    ViewData["Title"]="جزئیات اطلاعیه";
    Layout="~/Pages/Shared/_AdminLayout.cshtml";
}
<div class="vz-page" dir="rtl">
<section class="vz-hero">
<div class="vz-hero-main">
<div class="vz-eyebrow">
<i data-lucide="bell">
</i>اطلاعیه</div>

<h1 class="vz-title">@Model.Item.Title</h1>
<p class="vz-desc">@Model.Item.UserFullName - @AdminUiHelper.Date(Model.Item.CreatedAt)</p>
</div>

<a asp-page="Index" class="vz-btn vz-btn-light">
<i data-lucide="arrow-right">
</i>بازگشت</a>
</section>

<section class="vz-form-card">
<div class="vz-kv">
<div class="vz-kv-item">
<span>کاربر</span>
<strong>@Model.Item.UserFullName - @Model.Item.UserMobile</strong>
</div>

<div class="vz-kv-item">
<span>نوع</span>
<strong>@AdminUiHelper.NotificationType(Model.Item.Type)</strong>
</div>

<div class="vz-kv-item">
<span>وضعیت</span>
<strong>@(Model.Item.IsRead?"خوانده‌شده":"خوانده‌نشده")</strong>
</div>

<div class="vz-kv-item">
<span>زمان خواندن</span>
<strong>@AdminUiHelper.Date(Model.Item.ReadAt)</strong>
</div>

</div>

<div class="vz-field" style="margin-top:18px">
<label>متن پیام</label>
<div class="vz-muted-box">@Model.Item.Message</div>

</div>

</section>

</div>

@section Scripts {

<script>
if(window.lucide){lucide.createIcons();}

</script>
}
