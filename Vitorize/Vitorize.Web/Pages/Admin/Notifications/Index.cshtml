@page
@model Vitorize.Web.Pages.Admin.Notifications.IndexModel
@using Vitorize.Web.Helpers
@{
    ViewData["Title"]="اطلاعیه‌ها";
    Layout="~/Pages/Shared/_AdminLayout.cshtml";
}
<div class="vz-page" dir="rtl">
<section class="vz-hero">
<div class="vz-hero-main">
<div class="vz-eyebrow">
<i data-lucide="bell">
</i>اطلاعیه‌ها</div>

<h1 class="vz-title">اطلاعیه‌های کاربران</h1>
<p class="vz-desc">پیام‌ها و اعلان‌های ارسال‌شده برای کاربران را بررسی کن.</p>
</div>

</section>
@if(!string.IsNullOrWhiteSpace(Model.SuccessMessage)){
<div class="vz-alert vz-alert-success">
<i data-lucide="check-circle-2">
</i>
<span>@Model.SuccessMessage</span>
</div>
}
@if(!string.IsNullOrWhiteSpace(Model.ErrorMessage)){
<div class="vz-alert vz-alert-danger">
<i data-lucide="triangle-alert">
</i>
<span>@Model.ErrorMessage</span>
</div>
}
<section class="vz-form-card">
<form method="get" class="vz-filter-grid">
<div class="vz-field">
<label>جستجو</label>
<div class="vz-input-shell">
<i data-lucide="search">
</i>
<input name="Filter.Search" value="@Model.Filter.Search" class="vz-input" placeholder="عنوان، پیام یا نام کاربر" />
</div>

</div>

<div class="vz-field">
<label>وضعیت</label>
<div class="vz-input-shell vz-select-wrap">
<select name="Filter.IsRead" class="vz-select">
<option value="">همه</option>
<option value="false" selected="@(Model.Filter.IsRead==false)">خوانده‌نشده</option>
<option value="true" selected="@(Model.Filter.IsRead==true)">خوانده‌شده</option>
</select>
</div>

</div>

<div>
</div>

<button class="vz-btn vz-btn-primary">
<i data-lucide="filter">
</i>اعمال</button>
</form>

</section>

<section class="vz-table-card">
<div class="vz-table-wrap">
<table class="vz-table">
<thead>
<tr>
<th>عنوان</th>
<th>کاربر</th>
<th>نوع</th>
<th>وضعیت</th>
<th>زمان</th>
<th>
</th>
</tr>

</thead>

<tbody>@foreach(var item in Model.Items){
<tr>
<td>
<strong>@item.Title</strong>
<br/>
<small>@AdminUiHelper.ShortText(item.Message,70)</small>
</td>
<td>@item.UserFullName<br/>
<small>@item.UserMobile</small>
</td>
<td>@AdminUiHelper.NotificationType(item.Type)</td>
<td>
<span class="@(item.IsRead?"vz-badge vz-badge-muted":"vz-badge vz-badge-warning")">@(item.IsRead?"خوانده‌شده":"جدید")</span>
</td>
<td>@AdminUiHelper.Date(item.CreatedAt)</td>
<td>
<div class="vz-actions">
<a asp-page="Details" asp-route-id="@item.Id" class="vz-icon-btn info">
<i data-lucide="eye">
</i>
</a>@if(!item.IsRead){
<form method="post" asp-page-handler="Read" asp-route-id="@item.Id">
<button class="vz-icon-btn success">
<i data-lucide="check">
</i>
</button>
</form>
}
</div>

</td>
</tr>
}
</tbody>

</table>

</div>
@if(!Model.Items.Any()){
<div class="vz-empty">
<div class="vz-empty-icon">
<i data-lucide="bell">
</i>
</div>

<h3>اطلاعیه‌ای برای نمایش وجود ندارد</h3>
</div>
}
</section>

</div>

@section Scripts {

<script>
if(window.lucide){lucide.createIcons();}

</script>
}
