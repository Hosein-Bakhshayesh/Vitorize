@page "{id:guid}"
@model Vitorize.Web.Pages.Admin.Categories.DetailsModel
@{
    ViewData["Title"] = "جزئیات دسته‌بندی"; Layout = "~/Pages/Shared/_AdminLayout.cshtml";
}
<div class="vz-page" dir="rtl">
    <section class="vz-hero">
        <div class="vz-hero-main">
            <div class="vz-detail-hero">
                <div class="vz-detail-image">@if (!string.IsNullOrWhiteSpace(Model.Image(Model.Item.ImagePath))) { <img src="@Model.Image(Model.Item.ImagePath)" alt="@Model.Item.Title" /> } else { <i data-lucide="grid-2x2">
</i> }
</div>

                <div>
<div class="vz-eyebrow">
<i data-lucide="grid-2x2">
</i>دسته‌بندی</div>

<h1 class="vz-title">@Model.Item.Title</h1>
<p class="vz-desc">@Model.Item.Slug</p>
</div>

            </div>

        </div>

        <div class="vz-actions">
<a asp-page="Edit" asp-route-id="@Model.Item.Id" class="vz-btn vz-btn-primary">
<i data-lucide="pencil">
</i>ویرایش</a>
<a asp-page="Index" class="vz-btn vz-btn-light">
<i data-lucide="arrow-right">
</i>بازگشت</a>
</div>

    </section>

    <section class="vz-form-card">
<div class="vz-card-head">
<div>
<h2>اطلاعات</h2>
<p>جزئیات ثبت‌شده برای این مورد.</p>
</div>

</div>

<div class="vz-kv">
<div class="vz-kv-item">
<span>عنوان</span>
<strong>@Model.Item.Title</strong>
</div>

<div class="vz-kv-item">
<span>اسلاگ</span>
<strong>@Model.Item.Slug</strong>
</div>

<div class="vz-kv-item">
<span>وضعیت</span>
<strong>@(Model.Item.IsActive ? "فعال" : "غیرفعال")</strong>
</div>

<div class="vz-kv-item">
<span>تاریخ ایجاد</span>
<strong>@Vitorize.Web.Helpers.AdminUiHelper.Date(Model.Item.CreatedAt)</strong>
</div>

<div class="vz-kv-item">
<span>ترتیب نمایش</span>
<strong>@Model.Item.SortOrder</strong>
</div>

<div class="vz-kv-item">
<span>آیکن</span>
<strong>@(Model.Item.Icon ?? "-")</strong>
</div>

</div>

</section>

</div>

@section Scripts {
<script>
if(window.lucide){lucide.createIcons();}

</script>
 }
