@page "{id:guid}"
@model Vitorize.Web.Pages.Admin.Payments.DetailsModel
@using Vitorize.Web.Helpers
@{
    ViewData["Title"]="جزئیات پرداخت";
    Layout="~/Pages/Shared/_AdminLayout.cshtml";
}
<div class="vz-page" dir="rtl">
<section class="vz-hero">
<div class="vz-hero-main">
<div class="vz-eyebrow">
<i data-lucide="receipt">
</i>پرداخت</div>

<h1 class="vz-title">جزئیات پرداخت</h1>
<p class="vz-desc">@Model.Item.OrderNumber - @Model.Item.UserFullName</p>
</div>

<a asp-page="Index" class="vz-btn vz-btn-light">
<i data-lucide="arrow-right">
</i>بازگشت</a>
</section>

<section class="vz-form-card">
<div class="vz-kv">
<div class="vz-kv-item">
<span>مبلغ</span>
<strong>@AdminUiHelper.Money(Model.Item.Amount)</strong>
</div>

<div class="vz-kv-item">
<span>وضعیت</span>
<strong>@AdminUiHelper.PaymentStatus(Model.Item.Status)</strong>
</div>

<div class="vz-kv-item">
<span>شماره سفارش</span>
<strong>@Model.Item.OrderNumber</strong>
</div>

<div class="vz-kv-item">
<span>مشتری</span>
<strong>@Model.Item.UserFullName - @Model.Item.UserMobile</strong>
</div>

<div class="vz-kv-item">
<span>درگاه</span>
<strong>@Model.Item.Gateway</strong>
</div>

<div class="vz-kv-item">
<span>تأیید بازگشت</span>
<strong>@(Model.Item.CallbackVerified?"بله":"خیر")</strong>
</div>

<div class="vz-kv-item">
<span>کد پیگیری</span>
<strong>@(Model.Item.GatewayTrackingCode ?? "-")</strong>
</div>

<div class="vz-kv-item">
<span>شماره مرجع</span>
<strong>@(Model.Item.ReferenceNumber ?? "-")</strong>
</div>

<div class="vz-kv-item">
<span>زمان درخواست</span>
<strong>@AdminUiHelper.Date(Model.Item.RequestedAt)</strong>
</div>

<div class="vz-kv-item">
<span>زمان تأیید</span>
<strong>@AdminUiHelper.Date(Model.Item.VerifiedAt)</strong>
</div>

</div>
@if(!string.IsNullOrWhiteSpace(Model.Item.ErrorMessage)){
<div class="vz-field" style="margin-top:18px">
<label>پیام خطا</label>
<div class="vz-muted-box">@Model.Item.ErrorMessage</div>

</div>
}
</section>

</div>

@section Scripts {

<script>
if(window.lucide){lucide.createIcons();}

</script>
}
