@page
@model Vitorize.Web.Pages.Admin.Payments.IndexModel
@using Vitorize.Web.Helpers
@using Vitorize.Shared.Enums
@{
    ViewData["Title"]="پرداخت‌ها";
    Layout="~/Pages/Shared/_AdminLayout.cshtml";
}
<div class="vz-page" dir="rtl">
<section class="vz-hero">
<div class="vz-hero-main">
<div class="vz-eyebrow">
<i data-lucide="repeat-2">
</i>پرداخت‌ها</div>

<h1 class="vz-title">پرداخت‌ها</h1>
<p class="vz-desc">وضعیت پرداخت‌ها و تراکنش‌های سفارش‌ها را بررسی کن.</p>
</div>

</section>
@if(!string.IsNullOrWhiteSpace(Model.ErrorMessage)){
<div class="vz-alert vz-alert-danger">
<i data-lucide="triangle-alert">
</i>
<span>@Model.ErrorMessage</span>
</div>
}
<section class="vz-form-card">
<form method="get" class="vz-filter-grid">
<div class="vz-field">
<label>جستجو</label>
<div class="vz-input-shell">
<i data-lucide="search">
</i>
<input name="Filter.Search" value="@Model.Filter.Search" class="vz-input" placeholder="شماره سفارش، مشتری یا کد پیگیری" />
</div>

</div>

<div class="vz-field">
<label>وضعیت</label>
<div class="vz-input-shell vz-select-wrap">
<select name="Filter.Status" class="vz-select">
<option value="">همه</option>
<option value="@((byte)PaymentStatus.Pending)" selected="@(Model.Filter.Status==(byte)PaymentStatus.Pending)">در انتظار</option>
<option value="@((byte)PaymentStatus.Paid)" selected="@(Model.Filter.Status==(byte)PaymentStatus.Paid)">پرداخت شده</option>
<option value="@((byte)PaymentStatus.Failed)" selected="@(Model.Filter.Status==(byte)PaymentStatus.Failed)">ناموفق</option>
<option value="@((byte)PaymentStatus.Refunded)" selected="@(Model.Filter.Status==(byte)PaymentStatus.Refunded)">بازگشت وجه</option>
</select>
</div>

</div>

<div class="vz-field">
<label>از تاریخ</label>
<div class="vz-input-shell">
<input type="date" name="Filter.DateFrom" value='@(Model.Filter.DateFrom?.ToString("yyyy-MM-dd"))' class="vz-input ltr" />
</div>

</div>

<button class="vz-btn vz-btn-primary">
<i data-lucide="filter">
</i>اعمال</button>
</form>

</section>

<section class="vz-table-card">
<div class="vz-table-wrap">
<table class="vz-table">
<thead>
<tr>
<th>سفارش</th>
<th>مشتری</th>
<th>مبلغ</th>
<th>درگاه</th>
<th>وضعیت</th>
<th>زمان</th>
<th>
</th>
</tr>

</thead>

<tbody>@foreach(var item in Model.Items){var intent=AdminUiHelper.StatusBadgeIntent(item.Status,"payment");<tr>
<td>
<a asp-page="/Admin/Orders/Details" asp-route-id="@item.OrderId" class="vz-code">@item.OrderNumber</a>
</td>
<td>@item.UserFullName<br/>
<small>@item.UserMobile</small>
</td>
<td>@AdminUiHelper.Money(item.Amount)</td>
<td>@item.Gateway</td>
<td>
<span class="@AdminUiHelper.BadgeClass(intent)">@AdminUiHelper.PaymentStatus(item.Status)</span>
</td>
<td>@AdminUiHelper.Date(item.RequestedAt)</td>
<td>
<a asp-page="Details" asp-route-id="@item.Id" class="vz-icon-btn info">
<i data-lucide="eye">
</i>
</a>
</td>
</tr>
}
</tbody>

</table>

</div>
@if(!Model.Items.Any()){
<div class="vz-empty">
<div class="vz-empty-icon">
<i data-lucide="repeat-2">
</i>
</div>

<h3>پرداختی برای نمایش وجود ندارد</h3>
</div>
}
</section>

</div>

@section Scripts {

<script>
if(window.lucide){lucide.createIcons();}

</script>
}
