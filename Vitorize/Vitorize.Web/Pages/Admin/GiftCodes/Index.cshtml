@page
@model Vitorize.Web.Pages.Admin.GiftCodes.IndexModel
@{
    ViewData["Title"] = "گیفت‌کارت‌ها"; Layout = "~/Pages/Shared/_AdminLayout.cshtml";
}
<div class="vz-page" dir="rtl">
<section class="vz-hero">
<div class="vz-hero-main">
<div class="vz-eyebrow">
<i data-lucide="credit-card">
</i>گیفت‌کارت‌ها</div>

<h1 class="vz-title">مدیریت موجودی کدها</h1>
<p class="vz-desc">بچ‌های واردشده و موجودی آماده فروش را بررسی کن.</p>
</div>

<div class="vz-actions">
<a asp-page="Import" class="vz-btn vz-btn-primary">
<i data-lucide="upload-cloud">
</i>ورود کدها</a>
</div>

</section>
@if(!string.IsNullOrWhiteSpace(Model.SuccessMessage)){
<div class="vz-alert vz-alert-success">
<i data-lucide="check-circle-2">
</i>
<span>@Model.SuccessMessage</span>
</div>
}
@if(!string.IsNullOrWhiteSpace(Model.ErrorMessage)){
<div class="vz-alert vz-alert-danger">
<i data-lucide="triangle-alert">
</i>
<span>@Model.ErrorMessage</span>
</div>
}
<section class="vz-stats">
<article class="vz-stats-card">
<div class="vz-stat-icon purple">
<i data-lucide="archive">
</i>
</div>

<div class="vz-stat-content">
<span class="vz-stat-label">بچ‌ها</span>
<strong class="vz-stat-value">@Model.Batches.Count</strong>
</div>

</article>
<article class="vz-stats-card">
<div class="vz-stat-icon blue">
<i data-lucide="credit-card">
</i>
</div>

<div class="vz-stat-content">
<span class="vz-stat-label">کل کدها</span>
<strong class="vz-stat-value">@Model.TotalCodes</strong>
</div>

</article>
<article class="vz-stats-card">
<div class="vz-stat-icon green">
<i data-lucide="check-circle-2">
</i>
</div>

<div class="vz-stat-content">
<span class="vz-stat-label">آماده فروش</span>
<strong class="vz-stat-value">@Model.AvailableCodes</strong>
</div>

</article>
<article class="vz-stats-card">
<div class="vz-stat-icon orange">
<i data-lucide="shopping-bag">
</i>
</div>

<div class="vz-stat-content">
<span class="vz-stat-label">فروخته شده</span>
<strong class="vz-stat-value">@Model.SoldCodes</strong>
</div>

</article>
</section>

<section class="vz-table-card">
<form method="get" class="vz-filter-grid" style="margin-bottom:18px">
<div class="vz-field">
<label>جستجو</label>
<div class="vz-input-shell">
<i data-lucide="search">
</i>
<input asp-for="Search" class="vz-input" placeholder="عنوان بچ یا تامین‌کننده" />
</div>

</div>

<div class="vz-actions">
<button class="vz-btn vz-btn-light">
<i data-lucide="filter">
</i>فیلتر</button>
</div>

</form>
@if(!Model.Batches.Any()){
<div class="vz-empty">
<div class="vz-empty-icon">
<i data-lucide="credit-card">
</i>
</div>

<h3>بچی ثبت نشده است</h3>
<p>برای شروع، کدهای محصول را وارد کن.</p>
</div>
}else{
<div class="vz-table-wrap">
<table class="vz-table">
<thead>
<tr>
<th>بچ</th>
<th>محصول</th>
<th>تامین‌کننده</th>
<th>کل</th>
<th>آماده</th>
<th>فروخته</th>
<th>تاریخ</th>
<th>عملیات</th>
</tr>

</thead>

<tbody>@foreach(var b in Model.Batches){
<tr>
<td>
<strong>@b.BatchTitle</strong>
</td>
<td>@(b.ProductTitle ?? "-")</td>
<td>@(b.SourceName ?? "-")</td>
<td>@b.TotalCodes</td>
<td>@b.AvailableCodes</td>
<td>@b.SoldCodes</td>
<td>@Vitorize.Web.Helpers.AdminUiHelper.Date(b.ImportedAt)</td>
<td>
<div class="vz-actions">
<a asp-page="Details" asp-route-id="@b.Id" class="vz-icon-btn info">
<i data-lucide="eye">
</i>
</a>
<form method="post" asp-page-handler="Delete" asp-route-id="@b.Id" onsubmit="return confirm('بچ حذف شود؟');">
<button class="vz-icon-btn danger">
<i data-lucide="trash-2">
</i>
</button>
</form>

</div>

</td>
</tr>
}
</tbody>

</table>

</div>
}
</section>

</div>

@section Scripts {
<script>
if(window.lucide){lucide.createIcons();}

</script>
 }
