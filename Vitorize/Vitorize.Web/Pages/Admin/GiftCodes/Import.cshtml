@page
@model Vitorize.Web.Pages.Admin.GiftCodes.ImportModel
@{
    ViewData["Title"] = "ورود کدها"; Layout = "~/Pages/Shared/_AdminLayout.cshtml";
}
<div class="vz-page" dir="rtl">
<section class="vz-hero">
<div class="vz-hero-main">
<div class="vz-eyebrow">
<i data-lucide="upload-cloud">
</i>ورود کدها</div>

<h1 class="vz-title">ورود دسته‌ای گیفت‌کارت</h1>
<p class="vz-desc">کدها را خط به خط وارد کن و برای محصول موردنظر ثبت کن.</p>
</div>

<div class="vz-actions">
<a asp-page="Index" class="vz-btn vz-btn-light">
<i data-lucide="arrow-right">
</i>بازگشت</a>
</div>

</section>
@if(!string.IsNullOrWhiteSpace(Model.ErrorMessage)){
<div class="vz-alert vz-alert-danger">
<i data-lucide="triangle-alert">
</i>
<span>@Model.ErrorMessage</span>
</div>
}
<form method="post" class="vz-form-layout">
<div class="vz-main-col">
<section class="vz-form-card">
<div class="vz-card-head">
<div>
<h2>اطلاعات بچ</h2>
<p>محصول و عنوان بچ را مشخص کن.</p>
</div>

</div>

<div class="vz-form-grid two">
<div class="vz-field">
<label asp-for="ImportRequest.ProductId">محصول</label>
<div class="vz-input-shell">
<i data-lucide="package">
</i>
<select asp-for="ImportRequest.ProductId" class="vz-select">
<option value="">انتخاب محصول</option>@foreach(var p in Model.Products){
<option value="@p.Id">@p.Title</option>}
</select>
</div>

</div>

<div class="vz-field">
<label asp-for="ImportRequest.ProductVariantId">واریانت</label>
<div class="vz-input-shell">
<i data-lucide="layers-3">
</i>
<select asp-for="ImportRequest.ProductVariantId" class="vz-select">
<option value="">بدون واریانت</option>@foreach(var v in Model.Variants){
<option value="@v.Id">@v.Title</option>}
</select>
</div>

</div>

</div>

<div class="vz-form-grid two" style="margin-top:16px">
<div class="vz-field">
<label asp-for="ImportRequest.BatchTitle">عنوان بچ</label>
<div class="vz-input-shell">
<i data-lucide="archive">
</i>
<input asp-for="ImportRequest.BatchTitle" class="vz-input" />
</div>

</div>

<div class="vz-field">
<label asp-for="ImportRequest.SourceName">تامین‌کننده</label>
<div class="vz-input-shell">
<i data-lucide="truck">
</i>
<input asp-for="ImportRequest.SourceName" class="vz-input" />
</div>

</div>

</div>

<div class="vz-field" style="margin-top:16px">
<label asp-for="CodesText">کدها</label>
<textarea asp-for="CodesText" class="vz-textarea ltr" style="min-height:320px" placeholder="CODE-111&#10;CODE-222">
</textarea>
<span asp-validation-for="CodesText" class="vz-validation">
</span>
</div>

</section>

</div>

<div class="vz-side-col">
<section class="vz-side-card vz-side-sticky">
<div class="vz-field">
<label asp-for="ImportRequest.PurchasePrice">قیمت خرید</label>
<div class="vz-input-shell">
<i data-lucide="circle-dollar-sign">
</i>
<input asp-for="ImportRequest.PurchasePrice" type="number" class="vz-input ltr" />
</div>

</div>

<div class="vz-field" style="margin-top:14px">
<label asp-for="ImportRequest.Notes">یادداشت</label>
<textarea asp-for="ImportRequest.Notes" class="vz-textarea" style="min-height:120px">
</textarea>
</div>

<div style="height:14px">
</div>

<button class="vz-btn vz-btn-primary vz-btn-full">
<i data-lucide="save">
</i>ثبت کدها</button>
</section>

</div>

</form>

</div>

@section Scripts { <partial name="_ValidationScriptsPartial" />

<script>
if(window.lucide){lucide.createIcons();}

</script>
 }
