@page
@model Vitorize.Web.Pages.Admin.Roles.IndexModel
@using Vitorize.Web.Helpers
@{
    ViewData["Title"]="نقش‌ها";
    Layout="~/Pages/Shared/_AdminLayout.cshtml";
}
<div class="vz-page" dir="rtl">
<section class="vz-hero">
<div class="vz-hero-main">
<div class="vz-eyebrow">
<i data-lucide="shield">
</i>نقش‌ها</div>

<h1 class="vz-title">نقش‌های سیستم</h1>
<p class="vz-desc">نقش‌ها به‌صورت اولیه توسط سیستم آماده می‌شوند و در این بخش قابل مشاهده هستند.</p>
</div>

</section>
@if(!string.IsNullOrWhiteSpace(Model.ErrorMessage)){
<div class="vz-alert vz-alert-danger">
<i data-lucide="triangle-alert">
</i>
<span>@Model.ErrorMessage</span>
</div>
}
<section class="vz-table-card">
<div class="vz-table-wrap">
<table class="vz-table">
<thead>
<tr>
<th>نقش</th>
<th>نام سیستمی</th>
<th>تعداد کاربران</th>
<th>ایجاد شده</th>
<th>
</th>
</tr>

</thead>

<tbody>@foreach(var role in Model.Roles){
<tr>
<td>
<div class="vz-item">
<div class="vz-thumb-fallback sm">
<i data-lucide="shield">
</i>
</div>

<div class="vz-item-text">
<strong>@role.DisplayName</strong>
<span>@role.Name</span>
</div>

</div>

</td>
<td class="ltr">@role.Name</td>
<td>@role.UsersCount</td>
<td>@AdminUiHelper.Date(role.CreatedAt)</td>
<td>
<a asp-page="Details" asp-route-id="@role.Id" class="vz-icon-btn info">
<i data-lucide="eye">
</i>
</a>
</td>
</tr>
}
</tbody>

</table>

</div>

</section>

</div>

@section Scripts {

<script>
if(window.lucide){lucide.createIcons();}

</script>
}
