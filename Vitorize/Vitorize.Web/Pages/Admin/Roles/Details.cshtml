@page "{id:guid}"
@model Vitorize.Web.Pages.Admin.Roles.DetailsModel
@using Vitorize.Web.Helpers
@{
    ViewData["Title"]="جزئیات نقش";
    Layout="~/Pages/Shared/_AdminLayout.cshtml";
}
<div class="vz-page" dir="rtl">
<section class="vz-hero">
<div class="vz-hero-main">
<div class="vz-eyebrow">
<i data-lucide="shield">
</i>نقش</div>

<h1 class="vz-title">@Model.Role.DisplayName</h1>
<p class="vz-desc">این نقش توسط سیستم مدیریت می‌شود.</p>
</div>

<a asp-page="Index" class="vz-btn vz-btn-light">
<i data-lucide="arrow-right">
</i>بازگشت</a>
</section>

<section class="vz-form-card">
<div class="vz-kv">
<div class="vz-kv-item">
<span>عنوان</span>
<strong>@Model.Role.DisplayName</strong>
</div>

<div class="vz-kv-item">
<span>نام</span>
<strong class="ltr">@Model.Role.Name</strong>
</div>

<div class="vz-kv-item">
<span>تعداد کاربران</span>
<strong>@Model.Role.UsersCount</strong>
</div>

<div class="vz-kv-item">
<span>ایجاد شده</span>
<strong>@AdminUiHelper.Date(Model.Role.CreatedAt)</strong>
</div>

</div>

</section>

</div>

@section Scripts {

<script>
if(window.lucide){lucide.createIcons();}

</script>
}
