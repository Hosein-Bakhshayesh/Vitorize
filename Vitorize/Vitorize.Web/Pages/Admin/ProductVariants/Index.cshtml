@page
@model Vitorize.Web.Pages.Admin.ProductVariants.IndexModel
@using Vitorize.Web.Helpers
@{
    ViewData["Title"] = "واریانت‌های محصول";
    Layout = "~/Pages/Shared/_AdminLayout.cshtml";
}
<div class="vz-page" dir="rtl">
<section class="vz-hero">
<div class="vz-hero-main">
<div class="vz-eyebrow">
<i data-lucide="layers-3">
</i>واریانت‌ها</div>

<h1 class="vz-title">مدیریت واریانت‌های محصول</h1>
<p class="vz-desc">قیمت، مقدار و حالت موجودی هر واریانت را مدیریت کن.</p>
</div>

<div class="vz-actions">@if (Model.Product != null) { <a asp-page="Create" asp-route-productId="@Model.Product.Id" class="vz-btn vz-btn-primary">
<i data-lucide="plus">
</i>واریانت جدید</a>
<a asp-page="/Admin/Products/Details" asp-route-id="@Model.Product.Id" class="vz-btn vz-btn-light">
<i data-lucide="package">
</i>محصول</a> }
</div>

</section>

@if (!string.IsNullOrWhiteSpace(Model.SuccessMessage)) { <div class="vz-alert vz-alert-success">
<i data-lucide="check-circle-2">
</i>
<span>@Model.SuccessMessage</span>
</div>
 }
@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage)) { <div class="vz-alert vz-alert-danger">
<i data-lucide="triangle-alert">
</i>
<span>@Model.ErrorMessage</span>
</div>
 }
<section class="vz-form-card">
<form method="get" class="vz-form-grid two">
<div class="vz-field">
<label>محصول</label>
<div class="vz-input-shell">
<i data-lucide="package">
</i>
<select asp-for="ProductId" class="vz-select" onchange="this.form.submit()">
<option value="">انتخاب محصول</option>@foreach (var p in Model.Products) { <option value="@p.Id">@p.Title</option> }
</select>
</div>

</div>

</form>

</section>

@if (Model.Product != null) { <section class="vz-table-card">
<div class="vz-card-head">
<div>
<h2>@Model.Product.Title</h2>
<p>@Model.Variants.Count واریانت ثبت شده است.</p>
</div>

</div>
@if (!Model.Variants.Any()) { <div class="vz-empty">
<div class="vz-empty-icon">
<i data-lucide="layers-3">
</i>
</div>

<h3>واریانتی ثبت نشده است</h3>
<p>برای این محصول یک واریانت جدید تعریف کن.</p>
</div>
 } else { <div class="vz-table-wrap">
<table class="vz-table">
<thead>
<tr>
<th>واریانت</th>
<th>قیمت</th>
<th>موجودی</th>
<th>وضعیت</th>
<th>عملیات</th>
</tr>

</thead>

<tbody>@foreach (var item in Model.Variants) { <tr>
<td>
<div class="vz-item">
<div class="vz-thumb-fallback sm">
<i data-lucide="layers-3">
</i>
</div>

<div class="vz-item-text">
<strong>@item.Title</strong>
<span>@(item.Value ?? "-")</span>
<small>@(item.Sku ?? "بدون SKU")</small>
</div>

</div>

</td>
<td>
<strong>@AdminUiHelper.Money(item.FinalPrice, item.CurrencyType)</strong>@if(item.DiscountPrice.HasValue && item.DiscountPrice.Value > 0){
<small style="display:block;color:#94a3b8;text-decoration:line-through">@AdminUiHelper.Money(item.Price,item.CurrencyType)</small>}
</td>
<td>
<span class="vz-badge vz-badge-info">@AdminUiHelper.StockMode(item.StockMode)</span>
</td>
<td>@if(item.IsDefault){
<span class="vz-badge vz-badge-warning">پیش‌فرض</span>} @if(item.IsActive){
<span class="vz-badge vz-badge-success">فعال</span>}else{
<span class="vz-badge vz-badge-muted">غیرفعال</span>}
</td>
<td>
<div class="vz-actions">
<a asp-page="Details" asp-route-productId="@Model.Product.Id" asp-route-id="@item.Id" class="vz-icon-btn info">
<i data-lucide="eye">
</i>
</a>
<a asp-page="Edit" asp-route-productId="@Model.Product.Id" asp-route-id="@item.Id" class="vz-icon-btn">
<i data-lucide="pencil">
</i>
</a>
<form method="post" asp-page-handler="Delete" asp-route-productId="@Model.Product.Id" asp-route-id="@item.Id" onsubmit="return confirm('واریانت حذف شود؟');">
<button class="vz-icon-btn danger" type="submit">
<i data-lucide="trash-2">
</i>
</button>
</form>

</div>

</td>
</tr>
 }
</tbody>

</table>

</div>
 }
</section>
 }
</div>

@section Scripts {
<script>
if(window.lucide){lucide.createIcons();}

</script>
 }
