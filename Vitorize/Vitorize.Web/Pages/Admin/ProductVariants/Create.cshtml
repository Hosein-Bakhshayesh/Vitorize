@page "{productId:guid}"
@model Vitorize.Web.Pages.Admin.ProductVariants.CreateModel
@using Vitorize.Web.Helpers
@{
    ViewData["Title"] = "افزودن واریانت"; Layout = "~/Pages/Shared/_AdminLayout.cshtml";
}
<div class="vz-page" dir="rtl">
<section class="vz-hero">
<div class="vz-hero-main">
<div class="vz-eyebrow">
<i data-lucide="layers-3">
</i>واریانت</div>

<h1 class="vz-title">افزودن واریانت</h1>
<p class="vz-desc">برای @Model.Product.Title واریانت فروش تعریف کن.</p>
</div>

<div class="vz-actions">
<a asp-page="Index" asp-route-productId="@Model.Product.Id" class="vz-btn vz-btn-light">
<i data-lucide="arrow-right">
</i>بازگشت</a>
</div>

</section>
@if(!string.IsNullOrWhiteSpace(Model.ErrorMessage)){
<div class="vz-alert vz-alert-danger">
<i data-lucide="triangle-alert">
</i>
<span>@Model.ErrorMessage</span>
</div>
}
<form method="post" class="vz-form-layout">
<div class="vz-main-col">
<section class="vz-form-card">
<div class="vz-card-head">
<div>
<h2>اطلاعات واریانت</h2>
<p>عنوان، قیمت و موجودی این گزینه خرید را تنظیم کن.</p>
</div>

</div>

<div class="vz-form-grid two">
<div class="vz-field">
<label asp-for="Input.Title">عنوان</label>
<div class="vz-input-shell">
<i data-lucide="type">
</i>
<input asp-for="Input.Title" class="vz-input" />
</div>

<span asp-validation-for="Input.Title" class="vz-validation">
</span>
</div>

<div class="vz-field">
<label asp-for="Input.Sku">SKU</label>
<div class="vz-input-shell">
<i data-lucide="barcode">
</i>
<input asp-for="Input.Sku" class="vz-input ltr" />
</div>

</div>

</div>

<div class="vz-form-grid three" style="margin-top:16px">
<div class="vz-field">
<label asp-for="Input.Price">قیمت اصلی</label>
<div class="vz-input-shell">
<i data-lucide="circle-dollar-sign">
</i>
<input asp-for="Input.Price" type="number" class="vz-input ltr" />
</div>

</div>

<div class="vz-field">
<label asp-for="Input.DiscountPrice">قیمت تخفیفی</label>
<div class="vz-input-shell">
<i data-lucide="badge-percent">
</i>
<input asp-for="Input.DiscountPrice" type="number" class="vz-input ltr" />
</div>

<span asp-validation-for="Input.DiscountPrice" class="vz-validation">
</span>
</div>

<div class="vz-field">
<label asp-for="Input.SortOrder">ترتیب</label>
<div class="vz-input-shell">
<i data-lucide="arrow-down-up">
</i>
<input asp-for="Input.SortOrder" type="number" class="vz-input ltr" />
</div>

</div>

</div>

<div class="vz-form-grid two" style="margin-top:16px">
<div class="vz-field">
<label asp-for="Input.Value">مقدار</label>
<div class="vz-input-shell">
<i data-lucide="tag">
</i>
<input asp-for="Input.Value" class="vz-input" />
</div>

</div>

<div class="vz-field">
<label asp-for="Input.StockMode">حالت موجودی</label>
<div class="vz-input-shell">
<i data-lucide="boxes">
</i>
<select asp-for="Input.StockMode" class="vz-select">
<option value="1">وابسته به کد</option>
<option value="2">موجودی دستی</option>
<option value="3">بدون محدودیت</option>
</select>
</div>

</div>

</div>

</section>

</div>

<div class="vz-side-col">
<section class="vz-side-card vz-side-sticky">
<div class="vz-switch-card">
<div>
<strong>فعال باشد</strong>
<span>امکان انتخاب توسط مشتری داشته باشد.</span>
</div>

<label class="vz-switch">
<input asp-for="Input.IsActive" />
<span class="vz-switch-ui">
</span>
</label>
</div>

<div style="height:14px">
</div>

<div class="vz-switch-card">
<div>
<strong>پیش‌فرض</strong>
<span>اولین گزینه پیشنهادی باشد.</span>
</div>

<label class="vz-switch">
<input asp-for="Input.IsDefault" />
<span class="vz-switch-ui">
</span>
</label>
</div>

<div style="height:14px">
</div>

<button class="vz-btn vz-btn-primary vz-btn-full" type="submit">
<i data-lucide="save">
</i>ذخیره</button>
</section>

</div>

</form>

</div>

@section Scripts { <partial name="_ValidationScriptsPartial" />

<script>
if(window.lucide){lucide.createIcons();}

</script>
 }
