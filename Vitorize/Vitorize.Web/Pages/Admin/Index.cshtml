@page
@model Vitorize.Web.Pages.Admin.IndexModel

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "داشبورد";
}

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="admin-error-box">
        @Model.ErrorMessage
    </div>
}
else
{
    <div class="admin-dashboard">

        <section class="dashboard-stats">
            <div class="admin-glass-card dashboard-stat-card">
                <div class="dashboard-stat-icon blue">
                    <i data-lucide="shopping-bag"></i>
                </div>

                <div class="dashboard-stat-content">
                    <div class="dashboard-stat-label">کل سفارش‌ها</div>
                    <div class="dashboard-stat-value">@Model.Dashboard.TotalOrders.ToString("N0")</div>
                    <div class="dashboard-stat-change up">+12.5% نسبت به ۷ روز قبل</div>
                </div>
            </div>

            <div class="admin-glass-card dashboard-stat-card">
                <div class="dashboard-stat-icon purple">
                    <i data-lucide="shopping-cart"></i>
                </div>

                <div class="dashboard-stat-content">
                    <div class="dashboard-stat-label">سفارش‌های در انتظار</div>
                    <div class="dashboard-stat-value">@Model.Dashboard.PendingOrders.ToString("N0")</div>
                    <div class="dashboard-stat-change up">+18.7% نسبت به دیروز</div>
                </div>
            </div>

            <div class="admin-glass-card dashboard-stat-card">
                <div class="dashboard-stat-icon green">
                    <i data-lucide="circle-dollar-sign"></i>
                </div>

                <div class="dashboard-stat-content">
                    <div class="dashboard-stat-label">کل فروش</div>
                    <div class="dashboard-stat-value">@Model.Dashboard.TotalRevenue.ToString("N0")</div>
                    <div class="dashboard-stat-change up">+9.8% نسبت به ۷ روز قبل</div>
                </div>
            </div>

            <div class="admin-glass-card dashboard-stat-card">
                <div class="dashboard-stat-icon orange">
                    <i data-lucide="wallet-cards"></i>
                </div>

                <div class="dashboard-stat-content">
                    <div class="dashboard-stat-label">کدهای آماده تحویل</div>
                    <div class="dashboard-stat-value">@Model.Dashboard.AvailableGiftCodes.ToString("N0")</div>
                    <div class="dashboard-stat-change down">-2.1% نسبت به ۷ روز قبل</div>
                </div>
            </div>
        </section>

        <section class="dashboard-charts">
            <div class="admin-glass-card dashboard-chart-card">
                <div class="dashboard-card-header">
                    <button type="button" class="dashboard-filter">
                        <i data-lucide="refresh-cw"></i>
                        <span>۷ روز اخیر</span>
                    </button>

                    <h2 class="dashboard-card-title">نمودار فروش ۷ روز اخیر</h2>
                </div>

                <svg viewBox="0 0 610 230" class="dashboard-chart-svg" preserveAspectRatio="none">
                    <defs>
                        <linearGradient id="salesFill" x1="0" y1="0" x2="0" y2="1">
                            <stop offset="0%" stop-color="#755df6" stop-opacity=".24" />
                            <stop offset="100%" stop-color="#755df6" stop-opacity=".02" />
                        </linearGradient>
                    </defs>

                    <line class="chart-grid-line" x1="42" y1="22" x2="590" y2="22" />
                    <line class="chart-grid-line" x1="42" y1="72" x2="590" y2="72" />
                    <line class="chart-grid-line" x1="42" y1="122" x2="590" y2="122" />
                    <line class="chart-grid-line" x1="42" y1="172" x2="590" y2="172" />

                    <text class="chart-axis-label" x="5" y="27">40M</text>
                    <text class="chart-axis-label" x="5" y="77">30M</text>
                    <text class="chart-axis-label" x="5" y="127">20M</text>
                    <text class="chart-axis-label" x="5" y="177">10M</text>
                    <text class="chart-axis-label" x="20" y="218">0</text>

                    <path d="M58 154 C88 154, 96 142, 124 143 C160 144, 166 157, 206 153 C250 149, 265 122, 302 125 C340 128, 340 161, 375 151 C405 142, 408 112, 438 104 C476 93, 493 111, 526 99 C558 87, 566 119, 590 111 L590 204 L58 204 Z"
                          fill="url(#salesFill)" />

                    <path d="M58 154 C88 154, 96 142, 124 143 C160 144, 166 157, 206 153 C250 149, 265 122, 302 125 C340 128, 340 161, 375 151 C405 142, 408 112, 438 104 C476 93, 493 111, 526 99 C558 87, 566 119, 590 111"
                          fill="none"
                          stroke="#755df6"
                          stroke-width="3"
                          stroke-linecap="round" />

                    <circle cx="375" cy="151" r="7" fill="#755df6" stroke="#fff" stroke-width="3" />
                    <circle cx="526" cy="99" r="4" fill="#755df6" stroke="#fff" stroke-width="2" />

                    <g>
                        <rect x="325" y="42" width="96" height="58" rx="10" fill="white" stroke="#dbe3ef" />
                        <text x="373" y="66" text-anchor="middle" font-size="12" font-weight="800" fill="#64748b">۲۱ خرداد</text>
                        <text x="373" y="86" text-anchor="middle" font-size="12" font-weight="950" fill="#0f172a">28,450,000 تومان</text>
                    </g>

                    <text class="chart-axis-label" x="58" y="224">خرداد ۱۷</text>
                    <text class="chart-axis-label" x="146" y="224">خرداد ۱۸</text>
                    <text class="chart-axis-label" x="235" y="224">خرداد ۱۹</text>
                    <text class="chart-axis-label" x="326" y="224">خرداد ۲۰</text>
                    <text class="chart-axis-label" x="416" y="224">خرداد ۲۱</text>
                    <text class="chart-axis-label" x="506" y="224">خرداد ۲۲</text>
                </svg>
            </div>

            <div class="admin-glass-card dashboard-chart-card">
                <div class="dashboard-card-header">
                    <button type="button" class="dashboard-filter">
                        <i data-lucide="refresh-cw"></i>
                        <span>۷ روز اخیر</span>
                    </button>

                    <h2 class="dashboard-card-title">نمودار سفارش‌ها ۷ روز اخیر</h2>
                </div>

                <svg viewBox="0 0 610 230" class="dashboard-chart-svg" preserveAspectRatio="none">
                    <defs>
                        <linearGradient id="ordersFill" x1="0" y1="0" x2="0" y2="1">
                            <stop offset="0%" stop-color="#2f80ed" stop-opacity=".24" />
                            <stop offset="100%" stop-color="#2f80ed" stop-opacity=".02" />
                        </linearGradient>
                    </defs>

                    <line class="chart-grid-line" x1="42" y1="22" x2="590" y2="22" />
                    <line class="chart-grid-line" x1="42" y1="72" x2="590" y2="72" />
                    <line class="chart-grid-line" x1="42" y1="122" x2="590" y2="122" />
                    <line class="chart-grid-line" x1="42" y1="172" x2="590" y2="172" />

                    <text class="chart-axis-label" x="18" y="27">50</text>
                    <text class="chart-axis-label" x="18" y="77">40</text>
                    <text class="chart-axis-label" x="18" y="127">30</text>
                    <text class="chart-axis-label" x="18" y="177">20</text>

                    <path d="M58 113 C91 95, 107 145, 136 132 C173 115, 192 123, 224 105 C258 86, 274 70, 312 83 C348 95, 348 112, 381 91 C413 71, 454 91, 484 76 C520 59, 550 63, 590 83 L590 204 L58 204 Z"
                          fill="url(#ordersFill)" />

                    <path d="M58 113 C91 95, 107 145, 136 132 C173 115, 192 123, 224 105 C258 86, 274 70, 312 83 C348 95, 348 112, 381 91 C413 71, 454 91, 484 76 C520 59, 550 63, 590 83"
                          fill="none"
                          stroke="#2f80ed"
                          stroke-width="3"
                          stroke-linecap="round" />

                    <circle cx="381" cy="91" r="7" fill="#2f80ed" stroke="#fff" stroke-width="3" />
                    <circle cx="526" cy="63" r="4" fill="#2f80ed" stroke="#fff" stroke-width="2" />

                    <g>
                        <rect x="348" y="42" width="88" height="58" rx="10" fill="white" stroke="#dbe3ef" />
                        <text x="392" y="66" text-anchor="middle" font-size="12" font-weight="800" fill="#64748b">۲۱ خرداد</text>
                        <text x="392" y="86" text-anchor="middle" font-size="12" font-weight="950" fill="#0f172a">۳۸ سفارش</text>
                    </g>

                    <text class="chart-axis-label" x="58" y="224">خرداد ۱۷</text>
                    <text class="chart-axis-label" x="146" y="224">خرداد ۱۸</text>
                    <text class="chart-axis-label" x="235" y="224">خرداد ۱۹</text>
                    <text class="chart-axis-label" x="326" y="224">خرداد ۲۰</text>
                    <text class="chart-axis-label" x="416" y="224">خرداد ۲۱</text>
                    <text class="chart-axis-label" x="506" y="224">خرداد ۲۲</text>
                </svg>
            </div>
        </section>

        <section class="dashboard-bottom">
            <div class="admin-glass-card dashboard-panel">
                <div class="dashboard-card-header">
                    <a href="/Admin/Orders" class="dashboard-card-action">مشاهده همه</a>
                    <h2 class="dashboard-card-title">آخرین سفارش‌ها</h2>
                </div>

                <div class="dashboard-table-wrap">
                    <table class="dashboard-table">
                        <thead>
                            <tr>
                                <th>سفارش</th>
                                <th>کاربر</th>
                                <th>مبلغ</th>
                                <th>وضعیت</th>
                                <th></th>
                            </tr>
                        </thead>

                        <tbody>
                            @if (Model.Dashboard.RecentOrders == null || !Model.Dashboard.RecentOrders.Any())
                            {
                                <tr>
                                    <td>#12548</td>
                                    <td>علی محمدی</td>
                                    <td>1,250,000 تومان</td>
                                    <td><span class="status-pill status-success">تحویل شده</span></td>
                                    <td>←</td>
                                </tr>
                                <tr>
                                    <td>#12547</td>
                                    <td>رضا حسینی</td>
                                    <td>780,000 تومان</td>
                                    <td><span class="status-pill status-process">در حال پردازش</span></td>
                                    <td>←</td>
                                </tr>
                                <tr>
                                    <td>#12546</td>
                                    <td>زهرا احمدی</td>
                                    <td>450,000 تومان</td>
                                    <td><span class="status-pill status-success">پرداخت شده</span></td>
                                    <td>←</td>
                                </tr>
                                <tr>
                                    <td>#12545</td>
                                    <td>امیر کریمی</td>
                                    <td>320,000 تومان</td>
                                    <td><span class="status-pill status-danger">لغو شده</span></td>
                                    <td>←</td>
                                </tr>
                                <tr>
                                    <td>#12544</td>
                                    <td>سارا مرادی</td>
                                    <td>2,100,000 تومان</td>
                                    <td><span class="status-pill status-success">تحویل شده</span></td>
                                    <td>←</td>
                                </tr>
                            }
                            else
                            {
                                foreach (var order in Model.Dashboard.RecentOrders.Take(5))
                                {
                                    <tr>
                                        <td dir="ltr">@order.OrderNumber</td>
                                        <td>@order.CustomerName</td>
                                        <td>@Model.FormatMoney(order.FinalAmount)</td>
                                        <td>
                                            <span class="status-pill @Model.GetStatusCss(order.Status)">
                                                @Model.GetOrderStatus(order.Status)
                                            </span>
                                        </td>
                                        <td>
                                            <a href="/Admin/Orders">←</a>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>

                <div style="margin-top: 15px;">
                    <a href="/Admin/Orders" class="dashboard-card-action">مشاهده همه سفارش‌ها</a>
                </div>
            </div>

            <div class="admin-glass-card dashboard-panel">
                <div class="dashboard-card-header">
                    <a href="/Admin/Products" class="dashboard-card-action">مشاهده همه</a>
                    <h2 class="dashboard-card-title">محصولات پرفروش</h2>
                </div>

                <div class="product-sale-row">
                    <div class="product-sale-logo" style="background:linear-gradient(135deg,#2f80ed,#174ea6);">PS</div>
                    <div class="product-sale-title">گیفت کارت پلی استیشن 100 دلاری</div>
                    <div class="product-sale-count">245 عدد</div>
                    <div class="product-sale-rank hot">1</div>
                </div>

                <div class="product-sale-row">
                    <div class="product-sale-logo" style="background:linear-gradient(135deg,#111827,#334155);">ST</div>
                    <div class="product-sale-title">گیفت کارت استیم 50 دلاری</div>
                    <div class="product-sale-count">189 عدد</div>
                    <div class="product-sale-rank">2</div>
                </div>

                <div class="product-sale-row">
                    <div class="product-sale-logo" style="background:linear-gradient(135deg,#22c55e,#15803d);">SP</div>
                    <div class="product-sale-title">اکانت پریمیوم اسپاتیفای</div>
                    <div class="product-sale-count">156 عدد</div>
                    <div class="product-sale-rank">3</div>
                </div>

                <div class="product-sale-row">
                    <div class="product-sale-logo" style="background:linear-gradient(135deg,#10b981,#047857);">XB</div>
                    <div class="product-sale-title">گیفت کارت Xbox 50 دلاری</div>
                    <div class="product-sale-count">133 عدد</div>
                    <div class="product-sale-rank">4</div>
                </div>

                <div style="margin-top: 18px;">
                    <a href="/Admin/Products" class="dashboard-card-action">مشاهده همه محصولات</a>
                </div>
            </div>

            <div class="admin-glass-card dashboard-panel">
                <div class="dashboard-card-header">
                    <span></span>
                    <h2 class="dashboard-card-title">آمار سریع</h2>
                </div>

                <div class="quick-stat-row">
                    <div class="quick-icon quick-blue">
                        <i data-lucide="users"></i>
                    </div>
                    <div>
                        <div class="quick-label">تعداد کاربران</div>
                        <div class="quick-value">@Model.Dashboard.TotalUsers.ToString("N0") نفر</div>
                    </div>
                </div>

                <div class="quick-stat-row">
                    <div class="quick-icon quick-green">
                        <i data-lucide="package-check"></i>
                    </div>
                    <div>
                        <div class="quick-label">محصولات فعال</div>
                        <div class="quick-value">@Model.Dashboard.TotalProducts.ToString("N0") عدد</div>
                    </div>
                </div>

                <div class="quick-stat-row">
                    <div class="quick-icon quick-purple">
                        <i data-lucide="credit-card"></i>
                    </div>
                    <div>
                        <div class="quick-label">تعداد گیفت کارت‌ها</div>
                        <div class="quick-value">@Model.Dashboard.AvailableGiftCodes.ToString("N0") عدد</div>
                    </div>
                </div>

                <div class="quick-stat-row">
                    <div class="quick-icon quick-orange">
                        <i data-lucide="ticket-percent"></i>
                    </div>
                    <div>
                        <div class="quick-label">کوپن‌های فعال</div>
                        <div class="quick-value">@Model.Dashboard.ActiveCoupons.ToString("N0") مورد</div>
                    </div>
                </div>

                <div class="quick-stat-row">
                    <div class="quick-icon quick-red">
                        <i data-lucide="clock-alert"></i>
                    </div>
                    <div>
                        <div class="quick-label">سفارش‌های در انتظار</div>
                        <div class="quick-value">@Model.Dashboard.PendingOrders.ToString("N0") مورد</div>
                    </div>
                </div>
            </div>
        </section>

        <section class="admin-glass-card dashboard-panel">
            <div class="dashboard-card-header">
                <a href="/Admin/Notifications" class="dashboard-card-action">مشاهده همه</a>
                <h2 class="dashboard-card-title">اعلان‌های سیستم</h2>
            </div>

            <div class="system-alerts">
                <div class="system-alert blue">
                    <div>
                        <div class="system-alert-title">نسخه جدید سیستم موجود است</div>
                        <div class="system-alert-text">نسخه 2.1.0 با قابلیت‌های جدید منتشر شد.</div>
                        <div class="system-alert-time">۲ ساعت پیش</div>
                    </div>

                    <div class="quick-icon quick-blue">
                        <i data-lucide="rocket"></i>
                    </div>
                </div>

                <div class="system-alert orange">
                    <div>
                        <div class="system-alert-title">موجودی گیفت کارت PSN کم است</div>
                        <div class="system-alert-text">لطفاً موجودی این محصول را بررسی کنید.</div>
                        <div class="system-alert-time">۵ ساعت پیش</div>
                    </div>

                    <div class="quick-icon quick-orange">
                        <i data-lucide="wallet-cards"></i>
                    </div>
                </div>

                <div class="system-alert green">
                    <div>
                        <div class="system-alert-title">پرداخت ناموفق</div>
                        <div class="system-alert-text">تراکنش شماره #12548 ناموفق بود.</div>
                        <div class="system-alert-time">۱ ساعت پیش</div>
                    </div>

                    <div class="quick-icon quick-green">
                        <i data-lucide="shield-check"></i>
                    </div>
                </div>
            </div>
        </section>

    </div>
}

@section Scripts {
    <script>
        if (window.lucide) {
            lucide.createIcons();
        }
    </script>
}