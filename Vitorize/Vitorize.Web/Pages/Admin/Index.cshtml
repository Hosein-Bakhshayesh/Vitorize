@page
@model Vitorize.Web.Pages.Admin.IndexModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "داشبورد";
}

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="rounded-3xl border border-red-100 bg-red-50 p-5 text-red-700">
        @Model.ErrorMessage
    </div>
}
else
{
    <div class="space-y-8">
        <section class="relative overflow-hidden rounded-[2.5rem] bg-gradient-to-br from-vitorize-700 to-vitorize-500 p-8 text-white shadow-teal">
            <div class="absolute -left-20 -top-20 h-72 w-72 rounded-full bg-white/15 blur-3xl"></div>
            <div class="absolute bottom-0 right-20 h-80 w-80 rounded-full bg-white/10 blur-3xl"></div>

            <div class="relative z-10 flex flex-col gap-6 lg:flex-row lg:items-center lg:justify-between">
                <div>
                    <p class="inline-flex rounded-full bg-white/15 px-4 py-2 text-xs font-black text-white/80">
                        داشبورد زنده Vitorize
                    </p>

                    <h1 class="mt-5 text-4xl font-black leading-relaxed">
                        کنترل کامل فروشگاه دیجیتال
                    </h1>

                    <p class="mt-3 max-w-2xl text-sm leading-8 text-white/70">
                        آمار فروش، سفارش‌ها، محصولات، کاربران و موجودی کدها مستقیماً از API خوانده می‌شود.
                    </p>
                </div>

                <div class="rounded-[2rem] bg-white/15 p-6 backdrop-blur-xl">
                    <p class="text-sm text-white/70">درآمد تایید شده</p>
                    <p class="mt-2 text-4xl font-black">@Model.FormatMoney(Model.Dashboard.TotalRevenue)</p>
                </div>
            </div>
        </section>

        <section class="grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-4">
            <div class="rounded-[2rem] border border-white/70 bg-white/75 p-6 shadow-soft backdrop-blur-xl">
                <p class="text-sm font-bold text-slate-500">کاربران</p>
                <p class="mt-4 text-3xl font-black text-slate-900">@Model.Dashboard.TotalUsers.ToString("N0")</p>
                <p class="mt-2 text-xs text-vitorize-700">کل کاربران ثبت‌شده</p>
            </div>

            <div class="rounded-[2rem] border border-white/70 bg-white/75 p-6 shadow-soft backdrop-blur-xl">
                <p class="text-sm font-bold text-slate-500">محصولات فعال</p>
                <p class="mt-4 text-3xl font-black text-slate-900">@Model.Dashboard.TotalProducts.ToString("N0")</p>
                <p class="mt-2 text-xs text-vitorize-700">آماده فروش</p>
            </div>

            <div class="rounded-[2rem] border border-white/70 bg-white/75 p-6 shadow-soft backdrop-blur-xl">
                <p class="text-sm font-bold text-slate-500">سفارش‌ها</p>
                <p class="mt-4 text-3xl font-black text-slate-900">@Model.Dashboard.TotalOrders.ToString("N0")</p>
                <p class="mt-2 text-xs text-vitorize-700">کل سفارش‌های ثبت‌شده</p>
            </div>

            <div class="rounded-[2rem] border border-white/70 bg-white/75 p-6 shadow-soft backdrop-blur-xl">
                <p class="text-sm font-bold text-slate-500">کدهای آماده</p>
                <p class="mt-4 text-3xl font-black text-slate-900">@Model.Dashboard.AvailableGiftCodes.ToString("N0")</p>
                <p class="mt-2 text-xs text-vitorize-700">موجودی قابل تحویل</p>
            </div>
        </section>

        <section class="grid grid-cols-1 gap-6 xl:grid-cols-3">
            <div class="xl:col-span-2 rounded-[2rem] border border-white/70 bg-white/80 p-6 shadow-soft backdrop-blur-xl">
                <div class="mb-6 flex items-center justify-between">
                    <div>
                        <h2 class="text-xl font-black text-slate-900">آخرین سفارش‌ها</h2>
                        <p class="mt-1 text-xs text-slate-500">۵ سفارش آخر سیستم</p>
                    </div>
                    <a href="/Admin/Orders" class="rounded-2xl bg-vitorize-700 px-4 py-2 text-xs font-black text-white shadow-teal">
                        مشاهده همه
                    </a>
                </div>

                <div class="overflow-hidden rounded-3xl border border-slate-100">
                    <table class="w-full text-right text-sm">
                        <thead class="bg-slate-50 text-xs text-slate-500">
                            <tr>
                                <th class="px-5 py-4">شماره سفارش</th>
                                <th class="px-5 py-4">مشتری</th>
                                <th class="px-5 py-4">مبلغ</th>
                                <th class="px-5 py-4">وضعیت</th>
                                <th class="px-5 py-4">تاریخ</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100">
                            @foreach (var order in Model.Dashboard.RecentOrders)
                            {
                                <tr class="transition hover:bg-vitorize-50/60">
                                    <td class="px-5 py-4 font-black text-vitorize-700">@order.OrderNumber</td>
                                    <td class="px-5 py-4">@order.CustomerName</td>
                                    <td class="px-5 py-4">@Model.FormatMoney(order.FinalAmount)</td>
                                    <td class="px-5 py-4">
                                        <span class="rounded-full bg-vitorize-50 px-3 py-1 text-xs font-black text-vitorize-700">
                                            @Model.GetOrderStatus(order.Status)
                                        </span>
                                    </td>
                                    <td class="px-5 py-4 text-slate-500">@order.CreatedAt.ToString("yyyy/MM/dd")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="space-y-6">
                <div class="rounded-[2rem] border border-white/70 bg-white/80 p-6 shadow-soft backdrop-blur-xl">
                    <h2 class="text-xl font-black text-slate-900">وضعیت سفارش‌ها</h2>

                    <div class="mt-6 space-y-4">
                        <div class="flex items-center justify-between rounded-3xl bg-amber-50 p-4">
                            <span class="text-sm font-bold text-slate-600">در انتظار</span>
                            <span class="text-xl font-black text-amber-600">@Model.Dashboard.PendingOrders.ToString("N0")</span>
                        </div>

                        <div class="flex items-center justify-between rounded-3xl bg-vitorize-50 p-4">
                            <span class="text-sm font-bold text-slate-600">تکمیل شده</span>
                            <span class="text-xl font-black text-vitorize-700">@Model.Dashboard.CompletedOrders.ToString("N0")</span>
                        </div>

                        <div class="flex items-center justify-between rounded-3xl bg-slate-50 p-4">
                            <span class="text-sm font-bold text-slate-600">کدهای تخفیف فعال</span>
                            <span class="text-xl font-black text-slate-900">@Model.Dashboard.ActiveCoupons.ToString("N0")</span>
                        </div>
                    </div>
                </div>

                <div class="rounded-[2rem] bg-gradient-to-br from-vitorize-700 to-vitorize-500 p-6 text-white shadow-teal">
                    <h2 class="text-xl font-black">مرحله بعد</h2>
                    <p class="mt-3 text-sm leading-8 text-white/70">
                        صفحه محصولات، دسته‌بندی‌ها، برندها و سفارش‌ها را به همین سبک و متصل به API می‌سازیم.
                    </p>
                </div>
            </div>
        </section>
    </div>
}