@page
@model Vitorize.Web.Pages.Admin.IndexModel
@using Vitorize.Web.Helpers
@{
    ViewData["Title"]="داشبورد";
    Layout="~/Pages/Shared/_AdminLayout.cshtml";
}
<div class="vz-page" dir="rtl">
    @if(!string.IsNullOrWhiteSpace(Model.ErrorMessage)){
<div class="vz-alert vz-alert-danger">
<i data-lucide="triangle-alert">
</i>
<span>@Model.ErrorMessage</span>
</div>
}
    <section class="vz-hero">
<div class="vz-hero-main">
<div class="vz-eyebrow">
<i data-lucide="layout-grid">
</i>داشبورد</div>

<h1 class="vz-title">نمای کلی فروشگاه</h1>
<p class="vz-desc">وضعیت فروش، کاربران، سفارش‌ها، کدها و درخواست‌های مهم را یکجا ببین.</p>
</div>

<div class="vz-actions">
<a href="/Admin/Orders" class="vz-btn vz-btn-light">
<i data-lucide="shopping-cart">
</i>سفارش‌ها</a>
<a href="/Admin/Reports/Sales" class="vz-btn vz-btn-primary">
<i data-lucide="line-chart">
</i>گزارش فروش</a>
</div>

</section>

    <section class="vz-stats">
        <article class="vz-stats-card">
<div class="vz-stat-icon teal">
<i data-lucide="circle-dollar-sign">
</i>
</div>

<div class="vz-stat-content">
<span class="vz-stat-label">فروش امروز</span>
<strong class="vz-stat-value">@AdminUiHelper.Money(Model.Dashboard.Summary.RevenueToday)</strong>
</div>

</article>
        <article class="vz-stats-card">
<div class="vz-stat-icon blue">
<i data-lucide="shopping-bag">
</i>
</div>

<div class="vz-stat-content">
<span class="vz-stat-label">سفارش‌های امروز</span>
<strong class="vz-stat-value">@Model.Dashboard.Summary.OrdersToday</strong>
</div>

</article>
        <article class="vz-stats-card">
<div class="vz-stat-icon purple">
<i data-lucide="users">
</i>
</div>

<div class="vz-stat-content">
<span class="vz-stat-label">کاربران</span>
<strong class="vz-stat-value">@Model.Dashboard.Summary.TotalUsers</strong>
</div>

</article>
        <article class="vz-stats-card">
<div class="vz-stat-icon orange">
<i data-lucide="headphones">
</i>
</div>

<div class="vz-stat-content">
<span class="vz-stat-label">تیکت‌های باز</span>
<strong class="vz-stat-value">@Model.Dashboard.Summary.PendingTickets</strong>
</div>

</article>
    </section>

    <section class="vz-stats">
        <article class="vz-stats-card">
<div class="vz-stat-icon green">
<i data-lucide="wallet">
</i>
</div>

<div class="vz-stat-content">
<span class="vz-stat-label">موجودی کیف پول‌ها</span>
<strong class="vz-stat-value">@AdminUiHelper.Money(Model.Dashboard.Summary.TotalWalletBalance)</strong>
</div>

</article>
        <article class="vz-stats-card">
<div class="vz-stat-icon blue">
<i data-lucide="badge-check">
</i>
</div>

<div class="vz-stat-content">
<span class="vz-stat-label">احراز هویت در انتظار</span>
<strong class="vz-stat-value">@Model.Dashboard.Summary.PendingVerifications</strong>
</div>

</article>
        <article class="vz-stats-card">
<div class="vz-stat-icon purple">
<i data-lucide="credit-card">
</i>
</div>

<div class="vz-stat-content">
<span class="vz-stat-label">کد آماده فروش</span>
<strong class="vz-stat-value">@Model.Dashboard.Summary.AvailableGiftCodes</strong>
</div>

</article>
        <article class="vz-stats-card">
<div class="vz-stat-icon orange">
<i data-lucide="bell">
</i>
</div>

<div class="vz-stat-content">
<span class="vz-stat-label">اعلان خوانده‌نشده</span>
<strong class="vz-stat-value">@Model.Dashboard.Summary.UnreadNotifications</strong>
</div>

</article>
    </section>

    <div class="vz-dashboard-grid">
        <section class="vz-form-card">
<div class="vz-card-head">
<div>
<h2>روند ۷ روز اخیر</h2>
<p>مقایسه فروش و سفارش‌ها در روزهای اخیر.</p>
</div>

</div>

<div class="vz-chart-list">@foreach(var p in Model.Dashboard.SalesLast7Days){var w=(int)Math.Round((p.Value/Model.MaxSales)*100);<div class="vz-chart-row">
<span class="vz-chart-label">@p.Date.ToString("MM/dd")</span>
<div class="vz-chart-track">
<div class="vz-chart-fill" style="width:@w%">
</div>

</div>

<span class="vz-chart-value">@p.Value.ToString("N0")</span>
</div>
}
</div>

</section>

        <section class="vz-form-card">
<div class="vz-card-head">
<div>
<h2>محصولات پرفروش</h2>
<p>بر اساس سفارش‌های پرداخت‌شده.</p>
</div>

</div>

<div class="vz-timeline">@foreach(var item in Model.Dashboard.TopProducts.Take(8)){
<div class="vz-timeline-item">
<div class="vz-timeline-icon">
<i data-lucide="package">
</i>
</div>

<div>
<div class="vz-timeline-title">@item.ProductTitle</div>

<div class="vz-timeline-sub">@item.TotalSold فروش - @AdminUiHelper.Money(item.Revenue)</div>

</div>

</div>
} @if(!Model.Dashboard.TopProducts.Any()){
<div class="vz-empty">
<h3>هنوز فروشی ثبت نشده</h3>
</div>
}
</div>

</section>

    </div>

</div>

@section Scripts {

<script>
if(window.lucide){lucide.createIcons();}

</script>
}
