@page
@model Vitorize.Web.Pages.Admin.Reports.Sales.IndexModel
@using Vitorize.Web.Helpers
@{
    ViewData["Title"]="گزارش فروش";
    Layout="~/Pages/Shared/_AdminLayout.cshtml";
}
<div class="vz-page" dir="rtl">
<section class="vz-hero">
<div class="vz-hero-main">
<div class="vz-eyebrow">
<i data-lucide="line-chart">
</i>گزارش فروش</div>

<h1 class="vz-title">گزارش فروش</h1>
<p class="vz-desc">نمای کلی فروش و سفارش‌های تکمیل‌شده.</p>
</div>

</section>

<section class="vz-stats">
<article class="vz-stats-card">
<div class="vz-stat-icon green">
<i data-lucide="circle-dollar-sign">
</i>
</div>

<div class="vz-stat-content">
<span class="vz-stat-label">کل فروش</span>
<strong class="vz-stat-value">@AdminUiHelper.Money(Model.Report.TotalSales)</strong>
</div>

</article>
<article class="vz-stats-card">
<div class="vz-stat-icon blue">
<i data-lucide="shopping-cart">
</i>
</div>

<div class="vz-stat-content">
<span class="vz-stat-label">سفارش‌ها</span>
<strong class="vz-stat-value">@Model.Report.TotalOrders</strong>
</div>

</article>
<article class="vz-stats-card">
<div class="vz-stat-icon purple">
<i data-lucide="check-circle-2">
</i>
</div>

<div class="vz-stat-content">
<span class="vz-stat-label">تکمیل‌شده</span>
<strong class="vz-stat-value">@Model.Report.CompletedOrders</strong>
</div>

</article>
<article class="vz-stats-card">
<div class="vz-stat-icon orange">
<i data-lucide="x-circle">
</i>
</div>

<div class="vz-stat-content">
<span class="vz-stat-label">لغوشده</span>
<strong class="vz-stat-value">@Model.Report.CancelledOrders</strong>
</div>

</article>
</section>

</div>

@section Scripts {

<script>
if(window.lucide){lucide.createIcons();}

</script>
}
