@page
@model Vitorize.Web.Pages.Admin.Reports.IndexModel
@{
    ViewData["Title"]="گزارش‌ها";
    Layout="~/Pages/Shared/_AdminLayout.cshtml";
}
<div class="vz-page" dir="rtl">
<section class="vz-hero">
<div class="vz-hero-main">
<div class="vz-eyebrow">
<i data-lucide="bar-chart-3">
</i>گزارش‌ها</div>

<h1 class="vz-title">گزارش‌های مدیریتی</h1>
<p class="vz-desc">خلاصه عملکرد بخش‌های اصلی فروشگاه.</p>
</div>

<div class="vz-actions">
<a href="/Admin/Reports/Sales" class="vz-btn vz-btn-primary">
<i data-lucide="line-chart">
</i>گزارش فروش</a>
</div>

</section>

<section class="vz-stats">
<article class="vz-stats-card">
<div class="vz-stat-icon green">
<i data-lucide="credit-card">
</i>
</div>

<div class="vz-stat-content">
<span class="vz-stat-label">کد آماده فروش</span>
<strong class="vz-stat-value">@Model.GiftCodes.AvailableCodes</strong>
</div>

</article>
<article class="vz-stats-card">
<div class="vz-stat-icon orange">
<i data-lucide="shopping-bag">
</i>
</div>

<div class="vz-stat-content">
<span class="vz-stat-label">کد فروخته شده</span>
<strong class="vz-stat-value">@Model.GiftCodes.SoldCodes</strong>
</div>

</article>
<article class="vz-stats-card">
<div class="vz-stat-icon blue">
<i data-lucide="users">
</i>
</div>

<div class="vz-stat-content">
<span class="vz-stat-label">کاربران</span>
<strong class="vz-stat-value">@Model.Users.TotalUsers</strong>
</div>

</article>
<article class="vz-stats-card">
<div class="vz-stat-icon purple">
<i data-lucide="shield-check">
</i>
</div>

<div class="vz-stat-content">
<span class="vz-stat-label">احراز شده</span>
<strong class="vz-stat-value">@Model.Users.VerifiedUsers</strong>
</div>

</article>
</section>

</div>

@section Scripts {

<script>
if(window.lucide){lucide.createIcons();}

</script>
}
