@page
@model Vitorize.Web.Pages.Admin.Reviews.DetailsModel
@using Vitorize.Web.Helpers
@{
    ViewData["Title"] = "جزئیات نظر";
    Layout = "~/Pages/Shared/_AdminLayout.cshtml";
}
<div class="vz-page" dir="rtl">
    <section class="vz-hero">
        <div class="vz-hero-main">
            <div class="vz-eyebrow"><i data-lucide="message-square-text"></i>بررسی نظر</div>
            <h1 class="vz-title">جزئیات نظر کاربر</h1>
            <p class="vz-desc">محتوای نظر را بررسی و درباره انتشار آن تصمیم بگیر.</p>
        </div>
        <div class="vz-actions">
            <a asp-page="Index" class="vz-btn vz-btn-light"><i data-lucide="arrow-right"></i>بازگشت به فهرست</a>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
    {
        <div class="vz-alert vz-alert-success"><i data-lucide="check-circle-2"></i><span>@Model.SuccessMessage</span></div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="vz-alert vz-alert-danger"><i data-lucide="triangle-alert"></i><span>@Model.ErrorMessage</span></div>
    }

    <div class="vz-form-layout">
        <div class="vz-main-col">
            <section class="vz-form-card">
                <div class="vz-card-head">
                    <div>
                        <h2>@(string.IsNullOrWhiteSpace(Model.Item.Title) ? "نظر کاربر" : Model.Item.Title)</h2>
                        <p>درباره محصول: <strong>@Model.Item.ProductTitle</strong></p>
                    </div>
                    <span class="@AdminUiHelper.BadgeClass(AdminUiHelper.ReviewStatusIntent(Model.Item.IsApproved, Model.Item.IsRejected))">@AdminUiHelper.ReviewStatusText(Model.Item.IsApproved, Model.Item.IsRejected)</span>
                </div>

                <div class="vz-data-line" style="margin-bottom:16px">
                    <span class="vz-stars" style="font-size:18px">@AdminUiHelper.Stars(Model.Item.Rating)</span>
                    <span class="vz-badge vz-badge-muted">@Model.Item.Rating از ۵</span>
                    @if (Model.Item.IsBuyer)
                    {
                        <span class="vz-badge vz-badge-success"><i data-lucide="shopping-bag"></i>خریدار محصول</span>
                    }
                </div>

                <div class="vz-muted-box" style="line-height:2.1;color:var(--admin-text)">@Model.Item.Comment</div>

                @if (Model.Item.IsRejected && !string.IsNullOrWhiteSpace(Model.Item.RejectionReason))
                {
                    <div class="vz-alert vz-alert-danger" style="margin-top:16px"><i data-lucide="info"></i><span>دلیل رد: @Model.Item.RejectionReason</span></div>
                }

                <div class="vz-kv" style="margin-top:18px">
                    <div class="vz-kv-item"><span>کاربر</span><strong>@(string.IsNullOrWhiteSpace(Model.Item.UserFullName) ? "کاربر" : Model.Item.UserFullName)</strong></div>
                    <div class="vz-kv-item"><span>موبایل</span><strong class="ltr">@(string.IsNullOrWhiteSpace(Model.Item.UserMobile) ? "-" : Model.Item.UserMobile)</strong></div>
                    <div class="vz-kv-item"><span>پسندیده شده</span><strong>@Model.Item.LikeCount.ToString("N0")</strong></div>
                    <div class="vz-kv-item"><span>نپسندیده شده</span><strong>@Model.Item.DislikeCount.ToString("N0")</strong></div>
                    <div class="vz-kv-item"><span>تاریخ ثبت</span><strong>@AdminUiHelper.Date(Model.Item.CreatedAt)</strong></div>
                    <div class="vz-kv-item"><span>آخرین تغییر</span><strong>@AdminUiHelper.Date(Model.Item.UpdatedAt)</strong></div>
                </div>
            </section>
        </div>

        <div class="vz-side-col">
            <section class="vz-side-card vz-side-sticky">
                <div class="vz-card-head"><div><h2>اقدامات بررسی</h2><p>درباره وضعیت انتشار این نظر تصمیم بگیر.</p></div></div>

                @if (!Model.Item.IsApproved)
                {
                    <form method="post" asp-page-handler="Approve" asp-route-id="@Model.Item.Id" style="margin-bottom:14px">
                        <button type="submit" class="vz-btn vz-btn-success vz-btn-full"><i data-lucide="check-circle-2"></i>تأیید و انتشار نظر</button>
                    </form>
                }

                <form method="post" asp-page-handler="Reject" asp-route-id="@Model.Item.Id" style="margin-bottom:14px">
                    <div class="vz-field" style="margin-bottom:12px">
                        <label>دلیل رد نظر</label>
                        <textarea asp-for="Reject.Reason" class="vz-textarea" style="min-height:96px" placeholder="دلیل رد نظر را بنویس؛ این متن برای پیگیری ثبت می‌شود."></textarea>
                        <span asp-validation-for="Reject.Reason" class="vz-validation"></span>
                    </div>
                    <button type="submit" class="vz-btn vz-btn-light vz-btn-full" style="color:var(--admin-danger)"><i data-lucide="x-circle"></i>رد نظر</button>
                </form>

                <form method="post" asp-page-handler="Delete" asp-route-id="@Model.Item.Id" onsubmit="return confirm('این نظر برای همیشه حذف می‌شود. ادامه می‌دهی؟');">
                    <button type="submit" class="vz-btn vz-btn-danger vz-btn-full"><i data-lucide="trash-2"></i>حذف کامل نظر</button>
                </form>
            </section>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>if (window.lucide) { lucide.createIcons(); }</script>
}
