@page
@model Vitorize.Web.Pages.Admin.Reviews.IndexModel
@using Vitorize.Web.Helpers
@{
    ViewData["Title"] = "نظرات محصولات";
    Layout = "~/Pages/Shared/_AdminLayout.cshtml";
}
<div class="vz-page" dir="rtl">
    <section class="vz-hero">
        <div class="vz-hero-main">
            <div class="vz-eyebrow"><i data-lucide="message-square-text"></i>بازخورد مشتریان</div>
            <h1 class="vz-title">مدیریت نظرات محصولات</h1>
            <p class="vz-desc">نظرات کاربران را پیش از نمایش عمومی بررسی، تأیید یا رد کن.</p>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
    {
        <div class="vz-alert vz-alert-success"><i data-lucide="check-circle-2"></i><span>@Model.SuccessMessage</span></div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="vz-alert vz-alert-danger"><i data-lucide="triangle-alert"></i><span>@Model.ErrorMessage</span></div>
    }

    <section class="vz-stats">
        <article class="vz-stats-card">
            <div class="vz-stat-icon teal"><i data-lucide="messages-square"></i></div>
            <div class="vz-stat-content"><span class="vz-stat-label">همه نظرات</span><strong class="vz-stat-value">@Model.TotalCount.ToString("N0")</strong></div>
        </article>
        <article class="vz-stats-card">
            <div class="vz-stat-icon orange"><i data-lucide="clock"></i></div>
            <div class="vz-stat-content"><span class="vz-stat-label">در انتظار بررسی</span><strong class="vz-stat-value">@Model.PendingCount.ToString("N0")</strong></div>
        </article>
        <article class="vz-stats-card">
            <div class="vz-stat-icon green"><i data-lucide="badge-check"></i></div>
            <div class="vz-stat-content"><span class="vz-stat-label">تأییدشده</span><strong class="vz-stat-value">@Model.ApprovedCount.ToString("N0")</strong></div>
        </article>
        <article class="vz-stats-card">
            <div class="vz-stat-icon purple"><i data-lucide="x-circle"></i></div>
            <div class="vz-stat-content"><span class="vz-stat-label">ردشده</span><strong class="vz-stat-value">@Model.RejectedCount.ToString("N0")</strong></div>
        </article>
    </section>

    <section class="vz-form-card">
        <form method="get" class="vz-filter-grid">
            <div class="vz-field">
                <label>جستجو</label>
                <div class="vz-input-shell">
                    <i data-lucide="search"></i>
                    <input asp-for="Search" class="vz-input" placeholder="عنوان، متن نظر، محصول یا کاربر" />
                </div>
            </div>
            <div class="vz-field">
                <label>وضعیت</label>
                <div class="vz-input-shell">
                    <i data-lucide="filter"></i>
                    <select class="vz-select" asp-for="Status">
                        <option value="">همه وضعیت‌ها</option>
                        <option value="pending">در انتظار بررسی</option>
                        <option value="approved">تأییدشده</option>
                        <option value="rejected">ردشده</option>
                    </select>
                </div>
            </div>
            <div class="vz-field">
                <label>امتیاز</label>
                <div class="vz-input-shell">
                    <i data-lucide="star"></i>
                    <select class="vz-select" asp-for="Rating">
                        <option value="">همه امتیازها</option>
                        <option value="5">۵ ستاره</option>
                        <option value="4">۴ ستاره</option>
                        <option value="3">۳ ستاره</option>
                        <option value="2">۲ ستاره</option>
                        <option value="1">۱ ستاره</option>
                    </select>
                </div>
            </div>
            <div class="vz-actions">
                <button type="submit" class="vz-btn vz-btn-primary"><i data-lucide="filter"></i>اعمال فیلتر</button>
                <a asp-page="Index" class="vz-btn vz-btn-light"><i data-lucide="rotate-ccw"></i>پاک کردن</a>
            </div>
        </form>
    </section>

    <section class="vz-table-card">
        <div class="vz-card-head">
            <div>
                <h2>فهرست نظرات</h2>
                <p>نظرات تأییدنشده پیش از انتشار باید بررسی شوند.</p>
            </div>
            <span class="vz-badge vz-badge-muted">@Model.TotalCount.ToString("N0") نظر</span>
        </div>

        @if (!Model.Reviews.Any())
        {
            <div class="vz-empty">
                <div class="vz-empty-icon"><i data-lucide="inbox"></i></div>
                <h3>نظری یافت نشد</h3>
                <p>با فیلترهای فعلی نظری ثبت نشده است. فیلترها را تغییر بده یا منتظر ثبت نظرات کاربران بمان.</p>
            </div>
        }
        else
        {
            <div class="vz-table-wrap">
                <table class="vz-table">
                    <thead>
                        <tr>
                            <th>محصول و نظر</th>
                            <th>کاربر</th>
                            <th>امتیاز</th>
                            <th>وضعیت</th>
                            <th>تاریخ</th>
                            <th>عملیات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Reviews)
                        {
                            <tr>
                                <td>
                                    <div class="vz-item-text" style="min-width:240px">
                                        <strong>@item.ProductTitle</strong>
                                        <span>@(string.IsNullOrWhiteSpace(item.Title) ? AdminUiHelper.ShortText(item.Comment, 70) : item.Title)</span>
                                    </div>
                                </td>
                                <td>
                                    <div class="vz-item-text">
                                        <strong>@(string.IsNullOrWhiteSpace(item.UserFullName) ? "کاربر" : item.UserFullName)</strong>
                                        @if (item.IsBuyer)
                                        {
                                            <span class="vz-badge vz-badge-success" style="margin-top:6px;width:max-content"><i data-lucide="shopping-bag"></i>خریدار</span>
                                        }
                                        else
                                        {
                                            <span class="vz-badge vz-badge-muted" style="margin-top:6px;width:max-content">بدون خرید</span>
                                        }
                                    </div>
                                </td>
                                <td><span class="vz-stars" title="@item.Rating از ۵">@AdminUiHelper.Stars(item.Rating)</span></td>
                                <td><span class="@AdminUiHelper.BadgeClass(AdminUiHelper.ReviewStatusIntent(item.IsApproved, item.IsRejected))">@AdminUiHelper.ReviewStatusText(item.IsApproved, item.IsRejected)</span></td>
                                <td>@AdminUiHelper.Date(item.CreatedAt)</td>
                                <td>
                                    <div class="vz-actions">
                                        <a asp-page="Details" asp-route-id="@item.Id" class="vz-icon-btn info" title="جزئیات"><i data-lucide="eye"></i></a>
                                        @if (!item.IsApproved)
                                        {
                                            <form method="post" asp-page-handler="Approve" asp-route-id="@item.Id" asp-route-Status="@Model.Status" asp-route-Rating="@Model.Rating" asp-route-Search="@Model.Search" asp-route-page="@Model.PageNumber">
                                                <button class="vz-icon-btn success" type="submit" title="تأیید"><i data-lucide="check"></i></button>
                                            </form>
                                        }
                                        <form method="post" asp-page-handler="Delete" asp-route-id="@item.Id" asp-route-Status="@Model.Status" asp-route-Rating="@Model.Rating" asp-route-Search="@Model.Search" asp-route-page="@Model.PageNumber" onsubmit="return confirm('آیا از حذف کامل این نظر مطمئن هستید؟');">
                                            <button class="vz-icon-btn danger" type="submit" title="حذف"><i data-lucide="trash-2"></i></button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (Model.TotalPages > 1)
            {
                <div class="vz-pagination">
                    @if (Model.PageNumber > 1)
                    {
                        <a class="vz-btn vz-btn-light" asp-page="Index" asp-route-Status="@Model.Status" asp-route-Rating="@Model.Rating" asp-route-Search="@Model.Search" asp-route-page="@(Model.PageNumber - 1)"><i data-lucide="chevron-right"></i>قبلی</a>
                    }
                    @for (var p = Math.Max(1, Model.PageNumber - 2); p <= Math.Min(Model.TotalPages, Model.PageNumber + 2); p++)
                    {
                        if (p == Model.PageNumber)
                        {
                            <span class="vz-btn vz-btn-primary">@p</span>
                        }
                        else
                        {
                            <a class="vz-btn vz-btn-light" asp-page="Index" asp-route-Status="@Model.Status" asp-route-Rating="@Model.Rating" asp-route-Search="@Model.Search" asp-route-page="@p">@p</a>
                        }
                    }
                    @if (Model.PageNumber < Model.TotalPages)
                    {
                        <a class="vz-btn vz-btn-light" asp-page="Index" asp-route-Status="@Model.Status" asp-route-Rating="@Model.Rating" asp-route-Search="@Model.Search" asp-route-page="@(Model.PageNumber + 1)">بعدی<i data-lucide="chevron-left"></i></a>
                    }
                </div>
            }
        }
    </section>
</div>

@section Scripts {
    <script>if (window.lucide) { lucide.createIcons(); }</script>
}
