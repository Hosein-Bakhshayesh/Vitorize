@page
@model Vitorize.Web.Pages.Admin.SecurityLogs.IndexModel
@using Vitorize.Web.Helpers
@{
    ViewData["Title"]="امنیت";
    Layout="~/Pages/Shared/_AdminLayout.cshtml";
}
<div class="vz-page" dir="rtl">
<section class="vz-hero">
<div class="vz-hero-main">
<div class="vz-eyebrow">
<i data-lucide="history">
</i>امنیت</div>

<h1 class="vz-title">رویدادهای امنیتی</h1>
<p class="vz-desc">ورودها، خطاها و رخدادهای امنیتی کاربران را بررسی کن.</p>
</div>

</section>
@if(!string.IsNullOrWhiteSpace(Model.ErrorMessage)){
<div class="vz-alert vz-alert-danger">
<i data-lucide="triangle-alert">
</i>
<span>@Model.ErrorMessage</span>
</div>
}
<section class="vz-form-card">
<form method="get" class="vz-filter-grid">
<div class="vz-field">
<label>جستجو</label>
<div class="vz-input-shell">
<i data-lucide="search">
</i>
<input name="Filter.Search" value="@Model.Filter.Search" class="vz-input" placeholder="نوع رویداد یا توضیح" />
</div>

</div>

<div class="vz-field">
<label>وضعیت</label>
<div class="vz-input-shell vz-select-wrap">
<select name="Filter.IsSuccessful" class="vz-select">
<option value="">همه</option>
<option value="true" selected="@(Model.Filter.IsSuccessful==true)">موفق</option>
<option value="false" selected="@(Model.Filter.IsSuccessful==false)">ناموفق</option>
</select>
</div>

</div>

<div class="vz-field">
<label>از تاریخ</label>
<div class="vz-input-shell">
<input type="date" name="Filter.DateFrom" value='@(Model.Filter.DateFrom?.ToString("yyyy-MM-dd"))' class="vz-input ltr" />
</div>

</div>

<button class="vz-btn vz-btn-primary">
<i data-lucide="filter">
</i>اعمال</button>
</form>

</section>

<section class="vz-table-card">
<div class="vz-table-wrap">
<table class="vz-table">
<thead>
<tr>
<th>رویداد</th>
<th>نتیجه</th>
<th>کاربر</th>
<th>آدرس</th>
<th>زمان</th>
<th>
</th>
</tr>

</thead>

<tbody>@foreach(var item in Model.Items){
<tr>
<td>@item.EventType</td>
<td>
<span class="@(item.IsSuccessful?"vz-badge vz-badge-success":"vz-badge vz-badge-danger")">@(item.IsSuccessful?"موفق":"ناموفق")</span>
</td>
<td>@(item.UserFullName ?? "-")</td>
<td class="ltr">@(item.IpAddress ?? "-")</td>
<td>@AdminUiHelper.Date(item.CreatedAt)</td>
<td>
<a asp-page="Details" asp-route-id="@item.Id" class="vz-icon-btn info">
<i data-lucide="eye">
</i>
</a>
</td>
</tr>
}
</tbody>

</table>

</div>
@if(!Model.Items.Any()){
<div class="vz-empty">
<div class="vz-empty-icon">
<i data-lucide="shield-check">
</i>
</div>

<h3>رویدادی برای نمایش وجود ندارد</h3>
</div>
}
</section>

</div>

@section Scripts {

<script>
if(window.lucide){lucide.createIcons();}

</script>
}
