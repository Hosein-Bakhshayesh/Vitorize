@page "{id:guid}"
@model Vitorize.Web.Pages.Admin.Coupons.DetailsModel
@using Vitorize.Web.Helpers
@{
    ViewData["Title"] = "جزئیات کوپن"; Layout = "~/Pages/Shared/_AdminLayout.cshtml";
}
<div class="vz-page" dir="rtl">
<section class="vz-hero">
<div class="vz-hero-main">
<div class="vz-eyebrow">
<i data-lucide="ticket-percent">
</i>کوپن</div>

<h1 class="vz-title">@Model.Coupon.Title</h1>
<p class="vz-desc">@Model.Coupon.Code</p>
</div>

<div class="vz-actions">
<a asp-page="Edit" asp-route-id="@Model.Coupon.Id" class="vz-btn vz-btn-primary">
<i data-lucide="pencil">
</i>ویرایش</a>
<a asp-page="Index" class="vz-btn vz-btn-light">
<i data-lucide="arrow-right">
</i>بازگشت</a>
</div>

</section>

<section class="vz-form-card">
<div class="vz-kv">
<div class="vz-kv-item">
<span>نوع تخفیف</span>
<strong>@AdminUiHelper.DiscountType(Model.Coupon.DiscountType)</strong>
</div>

<div class="vz-kv-item">
<span>مقدار</span>
<strong>@Model.Coupon.DiscountValue.ToString("N0")</strong>
</div>

<div class="vz-kv-item">
<span>استفاده شده</span>
<strong>@Model.Coupon.UsedCount</strong>
</div>

<div class="vz-kv-item">
<span>وضعیت</span>
<strong>@(Model.Coupon.IsActive ? "فعال" : "غیرفعال")</strong>
</div>

</div>

</section>

</div>

@section Scripts {
<script>
if(window.lucide){lucide.createIcons();}

</script>
 }
