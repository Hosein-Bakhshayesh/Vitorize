@page
@model Vitorize.Web.Pages.Admin.Coupons.IndexModel
@using Vitorize.Web.Helpers
@{
    ViewData["Title"] = "کوپن‌ها"; Layout = "~/Pages/Shared/_AdminLayout.cshtml";
}
<div class="vz-page" dir="rtl">
<section class="vz-hero">
<div class="vz-hero-main">
<div class="vz-eyebrow">
<i data-lucide="ticket-percent">
</i>کوپن‌ها</div>

<h1 class="vz-title">مدیریت کوپن‌ها</h1>
<p class="vz-desc">کدهای تخفیف و کمپین‌های فروش را مدیریت کن.</p>
</div>

<div class="vz-actions">
<a asp-page="Create" class="vz-btn vz-btn-primary">
<i data-lucide="plus">
</i>کوپن جدید</a>
</div>

</section>

@if(!string.IsNullOrWhiteSpace(Model.SuccessMessage)){
<div class="vz-alert vz-alert-success">
<i data-lucide="check-circle-2">
</i>
<span>@Model.SuccessMessage</span>
</div>
}
@if(!string.IsNullOrWhiteSpace(Model.ErrorMessage)){
<div class="vz-alert vz-alert-danger">
<i data-lucide="triangle-alert">
</i>
<span>@Model.ErrorMessage</span>
</div>
}
<section class="vz-table-card">
<form method="get" class="vz-filter-grid" style="margin-bottom:18px">
<div class="vz-field">
<label>جستجو</label>
<div class="vz-input-shell">
<i data-lucide="search">
</i>
<input asp-for="Search" class="vz-input" placeholder="کد یا عنوان" />
</div>

</div>

<div class="vz-actions">
<button class="vz-btn vz-btn-light">
<i data-lucide="filter">
</i>فیلتر</button>
<a asp-page="Index" class="vz-btn vz-btn-light">
<i data-lucide="rotate-ccw">
</i>پاک کردن</a>
</div>

</form>

@if(!Model.Coupons.Any()){
<div class="vz-empty">
<div class="vz-empty-icon">
<i data-lucide="ticket-percent">
</i>
</div>

<h3>کوپنی ثبت نشده است</h3>
<p>برای شروع کوپن جدید تعریف کن.</p>
</div>
}else{
<div class="vz-table-wrap">
<table class="vz-table">
<thead>
<tr>
<th>کوپن</th>
<th>نوع</th>
<th>مقدار</th>
<th>استفاده</th>
<th>وضعیت</th>
<th>عملیات</th>
</tr>

</thead>

<tbody>@foreach(var c in Model.Coupons){
<tr>
<td>
<div class="vz-item">
<div class="vz-thumb-fallback sm">
<i data-lucide="ticket-percent">
</i>
</div>

<div class="vz-item-text">
<strong>@c.Title</strong>
<span>@c.Code</span>
</div>

</div>

</td>
<td>@AdminUiHelper.DiscountType(c.DiscountType)</td>
<td>@c.DiscountValue.ToString("N0")</td>
<td>@c.UsedCount / @(c.MaxUsageCount?.ToString() ?? "∞")</td>
<td>@if(c.IsActive){
<span class="vz-badge vz-badge-success">فعال</span>}else{
<span class="vz-badge vz-badge-muted">غیرفعال</span>}
</td>
<td>
<div class="vz-actions">
<a asp-page="Details" asp-route-id="@c.Id" class="vz-icon-btn info">
<i data-lucide="eye">
</i>
</a>
<a asp-page="Edit" asp-route-id="@c.Id" class="vz-icon-btn">
<i data-lucide="pencil">
</i>
</a>
<form method="post" asp-page-handler="Delete" asp-route-id="@c.Id" onsubmit="return confirm('کوپن حذف شود؟');">
<button class="vz-icon-btn danger">
<i data-lucide="trash-2">
</i>
</button>
</form>

</div>

</td>
</tr>
}
</tbody>

</table>

</div>
}
</section>

</div>

@section Scripts {
<script>
if(window.lucide){lucide.createIcons();}

</script>
 }
