@page "{id:guid}"
@model Vitorize.Web.Pages.Admin.Tickets.DetailsModel
@using Vitorize.Web.Helpers
@{
    ViewData["Title"]="جزئیات تیکت";
    Layout="~/Pages/Shared/_AdminLayout.cshtml"; var messages=Model.Ticket.Messages.Any()?Model.Ticket.Messages:Model.Ticket.TicketMessages;
}
<div class="vz-page" dir="rtl">
<section class="vz-hero">
<div class="vz-hero-main">
<div class="vz-eyebrow">
<i data-lucide="headphones">
</i>تیکت</div>

<h1 class="vz-title">@Model.Ticket.Subject</h1>
<p class="vz-desc">@AdminUiHelper.TicketStatus(Model.Ticket.Status)</p>
</div>

<div class="vz-actions">
<form method="post" asp-page-handler="Close" asp-route-id="@Model.Ticket.Id">
<button class="vz-btn vz-btn-danger">بستن</button>
</form>

<form method="post" asp-page-handler="Reopen" asp-route-id="@Model.Ticket.Id">
<button class="vz-btn vz-btn-light">باز کردن</button>
</form>

<a asp-page="Index" class="vz-btn vz-btn-light">
<i data-lucide="arrow-right">
</i>بازگشت</a>
</div>

</section>
@if(!string.IsNullOrWhiteSpace(Model.SuccessMessage)){
<div class="vz-alert vz-alert-success">
<i data-lucide="check-circle-2">
</i>
<span>@Model.SuccessMessage</span>
</div>
}
@if(!string.IsNullOrWhiteSpace(Model.ErrorMessage)){
<div class="vz-alert vz-alert-danger">
<i data-lucide="triangle-alert">
</i>
<span>@Model.ErrorMessage</span>
</div>
}
<section class="vz-form-card">
<div class="vz-card-head">
<div>
<h2>گفتگو</h2>
<p>پیام‌های ثبت‌شده برای این تیکت.</p>
</div>

</div>
@foreach(var m in messages){
<div class="vz-kv-item" style="margin-bottom:12px">
<span>@m.SenderName · @AdminUiHelper.Date(m.CreatedAt)</span>
<strong style="white-space:pre-line">@m.Message</strong>@if(!string.IsNullOrWhiteSpace(m.AttachmentPath)){
<a href="@AdminUiHelper.ImageUrl(m.AttachmentPath)" target="_blank" class="vz-btn vz-btn-light" style="margin-top:10px">مشاهده پیوست</a>}
</div>
}
</section>

<section class="vz-form-card">
<form method="post" enctype="multipart/form-data" asp-page-handler="Reply" asp-route-id="@Model.Ticket.Id">
<div class="vz-field">
<label asp-for="Reply.Message">پاسخ</label>
<textarea asp-for="Reply.Message" class="vz-textarea">
</textarea>
</div>

<div class="vz-field" style="margin-top:14px">
<label>پیوست</label>
<div class="vz-input-shell">
<i data-lucide="paperclip">
</i>
<input type="file" name="AttachmentFile" class="vz-input" />
</div>

</div>

<div style="height:14px">
</div>

<button class="vz-btn vz-btn-primary">ثبت پاسخ</button>
</form>

</section>

</div>

@section Scripts {

<partial name="_ValidationScriptsPartial"/>

<script>
if(window.lucide){lucide.createIcons();}

</script>
}
