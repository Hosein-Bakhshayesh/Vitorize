@page
@model Vitorize.Web.Pages.Admin.Orders.IndexModel
@using Vitorize.Web.Helpers
@{
    ViewData["Title"] = "سفارش‌ها"; Layout = "~/Pages/Shared/_AdminLayout.cshtml";
}
<div class="vz-page" dir="rtl">
<section class="vz-hero">
<div class="vz-hero-main">
<div class="vz-eyebrow">
<i data-lucide="shopping-cart">
</i>سفارش‌ها</div>

<h1 class="vz-title">مدیریت سفارش‌ها</h1>
<p class="vz-desc">سفارش‌ها، وضعیت پرداخت و روند تحویل را بررسی کن.</p>
</div>

</section>
@if(!string.IsNullOrWhiteSpace(Model.ErrorMessage)){
<div class="vz-alert vz-alert-danger">
<i data-lucide="triangle-alert">
</i>
<span>@Model.ErrorMessage</span>
</div>
}
@if(!string.IsNullOrWhiteSpace(Model.SuccessMessage)){
<div class="vz-alert vz-alert-success">
<i data-lucide="check-circle-2">
</i>
<span>@Model.SuccessMessage</span>
</div>
}
<section class="vz-table-card">
<form method="get" class="vz-filter-grid" style="margin-bottom:18px">
<div class="vz-field">
<label>جستجو</label>
<div class="vz-input-shell">
<i data-lucide="search">
</i>
<input asp-for="Search" class="vz-input" placeholder="شماره سفارش یا مشتری" />
</div>

</div>

<div class="vz-actions">
<button class="vz-btn vz-btn-light">
<i data-lucide="filter">
</i>جستجو</button>
</div>

</form>
@if(!Model.Orders.Any()){
<div class="vz-empty">
<div class="vz-empty-icon">
<i data-lucide="shopping-cart">
</i>
</div>

<h3>سفارشی پیدا نشد</h3>
<p>سفارش‌های جدید در این بخش نمایش داده می‌شوند.</p>
</div>
}else{
<div class="vz-table-wrap">
<table class="vz-table">
<thead>
<tr>
<th>سفارش</th>
<th>مشتری</th>
<th>مبلغ</th>
<th>پرداخت</th>
<th>وضعیت</th>
<th>تاریخ</th>
<th>عملیات</th>
</tr>

</thead>

<tbody>@foreach(var o in Model.Orders){
<tr>
<td>
<strong>@o.OrderNumber</strong>
</td>
<td>@(o.UserFullName ?? o.UserMobile)</td>
<td>@AdminUiHelper.Money(o.FinalAmount)</td>
<td>
<span class="@AdminUiHelper.StatusBadgeClass(o.PaymentStatus)">@AdminUiHelper.PaymentStatus(o.PaymentStatus)</span>
</td>
<td>
<span class="@AdminUiHelper.StatusBadgeClass(o.Status)">@AdminUiHelper.OrderStatus(o.Status)</span>
</td>
<td>@AdminUiHelper.Date(o.CreatedAt)</td>
<td>
<a asp-page="Details" asp-route-id="@o.Id" class="vz-icon-btn info">
<i data-lucide="eye">
</i>
</a>
</td>
</tr>
}
</tbody>

</table>

</div>
}
</section>

</div>

@section Scripts {
<script>
if(window.lucide){lucide.createIcons();}

</script>
 }
