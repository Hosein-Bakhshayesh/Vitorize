@page "{id:guid}"
@model Vitorize.Web.Pages.Admin.Orders.DetailsModel
@{
    ViewData["Title"] = "جزئیات سفارش";
    Layout = "~/Pages/Shared/_AdminLayout.cshtml";
}

<div class="space-y-6" dir="rtl">
    <div class="rounded-[2rem] border border-white/70 bg-white/80 p-6 shadow-xl backdrop-blur-xl">
        <div class="flex flex-col gap-5 lg:flex-row lg:items-center lg:justify-between">
            <div>
                <p class="text-sm font-black text-indigo-600">Order Details</p>
                <h1 class="mt-2 text-3xl font-black text-slate-900">سفارش #@Model.Order.OrderNumber</h1>
                <p class="mt-2 text-sm text-slate-500">ثبت شده در @Model.FormatDate(Model.Order.CreatedAt)</p>
            </div>

            <div class="flex flex-wrap gap-2">
                <a asp-page="/Admin/Orders/Index"
                   class="rounded-2xl bg-slate-100 px-5 py-3 text-sm font-black text-slate-700">
                    بازگشت
                </a>

                <form method="post" asp-page-handler="Complete" asp-route-id="@Model.Order.Id"
                      onsubmit="return confirm('سفارش تکمیل شود؟')">
                    <button class="rounded-2xl bg-emerald-50 px-5 py-3 text-sm font-black text-emerald-700">
                        تکمیل سفارش
                    </button>
                </form>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
    {
        <div class="rounded-2xl border border-emerald-200 bg-emerald-50 px-5 py-4 text-sm font-bold text-emerald-700">
            @Model.SuccessMessage
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="rounded-2xl border border-rose-200 bg-rose-50 px-5 py-4 text-sm font-bold text-rose-700">
            @Model.ErrorMessage
        </div>
    }

    <div class="grid gap-4 md:grid-cols-4">
        <div class="rounded-[1.5rem] bg-white/85 p-5 shadow-sm ring-1 ring-white/70">
            <p class="text-xs font-bold text-slate-500">وضعیت سفارش</p>
            <p class="mt-2 text-xl font-black text-slate-900">@Model.GetOrderStatus(Model.Order.Status)</p>
        </div>

        <div class="rounded-[1.5rem] bg-white/85 p-5 shadow-sm ring-1 ring-white/70">
            <p class="text-xs font-bold text-slate-500">وضعیت پرداخت</p>
            <p class="mt-2 text-xl font-black text-emerald-600">@Model.GetPaymentStatus(Model.Order.PaymentStatus)</p>
        </div>

        <div class="rounded-[1.5rem] bg-white/85 p-5 shadow-sm ring-1 ring-white/70">
            <p class="text-xs font-bold text-slate-500">مبلغ نهایی</p>
            <p class="mt-2 text-xl font-black text-indigo-600">@Model.FormatMoney(Model.Order.FinalAmount)</p>
        </div>

        <div class="rounded-[1.5rem] bg-white/85 p-5 shadow-sm ring-1 ring-white/70">
            <p class="text-xs font-bold text-slate-500">تعداد آیتم</p>
            <p class="mt-2 text-xl font-black text-slate-900">@Model.Order.Items.Count</p>
        </div>
    </div>

    <div class="grid gap-6 xl:grid-cols-12">
        <div class="space-y-6 xl:col-span-8">
            <div class="rounded-[2rem] border border-white/70 bg-white/85 p-6 shadow-sm backdrop-blur">
                <h2 class="text-lg font-black text-slate-900">آیتم‌های سفارش</h2>

                <div class="mt-5 space-y-4">
                    @foreach (var item in Model.Order.Items)
                    {
                        <div class="rounded-3xl border border-slate-100 bg-slate-50 p-5">
                            <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
                                <div>
                                    <h3 class="text-lg font-black text-slate-900">@item.ProductTitle</h3>
                                    <p class="mt-1 text-sm text-slate-500">@(item.VariantTitle ?? "بدون تنوع")</p>

                                    <div class="mt-3 flex flex-wrap gap-2 text-xs font-bold">
                                        <span class="rounded-xl bg-white px-3 py-2 text-slate-600">
                                            تعداد: @item.Quantity
                                        </span>

                                        <span class="rounded-xl bg-white px-3 py-2 text-slate-600">
                                            @Model.GetDeliveryType(item.DeliveryType)
                                        </span>

                                        <span class="rounded-xl bg-white px-3 py-2 text-slate-600">
                                            @Model.GetDeliveryStatus(item.DeliveryStatus)
                                        </span>

                                        @if (item.RequiresVerification)
                                        {
                                            <span class="rounded-xl bg-amber-100 px-3 py-2 text-amber-700">
                                                نیازمند احراز هویت
                                            </span>
                                        }
                                    </div>
                                </div>

                                <div class="grid gap-3 sm:grid-cols-2 lg:w-[280px]">
                                    <div class="rounded-2xl bg-white p-4">
                                        <p class="text-xs font-bold text-slate-400">قیمت واحد</p>
                                        <p class="mt-1 text-sm font-black text-slate-900">@Model.FormatMoney(item.UnitPrice)</p>
                                    </div>

                                    <div class="rounded-2xl bg-white p-4">
                                        <p class="text-xs font-bold text-slate-400">جمع</p>
                                        <p class="mt-1 text-sm font-black text-emerald-700">@Model.FormatMoney(item.TotalPrice)</p>
                                    </div>
                                </div>
                            </div>

                            @if (item.Deliveries.Any())
                            {
                                <div class="mt-5 border-t border-slate-200 pt-4">
                                    <p class="mb-3 text-sm font-black text-slate-800">تحویل‌ها</p>

                                    <div class="space-y-3">
                                        @foreach (var delivery in item.Deliveries)
                                        {
                                            <div class="rounded-2xl bg-white p-4">
                                                <div class="flex items-center justify-between">
                                                    <span class="text-xs font-bold text-slate-500">
                                                        @Model.GetDeliveryType(delivery.DeliveryType)
                                                    </span>

                                                    <span class="text-xs font-bold text-slate-400">
                                                        @Model.FormatDate(delivery.CreatedAt)
                                                    </span>
                                                </div>

                                                @if (!string.IsNullOrWhiteSpace(delivery.DeliveredContent))
                                                {
                                                    <pre class="mt-3 overflow-auto rounded-2xl bg-slate-950 p-4 text-left text-sm text-emerald-300">@delivery.DeliveredContent</pre>
                                                }
                                                else
                                                {
                                                    <p class="mt-3 text-sm text-slate-400">محتوای تحویل ثبت نشده است.</p>
                                                }
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="space-y-6 xl:col-span-4">
            <div class="rounded-[2rem] border border-white/70 bg-white/85 p-6 shadow-sm backdrop-blur">
                <h2 class="text-lg font-black text-slate-900">خلاصه مالی</h2>

                <div class="mt-5 space-y-3 text-sm">
                    <div class="flex justify-between rounded-2xl bg-slate-50 p-4">
                        <span class="font-bold text-slate-500">جمع کل</span>
                        <span class="font-black text-slate-900">@Model.FormatMoney(Model.Order.SubtotalAmount)</span>
                    </div>

                    <div class="flex justify-between rounded-2xl bg-rose-50 p-4">
                        <span class="font-bold text-rose-500">تخفیف</span>
                        <span class="font-black text-rose-700">@Model.FormatMoney(Model.Order.DiscountAmount)</span>
                    </div>

                    <div class="flex justify-between rounded-2xl bg-emerald-50 p-4">
                        <span class="font-bold text-emerald-500">مبلغ نهایی</span>
                        <span class="font-black text-emerald-700">@Model.FormatMoney(Model.Order.FinalAmount)</span>
                    </div>
                </div>
            </div>

            <div class="rounded-[2rem] border border-white/70 bg-white/85 p-6 shadow-sm backdrop-blur">
                <h2 class="text-lg font-black text-slate-900">زمان‌ها</h2>

                <div class="mt-5 space-y-3 text-sm">
                    <div class="flex justify-between rounded-2xl bg-slate-50 p-4">
                        <span class="font-bold text-slate-500">ثبت</span>
                        <span class="font-black text-slate-900">@Model.FormatDate(Model.Order.CreatedAt)</span>
                    </div>

                    <div class="flex justify-between rounded-2xl bg-slate-50 p-4">
                        <span class="font-bold text-slate-500">پرداخت</span>
                        <span class="font-black text-slate-900">@Model.FormatDate(Model.Order.PaidAt)</span>
                    </div>

                    <div class="flex justify-between rounded-2xl bg-slate-50 p-4">
                        <span class="font-bold text-slate-500">تکمیل</span>
                        <span class="font-black text-slate-900">@Model.FormatDate(Model.Order.CompletedAt)</span>
                    </div>
                </div>
            </div>

            <form method="post"
                  asp-page-handler="Cancel"
                  asp-route-id="@Model.Order.Id"
                  onsubmit="return confirm('سفارش لغو شود؟')"
                  class="rounded-[2rem] border border-rose-100 bg-rose-50/80 p-6 shadow-sm">
                <h2 class="text-lg font-black text-rose-900">لغو سفارش</h2>

                <textarea asp-for="CancelReason"
                          rows="4"
                          placeholder="دلیل لغو..."
                          class="mt-4 w-full rounded-2xl border border-rose-100 bg-white px-4 py-3 text-sm"></textarea>

                <button class="mt-4 w-full rounded-2xl bg-rose-600 px-5 py-3 text-sm font-black text-white">
                    لغو سفارش
                </button>
            </form>
        </div>
    </div>
</div>