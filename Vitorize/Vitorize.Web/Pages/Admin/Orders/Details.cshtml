@page "{id:guid}"
@model Vitorize.Web.Pages.Admin.Orders.DetailsModel
@using Vitorize.Web.Helpers
@{
    ViewData["Title"] = "جزئیات سفارش"; Layout = "~/Pages/Shared/_AdminLayout.cshtml"; var items = Model.Order.Items.Any() ? Model.Order.Items : Model.Order.OrderItems;
}
<div class="vz-page" dir="rtl">
<section class="vz-hero">
<div class="vz-hero-main">
<div class="vz-eyebrow">
<i data-lucide="shopping-cart">
</i>سفارش</div>

<h1 class="vz-title">@Model.Order.OrderNumber</h1>
<p class="vz-desc">جزئیات سفارش و اقلام خریداری‌شده.</p>
</div>

<div class="vz-actions">
<form method="post" asp-page-handler="Complete" asp-route-id="@Model.Order.Id">
<button class="vz-btn vz-btn-success" type="submit">
<i data-lucide="check">
</i>تکمیل</button>
</form>

<a asp-page="Index" class="vz-btn vz-btn-light">
<i data-lucide="arrow-right">
</i>بازگشت</a>
</div>

</section>
@if(!string.IsNullOrWhiteSpace(Model.SuccessMessage)){
<div class="vz-alert vz-alert-success">
<i data-lucide="check-circle-2">
</i>
<span>@Model.SuccessMessage</span>
</div>
}
@if(!string.IsNullOrWhiteSpace(Model.ErrorMessage)){
<div class="vz-alert vz-alert-danger">
<i data-lucide="triangle-alert">
</i>
<span>@Model.ErrorMessage</span>
</div>
}
<section class="vz-stats">
<article class="vz-stats-card">
<div class="vz-stat-icon green">
<i data-lucide="circle-dollar-sign">
</i>
</div>

<div class="vz-stat-content">
<span class="vz-stat-label">مبلغ نهایی</span>
<strong class="vz-stat-value">@AdminUiHelper.Money(Model.Order.FinalAmount)</strong>
</div>

</article>
<article class="vz-stats-card">
<div class="vz-stat-icon blue">
<i data-lucide="credit-card">
</i>
</div>

<div class="vz-stat-content">
<span class="vz-stat-label">پرداخت</span>
<strong class="vz-stat-value">@AdminUiHelper.PaymentStatus(Model.Order.PaymentStatus)</strong>
</div>

</article>
<article class="vz-stats-card">
<div class="vz-stat-icon orange">
<i data-lucide="truck">
</i>
</div>

<div class="vz-stat-content">
<span class="vz-stat-label">وضعیت</span>
<strong class="vz-stat-value">@AdminUiHelper.OrderStatus(Model.Order.Status)</strong>
</div>

</article>
<article class="vz-stats-card">
<div class="vz-stat-icon purple">
<i data-lucide="calendar">
</i>
</div>

<div class="vz-stat-content">
<span class="vz-stat-label">تاریخ</span>
<strong class="vz-stat-value">@AdminUiHelper.ShortDate(Model.Order.CreatedAt)</strong>
</div>

</article>
</section>

<section class="vz-table-card">
<div class="vz-card-head">
<div>
<h2>اقلام سفارش</h2>
<p>@items.Count قلم در این سفارش ثبت شده است.</p>
</div>

</div>

<div class="vz-table-wrap">
<table class="vz-table">
<thead>
<tr>
<th>محصول</th>
<th>تعداد</th>
<th>قیمت واحد</th>
<th>جمع</th>
<th>تحویل</th>
</tr>

</thead>

<tbody>@foreach(var item in items){
<tr>
<td>@item.ProductTitle <small>@item.VariantTitle</small>
</td>
<td>@item.Quantity</td>
<td>@AdminUiHelper.Money(item.UnitPrice)</td>
<td>@AdminUiHelper.Money(item.TotalPrice)</td>
<td>@AdminUiHelper.DeliveryStatus(item.DeliveryStatus)</td>
</tr>
}
</tbody>

</table>

</div>

</section>

<section class="vz-form-card">
<form method="post" asp-page-handler="Cancel" asp-route-id="@Model.Order.Id">
<div class="vz-field">
<label asp-for="Reason">دلیل لغو</label>
<textarea asp-for="Reason" class="vz-textarea" style="min-height:90px">
</textarea>
</div>

<div style="height:12px">
</div>

<button class="vz-btn vz-btn-danger" type="submit">
<i data-lucide="x">
</i>لغو سفارش</button>
</form>

</section>

</div>

@section Scripts {
<script>
if(window.lucide){lucide.createIcons();}

</script>
 }
