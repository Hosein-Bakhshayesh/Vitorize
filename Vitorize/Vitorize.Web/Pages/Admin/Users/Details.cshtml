@page "{id:guid}"
@model Vitorize.Web.Pages.Admin.Users.DetailsModel
@using Vitorize.Web.Helpers
@{
    ViewData["Title"] = "جزئیات کاربر"; Layout = "~/Pages/Shared/_AdminLayout.cshtml"; var roles = Model.UserDetail.RoleNames.Any() ? Model.UserDetail.RoleNames : Model.UserDetail.Roles; var assignableRoles = Model.AvailableRoles.Where(x => !roles.Contains(x.Name, StringComparer.OrdinalIgnoreCase)).ToList();
}
<div class="vz-page" dir="rtl">
<section class="vz-hero">
<div class="vz-hero-main">
<div class="vz-eyebrow">
<i data-lucide="user">
</i>کاربر</div>

<h1 class="vz-title">@Model.UserDetail.FullName</h1>
<p class="vz-desc">@Model.UserDetail.Mobile</p>
</div>

<div class="vz-actions">
<a asp-page="Index" class="vz-btn vz-btn-light">
<i data-lucide="arrow-right">
</i>بازگشت</a>
</div>

</section>
@if(!string.IsNullOrWhiteSpace(Model.SuccessMessage)){
<div class="vz-alert vz-alert-success">
<i data-lucide="check-circle-2">
</i>
<span>@Model.SuccessMessage</span>
</div>
}
@if(!string.IsNullOrWhiteSpace(Model.ErrorMessage)){
<div class="vz-alert vz-alert-danger">
<i data-lucide="triangle-alert">
</i>
<span>@Model.ErrorMessage</span>
</div>
}
<section class="vz-form-card">
<div class="vz-kv">
<div class="vz-kv-item">
<span>ایمیل</span>
<strong>@(Model.UserDetail.Email ?? "-")</strong>
</div>

<div class="vz-kv-item">
<span>کد ملی</span>
<strong>@(Model.UserDetail.NationalCode ?? "-")</strong>
</div>

<div class="vz-kv-item">
<span>وضعیت</span>
<strong>@AdminUiHelper.UserStatus(Model.UserDetail.Status)</strong>
</div>

<div class="vz-kv-item">
<span>احراز هویت</span>
<strong>@AdminUiHelper.VerificationStatus(Model.UserDetail.VerificationStatus)</strong>
</div>

</div>

</section>

<section class="vz-form-card">
<div class="vz-card-head">
<div>
<h2>نقش‌های کاربر</h2>
<p>نقش‌های فعال کاربر را مشاهده یا تغییر بده.</p>
</div>

</div>

<div class="vz-actions">@foreach(var role in roles){
<form method="post" asp-page-handler="RemoveRole" asp-route-id="@Model.UserDetail.Id" asp-route-roleName="@role">
<button class="vz-badge vz-badge-primary" type="submit">@role ×</button>
</form>
} @if(!roles.Any()){
<span class="vz-badge vz-badge-muted">بدون نقش</span>}
</div>

<form method="post" asp-page-handler="AddRole" asp-route-id="@Model.UserDetail.Id" class="vz-form-grid two" style="margin-top:18px">
<div class="vz-field">
<label>افزودن نقش</label>
<div class="vz-input-shell vz-select-wrap">
<i data-lucide="shield">
</i>
<select asp-for="RoleRequest.RoleName" class="vz-select">
<option value="">انتخاب نقش</option>@foreach(var role in assignableRoles){
<option value="@role.Name">@role.DisplayName (@role.Name)</option>}
</select>
</div>

</div>

<div class="vz-field">
<label>&nbsp;</label>
<button class="vz-btn vz-btn-primary">
<i data-lucide="plus">
</i>افزودن نقش</button>
</div>

</form>

</section>

</div>

@section Scripts {
<script>
if(window.lucide){lucide.createIcons();}

</script>
 }
