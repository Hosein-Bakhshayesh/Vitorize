@page
@model Vitorize.Web.Pages.Admin.Users.IndexModel
@using Vitorize.Web.Helpers
@{
    ViewData["Title"] = "کاربران"; Layout = "~/Pages/Shared/_AdminLayout.cshtml";
}
<div class="vz-page" dir="rtl">
<section class="vz-hero">
<div class="vz-hero-main">
<div class="vz-eyebrow">
<i data-lucide="users">
</i>کاربران</div>

<h1 class="vz-title">مدیریت کاربران</h1>
<p class="vz-desc">وضعیت کاربران، احراز هویت و دسترسی‌ها را بررسی کن.</p>
</div>

</section>
@if(!string.IsNullOrWhiteSpace(Model.SuccessMessage)){
<div class="vz-alert vz-alert-success">
<i data-lucide="check-circle-2">
</i>
<span>@Model.SuccessMessage</span>
</div>
}
@if(!string.IsNullOrWhiteSpace(Model.ErrorMessage)){
<div class="vz-alert vz-alert-danger">
<i data-lucide="triangle-alert">
</i>
<span>@Model.ErrorMessage</span>
</div>
}
<section class="vz-table-card">
<form method="get" class="vz-filter-grid" style="margin-bottom:18px">
<div class="vz-field">
<label>جستجو</label>
<div class="vz-input-shell">
<i data-lucide="search">
</i>
<input asp-for="Search" class="vz-input" placeholder="نام، موبایل یا ایمیل" />
</div>

</div>

<div class="vz-actions">
<button class="vz-btn vz-btn-light">
<i data-lucide="filter">
</i>جستجو</button>
</div>

</form>

<div class="vz-table-wrap">
<table class="vz-table">
<thead>
<tr>
<th>کاربر</th>
<th>موبایل</th>
<th>وضعیت</th>
<th>احراز هویت</th>
<th>تاریخ عضویت</th>
<th>عملیات</th>
</tr>

</thead>

<tbody>@foreach(var u in Model.Users){
<tr>
<td>
<div class="vz-item">
<div class="vz-thumb-fallback sm">
<i data-lucide="user">
</i>
</div>

<div class="vz-item-text">
<strong>@u.FullName</strong>
<span>@(u.Email ?? "-")</span>
</div>

</div>

</td>
<td>@u.Mobile</td>
<td>
<span class="@AdminUiHelper.StatusBadgeClass(u.Status)">@AdminUiHelper.UserStatus(u.Status)</span>
</td>
<td>@AdminUiHelper.VerificationStatus(u.VerificationStatus)</td>
<td>@AdminUiHelper.Date(u.CreatedAt)</td>
<td>
<div class="vz-actions">
<a asp-page="Details" asp-route-id="@u.Id" class="vz-icon-btn info">
<i data-lucide="eye">
</i>
</a>
<form method="post" asp-page-handler="Status" asp-route-id="@u.Id" asp-route-action="activate">
<button class="vz-icon-btn success">
<i data-lucide="check">
</i>
</button>
</form>

<form method="post" asp-page-handler="Status" asp-route-id="@u.Id" asp-route-action="block">
<button class="vz-icon-btn danger">
<i data-lucide="ban">
</i>
</button>
</form>

</div>

</td>
</tr>
}
</tbody>

</table>

</div>

</section>

</div>

@section Scripts {
<script>
if(window.lucide){lucide.createIcons();}

</script>
 }
