@page
@model Vitorize.Web.Pages.Admin.Banners.IndexModel
@{
    ViewData["Title"] = "بنرها";
    Layout = "~/Pages/Shared/_AdminLayout.cshtml";
}

<div class="vz-page" dir="rtl">
    <section class="vz-hero">
        <div class="vz-hero-main">
            <div class="vz-eyebrow">
<i data-lucide="image-plus">
</i>بنرها</div>

            <h1 class="vz-title">مدیریت بنرهای سایت</h1>
            <p class="vz-desc">بنرهای صفحه اصلی و کمپین‌های فروش را مدیریت کن.</p>
        </div>

        <div class="vz-actions">
            <a asp-page="Create" class="vz-btn vz-btn-primary">
<i data-lucide="plus">
</i>افزودن بنر</a>
        </div>

    </section>

    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
    {
        <div class="vz-alert vz-alert-success">
<i data-lucide="check-circle-2">
</i>
<span>@Model.SuccessMessage</span>
</div>

    }
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="vz-alert vz-alert-danger">
<i data-lucide="triangle-alert">
</i>
<span>@Model.ErrorMessage</span>
</div>

    }

    <section class="vz-stats">
        <article class="vz-stats-card">
<div class="vz-stat-icon purple">
<i data-lucide="images">
</i>
</div>

<div class="vz-stat-content">
<span class="vz-stat-label">کل بنرها</span>
<strong class="vz-stat-value">@Model.TotalCount</strong>
</div>

</article>
        <article class="vz-stats-card">
<div class="vz-stat-icon green">
<i data-lucide="check-circle-2">
</i>
</div>

<div class="vz-stat-content">
<span class="vz-stat-label">فعال</span>
<strong class="vz-stat-value">@Model.ActiveCount</strong>
</div>

</article>
        <article class="vz-stats-card">
<div class="vz-stat-icon orange">
<i data-lucide="pause-circle">
</i>
</div>

<div class="vz-stat-content">
<span class="vz-stat-label">غیرفعال</span>
<strong class="vz-stat-value">@Model.InactiveCount</strong>
</div>

</article>
        <article class="vz-stats-card">
<div class="vz-stat-icon blue">
<i data-lucide="calendar-clock">
</i>
</div>

<div class="vz-stat-content">
<span class="vz-stat-label">زمان‌بندی‌شده</span>
<strong class="vz-stat-value">@Model.ScheduledCount</strong>
</div>

</article>
    </section>

    <section class="vz-table-card">
        <form method="get" class="vz-filter-grid" style="margin-bottom:18px">
            <div class="vz-field">
                <label>جستجو</label>
                <div class="vz-input-shell">
<i data-lucide="search">
</i>
<input class="vz-input" asp-for="Search" placeholder="عنوان، لینک یا جایگاه" />
</div>

            </div>

            <div class="vz-field">
                <label>جایگاه</label>
                <div class="vz-input-shell">
<i data-lucide="layout-template">
</i>
<select class="vz-select" asp-for="Position">
<option value="">همه جایگاه‌ها</option>@foreach (var p in Model.Positions){
<option value="@p.Value">@p.Title</option>}
</select>
</div>

            </div>

            <div class="vz-field">
                <label>وضعیت</label>
                <div class="vz-input-shell">
<i data-lucide="toggle-right">
</i>
<select class="vz-select" asp-for="IsActive">
<option value="">همه</option>
<option value="true">فعال</option>
<option value="false">غیرفعال</option>
</select>
</div>

            </div>

            <div class="vz-actions">
                <button type="submit" class="vz-btn vz-btn-light">
<i data-lucide="filter">
</i>اعمال فیلتر</button>
                <a asp-page="Index" class="vz-btn vz-btn-light">
<i data-lucide="rotate-ccw">
</i>پاک کردن</a>
            </div>

        </form>

        @if (!Model.Items.Any())
        {
            <div class="vz-empty">
<div class="vz-empty-icon">
<i data-lucide="image-off">
</i>
</div>

<h3>بنری پیدا نشد</h3>
<p>برای شروع، یک بنر جدید اضافه کن.</p>
</div>

        }
        else
        {
            <div class="vz-table-wrap">
                <table class="vz-table">
                    <thead>
<tr>
<th>بنر</th>
<th>جایگاه</th>
<th>وضعیت</th>
<th>زمان نمایش</th>
<th>عملیات</th>
</tr>

</thead>

                    <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>
                                <div class="vz-item">
                                    <div class="vz-thumb">
<img src="@Model.Image(item.ImagePath)" alt="@item.Title" />
</div>

                                    <div class="vz-item-text">
<strong>@item.Title</strong>
<span>@(string.IsNullOrWhiteSpace(item.LinkUrl) ? "بدون لینک" : item.LinkUrl)</span>
</div>

                                </div>

                            </td>
                            <td>
<span class="vz-badge vz-badge-primary">@Model.PositionTitle(item.Position)</span>
<small class="vz-code" style="margin-top:8px">@item.SortOrder</small>
</td>
                            <td>@if (item.IsActive) { <span class="vz-badge vz-badge-success">فعال</span> } else { <span class="vz-badge vz-badge-muted">غیرفعال</span> }
</td>
                            <td>
<div class="vz-item-text">
<span>شروع: @Model.Date(item.StartsAt)</span>
<span>پایان: @Model.Date(item.EndsAt)</span>
</div>

</td>
                            <td>
                                <div class="vz-actions">
                                    <a asp-page="Details" asp-route-id="@item.Id" class="vz-icon-btn info" title="جزئیات">
<i data-lucide="eye">
</i>
</a>
                                    <a asp-page="Edit" asp-route-id="@item.Id" class="vz-icon-btn" title="ویرایش">
<i data-lucide="pencil">
</i>
</a>
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@item.Id" onsubmit="return confirm('آیا از حذف این بنر مطمئن هستید؟');">
                                        <button class="vz-icon-btn danger" type="submit" title="حذف">
<i data-lucide="trash-2">
</i>
</button>
                                    </form>

                                </div>

                            </td>
                        </tr>

                    }
                    </tbody>

                </table>

            </div>

        }
    </section>

</div>

@section Scripts {
<script>
if(window.lucide){lucide.createIcons();}

</script>
 }
