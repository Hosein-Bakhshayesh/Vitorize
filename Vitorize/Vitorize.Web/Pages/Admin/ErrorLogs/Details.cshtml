@page "{id:guid}"
@model Vitorize.Web.Pages.Admin.ErrorLogs.DetailsModel
@using Vitorize.Web.Helpers
@{
    ViewData["Title"]="جزئیات خطا";
    Layout="~/Pages/Shared/_AdminLayout.cshtml";
}
<div class="vz-page" dir="rtl">
<section class="vz-hero">
<div class="vz-hero-main">
<div class="vz-eyebrow">
<i data-lucide="triangle-alert">
</i>خطا</div>

<h1 class="vz-title">جزئیات خطا</h1>
<p class="vz-desc">@AdminUiHelper.Date(Model.Item.CreatedAt)</p>
</div>

<a asp-page="Index" class="vz-btn vz-btn-light">
<i data-lucide="arrow-right">
</i>بازگشت</a>
</section>

<section class="vz-form-card">
<div class="vz-kv">
<div class="vz-kv-item">
<span>زمان</span>
<strong>@AdminUiHelper.Date(Model.Item.CreatedAt)</strong>
</div>

<div class="vz-kv-item">
<span>منبع</span>
<strong>@(Model.Item.Source ?? "-")</strong>
</div>

</div>

<div class="vz-field" style="margin-top:18px">
<label>پیام</label>
<div class="vz-muted-box">@Model.Item.Message</div>

</div>
@if(!string.IsNullOrWhiteSpace(Model.Item.StackTrace)){
<div class="vz-field" style="margin-top:18px">
<label>جزئیات فنی</label>
<pre class="vz-stack-box">@Model.Item.StackTrace</pre>
</div>
}
</section>

</div>

@section Scripts {

<script>
if(window.lucide){lucide.createIcons();}

</script>
}
