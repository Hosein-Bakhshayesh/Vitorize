@page
@model Vitorize.Web.Pages.Admin.ErrorLogs.IndexModel
@using Vitorize.Web.Helpers
@{
    ViewData["Title"]="خطاها";
    Layout="~/Pages/Shared/_AdminLayout.cshtml";
}
<div class="vz-page" dir="rtl">
<section class="vz-hero">
<div class="vz-hero-main">
<div class="vz-eyebrow">
<i data-lucide="triangle-alert">
</i>خطاها</div>

<h1 class="vz-title">خطاهای ثبت‌شده</h1>
<p class="vz-desc">خطاهای سیستم را بررسی و برای رفع مشکل پیگیری کن.</p>
</div>

</section>
@if(!string.IsNullOrWhiteSpace(Model.ErrorMessage)){
<div class="vz-alert vz-alert-danger">
<i data-lucide="triangle-alert">
</i>
<span>@Model.ErrorMessage</span>
</div>
}
<section class="vz-form-card">
<form method="get" class="vz-filter-grid">
<div class="vz-field">
<label>جستجو</label>
<div class="vz-input-shell">
<i data-lucide="search">
</i>
<input name="Filter.Search" value="@Model.Filter.Search" class="vz-input" placeholder="متن خطا یا منبع" />
</div>

</div>

<div class="vz-field">
<label>از تاریخ</label>
<div class="vz-input-shell">
<input type="date" name="Filter.DateFrom" value='@(Model.Filter.DateFrom?.ToString("yyyy-MM-dd"))' class="vz-input ltr" />
</div>

</div>

<div class="vz-field">
<label>تا تاریخ</label>
<div class="vz-input-shell">
<input type="date" name="Filter.DateTo" value='@(Model.Filter.DateTo?.ToString("yyyy-MM-dd"))' class="vz-input ltr" />
</div>

</div>

<button class="vz-btn vz-btn-primary">
<i data-lucide="filter">
</i>اعمال</button>
</form>

</section>

<section class="vz-table-card">
<div class="vz-table-wrap">
<table class="vz-table">
<thead>
<tr>
<th>پیام</th>
<th>منبع</th>
<th>زمان</th>
<th>
</th>
</tr>

</thead>

<tbody>@foreach(var item in Model.Items){
<tr>
<td>
<div class="vz-log-message">@item.Message</div>

</td>
<td>@(item.Source ?? "-")</td>
<td>@AdminUiHelper.Date(item.CreatedAt)</td>
<td>
<a asp-page="Details" asp-route-id="@item.Id" class="vz-icon-btn info">
<i data-lucide="eye">
</i>
</a>
</td>
</tr>
}
</tbody>

</table>

</div>
@if(!Model.Items.Any()){
<div class="vz-empty">
<div class="vz-empty-icon">
<i data-lucide="check-circle-2">
</i>
</div>

<h3>خطایی برای نمایش وجود ندارد</h3>
<p>در بازه انتخاب‌شده خطایی ثبت نشده است.</p>
</div>
}
</section>

</div>

@section Scripts {

<script>
if(window.lucide){lucide.createIcons();}

</script>
}
