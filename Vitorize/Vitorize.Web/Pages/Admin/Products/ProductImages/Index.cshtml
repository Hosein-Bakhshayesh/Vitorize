@page
@model Vitorize.Web.Pages.Admin.ProductImages.IndexModel

@{
    ViewData["Title"] = "تصاویر محصول";
    Layout = "~/Pages/Shared/_AdminLayout.cshtml";
}

<div class="product-images-page" dir="rtl">

    <section class="pi-hero">
        <div class="pi-hero-main">
            <div class="pi-product-preview">
                @if (!string.IsNullOrWhiteSpace(Model.GetProductImagePath()))
                {
                    <img src="@Model.GetProductImagePath()" alt="@Model.Product?.Title" />
                }
                else
                {
                    <span>@Model.GetProductInitial()</span>
                }
            </div>

            <div>
                <div class="pi-eyebrow">
                    <i data-lucide="image"></i>
                    مدیریت گالری محصول
                </div>

                <h1>@(Model.Product?.Title ?? "تصاویر محصول")</h1>

                <p>
                    تصاویر محصول را آپلود کن، تصویر اصلی را انتخاب کن، متن جایگزین و ترتیب نمایش را مدیریت کن.
                    فایل روی سرور ذخیره می‌شود و فقط مسیر آن در دیتابیس ثبت می‌شود.
                </p>

                @if (Model.Product != null)
                {
                    <div class="pi-hero-meta">
                        <span>
                            <i data-lucide="folder"></i>
                            @Model.Product.CategoryTitle
                        </span>

                        <span>
                            <i data-lucide="badge-check"></i>
                            @(Model.Product.BrandTitle ?? "بدون برند")
                        </span>

                        <span>
                            <i data-lucide="images"></i>
                            @Model.FormatNumber(Model.Images.Count)
                            تصویر
                        </span>
                    </div>
                }
            </div>
        </div>

        <div class="pi-hero-actions">
            <a asp-page="/Admin/Products/Details"
               asp-route-id="@Model.ProductId"
               class="pi-btn pi-btn-soft">
                <i data-lucide="eye"></i>
                جزئیات محصول
            </a>

            <a asp-page="/Admin/Products/Edit"
               asp-route-id="@Model.ProductId"
               class="pi-btn pi-btn-soft">
                <i data-lucide="pencil"></i>
                ویرایش محصول
            </a>

            <a asp-page="/Admin/Products/Index"
               class="pi-btn pi-btn-soft">
                <i data-lucide="arrow-right"></i>
                بازگشت
            </a>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
    {
        <div class="pi-alert success">
            <i data-lucide="check-circle-2"></i>
            <span>@Model.SuccessMessage</span>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="pi-alert danger">
            <i data-lucide="triangle-alert"></i>
            <span>@Model.ErrorMessage</span>
        </div>
    }

    <section class="pi-upload-card">
        <div class="pi-upload-header">
            <div>
                <div class="pi-card-kicker">
                    <i data-lucide="upload-cloud"></i>
                    آپلود تصویر جدید
                </div>

                <h2>افزودن تصویر به گالری</h2>

                <p>
                    فرمت‌های مجاز: JPG، JPEG، PNG، WEBP. حجم پیشنهادی کمتر از ۵ مگابایت.
                </p>
            </div>

            <div class="pi-upload-badge">
                <span>Storage</span>
                <small>/uploads/products</small>
            </div>
        </div>

        <form method="post"
              enctype="multipart/form-data"
              asp-page-handler="Upload"
              asp-route-productId="@Model.ProductId"
              class="pi-upload-form">

            <div class="pi-upload-preview">
                <img id="imagePreview" src="" alt="Preview" hidden />

                <div id="imagePreviewPlaceholder" class="pi-upload-placeholder">
                    <i data-lucide="image-plus"></i>
                    <strong>Preview</strong>
                    <small>تصویر انتخاب‌شده اینجا نمایش داده می‌شود</small>
                </div>
            </div>

            <div class="pi-upload-fields">
                <div class="pi-file-zone">
                    <i data-lucide="upload"></i>

                    <div>
                        <strong>انتخاب فایل تصویر</strong>
                        <small>فایل را انتخاب کن تا قبل از آپلود پیش‌نمایش داده شود.</small>
                    </div>

                    <input asp-for="ImageFile"
                           type="file"
                           class="pi-file-input"
                           accept="image/jpeg,image/png,image/webp"
                           onchange="previewProductImage(event)" />
                </div>

                <div class="pi-form-grid">
                    <div class="pi-field">
                        <label asp-for="AltText">Alt Text</label>
                        <input asp-for="AltText"
                               class="pi-control"
                               autocomplete="off"
                               placeholder="مثلاً تصویر گیفت کارت پلی استیشن" />
                        <span asp-validation-for="AltText" class="pi-validation"></span>
                    </div>

                    <div class="pi-field">
                        <label asp-for="SortOrder">ترتیب نمایش</label>
                        <input asp-for="SortOrder"
                               class="pi-control ltr"
                               type="number"
                               inputmode="numeric"
                               placeholder="مثلاً 10" />
                        <span asp-validation-for="SortOrder" class="pi-validation"></span>
                    </div>

                    <label class="pi-switch">
                        <span>
                            <strong>تصویر اصلی محصول</strong>
                            <small>این تصویر به عنوان Thumbnail محصول ثبت شود.</small>
                        </span>

                        <input asp-for="SetAsThumbnail" class="pi-switch-input" />
                        <i class="pi-switch-ui"></i>
                    </label>

                    <button type="submit" class="pi-btn pi-btn-primary pi-upload-submit">
                        <i data-lucide="upload-cloud"></i>
                        آپلود و ثبت مسیر
                    </button>
                </div>
            </div>
        </form>
    </section>

    @if (!Model.Images.Any())
    {
        <section class="pi-empty">
            <div class="pi-empty-icon">
                <i data-lucide="image-off"></i>
            </div>

            <h2>هنوز تصویری برای این محصول ثبت نشده</h2>

            <p>
                اولین تصویر را از بخش بالا آپلود کن. بعد از آپلود، مسیر تصویر در دیتابیس ذخیره می‌شود.
            </p>
        </section>
    }
    else
    {
        <section class="pi-gallery-card">
            <div class="pi-gallery-header">
                <div>
                    <div class="pi-card-kicker">
                        <i data-lucide="gallery-horizontal"></i>
                        گالری محصول
                    </div>

                    <h2>تصاویر ثبت‌شده</h2>

                    <p>
                        تصویر اصلی، Alt Text و ترتیب نمایش تصاویر محصول را مدیریت کن.
                    </p>
                </div>

                <span>
                    @Model.FormatNumber(Model.Images.Count)
                    تصویر
                </span>
            </div>

            <div class="pi-gallery-grid">
                @foreach (var image in Model.Images)
                {
                    <article class="pi-image-card">
                        <div class="pi-image-frame">
                            <img src="@Model.GetImagePath(image.ImagePath)"
                                 alt="@image.AltText" />

                            <div class="pi-image-badges">
                                @if (image.IsThumbnail)
                                {
                                    <span class="pi-badge success">
                                        <i data-lucide="star"></i>
                                        تصویر اصلی
                                    </span>
                                }

                                <span class="pi-badge dark">
                                    #@image.SortOrder
                                </span>
                            </div>
                        </div>

                        <div class="pi-image-body">
                            <form method="post"
                                  asp-page-handler="Update"
                                  asp-route-productId="@Model.ProductId"
                                  asp-route-imageId="@image.Id"
                                  class="pi-image-edit-form">

                                <div class="pi-field">
                                    <label>Alt Text</label>
                                    <input name="altText"
                                           value="@image.AltText"
                                           class="pi-control"
                                           autocomplete="off"
                                           placeholder="Alt Text تصویر" />
                                </div>

                                <div class="pi-field">
                                    <label>Sort Order</label>
                                    <input name="sortOrder"
                                           value="@image.SortOrder"
                                           type="number"
                                           class="pi-control ltr"
                                           inputmode="numeric" />
                                </div>

                                <button type="submit" class="pi-mini-btn primary">
                                    <i data-lucide="save"></i>
                                    ذخیره اطلاعات
                                </button>
                            </form>

                            <div class="pi-path-box">
                                <span>مسیر ذخیره‌شده در دیتابیس</span>
                                <code>@image.ImagePath</code>
                            </div>

                            <div class="pi-image-actions">
                                <form method="post"
                                      asp-page-handler="SetThumbnail"
                                      asp-route-productId="@Model.ProductId"
                                      asp-route-imageId="@image.Id">
                                    <button type="submit"
                                            class="pi-mini-icon success"
                                            title="انتخاب تصویر اصلی"
                                            disabled="@image.IsThumbnail">
                                        <i data-lucide="star"></i>
                                    </button>
                                </form>

                                <a href="@Model.GetImagePath(image.ImagePath)"
                                   target="_blank"
                                   class="pi-mini-icon view"
                                   title="نمایش تصویر">
                                    <i data-lucide="external-link"></i>
                                </a>

                                <form method="post"
                                      asp-page-handler="Delete"
                                      asp-route-productId="@Model.ProductId"
                                      asp-route-imageId="@image.Id"
                                      onsubmit="return confirm('آیا از حذف این تصویر مطمئن هستید؟ فایل از سرور و رکورد از دیتابیس حذف می‌شود.');">
                                    <button type="submit"
                                            class="pi-mini-icon danger"
                                            title="حذف تصویر">
                                        <i data-lucide="trash-2"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </article>
                }
            </div>
        </section>
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function previewProductImage(event) {
            const file = event.target.files && event.target.files.length > 0
                ? event.target.files[0]
                : null;

            const preview = document.getElementById('imagePreview');
            const placeholder = document.getElementById('imagePreviewPlaceholder');

            if (!preview || !placeholder) {
                return;
            }

            if (!file) {
                preview.src = '';
                preview.hidden = true;
                placeholder.hidden = false;
                return;
            }

            const reader = new FileReader();

            reader.onload = function (e) {
                preview.src = e.target.result;
                preview.hidden = false;
                placeholder.hidden = true;
            };

            reader.readAsDataURL(file);
        }

        if (window.lucide) {
            lucide.createIcons();
        }
    </script>
}