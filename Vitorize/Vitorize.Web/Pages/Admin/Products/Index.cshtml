@page
@model Vitorize.Web.Pages.Admin.Products.IndexModel
@using Vitorize.Web.Helpers
@using Vitorize.Shared.Enums
@{
    ViewData["Title"] = "محصولات";
    Layout = "~/Pages/Shared/_AdminLayout.cshtml";
}
<div class="vz-page" dir="rtl">
    <section class="vz-hero">
        <div class="vz-hero-main">
<div class="vz-eyebrow">
<i data-lucide="package">
</i>محصولات</div>

<h1 class="vz-title">مدیریت محصولات</h1>
<p class="vz-desc">محصولات، قیمت‌ها، وضعیت فروش و مسیرهای مدیریت تصویر و واریانت را کنترل کن.</p>
</div>

        <div class="vz-actions">
<a asp-page="Create" class="vz-btn vz-btn-primary">
<i data-lucide="plus">
</i>محصول جدید</a>
</div>

    </section>

    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage)) { <div class="vz-alert vz-alert-success">
<i data-lucide="check-circle-2">
</i>
<span>@Model.SuccessMessage</span>
</div>
 }
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage)) { <div class="vz-alert vz-alert-danger">
<i data-lucide="triangle-alert">
</i>
<span>@Model.ErrorMessage</span>
</div>
 }
    <section class="vz-stats">
        <article class="vz-stats-card">
<div class="vz-stat-icon purple">
<i data-lucide="package">
</i>
</div>

<div class="vz-stat-content">
<span class="vz-stat-label">کل محصولات</span>
<strong class="vz-stat-value">@Model.TotalCount</strong>
</div>

</article>
        <article class="vz-stats-card">
<div class="vz-stat-icon green">
<i data-lucide="check-circle-2">
</i>
</div>

<div class="vz-stat-content">
<span class="vz-stat-label">فعال</span>
<strong class="vz-stat-value">@Model.ActiveCount</strong>
</div>

</article>
        <article class="vz-stats-card">
<div class="vz-stat-icon blue">
<i data-lucide="star">
</i>
</div>

<div class="vz-stat-content">
<span class="vz-stat-label">ویژه</span>
<strong class="vz-stat-value">@Model.FeaturedCount</strong>
</div>

</article>
        <article class="vz-stats-card">
<div class="vz-stat-icon orange">
<i data-lucide="credit-card">
</i>
</div>

<div class="vz-stat-content">
<span class="vz-stat-label">کد آماده</span>
<strong class="vz-stat-value">@Model.GiftCodeStock</strong>
</div>

</article>
    </section>

    <section class="vz-table-card">
        <form method="get" class="vz-filter-grid" style="margin-bottom:18px">
            <div class="vz-field">
<label>جستجو</label>
<div class="vz-input-shell">
<i data-lucide="search">
</i>
<input asp-for="Search" class="vz-input" placeholder="عنوان، دسته‌بندی یا برند" />
</div>

</div>

            <div class="vz-field">
<label>نوع محصول</label>
<div class="vz-input-shell">
<i data-lucide="filter">
</i>
<select asp-for="ProductType" class="vz-select">
<option value="">همه</option>
<option value="1">گیفت کارت</option>
<option value="2">اکانت بازی</option>
<option value="3">سرویس بازی</option>
<option value="4">اشتراک</option>
<option value="99">سایر</option>
</select>
</div>

</div>

            <div class="vz-field">
<label>وضعیت</label>
<div class="vz-input-shell">
<i data-lucide="toggle-left">
</i>
<select asp-for="IsActive" class="vz-select">
<option value="">همه</option>
<option value="true">فعال</option>
<option value="false">غیرفعال</option>
</select>
</div>

</div>

            <div class="vz-actions">
<button class="vz-btn vz-btn-light">
<i data-lucide="filter">
</i>فیلتر</button>
<a asp-page="Index" class="vz-btn vz-btn-light">
<i data-lucide="rotate-ccw">
</i>پاک کردن</a>
</div>

        </form>

        @if (!Model.Products.Any()) { <div class="vz-empty">
<div class="vz-empty-icon">
<i data-lucide="inbox">
</i>
</div>

<h3>محصولی پیدا نشد</h3>
<p>برای شروع، محصول جدید اضافه کن.</p>
</div>
 }
        else { <div class="vz-table-wrap">
<table class="vz-table">
<thead>
<tr>
<th>محصول</th>
<th>نوع</th>
<th>قیمت</th>
<th>موجودی</th>
<th>وضعیت</th>
<th>عملیات</th>
</tr>

</thead>

<tbody>
        @foreach (var item in Model.Products) {
            <tr>
                <td>
<div class="vz-item">@if (!string.IsNullOrWhiteSpace(item.ThumbnailImagePath)) { <div class="vz-thumb">
<img src="@Model.Image(item.ThumbnailImagePath)" alt="@item.Title" />
</div>
 } else { <div class="vz-thumb-fallback">
<i data-lucide="package">
</i>
</div>
 }
<div class="vz-item-text">
<strong>@item.Title</strong>
<span>@item.CategoryTitle · @(item.BrandTitle ?? "بدون برند")</span>
<small>@item.Slug</small>
</div>

</div>

</td>
                <td>
<span class="vz-badge vz-badge-primary">@AdminUiHelper.ProductType(item.ProductType)</span>
</td>
                <td>
<strong>@AdminUiHelper.Money(item.FinalPrice, item.CurrencyType)</strong>@if (item.DiscountPrice.HasValue && item.DiscountPrice.Value > 0) { <small style="display:block;color:#94a3b8;text-decoration:line-through">@AdminUiHelper.Money(item.BasePrice, item.CurrencyType)</small> }
</td>
                <td>@item.AvailableStock</td>
                <td>@if (item.IsActive) { <span class="vz-badge vz-badge-success">فعال</span> } else { <span class="vz-badge vz-badge-muted">غیرفعال</span> } @if (item.IsFeatured) { <span class="vz-badge vz-badge-warning">ویژه</span> }
</td>
                <td>
<div class="vz-actions">
<a asp-page="Details" asp-route-id="@item.Id" class="vz-icon-btn info">
<i data-lucide="eye">
</i>
</a>
<a asp-page="Edit" asp-route-id="@item.Id" class="vz-icon-btn">
<i data-lucide="pencil">
</i>
</a>
<a asp-page="/Admin/ProductImages/Index" asp-route-productId="@item.Id" class="vz-icon-btn success">
<i data-lucide="image">
</i>
</a>
<a asp-page="/Admin/ProductVariants/Index" asp-route-productId="@item.Id" class="vz-icon-btn success">
<i data-lucide="layers-3">
</i>
</a>
<form method="post" asp-page-handler="Delete" asp-route-id="@item.Id" onsubmit="return confirm('آیا از حذف این محصول مطمئن هستید؟');">
<button class="vz-icon-btn danger" type="submit">
<i data-lucide="trash-2">
</i>
</button>
</form>

</div>

</td>
            </tr>

        }
        </tbody>

</table>

</div>
 }
    </section>

</div>

@section Scripts {
<script>
if(window.lucide){lucide.createIcons();}

</script>
 }
