@page
@model Vitorize.Web.Pages.Admin.Products.IndexModel
@{
    ViewData["Title"] = "مدیریت محصولات";
    Layout = "~/Pages/Shared/_AdminLayout.cshtml";
}

<div class="space-y-6" dir="rtl">
    <div class="rounded-[2rem] border border-white/70 bg-white/80 p-6 shadow-xl backdrop-blur-xl">
        <div class="flex flex-col gap-5 lg:flex-row lg:items-center lg:justify-between">
            <div>
                <p class="text-sm font-black text-fuchsia-600">Products Center</p>
                <h1 class="mt-2 text-3xl font-black text-slate-900">مدیریت محصولات</h1>
                <p class="mt-2 text-sm text-slate-500">ساخت، ویرایش، تصاویر، تنوع‌ها و موجودی محصولات Vitorize</p>
            </div>

            <a asp-page="/Admin/Products/Create"
               class="inline-flex items-center justify-center rounded-2xl bg-slate-950 px-5 py-3 text-sm font-black text-white shadow-lg shadow-slate-300">
                + محصول جدید
            </a>
        </div>
    </div>

    <div class="grid gap-4 md:grid-cols-4">
        <div class="rounded-[1.5rem] bg-white/80 p-5 shadow-sm ring-1 ring-white/70">
            <p class="text-xs font-bold text-slate-500">کل محصولات</p>
            <p class="mt-2 text-2xl font-black text-slate-900">@Model.TotalProducts</p>
        </div>
        <div class="rounded-[1.5rem] bg-white/80 p-5 shadow-sm ring-1 ring-white/70">
            <p class="text-xs font-bold text-slate-500">فعال</p>
            <p class="mt-2 text-2xl font-black text-emerald-600">@Model.ActiveProducts</p>
        </div>
        <div class="rounded-[1.5rem] bg-white/80 p-5 shadow-sm ring-1 ring-white/70">
            <p class="text-xs font-bold text-slate-500">ویژه</p>
            <p class="mt-2 text-2xl font-black text-fuchsia-600">@Model.FeaturedProducts</p>
        </div>
        <div class="rounded-[1.5rem] bg-white/80 p-5 shadow-sm ring-1 ring-white/70">
            <p class="text-xs font-bold text-slate-500">ناموجود</p>
            <p class="mt-2 text-2xl font-black text-rose-600">@Model.OutOfStockProducts</p>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
    {
        <div class="rounded-2xl border border-emerald-200 bg-emerald-50 px-5 py-4 text-sm font-bold text-emerald-700">
            @Model.SuccessMessage
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="rounded-2xl border border-rose-200 bg-rose-50 px-5 py-4 text-sm font-bold text-rose-700">
            @Model.ErrorMessage
        </div>
    }

    <form method="get" class="rounded-[2rem] border border-white/70 bg-white/80 p-5 shadow-sm backdrop-blur">
        <div class="grid gap-3 lg:grid-cols-12">
            <input asp-for="Search"
                   placeholder="جستجو بر اساس نام، اسلاگ، برند یا دسته‌بندی..."
                   class="lg:col-span-7 rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm outline-none focus:border-fuchsia-400" />

            <select asp-for="Status"
                    class="lg:col-span-3 rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm outline-none">
                <option value="">همه وضعیت‌ها</option>
                <option value="active">فعال</option>
                <option value="inactive">غیرفعال</option>
                <option value="featured">ویژه</option>
                <option value="out-stock">ناموجود</option>
            </select>

            <button class="lg:col-span-2 rounded-2xl bg-slate-900 px-5 py-3 text-sm font-black text-white">
                فیلتر
            </button>
        </div>
    </form>

    <div class="grid gap-5">
        @foreach (var product in Model.Products)
        {
            <div class="rounded-[2rem] border border-white/70 bg-white/85 p-5 shadow-sm backdrop-blur transition hover:-translate-y-1 hover:shadow-xl">
                <div class="flex flex-col gap-5 xl:flex-row xl:items-center xl:justify-between">
                    <div class="flex gap-4">
                        <div class="h-24 w-24 overflow-hidden rounded-3xl bg-slate-100 ring-1 ring-slate-200">
                            @if (!string.IsNullOrWhiteSpace(product.ThumbnailImagePath))
                            {
                                <img src="@product.ThumbnailImagePath" class="h-full w-full object-cover" />
                            }
                            else
                            {
                                <div class="flex h-full w-full items-center justify-center text-xs font-bold text-slate-400">
                                    No Image
                                </div>
                            }
                        </div>

                        <div>
                            <div class="flex flex-wrap items-center gap-2">
                                <h2 class="text-xl font-black text-slate-900">@product.Title</h2>

                                @if (product.IsActive)
                                {
                                    <span class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-black text-emerald-700">فعال</span>
                                }
                                else
                                {
                                    <span class="rounded-full bg-rose-50 px-3 py-1 text-xs font-black text-rose-700">غیرفعال</span>
                                }

                                @if (product.IsFeatured)
                                {
                                    <span class="rounded-full bg-fuchsia-50 px-3 py-1 text-xs font-black text-fuchsia-700">ویژه</span>
                                }
                            </div>

                            <p class="mt-1 text-xs text-slate-400">@product.Slug</p>

                            <div class="mt-3 flex flex-wrap gap-2 text-xs font-bold">
                                <span class="rounded-xl bg-slate-100 px-3 py-2 text-slate-600">@product.CategoryTitle</span>
                                <span class="rounded-xl bg-slate-100 px-3 py-2 text-slate-600">@(product.BrandTitle ?? "بدون برند")</span>
                                <span class="rounded-xl bg-cyan-50 px-3 py-2 text-cyan-700">@Model.GetProductType(product.ProductType)</span>
                                <span class="rounded-xl bg-indigo-50 px-3 py-2 text-indigo-700">@Model.GetDeliveryType(product.DeliveryType)</span>
                            </div>
                        </div>
                    </div>

                    <div class="grid gap-3 sm:grid-cols-3 xl:w-[420px]">
                        <div class="rounded-2xl bg-slate-50 p-4">
                            <p class="text-xs font-bold text-slate-400">قیمت</p>
                            <p class="mt-1 text-sm font-black text-slate-900">@Model.FormatMoney(product.FinalPrice)</p>
                        </div>
                        <div class="rounded-2xl bg-slate-50 p-4">
                            <p class="text-xs font-bold text-slate-400">موجودی</p>
                            <p class="mt-1 text-sm font-black @(product.AvailableStock <= 0 ? "text-rose-600" : "text-emerald-600")">@product.AvailableStock</p>
                        </div>
                        <div class="rounded-2xl bg-slate-50 p-4">
                            <p class="text-xs font-bold text-slate-400">تنوع</p>
                            <p class="mt-1 text-sm font-black text-slate-900">@(product.HasVariants ? "دارد" : "ندارد")</p>
                        </div>
                    </div>
                </div>

                <div class="mt-5 flex flex-wrap gap-2 border-t border-slate-100 pt-4">
                    <a asp-page="/Admin/Products/Details" asp-route-id="@product.Id"
                       class="rounded-xl bg-slate-100 px-4 py-2 text-xs font-black text-slate-700">جزئیات</a>

                    <a asp-page="/Admin/Products/Edit" asp-route-id="@product.Id"
                       class="rounded-xl bg-indigo-50 px-4 py-2 text-xs font-black text-indigo-700">ویرایش</a>

                    <a asp-page="/Admin/Products/Images/Index" asp-route-productId="@product.Id"
                       class="rounded-xl bg-fuchsia-50 px-4 py-2 text-xs font-black text-fuchsia-700">تصاویر</a>

                    <a asp-page="/Admin/Products/Variants/Index" asp-route-productId="@product.Id"
                       class="rounded-xl bg-cyan-50 px-4 py-2 text-xs font-black text-cyan-700">تنوع‌ها</a>

                    <a href="/Admin/GiftCodes?productId=@product.Id"
                       class="rounded-xl bg-amber-50 px-4 py-2 text-xs font-black text-amber-700">کدها</a>

                    <form method="post"
                          asp-page-handler="Delete"
                          asp-route-id="@product.Id"
                          onsubmit="return confirm('محصول حذف شود؟')">
                        <button class="rounded-xl bg-rose-50 px-4 py-2 text-xs font-black text-rose-700">
                            حذف
                        </button>
                    </form>
                </div>
            </div>
        }
    </div>
</div>