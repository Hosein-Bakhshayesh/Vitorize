@page "{id:guid}"
@model Vitorize.Web.Pages.Admin.Products.EditModel

@{
    ViewData["Title"] = "ویرایش محصول";
    Layout = "~/Pages/Shared/_AdminLayout.cshtml";
}

<div class="product-form-page" dir="rtl">

    <section class="pf-hero">
        <div class="pf-hero-content">
            <div class="pf-hero-title-with-image">
                <div class="pf-preview-thumb">
                    @if (!string.IsNullOrWhiteSpace(Model.GetImagePath()))
                    {
                        <img src="@Model.GetImagePath()" alt="@Model.Product.Title" />
                    }
                    else
                    {
                        <span>@Model.GetProductInitial()</span>
                    }
                </div>

                <div>
                    <div class="pf-eyebrow">
                        <i data-lucide="pencil"></i>
                        ویرایش محصول
                    </div>

                    <h1>@(string.IsNullOrWhiteSpace(Model.Product.Title) ? "ویرایش محصول" : Model.Product.Title)</h1>

                    <p>
                        اطلاعات محصول، قیمت، وضعیت فروش، تنظیمات تحویل و سئو را مدیریت کن.
                    </p>
                </div>
            </div>

            <div class="pf-hero-actions">
                <a asp-page="/Admin/Products/Details"
                   asp-route-id="@Model.ProductId"
                   class="pf-btn pf-btn-soft">
                    <i data-lucide="eye"></i>
                    جزئیات
                </a>

                <a asp-page="/Admin/Products/Index" class="pf-btn pf-btn-soft">
                    <i data-lucide="arrow-right"></i>
                    بازگشت
                </a>
            </div>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="pf-alert danger">
            <i data-lucide="triangle-alert"></i>
            <span>@Model.ErrorMessage</span>
        </div>
    }

    <form method="post" class="pf-layout" novalidate>
        <input asp-for="Product.ThumbnailImagePath" type="hidden" />

        <div class="pf-main">

            <div asp-validation-summary="ModelOnly" class="pf-validation-summary"></div>

            <section class="pf-card">
                <div class="pf-card-header">
                    <div>
                        <div class="pf-card-kicker">
                            <i data-lucide="info"></i>
                            اطلاعات اصلی
                        </div>

                        <h2>مشخصات پایه محصول</h2>

                        <p>
                            تغییر عنوان، اسلاگ، دسته‌بندی و توضیحات محصول روی نمایش عمومی فروشگاه اثر می‌گذارد.
                        </p>
                    </div>
                </div>

                <div class="pf-form-grid two">
                    <div class="pf-field">
                        <label asp-for="Product.Title">عنوان محصول</label>
                        <input asp-for="Product.Title"
                               class="pf-control"
                               autocomplete="off" />
                        <span asp-validation-for="Product.Title" class="pf-validation"></span>
                    </div>

                    <div class="pf-field">
                        <label asp-for="Product.Slug">اسلاگ محصول</label>
                        <input asp-for="Product.Slug"
                               class="pf-control ltr"
                               autocomplete="off" />
                        <span asp-validation-for="Product.Slug" class="pf-validation"></span>
                    </div>

                    <div class="pf-field">
                        <label asp-for="Product.CategoryId">دسته‌بندی</label>

                        <div class="pf-select-shell">
                            <i data-lucide="folder"></i>

                            <select asp-for="Product.CategoryId" class="pf-select-control">
                                <option value="">انتخاب دسته‌بندی</option>
                                @foreach (var category in Model.Categories)
                                {
                                    <option value="@category.Id">@category.Title</option>
                                }
                            </select>

                            <i data-lucide="chevron-down" class="pf-select-chevron"></i>
                        </div>

                        <span asp-validation-for="Product.CategoryId" class="pf-validation"></span>
                    </div>

                    <div class="pf-field">
                        <label asp-for="Product.BrandId">برند</label>

                        <div class="pf-select-shell">
                            <i data-lucide="badge-check"></i>

                            <select asp-for="Product.BrandId" class="pf-select-control">
                                <option value="">بدون برند</option>
                                @foreach (var brand in Model.Brands)
                                {
                                    <option value="@brand.Id">@brand.Title</option>
                                }
                            </select>

                            <i data-lucide="chevron-down" class="pf-select-chevron"></i>
                        </div>

                        <span asp-validation-for="Product.BrandId" class="pf-validation"></span>
                    </div>
                </div>

                <div class="pf-field pf-field-gap">
                    <label asp-for="Product.ShortDescription">توضیح کوتاه</label>
                    <textarea asp-for="Product.ShortDescription"
                              class="pf-textarea"
                              rows="3"></textarea>
                    <span asp-validation-for="Product.ShortDescription" class="pf-validation"></span>
                </div>

                <div class="pf-field pf-field-gap">
                    <label asp-for="Product.FullDescription">توضیح کامل</label>
                    <textarea asp-for="Product.FullDescription"
                              class="pf-textarea"
                              rows="8"></textarea>
                    <span asp-validation-for="Product.FullDescription" class="pf-validation"></span>
                </div>
            </section>

            <section class="pf-card">
                <div class="pf-card-header">
                    <div>
                        <div class="pf-card-kicker">
                            <i data-lucide="wallet"></i>
                            قیمت و خرید
                        </div>

                        <h2>قیمت‌گذاری و محدودیت سفارش</h2>

                        <p>
                            قیمت نهایی محصول و محدودیت تعداد خرید کاربر از این بخش کنترل می‌شود.
                        </p>
                    </div>
                </div>

                <div class="pf-form-grid two">
                    <div class="pf-field">
                        <label asp-for="Product.BasePrice">قیمت پایه</label>
                        <input asp-for="Product.BasePrice"
                               class="pf-control ltr"
                               inputmode="decimal" />
                        <span asp-validation-for="Product.BasePrice" class="pf-validation"></span>
                    </div>

                    <div class="pf-field">
                        <label asp-for="Product.DiscountPrice">قیمت تخفیف</label>
                        <input asp-for="Product.DiscountPrice"
                               class="pf-control ltr"
                               inputmode="decimal" />
                        <span asp-validation-for="Product.DiscountPrice" class="pf-validation"></span>
                    </div>

                    <div class="pf-field">
                        <label asp-for="Product.MinOrderQuantity">حداقل تعداد سفارش</label>
                        <input asp-for="Product.MinOrderQuantity"
                               class="pf-control ltr"
                               inputmode="numeric" />
                        <span asp-validation-for="Product.MinOrderQuantity" class="pf-validation"></span>
                    </div>

                    <div class="pf-field">
                        <label asp-for="Product.MaxOrderQuantity">حداکثر تعداد سفارش</label>
                        <input asp-for="Product.MaxOrderQuantity"
                               class="pf-control ltr"
                               inputmode="numeric" />
                        <span asp-validation-for="Product.MaxOrderQuantity" class="pf-validation"></span>
                    </div>
                </div>
            </section>

            <section class="pf-card">
                <div class="pf-card-header">
                    <div>
                        <div class="pf-card-kicker">
                            <i data-lucide="search-check"></i>
                            SEO
                        </div>

                        <h2>تنظیمات سئو</h2>
                    </div>
                </div>

                <div class="pf-form-grid">
                    <div class="pf-field">
                        <label asp-for="Product.SeoTitle">SEO Title</label>
                        <input asp-for="Product.SeoTitle" class="pf-control" />
                        <span asp-validation-for="Product.SeoTitle" class="pf-validation"></span>
                    </div>

                    <div class="pf-field">
                        <label asp-for="Product.SeoDescription">SEO Description</label>
                        <textarea asp-for="Product.SeoDescription"
                                  class="pf-textarea"
                                  rows="4"></textarea>
                        <span asp-validation-for="Product.SeoDescription" class="pf-validation"></span>
                    </div>
                </div>
            </section>
        </div>

        <aside class="pf-side">

            <section class="pf-card pf-sticky-card">
                <div class="pf-card-header compact">
                    <div>
                        <div class="pf-card-kicker">
                            <i data-lucide="settings-2"></i>
                            تنظیمات فروش
                        </div>

                        <h2>وضعیت و نوع محصول</h2>
                    </div>
                </div>

                <div class="pf-side-fields">
                    <div class="pf-image-box">
                        @if (!string.IsNullOrWhiteSpace(Model.GetImagePath()))
                        {
                            <img src="@Model.GetImagePath()" alt="@Model.Product.Title" />
                        }
                        else
                        {
                            <div>
                                <i data-lucide="image"></i>
                                <span>تصویر اصلی انتخاب نشده</span>
                            </div>
                        }

                        <a asp-page="/Admin/ProductImages/Index"
                           asp-route-productId="@Model.ProductId"
                           class="pf-btn pf-btn-soft">
                            <i data-lucide="image-plus"></i>
                            مدیریت تصاویر
                        </a>
                    </div>

                    <div class="pf-field">
                        <label asp-for="Product.ProductType">نوع محصول</label>

                        <div class="pf-select-shell">
                            <i data-lucide="box"></i>

                            <select asp-for="Product.ProductType" class="pf-select-control">
                                <option value="1">گیفت کارت</option>
                                <option value="2">اکانت بازی</option>
                                <option value="3">سرویس بازی</option>
                                <option value="4">اشتراک</option>
                                <option value="5">سایر</option>
                            </select>

                            <i data-lucide="chevron-down" class="pf-select-chevron"></i>
                        </div>
                    </div>

                    <div class="pf-field">
                        <label asp-for="Product.DeliveryType">نوع تحویل</label>

                        <div class="pf-select-shell">
                            <i data-lucide="truck"></i>

                            <select asp-for="Product.DeliveryType" class="pf-select-control">
                                <option value="1">تحویل آنی</option>
                                <option value="2">تحویل دستی</option>
                                <option value="3">نیازمند پشتیبانی</option>
                            </select>

                            <i data-lucide="chevron-down" class="pf-select-chevron"></i>
                        </div>
                    </div>

                    <div class="pf-field">
                        <label asp-for="Product.CurrencyType">واحد پول</label>

                        <div class="pf-select-shell">
                            <i data-lucide="coins"></i>

                            <select asp-for="Product.CurrencyType" class="pf-select-control">
                                <option value="1">ریال</option>
                                <option value="2">تومان</option>
                                <option value="3">دلار</option>
                            </select>

                            <i data-lucide="chevron-down" class="pf-select-chevron"></i>
                        </div>
                    </div>

                    <label class="pf-switch">
                        <span>
                            <strong>فعال باشد</strong>
                            <small>محصول در فروشگاه نمایش داده شود.</small>
                        </span>
                        <input asp-for="Product.IsActive" class="pf-switch-input" />
                        <i class="pf-switch-ui"></i>
                    </label>

                    <label class="pf-switch">
                        <span>
                            <strong>محصول ویژه</strong>
                            <small>در بخش‌های پیشنهادی قابل استفاده است.</small>
                        </span>
                        <input asp-for="Product.IsFeatured" class="pf-switch-input" />
                        <i class="pf-switch-ui"></i>
                    </label>

                    <label class="pf-switch">
                        <span>
                            <strong>نیازمند احراز هویت</strong>
                            <small>برای محصولات حساس فعال شود.</small>
                        </span>
                        <input asp-for="Product.RequiresVerification" class="pf-switch-input" />
                        <i class="pf-switch-ui"></i>
                    </label>

                    <label class="pf-switch">
                        <span>
                            <strong>نیازمند پیام پشتیبانی</strong>
                            <small>قبل یا بعد از خرید نیاز به ارتباط با پشتیبانی دارد.</small>
                        </span>
                        <input asp-for="Product.RequiresSupportMessage" class="pf-switch-input" />
                        <i class="pf-switch-ui"></i>
                    </label>
                </div>

                <div class="pf-submit-box">
                    <button type="submit" class="pf-btn pf-btn-primary pf-submit-btn">
                        <i data-lucide="save"></i>
                        ذخیره تغییرات
                    </button>

                    <a asp-page="/Admin/ProductVariants/Index"
                       asp-route-productId="@Model.ProductId"
                       class="pf-btn pf-btn-soft pf-submit-btn">
                        <i data-lucide="layers-3"></i>
                        مدیریت واریانت‌ها
                    </a>
                </div>
            </section>
        </aside>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        if (window.lucide) {
            lucide.createIcons();
        }
    </script>
}