@page "{id:guid}"
@model Vitorize.Web.Pages.Admin.Products.EditModel
@{
    ViewData["Title"] = "ویرایش محصول"; Layout = "~/Pages/Shared/_AdminLayout.cshtml";
}
<div class="vz-page" dir="rtl">
<section class="vz-hero">
<div class="vz-hero-main">
<div class="vz-eyebrow">
<i data-lucide="package">
</i>محصولات</div>

<h1 class="vz-title">ویرایش محصول</h1>
<p class="vz-desc">اطلاعات فروش، قیمت‌گذاری و تنظیمات نمایش محصول را وارد کن.</p>
</div>

<div class="vz-actions">
<a asp-page="Index" class="vz-btn vz-btn-light">
<i data-lucide="arrow-right">
</i>بازگشت</a>
</div>

</section>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage)) { <div class="vz-alert vz-alert-danger">
<i data-lucide="triangle-alert">
</i>
<span>@Model.ErrorMessage</span>
</div>
 }
<form method="post" class="vz-form-layout">
<div class="vz-main-col">
<section class="vz-form-card">
<div class="vz-card-head">
<div>
<h2>اطلاعات اصلی</h2>
<p>عنوان، دسته‌بندی و توضیحات محصول.</p>
</div>

</div>

<div asp-validation-summary="ModelOnly">
</div>

<div class="vz-form-grid two">
<div class="vz-field">
<label asp-for="Product.Title">عنوان</label>
<div class="vz-input-shell">
<i data-lucide="type">
</i>
<input asp-for="Product.Title" class="vz-input" />
</div>

<span asp-validation-for="Product.Title" class="vz-validation">
</span>
</div>

<div class="vz-field">
<label asp-for="Product.Slug">اسلاگ</label>
<div class="vz-input-shell">
<i data-lucide="link">
</i>
<input asp-for="Product.Slug" class="vz-input ltr" />
</div>

<span asp-validation-for="Product.Slug" class="vz-validation">
</span>
</div>

</div>

<div class="vz-form-grid two" style="margin-top:16px">
<div class="vz-field">
<label asp-for="Product.CategoryId">دسته‌بندی</label>
<div class="vz-input-shell">
<i data-lucide="grid-2x2">
</i>
<select asp-for="Product.CategoryId" class="vz-select">
<option value="">انتخاب کنید</option>@foreach (var c in Model.Categories) { <option value="@c.Id">@c.Title</option> }
</select>
</div>

<span asp-validation-for="Product.CategoryId" class="vz-validation">
</span>
</div>

<div class="vz-field">
<label asp-for="Product.BrandId">برند</label>
<div class="vz-input-shell">
<i data-lucide="badge-check">
</i>
<select asp-for="Product.BrandId" class="vz-select">
<option value="">بدون برند</option>@foreach (var b in Model.Brands) { <option value="@b.Id">@b.Title</option> }
</select>
</div>

</div>

</div>

<div class="vz-field" style="margin-top:16px">
<label asp-for="Product.ShortDescription">توضیح کوتاه</label>
<textarea asp-for="Product.ShortDescription" class="vz-textarea" style="min-height:100px">
</textarea>
</div>

<div class="vz-field" style="margin-top:16px">
<label asp-for="Product.FullDescription">توضیح کامل</label>
<textarea asp-for="Product.FullDescription" class="vz-textarea">
</textarea>
</div>

</section>

<section class="vz-form-card">
<div class="vz-card-head">
<div>
<h2>قیمت و فروش</h2>
<p>واحد پول فقط ریال یا تومان است.</p>
</div>

</div>

<div class="vz-form-grid three">
<div class="vz-field">
<label>واحد پول</label>
<div class="vz-input-shell">
<i data-lucide="wallet">
</i>
<select asp-for="Product.CurrencyType" class="vz-select">
<option value="1">ریال</option>
<option value="2">تومان</option>
</select>
</div>

</div>

<div class="vz-field">
<label asp-for="Product.BasePrice">قیمت اصلی</label>
<div class="vz-input-shell">
<i data-lucide="circle-dollar-sign">
</i>
<input asp-for="Product.BasePrice" type="number" class="vz-input ltr" />
</div>

<span asp-validation-for="Product.BasePrice" class="vz-validation">
</span>
</div>

<div class="vz-field">
<label asp-for="Product.DiscountPrice">قیمت تخفیفی</label>
<div class="vz-input-shell">
<i data-lucide="badge-percent">
</i>
<input asp-for="Product.DiscountPrice" type="number" class="vz-input ltr" />
</div>

<span asp-validation-for="Product.DiscountPrice" class="vz-validation">
</span>
</div>

</div>

<div class="vz-form-grid three" style="margin-top:16px">
<div class="vz-field">
<label>نوع محصول</label>
<div class="vz-input-shell">
<i data-lucide="package">
</i>
<select asp-for="Product.ProductType" class="vz-select">
<option value="1">گیفت کارت</option>
<option value="2">اکانت بازی</option>
<option value="3">سرویس بازی</option>
<option value="4">اشتراک</option>
<option value="99">سایر</option>
</select>
</div>

</div>

<div class="vz-field">
<label>نوع تحویل</label>
<div class="vz-input-shell">
<i data-lucide="truck">
</i>
<select asp-for="Product.DeliveryType" class="vz-select">
<option value="1">تحویل آنی</option>
<option value="2">تحویل دستی</option>
<option value="3">نیازمند پشتیبانی</option>
</select>
</div>

</div>

<div class="vz-field">
<label asp-for="Product.SortOrder">ترتیب نمایش</label>
<div class="vz-input-shell">
<i data-lucide="arrow-down-up">
</i>
<input asp-for="Product.SortOrder" type="number" class="vz-input ltr" />
</div>

</div>

</div>

<div class="vz-form-grid two" style="margin-top:16px">
<div class="vz-field">
<label asp-for="Product.MinOrderQuantity">حداقل سفارش</label>
<div class="vz-input-shell">
<i data-lucide="minus">
</i>
<input asp-for="Product.MinOrderQuantity" type="number" class="vz-input ltr" />
</div>

</div>

<div class="vz-field">
<label asp-for="Product.MaxOrderQuantity">حداکثر سفارش</label>
<div class="vz-input-shell">
<i data-lucide="plus">
</i>
<input asp-for="Product.MaxOrderQuantity" type="number" class="vz-input ltr" />
</div>

</div>

</div>

</section>

<section class="vz-form-card">
<div class="vz-card-head">
<div>
<h2>سئو</h2>
<p>اطلاعات نمایش در موتورهای جستجو.</p>
</div>

</div>

<div class="vz-form-grid two">
<div class="vz-field">
<label asp-for="Product.SeoTitle">عنوان سئو</label>
<div class="vz-input-shell">
<i data-lucide="search">
</i>
<input asp-for="Product.SeoTitle" class="vz-input" />
</div>

</div>

<div class="vz-field">
<label asp-for="Product.SeoDescription">توضیح سئو</label>
<div class="vz-input-shell">
<i data-lucide="file-text">
</i>
<input asp-for="Product.SeoDescription" class="vz-input" />
</div>

</div>

</div>

</section>

</div>

<div class="vz-side-col">
<section class="vz-side-card vz-side-sticky">
<div class="vz-card-head">
<div>
<h2>تنظیمات</h2>
<p>وضعیت و قابلیت‌های محصول.</p>
</div>

</div>

<div class="vz-form-grid">
<div class="vz-switch-card">
<div>
<strong>فعال باشد</strong>
<span>محصول قابل نمایش باشد.</span>
</div>

<label class="vz-switch">
<input asp-for="Product.IsActive" />
<span class="vz-switch-ui">
</span>
</label>
</div>

<div class="vz-switch-card">
<div>
<strong>محصول ویژه</strong>
<span>در بخش‌های برجسته نمایش داده شود.</span>
</div>

<label class="vz-switch">
<input asp-for="Product.IsFeatured" />
<span class="vz-switch-ui">
</span>
</label>
</div>

<div class="vz-switch-card">
<div>
<strong>نیازمند احراز هویت</strong>
<span>قبل از خرید نیاز به تایید کاربر داشته باشد.</span>
</div>

<label class="vz-switch">
<input asp-for="Product.RequiresVerification" />
<span class="vz-switch-ui">
</span>
</label>
</div>

<div class="vz-switch-card">
<div>
<strong>نیازمند پیام پشتیبانی</strong>
<span>برای تکمیل خرید اطلاعات بیشتری دریافت شود.</span>
</div>

<label class="vz-switch">
<input asp-for="Product.RequiresSupportMessage" />
<span class="vz-switch-ui">
</span>
</label>
</div>

<button type="submit" class="vz-btn vz-btn-primary vz-btn-full">
<i data-lucide="save">
</i>ذخیره محصول</button>
</div>

</section>

</div>

</form>

</div>

@section Scripts { <partial name="_ValidationScriptsPartial" />

<script>
if(window.lucide){lucide.createIcons();}

</script>
 }
