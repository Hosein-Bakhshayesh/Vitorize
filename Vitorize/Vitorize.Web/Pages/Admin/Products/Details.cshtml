@page "{id:guid}"
@model Vitorize.Web.Pages.Admin.Products.DetailsModel

@{
    ViewData["Title"] = "جزئیات محصول";
    Layout = "~/Pages/Shared/_AdminLayout.cshtml";
}

<div class="product-details-page" dir="rtl">

    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
    {
        <div class="pd-alert success">
            <i data-lucide="check-circle-2"></i>
            <span>@Model.SuccessMessage</span>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="pd-alert danger">
            <i data-lucide="triangle-alert"></i>
            <span>@Model.ErrorMessage</span>
        </div>
    }

    <section class="pd-hero">
        <div class="pd-product-head">
            <div class="pd-thumb">
                @if (!string.IsNullOrWhiteSpace(Model.GetImagePath()))
                {
                    <img src="@Model.GetImagePath()" alt="@Model.Product.Title" />
                }
                else
                {
                    <span>@Model.GetProductInitial()</span>
                }

                @if (Model.HasDiscount())
                {
                    <small>%@Model.GetDiscountPercent()</small>
                }
            </div>

            <div class="pd-title-box">
                <div class="pd-eyebrow">
                    <i data-lucide="package"></i>
                    جزئیات محصول
                </div>

                <div class="pd-title-row">
                    <h1>@Model.Product.Title</h1>

                    <span class="@Model.GetStatusCss()">
                        @Model.GetStatusText()
                    </span>

                    @if (Model.Product.IsFeatured)
                    {
                        <span class="pd-pill featured">ویژه</span>
                    }
                </div>

                <p>
                    @(string.IsNullOrWhiteSpace(Model.Product.ShortDescription)
                        ? "توضیح کوتاه برای این محصول ثبت نشده است."
                        : Model.Product.ShortDescription)
                </p>

                <div class="pd-slug">@Model.Product.Slug</div>
            </div>
        </div>

        <div class="pd-actions">
            <a asp-page="/Admin/Products/Edit"
               asp-route-id="@Model.Product.Id"
               class="pd-btn pd-btn-primary">
                <i data-lucide="pencil"></i>
                ویرایش
            </a>

            <a asp-page="/Admin/ProductImages/Index"
               asp-route-productId="@Model.Product.Id"
               class="pd-btn pd-btn-soft">
                <i data-lucide="image"></i>
                تصاویر
            </a>

            <a asp-page="/Admin/ProductVariants/Index"
               asp-route-productId="@Model.Product.Id"
               class="pd-btn pd-btn-soft">
                <i data-lucide="layers-3"></i>
                واریانت‌ها
            </a>

            <a asp-page="/Admin/Products/Index"
               class="pd-btn pd-btn-soft">
                <i data-lucide="arrow-right"></i>
                بازگشت
            </a>
        </div>
    </section>

    <section class="pd-stats">
        <div class="pd-stat">
            <div class="pd-stat-icon green">
                <i data-lucide="circle-dollar-sign"></i>
            </div>
            <div>
                <span>قیمت نهایی</span>
                <strong>@Model.FormatMoney(Model.Product.FinalPrice)</strong>
                @if (Model.HasDiscount())
                {
                    <small>قیمت پایه: @Model.FormatMoney(Model.Product.BasePrice)</small>
                }
                else
                {
                    <small>@Model.GetCurrencyType(Model.Product.CurrencyType)</small>
                }
            </div>
        </div>

        <div class="pd-stat">
            <div class="pd-stat-icon orange">
                <i data-lucide="credit-card"></i>
            </div>
            <div>
                <span>موجودی آماده</span>
                <strong class="@Model.GetStockCss()">@Model.FormatNumber(Model.Product.AvailableStock)</strong>
                <small>@Model.GetStockText()</small>
            </div>
        </div>

        <div class="pd-stat">
            <div class="pd-stat-icon blue">
                <i data-lucide="box"></i>
            </div>
            <div>
                <span>نوع محصول</span>
                <strong>@Model.GetProductType(Model.Product.ProductType)</strong>
                <small>@(Model.Product.HasVariants ? "دارای واریانت" : "بدون واریانت")</small>
            </div>
        </div>

        <div class="pd-stat">
            <div class="pd-stat-icon purple">
                <i data-lucide="truck"></i>
            </div>
            <div>
                <span>نوع تحویل</span>
                <strong>@Model.GetDeliveryType(Model.Product.DeliveryType)</strong>
                <small>@Model.FormatDate(Model.Product.CreatedAt)</small>
            </div>
        </div>
    </section>

    <section class="pd-grid">
        <div class="pd-main">

            <section class="pd-card">
                <div class="pd-card-header">
                    <div>
                        <div class="pd-card-kicker">
                            <i data-lucide="file-text"></i>
                            توضیحات
                        </div>

                        <h2>توضیحات کامل محصول</h2>
                    </div>
                </div>

                <div class="pd-description">
                    @(string.IsNullOrWhiteSpace(Model.Product.FullDescription)
                        ? "توضیح کاملی برای این محصول ثبت نشده است."
                        : Model.Product.FullDescription)
                </div>
            </section>

            <section class="pd-card">
                <div class="pd-card-header">
                    <div>
                        <div class="pd-card-kicker">
                            <i data-lucide="search-check"></i>
                            SEO
                        </div>

                        <h2>اطلاعات سئو</h2>
                    </div>
                </div>

                <div class="pd-info-grid">
                    <div class="pd-info-item">
                        <span>SEO Title</span>
                        <strong>@(string.IsNullOrWhiteSpace(Model.Product.SeoTitle) ? "-" : Model.Product.SeoTitle)</strong>
                    </div>

                    <div class="pd-info-item">
                        <span>SEO Description</span>
                        <strong>@(string.IsNullOrWhiteSpace(Model.Product.SeoDescription) ? "-" : Model.Product.SeoDescription)</strong>
                    </div>
                </div>
            </section>
        </div>

        <aside class="pd-side">
            <section class="pd-card">
                <div class="pd-card-header">
                    <div>
                        <div class="pd-card-kicker">
                            <i data-lucide="settings-2"></i>
                            تنظیمات فروش
                        </div>

                        <h2>وضعیت محصول</h2>
                    </div>
                </div>

                <div class="pd-status-list">
                    <div>
                        <span>دسته‌بندی</span>
                        <strong>@Model.Product.CategoryTitle</strong>
                    </div>

                    <div>
                        <span>برند</span>
                        <strong>@(Model.Product.BrandTitle ?? "بدون برند")</strong>
                    </div>

                    <div>
                        <span>واحد پول</span>
                        <strong>@Model.GetCurrencyType(Model.Product.CurrencyType)</strong>
                    </div>

                    <div>
                        <span>حداقل سفارش</span>
                        <strong>@Model.FormatNumber(Model.Product.MinOrderQuantity)</strong>
                    </div>

                    <div>
                        <span>حداکثر سفارش</span>
                        <strong>@(Model.Product.MaxOrderQuantity.HasValue ? Model.FormatNumber(Model.Product.MaxOrderQuantity.Value) : "بدون محدودیت")</strong>
                    </div>

                    <div>
                        <span>احراز هویت</span>
                        <strong>@(Model.Product.RequiresVerification ? "لازم است" : "لازم نیست")</strong>
                    </div>

                    <div>
                        <span>پیام پشتیبانی</span>
                        <strong>@(Model.Product.RequiresSupportMessage ? "لازم است" : "لازم نیست")</strong>
                    </div>
                </div>
            </section>

            <section class="pd-card">
                <div class="pd-card-header">
                    <div>
                        <div class="pd-card-kicker">
                            <i data-lucide="workflow"></i>
                            عملیات سریع
                        </div>

                        <h2>مدیریت مرتبط</h2>
                    </div>
                </div>

                <div class="pd-quick-links">
                    <a asp-page="/Admin/ProductImages/Index" asp-route-productId="@Model.Product.Id">
                        <i data-lucide="image"></i>
                        مدیریت تصاویر
                    </a>

                    <a asp-page="/Admin/ProductVariants/Index" asp-route-productId="@Model.Product.Id">
                        <i data-lucide="layers-3"></i>
                        مدیریت واریانت‌ها
                    </a>

                    <a asp-page="/Admin/GiftCodes/Import" asp-route-productId="@Model.Product.Id">
                        <i data-lucide="upload-cloud"></i>
                        ورود گیفت‌کارت
                    </a>
                </div>
            </section>
        </aside>
    </section>
</div>

@section Scripts {
    <script>
        if (window.lucide) {
            lucide.createIcons();
        }
    </script>
}