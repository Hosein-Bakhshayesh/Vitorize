@page "{id:guid}"
@model Vitorize.Web.Pages.Admin.Products.DetailsModel
@{
    ViewData["Title"] = "جزئیات محصول";
    Layout = "~/Pages/Shared/_AdminLayout.cshtml";
}

<div class="space-y-6" dir="rtl">
    <div class="overflow-hidden rounded-[2rem] border border-white/70 bg-white/80 shadow-xl backdrop-blur-xl">
        <div class="relative h-44 bg-gradient-to-l from-slate-950 via-indigo-950 to-fuchsia-700">
            <div class="absolute inset-0 bg-[radial-gradient(circle_at_20%_20%,rgba(255,255,255,.25),transparent_25%)]"></div>
        </div>

        <div class="-mt-16 flex flex-col gap-5 p-6 lg:flex-row lg:items-end lg:justify-between">
            <div class="flex flex-col gap-4 sm:flex-row sm:items-end">
                <div class="h-32 w-32 overflow-hidden rounded-[2rem] bg-slate-100 ring-4 ring-white">
                    @if (!string.IsNullOrWhiteSpace(Model.Product.ThumbnailImagePath))
                    {
                        <img src="@Model.Product.ThumbnailImagePath" class="h-full w-full object-cover" />
                    }
                    else
                    {
                        <div class="flex h-full w-full items-center justify-center text-xs font-bold text-slate-400">No Image</div>
                    }
                </div>

                <div class="pb-2">
                    <div class="flex flex-wrap items-center gap-2">
                        <h1 class="text-3xl font-black text-slate-900">@Model.Product.Title</h1>

                        @if (Model.Product.IsActive)
                        {
                            <span class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-black text-emerald-700">فعال</span>
                        }
                        else
                        {
                            <span class="rounded-full bg-rose-50 px-3 py-1 text-xs font-black text-rose-700">غیرفعال</span>
                        }

                        @if (Model.Product.IsFeatured)
                        {
                            <span class="rounded-full bg-fuchsia-50 px-3 py-1 text-xs font-black text-fuchsia-700">ویژه</span>
                        }
                    </div>

                    <p class="mt-2 text-sm text-slate-500">@Model.Product.ShortDescription</p>
                    <p class="mt-1 text-xs text-slate-400">@Model.Product.Slug</p>
                </div>
            </div>

            <div class="flex flex-wrap gap-2">
                <a asp-page="/Admin/Products/Edit" asp-route-id="@Model.Product.Id"
                   class="rounded-2xl bg-indigo-50 px-5 py-3 text-sm font-black text-indigo-700">ویرایش</a>

                <a asp-page="/Admin/Products/Images/Index" asp-route-productId="@Model.Product.Id"
                   class="rounded-2xl bg-fuchsia-50 px-5 py-3 text-sm font-black text-fuchsia-700">تصاویر</a>

                <a asp-page="/Admin/Products/Variants/Index" asp-route-productId="@Model.Product.Id"
                   class="rounded-2xl bg-cyan-50 px-5 py-3 text-sm font-black text-cyan-700">تنوع‌ها</a>

                <a asp-page="/Admin/Products/Index"
                   class="rounded-2xl bg-slate-100 px-5 py-3 text-sm font-black text-slate-700">بازگشت</a>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
    {
        <div class="rounded-2xl border border-emerald-200 bg-emerald-50 px-5 py-4 text-sm font-bold text-emerald-700">
            @Model.SuccessMessage
        </div>
    }

    <div class="grid gap-4 md:grid-cols-4">
        <div class="rounded-[1.5rem] bg-white/85 p-5 shadow-sm ring-1 ring-white/70">
            <p class="text-xs font-bold text-slate-500">قیمت نهایی</p>
            <p class="mt-2 text-xl font-black text-slate-900">@Model.FormatMoney(Model.Product.FinalPrice)</p>
        </div>

        <div class="rounded-[1.5rem] bg-white/85 p-5 shadow-sm ring-1 ring-white/70">
            <p class="text-xs font-bold text-slate-500">موجودی</p>
            <p class="mt-2 text-xl font-black @(Model.Product.AvailableStock <= 0 ? "text-rose-600" : "text-emerald-600")">
                @Model.Product.AvailableStock
            </p>
        </div>

        <div class="rounded-[1.5rem] bg-white/85 p-5 shadow-sm ring-1 ring-white/70">
            <p class="text-xs font-bold text-slate-500">نوع محصول</p>
            <p class="mt-2 text-xl font-black text-slate-900">@Model.GetProductType(Model.Product.ProductType)</p>
        </div>

        <div class="rounded-[1.5rem] bg-white/85 p-5 shadow-sm ring-1 ring-white/70">
            <p class="text-xs font-bold text-slate-500">تحویل</p>
            <p class="mt-2 text-xl font-black text-slate-900">@Model.GetDeliveryType(Model.Product.DeliveryType)</p>
        </div>
    </div>

    <div class="grid gap-6 xl:grid-cols-12">
        <div class="space-y-6 xl:col-span-8">
            <div class="rounded-[2rem] border border-white/70 bg-white/85 p-6 shadow-sm backdrop-blur">
                <h2 class="text-lg font-black text-slate-900">توضیحات کامل</h2>
                <div class="mt-4 whitespace-pre-line rounded-2xl bg-slate-50 p-5 text-sm leading-8 text-slate-600">
                    @(Model.Product.FullDescription ?? "توضیحی ثبت نشده است.")
                </div>
            </div>

            <div class="rounded-[2rem] border border-white/70 bg-white/85 p-6 shadow-sm backdrop-blur">
                <h2 class="text-lg font-black text-slate-900">SEO</h2>

                <div class="mt-4 grid gap-4 md:grid-cols-2">
                    <div class="rounded-2xl bg-slate-50 p-4">
                        <p class="text-xs font-bold text-slate-400">SEO Title</p>
                        <p class="mt-2 text-sm font-bold text-slate-700">@(Model.Product.SeoTitle ?? "-")</p>
                    </div>

                    <div class="rounded-2xl bg-slate-50 p-4">
                        <p class="text-xs font-bold text-slate-400">SEO Description</p>
                        <p class="mt-2 text-sm font-bold text-slate-700">@(Model.Product.SeoDescription ?? "-")</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="space-y-6 xl:col-span-4">
            <div class="rounded-[2rem] border border-white/70 bg-white/85 p-6 shadow-sm backdrop-blur">
                <h2 class="text-lg font-black text-slate-900">مشخصات</h2>

                <div class="mt-5 space-y-3 text-sm">
                    <div class="flex justify-between rounded-2xl bg-slate-50 p-4">
                        <span class="font-bold text-slate-500">دسته‌بندی</span>
                        <span class="font-black text-slate-900">@Model.Product.CategoryTitle</span>
                    </div>

                    <div class="flex justify-between rounded-2xl bg-slate-50 p-4">
                        <span class="font-bold text-slate-500">برند</span>
                        <span class="font-black text-slate-900">@(Model.Product.BrandTitle ?? "بدون برند")</span>
                    </div>

                    <div class="flex justify-between rounded-2xl bg-slate-50 p-4">
                        <span class="font-bold text-slate-500">واحد پول</span>
                        <span class="font-black text-slate-900">@Model.GetCurrencyType(Model.Product.CurrencyType)</span>
                    </div>

                    <div class="flex justify-between rounded-2xl bg-slate-50 p-4">
                        <span class="font-bold text-slate-500">تنوع</span>
                        <span class="font-black text-slate-900">@(Model.Product.HasVariants ? "دارد" : "ندارد")</span>
                    </div>

                    <div class="flex justify-between rounded-2xl bg-slate-50 p-4">
                        <span class="font-bold text-slate-500">حد سفارش</span>
                        <span class="font-black text-slate-900">
                            @Model.Product.MinOrderQuantity تا @(Model.Product.MaxOrderQuantity?.ToString() ?? "نامحدود")
                        </span>
                    </div>

                    <div class="flex justify-between rounded-2xl bg-slate-50 p-4">
                        <span class="font-bold text-slate-500">احراز هویت</span>
                        <span class="font-black text-slate-900">@(Model.Product.RequiresVerification ? "لازم دارد" : "ندارد")</span>
                    </div>

                    <div class="flex justify-between rounded-2xl bg-slate-50 p-4">
                        <span class="font-bold text-slate-500">پیام پشتیبانی</span>
                        <span class="font-black text-slate-900">@(Model.Product.RequiresSupportMessage ? "لازم دارد" : "ندارد")</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>