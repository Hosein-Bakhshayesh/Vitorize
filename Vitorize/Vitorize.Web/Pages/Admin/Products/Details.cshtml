@page "{id:guid}"
@model Vitorize.Web.Pages.Admin.Products.DetailsModel
@using Vitorize.Web.Helpers
@{
    ViewData["Title"] = "جزئیات محصول";
    Layout = "~/Pages/Shared/_AdminLayout.cshtml";
}
<div class="vz-page" dir="rtl">
    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage)) { <div class="vz-alert vz-alert-success">
<i data-lucide="check-circle-2">
</i>
<span>@Model.SuccessMessage</span>
</div>
 }
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage)) { <div class="vz-alert vz-alert-danger">
<i data-lucide="triangle-alert">
</i>
<span>@Model.ErrorMessage</span>
</div>
 }
    <section class="vz-hero">
<div class="vz-hero-main">
<div class="vz-detail-hero">
<div class="vz-detail-image">@if (!string.IsNullOrWhiteSpace(Model.Image(Model.Product.ThumbnailImagePath))) { <img src="@Model.Image(Model.Product.ThumbnailImagePath)" alt="@Model.Product.Title" /> } else { <i data-lucide="package">
</i> }
</div>

<div>
<div class="vz-eyebrow">
<i data-lucide="package">
</i>محصول</div>

<h1 class="vz-title">@Model.Product.Title</h1>
<p class="vz-desc">@(Model.Product.ShortDescription ?? "توضیح کوتاهی ثبت نشده است.")</p>
<div class="vz-actions" style="margin-top:12px">@if (Model.Product.IsActive) { <span class="vz-badge vz-badge-success">فعال</span> } else { <span class="vz-badge vz-badge-muted">غیرفعال</span> } @if (Model.Product.IsFeatured) { <span class="vz-badge vz-badge-warning">ویژه</span> }
</div>

</div>

</div>

</div>

<div class="vz-actions">
<a asp-page="Edit" asp-route-id="@Model.Product.Id" class="vz-btn vz-btn-primary">
<i data-lucide="pencil">
</i>ویرایش</a>
<a asp-page="/Admin/ProductImages/Index" asp-route-productId="@Model.Product.Id" class="vz-btn vz-btn-light">
<i data-lucide="image">
</i>تصاویر</a>
<a asp-page="/Admin/ProductVariants/Index" asp-route-productId="@Model.Product.Id" class="vz-btn vz-btn-light">
<i data-lucide="layers-3">
</i>واریانت‌ها</a>
<a asp-page="Index" class="vz-btn vz-btn-light">
<i data-lucide="arrow-right">
</i>بازگشت</a>
</div>

</section>

    <section class="vz-stats">
<article class="vz-stats-card">
<div class="vz-stat-icon green">
<i data-lucide="circle-dollar-sign">
</i>
</div>

<div class="vz-stat-content">
<span class="vz-stat-label">قیمت نهایی</span>
<strong class="vz-stat-value">@AdminUiHelper.Money(Model.Product.FinalPrice, Model.Product.CurrencyType)</strong>@if (Model.Product.DiscountPrice.HasValue && Model.Product.DiscountPrice.Value > 0) { <small style="color:#94a3b8;text-decoration:line-through;font-weight:900">@AdminUiHelper.Money(Model.Product.BasePrice, Model.Product.CurrencyType)</small> }
</div>

</article>
<article class="vz-stats-card">
<div class="vz-stat-icon orange">
<i data-lucide="boxes">
</i>
</div>

<div class="vz-stat-content">
<span class="vz-stat-label">موجودی کد</span>
<strong class="vz-stat-value">@Model.Product.AvailableStock</strong>
</div>

</article>
<article class="vz-stats-card">
<div class="vz-stat-icon blue">
<i data-lucide="folder">
</i>
</div>

<div class="vz-stat-content">
<span class="vz-stat-label">دسته‌بندی</span>
<strong class="vz-stat-value">@Model.Product.CategoryTitle</strong>
</div>

</article>
<article class="vz-stats-card">
<div class="vz-stat-icon purple">
<i data-lucide="badge-check">
</i>
</div>

<div class="vz-stat-content">
<span class="vz-stat-label">برند</span>
<strong class="vz-stat-value">@(Model.Product.BrandTitle ?? "بدون برند")</strong>
</div>

</article>
</section>

    <section class="vz-form-card">
<div class="vz-card-head">
<div>
<h2>مشخصات محصول</h2>
<p>تنظیمات اصلی فروش و نمایش.</p>
</div>

</div>

<div class="vz-kv">
<div class="vz-kv-item">
<span>اسلاگ</span>
<strong>@Model.Product.Slug</strong>
</div>

<div class="vz-kv-item">
<span>نوع محصول</span>
<strong>@AdminUiHelper.ProductType(Model.Product.ProductType)</strong>
</div>

<div class="vz-kv-item">
<span>نوع تحویل</span>
<strong>@AdminUiHelper.DeliveryType(Model.Product.DeliveryType)</strong>
</div>

<div class="vz-kv-item">
<span>واحد پول</span>
<strong>@AdminUiHelper.Currency(Model.Product.CurrencyType)</strong>
</div>

<div class="vz-kv-item">
<span>حداقل سفارش</span>
<strong>@Model.Product.MinOrderQuantity</strong>
</div>

<div class="vz-kv-item">
<span>حداکثر سفارش</span>
<strong>@(Model.Product.MaxOrderQuantity?.ToString() ?? "بدون محدودیت")</strong>
</div>

<div class="vz-kv-item">
<span>احراز هویت</span>
<strong>@(Model.Product.RequiresVerification ? "نیاز دارد" : "نیاز ندارد")</strong>
</div>

<div class="vz-kv-item">
<span>پیام پشتیبانی</span>
<strong>@(Model.Product.RequiresSupportMessage ? "نیاز دارد" : "نیاز ندارد")</strong>
</div>

</div>

<div class="vz-field" style="margin-top:18px">
<label>توضیح کامل</label>
<div class="vz-textarea" style="white-space:pre-line">@(string.IsNullOrWhiteSpace(Model.Product.FullDescription) ? "توضیح کاملی ثبت نشده است." : Model.Product.FullDescription)</div>

</div>

</section>

    <section class="vz-form-card">
<div class="vz-card-head">
<div>
<h2>سئو</h2>
<p>اطلاعات نمایش در جستجو.</p>
</div>

</div>

<div class="vz-kv">
<div class="vz-kv-item">
<span>عنوان سئو</span>
<strong>@(Model.Product.SeoTitle ?? "-")</strong>
</div>

<div class="vz-kv-item">
<span>توضیح سئو</span>
<strong>@(Model.Product.SeoDescription ?? "-")</strong>
</div>

</div>

</section>

</div>

@section Scripts {
<script>
if(window.lucide){lucide.createIcons();}

</script>
 }
