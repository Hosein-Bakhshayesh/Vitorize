@page
@model Vitorize.Web.Pages.Admin.Products.Variants.CreateModel
@{
    ViewData["Title"] = "ایجاد تنوع محصول";
    Layout = "~/Pages/Shared/_AdminLayout.cshtml";
}

<div class="space-y-6" dir="rtl">
    <div class="rounded-[2rem] border border-white/70 bg-white/80 p-6 shadow-xl backdrop-blur-xl">
        <div class="flex flex-col gap-5 lg:flex-row lg:items-center lg:justify-between">
            <div>
                <p class="text-sm font-black text-cyan-600">Create Variant</p>
                <h1 class="mt-2 text-3xl font-black text-slate-900">ایجاد تنوع محصول</h1>
                <p class="mt-2 text-sm text-slate-500">@(Model.Product?.Title ?? "")</p>
            </div>

            <a asp-page="/Admin/Products/Variants/Index" asp-route-productId="@Model.ProductId"
               class="rounded-2xl bg-slate-100 px-5 py-3 text-sm font-black text-slate-700">
                بازگشت به تنوع‌ها
            </a>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="rounded-2xl border border-rose-200 bg-rose-50 px-5 py-4 text-sm font-bold text-rose-700">
            @Model.ErrorMessage
        </div>
    }

    <form method="post" class="grid gap-6 xl:grid-cols-12">
        <div class="space-y-6 xl:col-span-8">
            <div class="rounded-[2rem] border border-white/70 bg-white/85 p-6 shadow-sm backdrop-blur">
                <h2 class="text-lg font-black text-slate-900">اطلاعات تنوع</h2>

                <div class="mt-5 grid gap-4 md:grid-cols-2">
                    <div>
                        <label class="mb-2 block text-xs font-black text-slate-500">عنوان تنوع</label>
                        <input asp-for="Variant.Title" placeholder="مثلا Steam 10 USD"
                               class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm" />
                        <span asp-validation-for="Variant.Title" class="text-xs text-rose-600"></span>
                    </div>

                    <div>
                        <label class="mb-2 block text-xs font-black text-slate-500">SKU</label>
                        <input asp-for="Variant.Sku" placeholder="STEAM-10-US"
                               class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm text-left ltr" />
                    </div>

                    <div>
                        <label class="mb-2 block text-xs font-black text-slate-500">Value</label>
                        <input asp-for="Variant.Value" placeholder="10 USD / Turkey / Global"
                               class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm" />
                    </div>

                    <div>
                        <label class="mb-2 block text-xs font-black text-slate-500">Sort Order</label>
                        <input asp-for="Variant.SortOrder"
                               class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm" />
                    </div>
                </div>
            </div>

            <div class="rounded-[2rem] border border-white/70 bg-white/85 p-6 shadow-sm backdrop-blur">
                <h2 class="text-lg font-black text-slate-900">قیمت‌گذاری</h2>

                <div class="mt-5 grid gap-4 md:grid-cols-2">
                    <div>
                        <label class="mb-2 block text-xs font-black text-slate-500">قیمت</label>
                        <input asp-for="Variant.Price"
                               class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm" />
                        <span asp-validation-for="Variant.Price" class="text-xs text-rose-600"></span>
                    </div>

                    <div>
                        <label class="mb-2 block text-xs font-black text-slate-500">قیمت تخفیف</label>
                        <input asp-for="Variant.DiscountPrice"
                               class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm" />
                    </div>
                </div>
            </div>
        </div>

        <div class="space-y-6 xl:col-span-4">
            <div class="rounded-[2rem] border border-white/70 bg-white/85 p-6 shadow-sm backdrop-blur">
                <h2 class="text-lg font-black text-slate-900">تنظیمات موجودی</h2>

                <div class="mt-5 space-y-4">
                    <div>
                        <label class="mb-2 block text-xs font-black text-slate-500">Stock Mode</label>
                        <select asp-for="Variant.StockMode"
                                class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm">
                            <option value="1">بر اساس کد گیفت</option>
                            <option value="2">موجودی دستی</option>
                            <option value="3">بدون محدودیت</option>
                        </select>
                    </div>

                    <label class="flex items-center justify-between rounded-2xl bg-slate-50 px-4 py-3 text-sm font-bold">
                        <span>تنوع پیش‌فرض</span>
                        <input asp-for="Variant.IsDefault" class="h-5 w-5" />
                    </label>

                    <label class="flex items-center justify-between rounded-2xl bg-slate-50 px-4 py-3 text-sm font-bold">
                        <span>فعال باشد</span>
                        <input asp-for="Variant.IsActive" class="h-5 w-5" />
                    </label>
                </div>
            </div>

            <div class="rounded-[2rem] border border-cyan-100 bg-cyan-50/80 p-6 shadow-sm">
                <h3 class="text-sm font-black text-cyan-900">راهنمای سریع</h3>
                <p class="mt-3 text-sm leading-7 text-cyan-800">
                    برای گیفت کارت‌ها بهتره Stock Mode روی GiftCode باشه تا موجودی از کدهای واردشده محاسبه بشه.
                </p>
            </div>

            <button class="w-full rounded-2xl bg-slate-950 px-5 py-4 text-sm font-black text-white shadow-lg">
                ایجاد تنوع
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}