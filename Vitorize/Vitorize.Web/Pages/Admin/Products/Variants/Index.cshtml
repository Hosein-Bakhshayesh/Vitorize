@page
@model Vitorize.Web.Pages.Admin.Products.Variants.IndexModel
@{
    ViewData["Title"] = "تنوع‌های محصول";
    Layout = "~/Pages/Shared/_AdminLayout.cshtml";
}

<div class="space-y-6" dir="rtl">
    <div class="rounded-[2rem] border border-white/70 bg-white/80 p-6 shadow-xl backdrop-blur-xl">
        <div class="flex flex-col gap-5 lg:flex-row lg:items-center lg:justify-between">
            <div class="flex items-center gap-4">
                <div class="h-20 w-20 overflow-hidden rounded-3xl bg-slate-100 ring-1 ring-slate-200">
                    @if (!string.IsNullOrWhiteSpace(Model.Product?.ThumbnailImagePath))
                    {
                        <img src="@Model.Product.ThumbnailImagePath" class="h-full w-full object-cover" />
                    }
                    else
                    {
                        <div class="flex h-full w-full items-center justify-center text-xs font-bold text-slate-400">
                            No Image
                        </div>
                    }
                </div>

                <div>
                    <p class="text-sm font-black text-cyan-600">Product Variants</p>
                    <h1 class="mt-2 text-3xl font-black text-slate-900">تنوع‌های محصول</h1>
                    <p class="mt-1 text-sm text-slate-500">@(Model.Product?.Title ?? "")</p>
                </div>
            </div>

            <div class="flex flex-wrap gap-2">
                <a asp-page="/Admin/Products/Variants/Create" asp-route-productId="@Model.ProductId"
                   class="rounded-2xl bg-slate-950 px-5 py-3 text-sm font-black text-white">
                    + تنوع جدید
                </a>

                <a asp-page="/Admin/Products/Images/Index" asp-route-productId="@Model.ProductId"
                   class="rounded-2xl bg-fuchsia-50 px-5 py-3 text-sm font-black text-fuchsia-700">
                    تصاویر
                </a>

                <a asp-page="/Admin/Products/Details" asp-route-id="@Model.ProductId"
                   class="rounded-2xl bg-slate-100 px-5 py-3 text-sm font-black text-slate-700">
                    جزئیات محصول
                </a>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
    {
        <div class="rounded-2xl border border-emerald-200 bg-emerald-50 px-5 py-4 text-sm font-bold text-emerald-700">
            @Model.SuccessMessage
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="rounded-2xl border border-rose-200 bg-rose-50 px-5 py-4 text-sm font-bold text-rose-700">
            @Model.ErrorMessage
        </div>
    }

    <div class="grid gap-4 md:grid-cols-4">
        <div class="rounded-[1.5rem] bg-white/85 p-5 shadow-sm ring-1 ring-white/70">
            <p class="text-xs font-bold text-slate-500">کل تنوع‌ها</p>
            <p class="mt-2 text-2xl font-black text-slate-900">@Model.TotalVariants</p>
        </div>

        <div class="rounded-[1.5rem] bg-white/85 p-5 shadow-sm ring-1 ring-white/70">
            <p class="text-xs font-bold text-slate-500">فعال</p>
            <p class="mt-2 text-2xl font-black text-emerald-600">@Model.ActiveVariants</p>
        </div>

        <div class="rounded-[1.5rem] bg-white/85 p-5 shadow-sm ring-1 ring-white/70">
            <p class="text-xs font-bold text-slate-500">موجودی قابل فروش</p>
            <p class="mt-2 text-2xl font-black text-cyan-600">@Model.TotalAvailableStock</p>
        </div>

        <div class="rounded-[1.5rem] bg-white/85 p-5 shadow-sm ring-1 ring-white/70">
            <p class="text-xs font-bold text-slate-500">ناموجود</p>
            <p class="mt-2 text-2xl font-black text-rose-600">@Model.OutOfStockVariants</p>
        </div>
    </div>

    @if (!Model.Variants.Any())
    {
        <div class="rounded-[2rem] border border-dashed border-slate-300 bg-white/70 p-10 text-center shadow-sm">
            <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-3xl bg-cyan-50 text-2xl">
                ✦
            </div>
            <h2 class="mt-4 text-xl font-black text-slate-900">هنوز تنوعی ثبت نشده</h2>
            <p class="mt-2 text-sm text-slate-500">برای محصولاتی مثل گیفت کارت ۱۰ دلاری، ۲۰ دلاری یا ریجن‌های مختلف، تنوع بساز.</p>
            <a asp-page="/Admin/Products/Variants/Create" asp-route-productId="@Model.ProductId"
               class="mt-5 inline-flex rounded-2xl bg-slate-950 px-5 py-3 text-sm font-black text-white">
                ایجاد اولین تنوع
            </a>
        </div>
    }
    else
    {
        <div class="grid gap-5 lg:grid-cols-2 2xl:grid-cols-3">
            @foreach (var variant in Model.Variants)
            {
                <div class="rounded-[2rem] border border-white/70 bg-white/85 p-5 shadow-sm backdrop-blur transition hover:-translate-y-1 hover:shadow-xl">
                    <div class="flex items-start justify-between gap-4">
                        <div>
                            <div class="flex flex-wrap items-center gap-2">
                                <h2 class="text-xl font-black text-slate-900">@variant.Title</h2>

                                @if (variant.IsDefault)
                                {
                                    <span class="rounded-full bg-indigo-50 px-3 py-1 text-xs font-black text-indigo-700">پیش‌فرض</span>
                                }

                                @if (variant.IsActive)
                                {
                                    <span class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-black text-emerald-700">فعال</span>
                                }
                                else
                                {
                                    <span class="rounded-full bg-rose-50 px-3 py-1 text-xs font-black text-rose-700">غیرفعال</span>
                                }
                            </div>

                            <p class="mt-2 text-xs text-slate-400">SKU: @(variant.Sku ?? "-")</p>
                            <p class="mt-1 text-xs font-bold text-slate-500">Value: @(variant.Value ?? "-")</p>
                        </div>

                        <div class="rounded-2xl bg-slate-50 px-4 py-3 text-center">
                            <p class="text-xs font-bold text-slate-400">Sort</p>
                            <p class="text-lg font-black text-slate-900">@variant.SortOrder</p>
                        </div>
                    </div>

                    <div class="mt-5 grid gap-3 sm:grid-cols-3">
                        <div class="rounded-2xl bg-slate-50 p-4">
                            <p class="text-xs font-bold text-slate-400">قیمت</p>
                            <p class="mt-1 text-sm font-black text-slate-900">@Model.FormatMoney(variant.FinalPrice)</p>
                        </div>

                        <div class="rounded-2xl bg-slate-50 p-4">
                            <p class="text-xs font-bold text-slate-400">موجودی</p>
                            <p class="mt-1 text-sm font-black @(variant.AvailableStock <= 0 ? "text-rose-600" : "text-emerald-600")">
                                @variant.AvailableStock
                            </p>
                        </div>

                        <div class="rounded-2xl bg-slate-50 p-4">
                            <p class="text-xs font-bold text-slate-400">Stock Mode</p>
                            <p class="mt-1 text-xs font-black text-cyan-700">@Model.GetStockMode(variant.StockMode)</p>
                        </div>
                    </div>

                    <div class="mt-5 flex flex-wrap gap-2 border-t border-slate-100 pt-4">
                        <a asp-page="/Admin/Products/Variants/Edit"
                           asp-route-productId="@Model.ProductId"
                           asp-route-id="@variant.Id"
                           class="rounded-xl bg-indigo-50 px-4 py-2 text-xs font-black text-indigo-700">
                            ویرایش
                        </a>

                        <a href="/Admin/GiftCodes?productId=@Model.ProductId&variantId=@variant.Id"
                           class="rounded-xl bg-amber-50 px-4 py-2 text-xs font-black text-amber-700">
                            کدهای گیفت
                        </a>

                        <form method="post"
                              asp-page-handler="Delete"
                              asp-route-productId="@Model.ProductId"
                              asp-route-id="@variant.Id"
                              onsubmit="return confirm('این تنوع حذف شود؟')">
                            <button class="rounded-xl bg-rose-50 px-4 py-2 text-xs font-black text-rose-700">
                                حذف
                            </button>
                        </form>
                    </div>
                </div>
            }
        </div>
    }
</div>