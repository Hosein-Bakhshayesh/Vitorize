@page "{id:guid}"
@model Vitorize.Web.Pages.Admin.AuditLogs.DetailsModel
@using Vitorize.Web.Helpers
@{
    ViewData["Title"]="جزئیات فعالیت";
    Layout="~/Pages/Shared/_AdminLayout.cshtml";
}
<div class="vz-page" dir="rtl">
<section class="vz-hero">
<div class="vz-hero-main">
<div class="vz-eyebrow">
<i data-lucide="file-text">
</i>جزئیات فعالیت</div>

<h1 class="vz-title">جزئیات فعالیت</h1>
<p class="vz-desc">@AdminUiHelper.Date(Model.Item.CreatedAt)</p>
</div>

<a asp-page="Index" class="vz-btn vz-btn-light">
<i data-lucide="arrow-right">
</i>بازگشت</a>
</section>

<section class="vz-form-card">
<div class="vz-kv">@foreach(var prop in Model.Item.GetType().GetProperties()){ if(prop.Name=="Data" || prop.Name=="UserAgent" || prop.Name=="Description"){continue;} <div class="vz-kv-item">
<span>@prop.Name</span>
<strong>@(prop.GetValue(Model.Item)?.ToString() ?? "-")</strong>
</div>
}
</div>
@{var longText = Model.Item.GetType().GetProperty("Data")?.GetValue(Model.Item)?.ToString() ?? Model.Item.GetType().GetProperty("Description")?.GetValue(Model.Item)?.ToString();}
@if(!string.IsNullOrWhiteSpace(longText)){
<div class="vz-field" style="margin-top:18px">
<label>توضیحات</label>
<div class="vz-muted-box">@longText</div>

</div>
}
@{var ua=Model.Item.GetType().GetProperty("UserAgent")?.GetValue(Model.Item)?.ToString();}
@if(!string.IsNullOrWhiteSpace(ua)){
<div class="vz-field" style="margin-top:18px">
<label>مرورگر</label>
<div class="vz-code">@ua</div>

</div>
}
</section>

</div>

@section Scripts {

<script>
if(window.lucide){lucide.createIcons();}

</script>
}
