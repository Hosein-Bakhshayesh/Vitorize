@page
@model Vitorize.Web.Pages.Admin.Wallets.IndexModel
@using Vitorize.Web.Helpers
@{
    ViewData["Title"] = "کیف پول‌ها"; Layout = "~/Pages/Shared/_AdminLayout.cshtml";
}
<div class="vz-page" dir="rtl">
    <section class="vz-hero">
<div class="vz-hero-main">
<div class="vz-eyebrow">
<i data-lucide="wallet">
</i>کیف پول</div>

<h1 class="vz-title">مدیریت کیف پول کاربران</h1>
<p class="vz-desc">کیف پول‌ها را جستجو کن، موجودی را ببین و عملیات مالی دستی را ثبت کن.</p>
</div>

</section>

    @if(!string.IsNullOrWhiteSpace(Model.SuccessMessage)){
<div class="vz-alert vz-alert-success">
<i data-lucide="check-circle-2">
</i>
<span>@Model.SuccessMessage</span>
</div>
}
    @if(!string.IsNullOrWhiteSpace(Model.ErrorMessage)){
<div class="vz-alert vz-alert-danger">
<i data-lucide="triangle-alert">
</i>
<span>@Model.ErrorMessage</span>
</div>
}
    <section class="vz-form-card">
<form method="get" class="vz-filter-grid">
<div class="vz-field">
<label>جستجو</label>
<div class="vz-input-shell">
<i data-lucide="search">
</i>
<input asp-for="Search" class="vz-input" placeholder="نام، موبایل یا ایمیل کاربر" />
</div>

</div>

<div>
</div>

<div>
</div>

<button class="vz-btn vz-btn-primary">
<i data-lucide="filter">
</i>اعمال</button>
</form>

</section>

    <section class="vz-table-card">
<div class="vz-card-head">
<div>
<h2>کیف پول‌ها</h2>
<p>برای مدیریت، روی کیف پول کاربر کلیک کن.</p>
</div>

<span class="vz-badge vz-badge-muted">@Model.Wallets.Count مورد</span>
</div>

<div class="vz-table-wrap">
<table class="vz-table">
<thead>
<tr>
<th>کاربر</th>
<th>موجودی</th>
<th>آخرین تغییر</th>
<th>
</th>
</tr>

</thead>

<tbody>@foreach(var item in Model.Wallets){
<tr>
<td>
<div class="vz-item">
<div class="vz-thumb-fallback sm">
<i data-lucide="user">
</i>
</div>

<div class="vz-item-text">
<strong>@item.UserFullName</strong>
<span>@item.UserMobile</span>
</div>

</div>

</td>
<td>@AdminUiHelper.Money(item.Balance)</td>
<td>@AdminUiHelper.Date(item.UpdatedAt ?? item.CreatedAt)</td>
<td>
<a asp-page="Index" asp-route-userId="@item.UserId" asp-route-search="@Model.Search" class="vz-icon-btn info">
<i data-lucide="eye">
</i>
</a>
</td>
</tr>
}
</tbody>

</table>

</div>
@if(!Model.Wallets.Any()){
<div class="vz-empty">
<div class="vz-empty-icon">
<i data-lucide="wallet">
</i>
</div>

<h3>کیف پولی برای نمایش وجود ندارد</h3>
</div>
}
</section>

    @if(Model.Wallet != null){
<section class="vz-stats">
<article class="vz-stats-card">
<div class="vz-stat-icon green">
<i data-lucide="wallet">
</i>
</div>

<div class="vz-stat-content">
<span class="vz-stat-label">موجودی @Model.Wallet.UserFullName</span>
<strong class="vz-stat-value">@AdminUiHelper.Money(Model.Wallet.Balance)</strong>
</div>

</article>
</section>

<section class="vz-form-card">
<div class="vz-card-head">
<div>
<h2>افزایش یا کاهش موجودی</h2>
<p>مبلغ و توضیح عملیات را ثبت کن.</p>
</div>

</div>

<div class="vz-form-grid two">
<form method="post" asp-page-handler="Charge" asp-route-userId="@Model.Wallet.UserId">
<div class="vz-field">
<label>مبلغ افزایش</label>
<div class="vz-input-shell">
<i data-lucide="plus">
</i>
<input asp-for="ChargeRequest.Amount" type="number" class="vz-input ltr" />
</div>

</div>

<div class="vz-field">
<label>توضیح</label>
<div class="vz-input-shell">
<i data-lucide="file-text">
</i>
<input asp-for="ChargeRequest.Description" class="vz-input" />
</div>

</div>

<div style="height:12px">
</div>

<button class="vz-btn vz-btn-success">افزایش موجودی</button>
</form>

<form method="post" asp-page-handler="Withdraw" asp-route-userId="@Model.Wallet.UserId">
<div class="vz-field">
<label>مبلغ کاهش</label>
<div class="vz-input-shell">
<i data-lucide="minus">
</i>
<input asp-for="WithdrawRequest.Amount" type="number" class="vz-input ltr" />
</div>

</div>

<div class="vz-field">
<label>توضیح</label>
<div class="vz-input-shell">
<i data-lucide="file-text">
</i>
<input asp-for="WithdrawRequest.Description" class="vz-input" />
</div>

</div>

<div style="height:12px">
</div>

<button class="vz-btn vz-btn-danger">کاهش موجودی</button>
</form>

</div>

</section>

<section class="vz-table-card">
<div class="vz-card-head">
<div>
<h2>تراکنش‌ها</h2>
</div>

</div>

<div class="vz-table-wrap">
<table class="vz-table">
<thead>
<tr>
<th>نوع</th>
<th>مبلغ</th>
<th>موجودی بعد</th>
<th>توضیح</th>
<th>تاریخ</th>
</tr>

</thead>

<tbody>@foreach(var t in Model.Transactions){
<tr>
<td>@AdminUiHelper.WalletTransactionType(t.Type)</td>
<td>@AdminUiHelper.Money(t.Amount)</td>
<td>@AdminUiHelper.Money(t.BalanceAfter)</td>
<td>@(t.Description ?? "-")</td>
<td>@AdminUiHelper.Date(t.CreatedAt)</td>
</tr>
}
</tbody>

</table>

</div>

</section>
}
</div>

@section Scripts {

<script>
if(window.lucide){lucide.createIcons();}

</script>
}
