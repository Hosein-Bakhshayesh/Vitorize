@page
@model Vitorize.Web.Pages.Admin.ProductImages.IndexModel
@{
    ViewData["Title"] = "تصاویر محصول";
    Layout = "~/Pages/Shared/_AdminLayout.cshtml";
}
<div class="vz-page" dir="rtl">
    <section class="vz-hero">
<div class="vz-hero-main">
<div class="vz-eyebrow">
<i data-lucide="image">
</i>تصاویر محصول</div>

<h1 class="vz-title">مدیریت تصاویر محصول</h1>
<p class="vz-desc">تصاویر محصول را اضافه، مرتب و به عنوان تصویر اصلی انتخاب کن.</p>
</div>

<div class="vz-actions">@if (Model.Product != null) { <a asp-page="/Admin/Products/Details" asp-route-id="@Model.Product.Id" class="vz-btn vz-btn-light">
<i data-lucide="package">
</i>بازگشت به محصول</a> }
</div>

</section>

    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage)) { <div class="vz-alert vz-alert-success">
<i data-lucide="check-circle-2">
</i>
<span>@Model.SuccessMessage</span>
</div>
 }
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage)) { <div class="vz-alert vz-alert-danger">
<i data-lucide="triangle-alert">
</i>
<span>@Model.ErrorMessage</span>
</div>
 }
    <section class="vz-form-card">
<form method="get" class="vz-form-grid two">
<div class="vz-field">
<label>محصول</label>
<div class="vz-input-shell">
<i data-lucide="package">
</i>
<select asp-for="ProductId" class="vz-select" onchange="this.form.submit()">
<option value="">انتخاب محصول</option>@foreach (var p in Model.Products) { <option value="@p.Id">@p.Title</option> }
</select>
</div>

</div>

</form>

</section>

    @if (Model.Product != null) {
    <section class="vz-form-card">
<div class="vz-card-head">
<div>
<h2>آپلود تصویر جدید</h2>
<p>قبل از ثبت، پیش‌نمایش تصویر را همینجا می‌بینی.</p>
</div>

</div>

<form method="post" enctype="multipart/form-data" asp-page-handler="Upload" asp-route-productId="@Model.Product.Id" class="vz-form-layout">
<input type="hidden" name="productId" value="@Model.Product.Id" />
<div class="vz-main-col">
<div class="vz-upload-card">
<label class="vz-dropzone js-upload-zone" data-target="productImagePreview" data-placeholder="productImagePlaceholder" data-info="productFileInfo" data-input="ImageFile">
<img id="productImagePreview" class="vz-preview-img" hidden alt="preview" />
<span id="productImagePlaceholder" class="vz-upload-placeholder">
<img src="~/images/admin/upload-placeholder.svg" asp-append-version="true" alt="" />
<strong>انتخاب تصویر محصول</strong>
<span>فایل تصویر را انتخاب کن یا روی این بخش رها کن.</span>
<small>JPG / PNG / WEBP</small>
</span>
<input id="ImageFile" name="ImageFile" type="file" accept=".jpg,.jpeg,.png,.webp" class="vz-file-input js-upload-input" />
</label>
<div id="productFileInfo" class="vz-file-info" hidden>
<div class="vz-file-info-icon">
<i data-lucide="file-image">
</i>
</div>

<section>
<strong class="js-file-name">-</strong>
<span class="js-file-size">-</span>
</section>

<button type="button" class="vz-clear-file js-clear-file">
<i data-lucide="x">
</i>
</button>
</div>

</div>

</div>

<div class="vz-side-col">
<section class="vz-side-card">
<div class="vz-field">
<label asp-for="AltText">متن جایگزین</label>
<div class="vz-input-shell">
<i data-lucide="type">
</i>
<input asp-for="AltText" class="vz-input" />
</div>

</div>

<div class="vz-field" style="margin-top:14px">
<label asp-for="SortOrder">ترتیب نمایش</label>
<div class="vz-input-shell">
<i data-lucide="arrow-down-up">
</i>
<input asp-for="SortOrder" type="number" class="vz-input ltr" />
</div>

</div>

<div style="height:14px">
</div>

<div class="vz-switch-card">
<div>
<strong>تصویر اصلی</strong>
<span>به عنوان تصویر شاخص محصول استفاده شود.</span>
</div>

<label class="vz-switch">
<input asp-for="SetAsThumbnail" />
<span class="vz-switch-ui">
</span>
</label>
</div>

<div style="height:14px">
</div>

<button type="submit" class="vz-btn vz-btn-primary vz-btn-full">
<i data-lucide="save">
</i>ثبت تصویر</button>
</section>

</div>

</form>

</section>

    <section class="vz-table-card">
<div class="vz-card-head">
<div>
<h2>گالری تصاویر</h2>
<p>@Model.Images.Count تصویر ثبت شده است.</p>
</div>

</div>
@if (!Model.Images.Any()) { <div class="vz-empty">
<div class="vz-empty-icon">
<i data-lucide="image-off">
</i>
</div>

<h3>هنوز تصویری ثبت نشده است</h3>
<p>اولین تصویر محصول را از بخش بالا ثبت کن.</p>
</div>
 } else { <div class="vz-gallery">@foreach (var img in Model.Images) { <article class="vz-gallery-card">
<div class="vz-gallery-img">
<img src="@Model.Image(img.ImagePath)" alt="@img.AltText" />
</div>

<div class="vz-gallery-body">
<span class="vz-code">@img.ImagePath</span>
<form method="post" asp-page-handler="Update" asp-route-productId="@Model.Product.Id" asp-route-imageId="@img.Id">
<input type="hidden" name="productId" value="@Model.Product.Id" />
<input type="hidden" name="imageId" value="@img.Id" />
<input type="hidden" name="imagePath" value="@img.ImagePath" />
<div class="vz-form-grid">
<div class="vz-field">
<label>متن جایگزین</label>
<div class="vz-input-shell">
<i data-lucide="type">
</i>
<input name="altText" value="@img.AltText" class="vz-input" />
</div>

</div>

<div class="vz-field">
<label>ترتیب</label>
<div class="vz-input-shell">
<i data-lucide="arrow-down-up">
</i>
<input name="sortOrder" value="@img.SortOrder" type="number" class="vz-input ltr" />
</div>

</div>

<button class="vz-btn vz-btn-light" type="submit">
<i data-lucide="save">
</i>ذخیره</button>
</div>

</form>

<div class="vz-actions">
<form method="post" asp-page-handler="SetThumbnail" asp-route-productId="@Model.Product.Id" asp-route-imageId="@img.Id">
<button class="vz-icon-btn success" type="submit">
<i data-lucide="star">
</i>
</button>
</form>

<a href="@Model.Image(img.ImagePath)" target="_blank" class="vz-icon-btn info">
<i data-lucide="external-link">
</i>
</a>
<form method="post" asp-page-handler="Delete" asp-route-productId="@Model.Product.Id" asp-route-imageId="@img.Id" onsubmit="return confirm('تصویر حذف شود؟');">
<button class="vz-icon-btn danger" type="submit">
<i data-lucide="trash-2">
</i>
</button>
</form>

</div>

</div>

</article> }
</div>
 }
</section>

    }
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" />

<script>
    function formatFileSize(bytes) {
        if (!bytes) {
            return '0 KB';
        }

        const kb = bytes / 1024;

        if (kb < 1024) {
            return kb.toFixed(1) + ' KB';
        }

        return (kb / 1024).toFixed(2) + ' MB';
    }

    function initUploadZones() {
        document.querySelectorAll('.js-upload-zone').forEach(function (zone) {
            const input = document.getElementById(zone.dataset.input);
            const preview = document.getElementById(zone.dataset.target);
            const placeholder = document.getElementById(zone.dataset.placeholder);
            const info = document.getElementById(zone.dataset.info);

            if (!input) {
                return;
            }

            function show(file) {
                if (!file) {
                    return;
                }

                const allowedTypes = [
                    'image/jpeg',
                    'image/png',
                    'image/webp'
                ];

                if (!allowedTypes.includes(file.type)) {
                    alert('فرمت تصویر مجاز نیست.');
                    input.value = '';
                    return;
                }

                if (file.size > 10 * 1024 * 1024) {
                    alert('حجم فایل بیش از حد مجاز است.');
                    input.value = '';
                    return;
                }

                const reader = new FileReader();

                reader.onload = function (event) {
                    if (preview) {
                        preview.src = event.target.result;
                        preview.hidden = false;
                    }

                    if (placeholder) {
                        placeholder.hidden = true;
                    }

                    if (info) {
                        info.hidden = false;

                        const fileName = info.querySelector('.js-file-name');
                        const fileSize = info.querySelector('.js-file-size');

                        if (fileName) {
                            fileName.textContent = file.name;
                        }

                        if (fileSize) {
                            fileSize.textContent = formatFileSize(file.size);
                        }
                    }

                    if (window.lucide) {
                        lucide.createIcons();
                    }
                };

                reader.readAsDataURL(file);
            }

            input.addEventListener('change', function (event) {
                show(event.target.files && event.target.files[0]);
            });

            zone.addEventListener('dragover', function (event) {
                event.preventDefault();
                zone.classList.add('is-dragover');
            });

            zone.addEventListener('dragleave', function () {
                zone.classList.remove('is-dragover');
            });

            zone.addEventListener('drop', function (event) {
                event.preventDefault();
                zone.classList.remove('is-dragover');

                const file = event.dataTransfer.files && event.dataTransfer.files[0];

                if (!file) {
                    return;
                }

                const dataTransfer = new DataTransfer();
                dataTransfer.items.add(file);
                input.files = dataTransfer.files;

                show(file);
            });

            if (info) {
                const clear = info.querySelector('.js-clear-file');

                if (clear) {
                    clear.addEventListener('click', function (event) {
                        event.preventDefault();
                        input.value = '';

                        if (preview) {
                            preview.src = '';
                            preview.hidden = true;
                        }

                        if (placeholder) {
                            placeholder.hidden = false;
                        }

                        info.hidden = true;
                    });
                }
            }
        });

        if (window.lucide) {
            lucide.createIcons();
        }
    }

    document.addEventListener('DOMContentLoaded', initUploadZones);
</script>
 }
