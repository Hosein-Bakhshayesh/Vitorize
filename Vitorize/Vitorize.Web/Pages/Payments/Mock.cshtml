@page
@model Vitorize.Web.Pages.Payments.MockModel
@{
    ViewData["Title"] = "پرداخت تستی | Vitorize";
}

<section class="vt-mock-payment">
    <div class="vt-mock-payment-card">
        <div class="vt-mock-payment-icon">💳</div>

        <h1>پرداخت تستی ویتورایز</h1>
        <p>
            این صفحه فعلاً جایگزین زرین‌پال است. بعداً همین مرحله به درگاه واقعی متصل می‌شود.
        </p>

        <div class="vt-mock-payment-amount">
            <span>مبلغ پرداخت</span>
            <b>@StorefrontFormat.Money(Model.Amount)</b>
        </div>

        <div class="vt-mock-payment-actions">
            <form method="post" asp-page-handler="Pay">
                <button type="submit" class="pay">
                    پرداخت موفق تستی
                </button>
            </form>

            <form method="post" asp-page-handler="Cancel">
                <button type="submit" class="cancel">
                    انصراف
                </button>
            </form>
        </div>
    </div>
</section>