<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@(ViewData["Title"] ?? "Vitorize")</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        vitorize: {
                            50: '#e4f8f5',
                            100: '#c6efea',
                            500: '#008b83',
                            600: '#007a73',
                            700: '#006b67',
                            800: '#075a56',
                            900: '#053f3e'
                        }
                    },
                    boxShadow: {
                        glass: '0 22px 70px rgba(15,82,87,.10)',
                        soft: '0 18px 45px rgba(15, 23, 42, .07)'
                    }
                }
            }
        }
    </script>

    <link rel="stylesheet" href="~/css/storefront.css" asp-append-version="true" />
</head>

<body class="vt-body">
    <header class="vt-header">
        <div class="vt-shell">
            <div class="vt-topbar">
                <div class="flex items-center gap-5">
                    <span class="vt-top-link">🎧 پشتیبانی ۲۴/۷</span>
                    <a asp-page="/Products/Index" asp-route-Search="PlayStation" class="vt-top-link">پلی‌استیشن</a>
                    <a asp-page="/Products/Index" asp-route-Search="Xbox" class="vt-top-link">ایکس‌باکس</a>
                    <a asp-page="/Products/Index" asp-route-Search="Telegram" class="vt-top-link">تلگرام</a>
                    <a asp-page="/Products/Index" asp-route-Search="ChatGPT" class="vt-top-link">هوش مصنوعی</a>
                </div>

                <div class="flex items-center gap-4">
                    <a asp-page="/Orders/Index" class="vt-top-link">پیگیری سفارش</a>
                </div>
            </div>

            <div class="vt-mainbar">
                <a asp-page="/Index" class="vt-brand">
                    <img src="~/img/vitorize-logo.png" class="vt-brand-logo" alt="Vitorize" />
                    <span>Vitorize</span>
                </a>

                <form asp-page="/Products/Index" method="get" class="vt-search">
                    <input name="Search" placeholder="جستجوی گیفت کارت، اکانت بازی، تلگرام، ChatGPT..." />
                    <button type="submit" aria-label="search">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                            <path d="M11 19a8 8 0 1 1 5.29-14.01A8 8 0 0 1 11 19Zm9 1-4.35-4.35" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                        </svg>
                    </button>
                </form>

                <div class="vt-header-actions">
                    @await Component.InvokeAsync("StoreHeader")
                </div>
            </div>

            <nav class="vt-nav">
                <a asp-page="/Index" class="vt-nav-item">خانه</a>

                <a asp-page="/Products/Index"
                   asp-route-Search="Gift Card"
                   class="vt-nav-item">
                    گیفت کارت
                </a>

                <a asp-page="/Products/Index"
                   asp-route-Search="PlayStation"
                   class="vt-nav-item">
                    پلی‌استیشن
                </a>

                <a asp-page="/Products/Index"
                   asp-route-Search="Xbox"
                   class="vt-nav-item">
                    ایکس‌باکس
                </a>

                <a asp-page="/Products/Index"
                   asp-route-Search="Game Account"
                   class="vt-nav-item">
                    اکانت بازی
                </a>

                <a asp-page="/Products/Index"
                   asp-route-Search="Telegram"
                   class="vt-nav-item">
                    اکانت تلگرام
                </a>

                <a asp-page="/Products/Index"
                   asp-route-Search="ChatGPT"
                   class="vt-nav-item">
                    ChatGPT و AI
                </a>

                <a asp-page="/Products/Index"
                   asp-route-IsFeatured="true"
                   class="vt-nav-item vt-nav-special">
                    پیشنهاد ویژه
                </a>
            </nav>
        </div>
    </header>

    <main class="vt-shell vt-main">
        @RenderBody()
    </main>

    <footer class="vt-footer">
        <div class="vt-shell">
            <div class="vt-footer-grid">
                <div class="vt-footer-about">
                    <div class="flex items-center gap-3">
                        <img src="~/img/vitorize-logo.png" class="h-11 w-11" alt="Vitorize" />
                        <b class="text-3xl">Vitorize</b>
                    </div>
                    <p>
                        ویتورایز، مرجع خرید گیفت کارت و سرویس‌های دیجیتال با تحویل سریع و پشتیبانی واقعی.
                    </p>
                    <div class="mt-5 space-y-2 text-sm">
                        <div>پشتیبانی: ۰۲۱-۹۱۰۰۰۰۰۰</div>
                        <div>support@vitorize.com</div>
                    </div>
                </div>

                <div>
                    <h4>درباره ویتورایز</h4>
                    <a href="#">درباره ما</a>
                    <a href="#">تماس با ما</a>
                    <a href="#">وبلاگ</a>
                    <a href="#">فرصت‌های شغلی</a>
                </div>

                <div>
                    <h4>راهنمای خرید</h4>
                    <a href="#">سوالات متداول</a>
                    <a href="#">روش‌های پرداخت</a>
                    <a href="#">راهنمای خرید</a>
                    <a href="#">قوانین و مقررات</a>
                    <a href="#">حریم خصوصی</a>
                </div>

                <div>
                    <h4>دسترسی سریع</h4>
                    <a asp-page="/Products/Index">گیفت کارت</a>
                    <a asp-page="/Products/Index">بازی‌ها</a>
                    <a asp-page="/Products/Index">اشتراک‌ها</a>
                    <a asp-page="/Products/Index">سرویس‌ها</a>
                    <a asp-page="/Products/Index" asp-route-IsFeatured="true">پیشنهادهای ویژه</a>
                </div>

                <div>
                    <h4>خبرنامه ویتورایز</h4>
                    <p class="mb-4 text-sm text-white/70">جدیدترین تخفیف‌ها و محصولات را دریافت کنید.</p>
                    <form class="vt-newsletter">
                        <input placeholder="ایمیل شما" />
                        <button type="button">ثبت</button>
                    </form>

                    <div class="mt-6">
                        <b>ما را دنبال کنید</b>
                        <div class="mt-3 flex gap-3">
                            <span class="vt-social">تل</span>
                            <span class="vt-social">این</span>
                            <span class="vt-social">ایکس</span>
                            <span class="vt-social">یوت</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="vt-footer-bottom">
                تمامی حقوق این وبسایت محفوظ است. © ۱۴۰۵ Vitorize
            </div>
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>