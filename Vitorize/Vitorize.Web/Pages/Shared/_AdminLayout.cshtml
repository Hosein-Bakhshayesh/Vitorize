<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] | Vitorize Admin</title>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Vitorize.Web.styles.css" asp-append-version="true" />

    <script src="https://unpkg.com/lucide@latest"></script>

    <style>
        @@font-face {
        font-family: 'Vazir';
        src: url('/css/fonts/Vazir/woff2/Vazir.woff2') format('woff2'), url('/css/fonts/Vazir/woff/Vazir.woff') format('woff'), url('/css/fonts/Vazir/ttf/Vazir.ttf') format('truetype');
        font-weight: 400;
        font-style: normal;
        font-display: swap;
        }

        @@font-face {
        font-family: 'Vazir';
        src: url('/css/fonts/Vazir/woff2/Vazir-Medium.woff2') format('woff2'), url('/css/fonts/Vazir/woff/Vazir-Medium.woff') format('woff'), url('/css/fonts/Vazir/ttf/Vazir-Medium.ttf') format('truetype');
        font-weight: 600;
        font-style: normal;
        font-display: swap;
        }

        @@font-face {
        font-family: 'Vazir';
        src: url('/css/fonts/Vazir/woff2/Vazir-Bold.woff2') format('woff2'), url('/css/fonts/Vazir/woff/Vazir-Bold.woff') format('woff'), url('/css/fonts/Vazir/ttf/Vazir-Bold.ttf') format('truetype');
        font-weight: 800;
        font-style: normal;
        font-display: swap;
        }

        :root {
        --admin-font: "Vazir", "Segoe UI", Tahoma, Arial, sans-serif;
        --admin-bg: #f6f9ff;
        --admin-text: #0f172a;
        --admin-muted: #94a3b8;
        --admin-border: rgba(226, 232, 240, .82);
        --admin-purple: #6246ea;
        --admin-blue: #2f80ed;
        --admin-sidebar-width: 284px;
        --admin-sidebar-collapsed-width: 96px;
        }

        * {
        box-sizing: border-box;
        }

        html,
        body {
        min-height: 100%;
        margin: 0;
        padding: 0;
        background: var(--admin-bg);
        color: var(--admin-text);
        font-family: var(--admin-font);
        }

        body {
        overflow-x: hidden;
        }

        body.admin-sidebar-collapsed {
        --admin-sidebar-width: var(--admin-sidebar-collapsed-width);
        }

        a {
        text-decoration: none;
        }

        .admin-shell {
        min-height: 100vh;
        background: radial-gradient(circle at 18% 12%, rgba(98, 70, 234, .07), transparent 28%), radial-gradient(circle at 72% 18%, rgba(47, 128, 237, .07), transparent 30%), linear-gradient(180deg, #fbfdff 0%, #f5f8ff 38%, #f7faff 100%);
        }

        .admin-overlay {
        position: fixed;
        inset: 0;
        z-index: 45;
        display: none;
        background: rgba(15, 23, 42, .32);
        backdrop-filter: blur(6px);
        -webkit-backdrop-filter: blur(6px);
        }

        .admin-overlay.show {
        display: block;
        }

        .admin-sidebar {
        position: fixed;
        top: 0;
        right: 0;
        z-index: 50;
        width: var(--admin-sidebar-width);
        height: 100vh;
        display: flex;
        flex-direction: column;
        background: rgba(255, 255, 255, .88);
        backdrop-filter: blur(24px);
        -webkit-backdrop-filter: blur(24px);
        border-left: 1px solid var(--admin-border);
        box-shadow: -14px 0 44px rgba(15, 23, 42, .04);
        transition: width .22s ease, transform .25s ease;
        }

        .admin-main {
        min-height: 100vh;
        margin-right: var(--admin-sidebar-width);
        transition: margin-right .22s ease;
        }

        .admin-topbar {
        position: fixed;
        top: 0;
        left: 0;
        right: var(--admin-sidebar-width);
        z-index: 35;
        height: 86px;
        background: rgba(255, 255, 255, .78);
        backdrop-filter: blur(22px);
        -webkit-backdrop-filter: blur(22px);
        border-bottom: 1px solid var(--admin-border);
        transition: right .22s ease;
        }

        .admin-topbar-inner {
        height: 100%;
        padding: 0 24px;
        display: grid;
        grid-template-columns: auto minmax(280px, 420px) auto;
        align-items: center;
        gap: 18px;
        }

        .admin-topbar-right {
        display: flex;
        align-items: center;
        justify-content: flex-start;
        gap: 12px;
        min-width: 0;
        }

        .admin-topbar-center {
        display: flex;
        align-items: center;
        justify-content: center;
        }

        .admin-topbar-left {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 12px;
        min-width: 0;
        }

        .admin-page-wrap {
        display: flex;
        align-items: center;
        gap: 12px;
        min-width: 0;
        }

        .admin-page-icon {
        width: 48px;
        height: 48px;
        border-radius: 17px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        background: linear-gradient(135deg, #7c5cff 0%, #6246ea 48%, #2f80ed 100%);
        box-shadow: 0 18px 34px rgba(98, 70, 234, .18);
        flex: 0 0 auto;
        }

        .admin-page-icon svg {
        width: 20px;
        height: 20px;
        }

        .admin-page-text {
        min-width: 0;
        text-align: right;
        }

        .admin-page-text h1 {
        margin: 0;
        color: #0f172a;
        font-size: 24px;
        font-weight: 950;
        line-height: 1.2;
        white-space: nowrap;
        }

        .admin-page-text small {
        display: block;
        margin-top: 4px;
        color: #94a3b8;
        font-size: 12px;
        font-weight: 800;
        white-space: nowrap;
        }

        .admin-search {
        width: 100%;
        height: 46px;
        max-width: 400px;
        border-radius: 16px;
        border: 1px solid rgba(203, 213, 225, .78);
        background: rgba(255, 255, 255, .72);
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 0 14px;
        transition: .18s ease;
        }

        .admin-search:focus-within {
        border-color: rgba(98, 70, 234, .34);
        background: rgba(255, 255, 255, .95);
        box-shadow: 0 0 0 4px rgba(98, 70, 234, .06);
        }

        .admin-search input {
        flex: 1 1 auto;
        height: 100%;
        border: 0;
        outline: none;
        background: transparent;
        color: #334155;
        font-size: 14px;
        font-weight: 700;
        text-align: right;
        direction: rtl;
        }

        .admin-search input::placeholder {
        color: #94a3b8;
        }

        .admin-icon-btn {
        width: 42px;
        height: 42px;
        border: 0;
        border-radius: 15px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: #64748b;
        background: transparent;
        position: relative;
        cursor: pointer;
        transition: .18s ease;
        flex: 0 0 auto;
        }

        .admin-icon-btn:hover {
        color: var(--admin-purple);
        background: rgba(241, 245, 249, .9);
        transform: translateY(-1px);
        }

        .admin-toggle-btn {
        background: rgba(255, 255, 255, .86);
        border: 1px solid var(--admin-border);
        color: #475569;
        }

        .admin-toggle-btn:hover {
        background: #fff;
        box-shadow: 0 14px 24px rgba(15, 23, 42, .05);
        }

        .admin-badge-dot {
        position: absolute;
        top: 2px;
        right: 2px;
        width: 18px;
        height: 18px;
        border-radius: 999px;
        background: #ef4444;
        color: #fff;
        font-size: 10px;
        font-weight: 900;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 2px solid #fff;
        }

        .admin-profile {
        display: flex;
        align-items: center;
        gap: 10px;
        padding-inline-start: 4px;
        }

        .admin-profile-info {
        text-align: right;
        }

        .admin-profile-name {
        color: #0f172a;
        font-size: 14px;
        font-weight: 950;
        line-height: 1.25;
        white-space: nowrap;
        }

        .admin-profile-role {
        margin-top: 2px;
        color: #94a3b8;
        font-size: 11px;
        font-weight: 800;
        white-space: nowrap;
        }

        .admin-avatar {
        width: 46px;
        height: 46px;
        border-radius: 999px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #0f172a;
        color: #fff;
        font-size: 16px;
        font-weight: 950;
        box-shadow: 0 14px 26px rgba(15, 23, 42, .12);
        flex: 0 0 auto;
        }

        .admin-divider {
        width: 1px;
        height: 34px;
        background: rgba(226, 232, 240, .92);
        }

        .admin-content {
        padding: 110px 28px 28px;
        }

        .admin-sidebar-header {
        padding: 22px 16px 0;
        }

        .admin-brand-card {
        position: relative;
        padding: 22px 16px 20px;
        border-radius: 28px;
        background: radial-gradient(circle at 18% 15%, rgba(98, 70, 234, .13), transparent 28%), radial-gradient(circle at 82% 18%, rgba(47, 128, 237, .11), transparent 28%), rgba(255, 255, 255, .78);
        border: 1px solid rgba(226, 232, 240, .88);
        box-shadow: 0 18px 36px rgba(15, 23, 42, .05);
        backdrop-filter: blur(18px);
        -webkit-backdrop-filter: blur(18px);
        text-align: center;
        }

        .admin-brand-top {
        height: 0;
        display: flex;
        justify-content: flex-end;
        align-items: center;
        }

        .admin-sidebar-close {
        display: none;
        }

        .admin-brand-logo-wrap {
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 13px;
        }

        .admin-brand-logo {
        width: 76px;
        height: 76px;
        object-fit: contain;
        border-radius: 22px;
        padding: 10px;
        background: rgba(255, 255, 255, .92);
        box-shadow: 0 14px 28px rgba(98, 70, 234, .12);
        border: 1px solid rgba(226, 232, 240, .95);
        }

        .admin-brand-fallback {
        width: 76px;
        height: 76px;
        border-radius: 22px;
        display: none;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #7c5cff 0%, #6246ea 45%, #2f80ed 100%);
        box-shadow: 0 18px 34px rgba(98, 70, 234, .18);
        }

        .admin-brand-v {
        color: #fff;
        font-weight: 1000;
        font-size: 34px;
        line-height: 1;
        transform: skewX(-8deg);
        letter-spacing: -2px;
        }

        .admin-brand-title {
        color: #0f172a;
        font-size: 28px;
        font-weight: 950;
        line-height: 1.1;
        direction: ltr;
        text-align: center;
        }

        .admin-brand-subtitle {
        margin-top: 8px;
        color: #94a3b8;
        font-size: 12px;
        font-weight: 800;
        text-align: center;
        }

        .admin-sidebar-scroll {
        flex: 1 1 auto;
        overflow-y: auto;
        padding-top: 20px;
        padding-bottom: 8px;
        }

        .admin-menu-section {
        display: flex;
        align-items: center;
        gap: 8px;
        margin: 22px 0 10px;
        padding: 0 22px;
        color: #94a3b8;
        font-size: 12px;
        font-weight: 900;
        transition: .18s ease;
        }

        .admin-menu-section svg {
        width: 15px;
        height: 15px;
        stroke-width: 2.2;
        flex: 0 0 auto;
        }

        .admin-nav-link {
        min-height: 46px;
        margin: 5px 14px;
        padding: 0 16px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        color: #1e293b;
        transition: .18s ease;
        }

        .admin-nav-link:hover {
        color: var(--admin-purple);
        background: rgba(241, 245, 249, .86);
        transform: translateX(-2px);
        }

        .admin-nav-link.active {
        color: var(--admin-purple);
        background: linear-gradient(90deg, rgba(98, 70, 234, .15), rgba(98, 70, 234, .05));
        box-shadow: inset 0 0 0 1px rgba(98, 70, 234, .07);
        }

        .admin-nav-link-content {
        display: flex;
        align-items: center;
        gap: 12px;
        min-width: 0;
        }

        .admin-nav-icon {
        width: 36px;
        height: 36px;
        border-radius: 12px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: rgba(248, 250, 252, .98);
        border: 1px solid rgba(226, 232, 240, .86);
        flex: 0 0 auto;
        transition: .18s ease;
        }

        .admin-nav-link:hover .admin-nav-icon,
        .admin-nav-link.active .admin-nav-icon {
        background: rgba(98, 70, 234, .08);
        border-color: rgba(98, 70, 234, .12);
        }

        .admin-nav-text {
        font-size: 13px;
        font-weight: 850;
        white-space: nowrap;
        }

        .admin-nav-link svg {
        width: 18px;
        height: 18px;
        stroke-width: 2.15;
        flex: 0 0 auto;
        }

        .admin-sidebar-footer {
        padding: 18px 16px 20px;
        }

        .admin-logout {
        min-height: 54px;
        border-radius: 18px;
        padding: 0 18px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        color: var(--admin-purple);
        background: rgba(98, 70, 234, .10);
        font-size: 13px;
        font-weight: 950;
        transition: .18s ease;
        }

        .admin-logout:hover {
        color: #fff;
        background: var(--admin-purple);
        box-shadow: 0 16px 34px rgba(98, 70, 234, .18);
        }

        .admin-logout-content {
        display: flex;
        align-items: center;
        gap: 10px;
        }

        body.admin-sidebar-collapsed .admin-sidebar-header {
        padding-inline: 10px;
        padding-top: 18px;
        }

        body.admin-sidebar-collapsed .admin-brand-card {
        padding: 14px 10px;
        border-radius: 22px;
        }

        body.admin-sidebar-collapsed .admin-brand-logo-wrap {
        margin-bottom: 0;
        }

        body.admin-sidebar-collapsed .admin-brand-logo,
        body.admin-sidebar-collapsed .admin-brand-fallback {
        width: 58px;
        height: 58px;
        border-radius: 18px;
        padding: 8px;
        }

        body.admin-sidebar-collapsed .admin-brand-v {
        font-size: 24px;
        }

        body.admin-sidebar-collapsed .admin-brand-title,
        body.admin-sidebar-collapsed .admin-brand-subtitle,
        body.admin-sidebar-collapsed .admin-menu-section,
        body.admin-sidebar-collapsed .admin-nav-text,
        body.admin-sidebar-collapsed .admin-logout-text {
        display: none;
        }

        body.admin-sidebar-collapsed .admin-nav-link {
        width: 56px;
        min-height: 50px;
        padding: 0;
        margin-inline: auto;
        justify-content: center;
        }

        body.admin-sidebar-collapsed .admin-nav-link-content {
        justify-content: center;
        }

        body.admin-sidebar-collapsed .admin-nav-icon {
        width: 40px;
        height: 40px;
        border-radius: 14px;
        }

        body.admin-sidebar-collapsed .admin-logout {
        width: 56px;
        min-height: 50px;
        padding: 0;
        margin-inline: auto;
        justify-content: center;
        }

        body.admin-sidebar-collapsed .admin-logout-content {
        justify-content: center;
        }

        @@media (max-width: 1200px) {
        .admin-profile-role {
        display: none;
        }

        .admin-page-text small {
        display: none;
        }

        .admin-topbar-inner {
        grid-template-columns: auto minmax(220px, 340px) auto;
        padding: 0 18px;
        }
        }

        @@media (max-width: 1024px) {
        :root,
        body.admin-sidebar-collapsed {
        --admin-sidebar-width: 284px;
        }

        .admin-main {
        margin-right: 0;
        }

        .admin-topbar {
        right: 0;
        }

        .admin-sidebar {
        transform: translateX(100%);
        width: 284px;
        }

        .admin-sidebar.open {
        transform: translateX(0);
        }

        .admin-sidebar-close {
        width: 40px;
        height: 40px;
        border: 0;
        border-radius: 14px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: transparent;
        color: #64748b;
        cursor: pointer;
        }

        .admin-sidebar-close:hover {
        color: var(--admin-purple);
        background: rgba(241, 245, 249, .9);
        }

        .admin-brand-title,
        .admin-brand-subtitle,
        .admin-menu-section,
        .admin-nav-text,
        .admin-logout-text {
        display: block !important;
        }

        .admin-nav-link {
        width: auto !important;
        min-height: 46px !important;
        padding: 0 16px !important;
        margin: 5px 14px !important;
        justify-content: space-between !important;
        }

        .admin-nav-link-content {
        justify-content: flex-start !important;
        }

        .admin-nav-icon {
        width: 36px !important;
        height: 36px !important;
        }

        .admin-logout {
        width: auto !important;
        min-height: 54px !important;
        padding: 0 18px !important;
        justify-content: space-between !important;
        }

        .admin-content {
        padding: 106px 16px 24px;
        }
        }

        @@media (max-width: 860px) {
        .admin-topbar-inner {
        grid-template-columns: auto 1fr;
        gap: 12px;
        }

        .admin-topbar-center {
        display: none;
        }

        .admin-profile-info {
        display: none;
        }
        }

        @@media (max-width: 640px) {
        .admin-topbar-left .admin-icon-btn:nth-child(1),
        .admin-topbar-left .admin-icon-btn:nth-child(2),
        .admin-topbar-left .admin-icon-btn:nth-child(3),
        .admin-topbar-left .admin-divider {
        display: none;
        }

        .admin-page-icon {
        width: 42px;
        height: 42px;
        border-radius: 15px;
        }

        .admin-page-text h1 {
        font-size: 20px;
        }

        .admin-topbar-inner {
        padding: 0 14px;
        }
        }
    </style>
</head>

<body class="admin-body">
    <div class="admin-shell">

        <div id="adminOverlay" class="admin-overlay" onclick="closeAdminSidebar()"></div>

        <aside id="adminSidebar" class="admin-sidebar">
            <div class="admin-sidebar-header">
                <div class="admin-brand-card">
                    <div class="admin-brand-top">
                        <button type="button"
                                class="admin-sidebar-close"
                                onclick="closeAdminSidebar()"
                                aria-label="بستن منو">
                            <i data-lucide="x"></i>
                        </button>
                    </div>

                    <a href="/Admin" class="admin-brand-link">
                        <div class="admin-brand-logo-wrap">
                            <img src="~/images/logo.png"
                                 asp-append-version="true"
                                 alt="Vitorize Logo"
                                 class="admin-brand-logo"
                                 onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />

                            <div class="admin-brand-fallback">
                                <span class="admin-brand-v">V</span>
                            </div>
                        </div>

                        <div class="admin-brand-title">Vitorize</div>
                        <div class="admin-brand-subtitle">پنل مدیریت فروشگاه</div>
                    </a>
                </div>
            </div>

            <div class="admin-sidebar-scroll">
                <partial name="_AdminNav" />
            </div>

            <div class="admin-sidebar-footer">
                <a href="/Admin/Auth/Logout" class="admin-logout" title="خروج">
                    <span class="admin-logout-content">
                        <i data-lucide="log-out"></i>
                        <span class="admin-logout-text">خروج</span>
                    </span>
                </a>
            </div>
        </aside>

        <main class="admin-main">
            <header class="admin-topbar">
                <div class="admin-topbar-inner">

                    <div class="admin-topbar-right">
                        <button type="button"
                                class="admin-icon-btn admin-toggle-btn"
                                onclick="toggleAdminSidebar()"
                                aria-label="باز و بسته کردن منو">
                            <i data-lucide="menu"></i>
                        </button>

                        <div class="admin-page-wrap">
                            <div class="admin-page-icon">
                                <i data-lucide="@GetPageIcon()"></i>
                            </div>

                            <div class="admin-page-text">
                                <h1>@ViewData["Title"]</h1>
                                <small>@GetPageSubtitle()</small>
                            </div>
                        </div>
                    </div>

                    <div class="admin-topbar-center">
                        <div class="admin-search">
                            <i data-lucide="search"></i>
                            <input type="text" placeholder="جستجو کنید..." />
                        </div>
                    </div>

                    <div class="admin-topbar-left">
                        <button type="button" class="admin-icon-btn" aria-label="اعلان‌ها">
                            <i data-lucide="bell"></i>
                            <span class="admin-badge-dot">5</span>
                        </button>

                        <button type="button" class="admin-icon-btn" aria-label="پیام‌ها">
                            <i data-lucide="mail"></i>
                        </button>

                        <button type="button" class="admin-icon-btn" aria-label="حالت نمایش">
                            <i data-lucide="moon"></i>
                        </button>

                        <button type="button"
                                class="admin-icon-btn"
                                onclick="toggleFullscreen()"
                                aria-label="تمام صفحه">
                            <i data-lucide="maximize"></i>
                        </button>

                        <div class="admin-divider"></div>

                        <div class="admin-profile">
                            <div class="admin-profile-info">
                                <div class="admin-profile-name">@GetAdminName()</div>
                                <div class="admin-profile-role">مدیر کل</div>
                            </div>

                            <div class="admin-avatar">V</div>
                        </div>
                    </div>

                </div>
            </header>

            <section class="admin-content">
                @RenderBody()
            </section>
        </main>
    </div>

    <script>
        function isAdminMobile() {
        return window.innerWidth <= 1024;
        }

        function refreshAdminIcons() {
        if (window.lucide) {
        lucide.createIcons();
        }
        }

        function openAdminSidebar() {
        const sidebar = document.getElementById('adminSidebar');
        const overlay = document.getElementById('adminOverlay');

        if (!sidebar || !overlay) {
        return;
        }

        sidebar.classList.add('open');
        overlay.classList.add('show');
        }

        function closeAdminSidebar() {
        const sidebar = document.getElementById('adminSidebar');
        const overlay = document.getElementById('adminOverlay');

        if (!sidebar || !overlay) {
        return;
        }

        sidebar.classList.remove('open');
        overlay.classList.remove('show');
        }

        function toggleAdminSidebar() {
        if (isAdminMobile()) {
        const sidebar = document.getElementById('adminSidebar');

        if (sidebar && sidebar.classList.contains('open')) {
        closeAdminSidebar();
        } else {
        openAdminSidebar();
        }

        return;
        }

        document.body.classList.toggle('admin-sidebar-collapsed');

        const isCollapsed = document.body.classList.contains('admin-sidebar-collapsed');

        localStorage.setItem(
        'vitorize.admin.sidebar.collapsed',
        isCollapsed ? 'true' : 'false');

        refreshAdminIcons();
        }

        function toggleFullscreen() {
        if (!document.fullscreenElement) {
        document.documentElement.requestFullscreen?.();
        } else {
        document.exitFullscreen?.();
        }
        }

        document.addEventListener('DOMContentLoaded', function () {
        if (!isAdminMobile()) {
        const collapsed = localStorage.getItem('vitorize.admin.sidebar.collapsed');

        if (collapsed === 'true') {
        document.body.classList.add('admin-sidebar-collapsed');
        }
        }

        refreshAdminIcons();
        });

        window.addEventListener('resize', function () {
        if (!isAdminMobile()) {
        closeAdminSidebar();
        } else {
        document.body.classList.remove('admin-sidebar-collapsed');
        }

        refreshAdminIcons();
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

