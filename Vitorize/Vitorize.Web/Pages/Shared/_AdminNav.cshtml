@{
    var groups = new List<AdminNavGroup>
    {
        new("داشبورد", "layout-grid", new List<AdminNavItem>
        {
            new("/Admin", "داشبورد", "home", true)
        }),
        new("فروش", "shopping-cart", new List<AdminNavItem>
        {
            new("/Admin/Orders", "سفارش‌ها", "shopping-cart"),
            new("/Admin/Payments", "پرداخت‌ها", "repeat-2"),
            new("/Admin/Reports/Sales", "گزارش فروش", "line-chart")
        }),
        new("کاتالوگ", "package", new List<AdminNavItem>
        {
            new("/Admin/Products", "محصولات", "package"),
            new("/Admin/Categories", "دسته‌بندی‌ها", "grid-2x2"),
            new("/Admin/Brands", "برندها", "badge-check"),
            new("/Admin/GiftCodes", "گیفت‌کارت‌ها", "credit-card"),
            new("/Admin/Coupons", "کوپن‌ها", "ticket-percent")
        }),
        new("نمایش سایت", "monitor", new List<AdminNavItem>
        {
            new("/Admin/Banners", "بنرها", "image-plus")
        }),
        new("مشتریان", "users", new List<AdminNavItem>
        {
            new("/Admin/Users", "کاربران", "users"),
            new("/Admin/Roles", "نقش‌ها", "shield"),
            new("/Admin/Verifications", "احراز هویت", "shield-check"),
            new("/Admin/Wallets", "کیف پول‌ها", "wallet")
        }),
        new("پشتیبانی", "headphones", new List<AdminNavItem>
        {
            new("/Admin/Tickets", "تیکت‌ها", "headphones"),
            new("/Admin/Notifications", "اطلاعیه‌ها", "bell")
        }),
        new("سیستم", "settings", new List<AdminNavItem>
        {
            new("/Admin/Settings", "تنظیمات", "settings"),
            new("/Admin/Reports", "گزارش‌ها", "bar-chart-3"),
            new("/Admin/AuditLogs", "فعالیت‌ها", "file-text"),
            new("/Admin/SecurityLogs", "امنیت", "history"),
            new("/Admin/ErrorLogs", "خطاها", "triangle-alert")
        })
    };
}

<nav class="admin-nav">
    @foreach (var group in groups)
    {
        <div class="admin-menu-section">
<i data-lucide="@group.Icon">
</i>
<span>@group.Title</span>
</div>

        foreach (var item in group.Items)
        {
            var activeClass = IsActive(item.Href, item.Exact) ? "active" : string.Empty;
            <a href="@item.Href" class="admin-nav-link @activeClass" title="@item.Title">
                <span class="admin-nav-link-content">
                    <span class="admin-nav-icon">
<i data-lucide="@item.Icon">
</i>
</span>
                    <span class="admin-nav-text">@item.Title</span>
                </span>
            </a>
        }
    }
</nav>

@functions {
    private bool IsActive(string href, bool exact = false)
    {
        var currentPath = (Context.Request.Path.Value ?? "/").TrimEnd('/').ToLowerInvariant();
        if (string.IsNullOrWhiteSpace(currentPath)) currentPath = "/";
        var targetPath = href.TrimEnd('/').ToLowerInvariant();
        if (string.IsNullOrWhiteSpace(targetPath)) targetPath = "/";
        if (exact) return currentPath == targetPath || currentPath == "/admin/index";
        return currentPath == targetPath || currentPath.StartsWith(targetPath + "/");
    }
    private sealed class AdminNavGroup { public AdminNavGroup(string title,string icon,List<AdminNavItem> items){Title=title;Icon=icon;Items=items;} public string Title{get;} public string Icon{get;} public List<AdminNavItem> Items{get;} }
    private sealed class AdminNavItem { public AdminNavItem(string href,string title,string icon,bool exact=false){Href=href;Title=title;Icon=icon;Exact=exact;} public string Href{get;} public string Title{get;} public string Icon{get;} public bool Exact{get;} }
}
