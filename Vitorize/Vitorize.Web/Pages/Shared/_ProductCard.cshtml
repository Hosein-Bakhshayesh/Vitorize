@model StoreProductCardModel

@{
    var img = StorefrontFormat.ProductImage(Model.ThumbnailImagePath);

    var hasDiscount =
        Model.DiscountPrice.HasValue &&
        Model.DiscountPrice.Value > 0 &&
        Model.DiscountPrice.Value < Model.BasePrice;

    var discountPercent = hasDiscount && Model.BasePrice > 0
        ? Math.Round((1 - (Model.DiscountPrice!.Value / Model.BasePrice)) * 100)
        : 0;

    var isAvailable = Model.AvailableStock > 0;
}

<a asp-page="/Products/Details"
   asp-route-slug="@Model.Slug"
   class="vt-product-card @(isAvailable ? "" : "vt-product-card-disabled")">

    <div class="vt-product-image-wrap">
        @if (hasDiscount)
        {
            <span class="vt-discount-badge">٪@StorefrontFormat.Number((int)discountPercent) تخفیف</span>
        }
        else if (Model.IsFeatured)
        {
            <span class="vt-featured-badge">فروش ویژه</span>
        }

        @if (!isAvailable)
        {
            <span class="vt-stock-badge">ناموجود</span>
        }

        <img src="@img" alt="@Model.Title" loading="lazy" />
    </div>

    <div class="vt-product-body">
        <h3 title="@Model.Title">@Model.Title</h3>

        <p>
            @(Model.BrandTitle ?? Model.CategoryTitle)
        </p>

        <div class="vt-product-meta">
            <span>@Model.CategoryTitle</span>

            @if (isAvailable)
            {
                <span>موجودی @StorefrontFormat.Number(Model.AvailableStock)</span>
            }
            else
            {
                <span>اتمام موجودی</span>
            }
        </div>

        <div class="vt-product-price">
            <b>@StorefrontFormat.Money(Model.FinalPrice)</b>

            @if (hasDiscount)
            {
                <del>@StorefrontFormat.Money(Model.BasePrice)</del>
            }
        </div>
    </div>
</a>