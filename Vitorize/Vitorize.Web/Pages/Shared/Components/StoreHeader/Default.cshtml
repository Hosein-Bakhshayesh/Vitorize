@model Vitorize.Web.Models.Storefront.StoreHeaderModel

<a asp-page="/Cart/Index" class="vt-cart-btn" title="سبد خرید">
    <span class="vt-cart-dot">@StorefrontFormat.Number(Model.CartCount)</span>
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
        <path d="M6.2 6h15l-1.6 8.5a2 2 0 0 1-2 1.6H8.7a2 2 0 0 1-2-1.7L5.4 3.8H2.8"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round" />
        <path d="M9 21a1 1 0 1 0 0-2 1 1 0 0 0 0 2Zm9 0a1 1 0 1 0 0-2 1 1 0 0 0 0 2Z"
              fill="currentColor" />
    </svg>
</a>

@if (Model.IsAuthenticated)
{
    <div class="vt-user-menu vt-user-menu-main">
        <button type="button" class="vt-user-menu-btn">
            <span class="vt-user-avatar">👤</span>
            <span class="hidden md:inline">@(!string.IsNullOrWhiteSpace(Model.FullName) ? Model.FullName : "حساب من")</span>
        </button>

        <div class="vt-user-dropdown">
            <div class="vt-user-dropdown-head">
                <b>@(!string.IsNullOrWhiteSpace(Model.FullName) ? Model.FullName : "کاربر ویتورایز")</b>
                <small>@Model.Mobile</small>
            </div>

            <a asp-page="/Orders/Index">سفارش‌های من</a>
            <a asp-page="/Cart/Index">سبد خرید</a>
            <a href="#">کیف پول</a>
            <a href="#">پشتیبانی</a>
            <hr />
            <a asp-page="/Auth/Logout" class="danger">خروج</a>
        </div>
    </div>
}
else
{
    <a asp-page="/Auth/Login" class="vt-login-pill">ورود</a>
}