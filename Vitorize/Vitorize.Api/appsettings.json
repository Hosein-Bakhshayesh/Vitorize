{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System.Net.Http.HttpClient": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} {Level:u3}] [{Application}] [{EventType}] [CorrelationId:{CorrelationId}] [TraceId:{TraceId}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/vitorize-api-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "fileSizeLimitBytes": 104857600,
          "rollOnFileSizeLimit": true,
          "shared": true,
          "flushToDiskInterval": "00:00:02",
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} {Level:u3}] [{Application}] [{EventType}] [CorrelationId:{CorrelationId}] [TraceId:{TraceId}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithEnvironmentName", "WithThreadId" ],
    "Properties": {
      "Application": "Vitorize.Api",
      "Service": "Api"
    }
  },
  "Seq": {
    "Enabled": false,
    "ServerUrl": "",
    "ApiKey": "",
    "ApplicationName": "Vitorize.Api",
    "QueueSizeLimit": 10000
  },
  "Monitoring": {
    "SeqUiUrl": "",
    "ShowSeqLink": false,
    "ErrorWindowHours": 24,
    "OutboxWarningThreshold": 20,
    "PaymentPendingMinutes": 30,
    "WorkerHeartbeatMinutes": 15
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=.;Database=VitorizeDb;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "Jwt": {
    "SecretKey": "",
    "Issuer": "Vitorize.Api",
    "Audience": "Vitorize.Client",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 30
  },
  "Encryption": {
    "Key": ""
  },
  "AllowedHosts": "*"
}
